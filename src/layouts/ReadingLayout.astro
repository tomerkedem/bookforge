---
import type { Language } from '../types/index';
import BaseLayout from './BaseLayout.astro';
import ReadingControls from '../components/ReadingControls.astro';
import '../styles/reading-typography.css';
import '../styles/bash-block.css';
import '../styles/code-runner.css';
import { SOURCE_LANGUAGE, getLanguageDirection } from '../utils/language';

interface Props {
  title: string;
  language?: Language;
  availableLanguages?: Language[];
  class?: string;
}

const { title, language = SOURCE_LANGUAGE, availableLanguages, class: className } = Astro.props;
const isRtl = getLanguageDirection(language) === 'rtl';
const COPY_SUCCESS_MESSAGE = 'Code copied!';
---

<BaseLayout
  title={title}
  language={language}
  availableLanguages={availableLanguages}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={true}
  showLanguageToggle={true}
>
  <!-- Sidebars passed through to body level -->
  <slot name="sidebars" slot="sidebars" />

  <article
    class:list={[
      'reading-article',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      'pt-0',
      'pb-4',
      'sm:pb-6',
      'lg:pb-8',
      isRtl && 'text-right',
      className,
    ]}
    style="background-color: var(--yuval-reading-bg);"
  >
    <!-- Chapter content -->
    <div
      class="reading-content prose prose-invert max-w-none space-y-6"
      data-language={language}
    >
      <slot />
    </div>
    <!-- Typography mode persistence and toggle logic -->
    <script is:inline>
      // Typography mode: 'modern' (Assistant) or 'clean' (Heebo)
      const STORAGE_KEY = 'typography-mode';
      const root = document.documentElement;
      function applyTypographyMode(mode) {
        if (mode === 'clean') {
          root.setAttribute('data-typography', 'clean');
        } else {
          root.setAttribute('data-typography', 'modern');
        }
      }
      // On load: apply saved mode or default
      const saved = localStorage.getItem(STORAGE_KEY);
      applyTypographyMode(saved === 'clean' ? 'clean' : 'modern');
      // Listen for custom event from ReadingControls
      window.addEventListener('typography-mode-change', (e) => {
        const mode = e.detail?.mode;
        if (mode === 'clean' || mode === 'modern') {
          applyTypographyMode(mode);
          localStorage.setItem(STORAGE_KEY, mode);
        }
      });
    </script>

    <!-- Custom prose styles for reading -->
    <style>
      /* ── Syntax highlighting (highlight.js GitHub Dark theme) ── */
      :global(.hljs) {
        color: #c9d1d9;
        background: #0d1117;
      }
      :global(.hljs-doctag, .hljs-keyword, .hljs-meta .hljs-keyword,
              .hljs-template-tag, .hljs-template-variable, .hljs-type,
              .hljs-variable.language_) { color: #ff7b72; }
      :global(.hljs-title, .hljs-title.class_, .hljs-title.class_.inherited__,
              .hljs-title.function_) { color: #d2a8ff; }
      :global(.hljs-attr, .hljs-attribute, .hljs-literal, .hljs-meta,
              .hljs-number, .hljs-operator, .hljs-selector-attr,
              .hljs-selector-class, .hljs-selector-id, .hljs-variable) { color: #79c0ff; }
      :global(.hljs-meta .hljs-string, .hljs-regexp, .hljs-string) { color: #a5d6ff; }
      :global(.hljs-built_in, .hljs-symbol) { color: #ffa657; }
      :global(.hljs-comment, .hljs-code, .hljs-formula) { color: #8b949e; }
      :global(.hljs-name, .hljs-quote, .hljs-selector-pseudo,
              .hljs-selector-tag) { color: #7ee787; }
      :global(.hljs-subst) { color: #c9d1d9; }
      :global(.hljs-section) { color: #1f6feb; font-weight: bold; }
      :global(.hljs-bullet) { color: #f2cc60; }
      :global(.hljs-emphasis) { color: #c9d1d9; font-style: italic; }
      :global(.hljs-strong) { color: #c9d1d9; font-weight: bold; }
      :global(.hljs-addition) { color: #aff5b4; background-color: #033a16; }
      :global(.hljs-deletion) { color: #ffdcd7; background-color: #67060c; }

      /* Code always LTR regardless of page language */
      :global(article pre),
      :global(article code) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }

      /* Code block wrapper */
      :global(article pre) {
        position: relative;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 0;
        overflow: hidden;
        margin: 1.75rem 0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      }

      /* Language badge */
      :global(article pre[data-lang]::before) {
        content: attr(data-lang);
        display: block;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 6px 16px;
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      :global(article pre code.hljs) {
        display: block;
        padding: 12px;
        overflow-x: auto;
        font-size: 0.75rem;
        line-height: 1.6;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: transparent;
      }

      @media (min-width: 640px) {
        :global(article pre code.hljs) {
          padding: 20px;
          font-size: 0.85rem;
          line-height: 1.7;
        }
      }

      /* Inline code */
      :global(article :not(pre) > code) {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.85em;
        background: rgba(110, 118, 129, 0.15);
        border: 1px solid rgba(110, 118, 129, 0.25);
        border-radius: 4px;
        padding: 0.15em 0.45em;
        color: #e6edf3;
      }
      :global(article h1) {
        @apply font-heading font-bold text-2xl sm:text-4xl lg:text-5xl leading-tight mt-10 sm:mt-16 mb-5 sm:mb-8 text-yuval-text;
        color: var(--yuval-chapter-title);
        letter-spacing: -0.01em;
      }

      :global(article h2) {
        @apply font-heading font-bold text-lg sm:text-2xl lg:text-3xl leading-snug mt-8 sm:mt-10 mb-3 sm:mb-4 text-yuval-text;
      }

      :global(article h3) {
        @apply font-heading font-semibold text-base sm:text-xl lg:text-2xl leading-snug mt-6 sm:mt-8 mb-2 sm:mb-3 text-yuval-text-secondary;
      }

      :global(article p) {
        @apply text-base sm:text-lg lg:text-xl leading-relaxed sm:leading-loose text-yuval-text-secondary mb-4 sm:mb-6 font-light;
      }

      :global(article blockquote) {
        @apply relative pl-4 sm:pl-6 py-3 sm:py-4 my-6 sm:my-8 text-base sm:text-xl leading-relaxed text-yuval-text-secondary bg-yuval-bg-secondary;
        border-left: 4px solid var(--yuval-blockquote-border);
      }

      :global(article [dir="rtl"] blockquote) {
        @apply pl-0 pr-6 border-l-0 border-r-4;
      }

      :global(article strong) {
        @apply font-semibold text-yuval-text;
      }

      :global(article em) {
        @apply italic;
      }

      :global(article ul,
      article ol) {
        @apply ml-6 space-y-2 my-6;
      }

      :global(article ul) {
        list-style-type: disc;
      }

      :global(article ol) {
        list-style-type: decimal;
      }

      :global(article [dir="rtl"] ul,
      article [dir="rtl"] ol) {
        @apply ml-0 mr-6;
      }

      :global(article li) {
        @apply text-base sm:text-lg leading-relaxed text-yuval-text-secondary font-light;
      }

      :global(article a) {
        @apply underline transition-colors duration-200;
        color: var(--yuval-link);
      }

      :global(article a:hover) {
        color: var(--yuval-link-hover);
      }

      :global(article img) {
        @apply max-w-full h-auto rounded-lg my-8 mx-auto block;
        background-color: #fff;
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

      /* Code block copy button */
      :global(article pre) {
        position: relative;
      }

      :global(.code-copy-btn) {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #30363d;
        background: #21262d;
        color: #8b949e;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms var(--ease-standard), color 150ms var(--ease-standard), background 150ms var(--ease-standard);
      }

      :global(article pre:hover .code-copy-btn),
      :global(.code-copy-btn:focus-visible) {
        opacity: 1;
      }

      :global(.code-copy-btn:hover) {
        color: #e6edf3;
        background: #30363d;
      }

      :global(.code-copy-btn.copied) {
        color: #3fb950;
      }

      :global(article hr) {
        @apply my-12 border-yuval-border;
      }

      /* ── Markdown Preview: tab bar replaces ::before label ── */
      :global(article pre[data-has-preview]::before) {
        display: none;
      }

      :global(article .md-tab-bar) {
        display: flex;
        align-items: center;
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 0 8px;
        gap: 0;
        flex-shrink: 0;
      }

      :global(article .md-lang-label) {
        font-size: 11px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 6px 12px 6px 8px;
        margin-right: 8px;
        border-right: 1px solid #30363d;
        flex-shrink: 0;
      }

      :global(article .md-tab) {
        padding: 6px 14px;
        font-size: 12px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #8b949e;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
        margin-bottom: -1px;
      }

      :global(article .md-tab:hover) {
        color: #c9d1d9;
      }

      :global(article .md-tab-active) {
        color: #e6edf3;
        border-bottom-color: #58a6ff;
      }

      /* Preview rendered area */
      :global(article .md-preview) {
        padding: 20px 24px;
        color: #c9d1d9;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 14px;
        line-height: 1.7;
      }
      :global(article .md-preview[dir="ltr"]) {
        direction: ltr;
        text-align: left;
      }
      :global(article .md-preview[dir="rtl"]) {
        direction: rtl;
        text-align: right;
        font-family: 'Heebo', 'Frank Ruhl Libre', -apple-system, sans-serif;
      }
      :global(article .md-preview[dir="rtl"] ul,
              article .md-preview[dir="rtl"] ol) {
        padding-left: 0;
        padding-right: 1.4em;
      }
      :global(article .md-preview[dir="rtl"] blockquote) {
        border-left: none;
        border-right: 3px solid #58a6ff;
        padding: 4px 16px 4px 0;
      }
      :global(article .md-preview[dir="rtl"] pre) {
        direction: ltr;
        text-align: left;
      }

      :global(article .md-preview h1) {
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--yuval-chapter-title);
        margin: 2.5rem 0 1.5rem;
        border-bottom: none;
        padding-bottom: 0;
        letter-spacing: -0.01em;
      }
      :global(article .md-preview h2) {
        font-size: 1.2em; font-weight: 600;
        color: #e6edf3; margin: 1em 0 0.4em;
        border-bottom: 1px solid #21262d; padding-bottom: 0.2em;
      }
      :global(article .md-preview h3) {
        font-size: 1.05em; font-weight: 600;
        color: #e6edf3; margin: 0.9em 0 0.3em;
      }
      :global(article .md-preview p) { margin: 0.5em 0; }
      :global(article .md-preview ul, article .md-preview ol) {
        margin: 0.5em 0; padding-left: 1.4em;
      }
      :global(article .md-preview ul) {
        list-style-type: disc;
      }
      :global(article .md-preview ol) {
        list-style-type: decimal;
      }
      :global(article .md-preview li) { margin: 0.2em 0; }
      :global(article .md-preview code) {
        background: rgba(110,118,129,0.2);
        border: 1px solid rgba(110,118,129,0.25);
        padding: 0.1em 0.4em; border-radius: 4px;
        font-family: ui-monospace, Menlo, monospace; font-size: 0.88em;
        color: #e6edf3;
      }
      :global(article .md-preview pre) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        overflow-x: auto; margin: 0.8em 0;
      }
      :global(article .md-preview pre code) {
        background: none; border: none; padding: 0; font-size: 0.85em;
      }
      :global(article .md-preview blockquote) {
        border-left: 3px solid #58a6ff;
        margin: 0.8em 0; padding: 4px 0 4px 16px;
        color: #8b949e;
      }
      :global(article .md-preview hr) {
        border: none; border-top: 1px solid #30363d; margin: 1em 0;
      }
      :global(article .md-preview strong) { font-weight: 600; color: #e6edf3; }
      :global(article .md-preview em) { font-style: italic; color: #c9d1d9; }
      :global(article .md-preview a) { color: #58a6ff; text-decoration: none; }
      :global(article .md-preview a:hover) { text-decoration: underline; }

      /* YAML frontmatter block in preview */
      :global(article .md-preview .md-frontmatter) {
        background: #0d1117; border: 1px solid #30363d;
        border-radius: 6px; padding: 12px 16px;
        margin-bottom: 1em;
        font-family: ui-monospace, Menlo, monospace;
        font-size: 12px; color: #8b949e;
      }
      :global(article .md-preview .md-frontmatter-key) { color: #79c0ff; }
      :global(article .md-preview .md-frontmatter-value) { color: #a5d6ff; }
      :global(article .md-preview .md-frontmatter-title) {
        font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
        color: #484f58; margin-bottom: 8px;
      }

      /* ── Premium data-grid tables: visible grid + gold header ── */
      :global(article .table-wrapper),
      :global(article table) {
        @apply my-6;
      }

      :global(article table) {
        width: 100%;
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        max-width: 100%;
        border-collapse: collapse;
        border: 1px solid color-mix(in srgb, var(--gold-500) 28%, var(--yuval-border-secondary));
        border-radius: 3px;
        font-size: 0.95rem;
        line-height: 1.55;
        box-shadow:
          0 1px 0 var(--gold-tint-18) inset,
          0 10px 24px rgba(15, 23, 42, 0.05);
      }

      @media (min-width: 768px) {
        :global(article table) {
          display: table;
          overflow: hidden;
          overflow-x: visible;
        }
      }

      /* Every cell gets a visible grid border */
      :global(article th),
      :global(article td) {
        border: 1px solid color-mix(in srgb, var(--gold-500) 16%, var(--yuval-border-secondary));
        padding: 0.7rem 1rem;
        text-align: start;
        vertical-align: top;
      }

      /* Header row - refined gold tone, stronger hierarchy */
      :global(article thead th) {
        background:
          linear-gradient(180deg,
            color-mix(in srgb, var(--gold-500) 14%, var(--yuval-bg)) 0%,
            color-mix(in srgb, var(--gold-500) 8%, var(--yuval-bg)) 100%);
        color: var(--yuval-chapter-title);
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 0.95rem;
        text-transform: uppercase;
        padding: 1rem 1.1rem;
        border-color: var(--gold-tint-35);
        border-bottom: 2px solid color-mix(in srgb, var(--gold-600) 85%, var(--gold-500));
        box-shadow: inset 0 1px 0 color-mix(in srgb, var(--gold-300) 28%, transparent);
        position: relative;
      }

      /* Vertical dividers inside header - keep gold, slightly stronger */
      :global(article thead th + th) {
        border-inline-start: 1px solid var(--gold-tint-35);
      }

      /* Row-header cells (th inside tbody) - slightly emphasised */
      :global(article tbody th) {
        background: color-mix(in srgb, var(--gold-500) 6%, var(--yuval-bg));
        font-weight: 700;
        color: var(--yuval-chapter-title);
      }

      /* Subtle zebra for scanning, kept under the grid */
      :global(article tbody tr:nth-child(even) td) {
        background: color-mix(in srgb, var(--yuval-bg-secondary, var(--yuval-bg)) 55%, transparent);
      }

      :global(article tbody tr:hover td) {
        background: color-mix(in srgb, var(--gold-500) 7%, var(--yuval-bg));
      }

      /* RTL */
      :global(article [dir="rtl"] table) {
        direction: rtl;
      }

      /* Mobile: same grid, tighter cells, sticky first column */
      @media (max-width: 767px) {
        :global(article th),
        :global(article td) {
          white-space: nowrap;
          padding: 0.6rem 0.8rem;
          font-size: 0.88rem;
        }

        :global(article thead th) {
          font-size: 0.82rem;
          padding: 0.8rem 0.85rem;
          letter-spacing: 0.03em;
        }

        :global(article th:first-child),
        :global(article td:first-child) {
          position: sticky;
          inset-inline-start: 0;
          background: var(--yuval-bg);
          z-index: 1;
          box-shadow: 1px 0 0 var(--gold-tint-25);
        }

        :global(article [dir="rtl"] th:first-child),
        :global(article [dir="rtl"] td:first-child) {
          box-shadow: -1px 0 0 var(--gold-tint-25);
        }

        :global(article thead th:first-child) {
          background:
            linear-gradient(180deg,
              color-mix(in srgb, var(--gold-500) 18%, var(--yuval-bg)) 0%,
              color-mix(in srgb, var(--gold-500) 10%, var(--yuval-bg)) 100%);
        }
      }

      /* Prevent long content from causing page overflow */
      :global(.chapter-content) {
        overflow-wrap: anywhere;
      }
      :global(.chapter-content > *) {
        max-width: 100%;
      }

      /* Reading article fills space between sidebars */
      .reading-article {
        margin-left: 0;
        margin-right: 0;
      }

      /* Force content text to follow the container's direction.
         Uses high-specificity selector + !important to defeat any inherited
         text-align: center from legacy Word-ingest wrappers. */
      :global([data-lang][dir="ltr"] .chapter-content),
      :global([data-lang][dir="ltr"] .chapter-content *) {
        text-align: start !important;
        direction: ltr;
      }
      :global([data-lang][dir="rtl"] .chapter-content),
      :global([data-lang][dir="rtl"] .chapter-content *) {
        text-align: start !important;
        direction: rtl;
      }
      /* Preserve intentional center/right in code, tables, figures */
      :global([data-lang] .chapter-content pre),
      :global([data-lang] .chapter-content code),
      :global([data-lang] .chapter-content figure),
      :global([data-lang] .chapter-content table),
      :global([data-lang] .chapter-content .coderunner),
      :global([data-lang] .chapter-content .bash-block) {
        text-align: initial !important;
      }

      /* Code components must always render LTR, even inside an RTL page.
         Overrides the wildcard direction:rtl rule above for code wrappers
         and every descendant (gutter, toolbar, buttons, line numbers, pre, code). */
     
      :global([data-lang][dir="rtl"] .chapter-content .coderunner),
      :global([data-lang][dir="rtl"] .chapter-content .coderunner *:not(.cr-gutter):not(.cr-gutter span)),
      :global([data-lang][dir="rtl"] .chapter-content .bash-block),
      :global([data-lang][dir="rtl"] .chapter-content .bash-block *) {
        direction: ltr !important;
        text-align: left !important;
        unicode-bidi: isolate;
      }
      /* Keep line-number gutter right-aligned (numbers flush to code) */
      :global([data-lang][dir="rtl"] .chapter-content .coderunner .cr-gutter),
      :global([data-lang][dir="rtl"] .chapter-content .coderunner .cr-gutter span) {
        direction: ltr !important;
        text-align: right !important;
        unicode-bidi: isolate;
      }
      
      @media (min-width: 1024px) {
        .reading-article {
          margin-left: 320px;
          margin-right: 320px;
        }
        /* Both sidebars stay pinned during scroll, so the article width
           stays constant — no reflow on immersive toggle. */
      }


      /* Zen mode: large centered text, no distractions */
      :global(body.reading-zen) .reading-article {
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      :global(body.reading-zen) .chapter-content {
        font-size: clamp(18px, 2.2vw, 24px) !important;
        line-height: 1.9 !important;
        max-width: 640px;
        margin: 0 auto;
      }

      /* Header stays visible in immersive mode */
      :global(body.reading-immersive) #site-header {
        opacity: 1;
      }
      :global(#site-header) {
        transition: background-color 0.3s, border-color 0.3s;
      }

      /* CodeRunner styles live in src/styles/code-runner.css.
         They support a global dark/light theme toggle via
         [data-code-theme] on <html>, set by ReadingControls. */

      /* Copy feedback animation */
      @keyframes fadeInOut {
        0% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
        15% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        85% { opacity: 1; }
        100% { opacity: 0; }
      }
    </style>
  </article>

  <!-- Reading Controls (Focus, Typography, Theme) -->
  <ReadingControls />

  <script type="module">
    // Inject copy buttons into all code blocks
    function addCopyButtons() {
      document.querySelectorAll('article pre').forEach((pre) => {
        // Skip <pre> elements inside styled block wrappers — they already
        // have their own Copy buttons (BashBlock, CodeBlock, CodeRunner).
        // Adding the generic floating Copy button on top would double up
        // and confuse readers.
        if (pre.closest('.bash-block') ||
            pre.closest('.coderunner')) return;
        if (pre.querySelector('.code-copy-btn')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.classList.add('copied');
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
            }, 2000);
          } catch {
            // Fallback: select text
            const range = document.createRange();
            range.selectNodeContents(code);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            sel?.addRange(range);
          }
        });
        pre.appendChild(btn);
      });
    }

    // Lazy-load content images
    function lazyLoadImages() {
      document.querySelectorAll('article img').forEach((img) => {
        if (!img.hasAttribute('loading')) {
          img.loading = 'lazy';
          img.decoding = 'async';
        }
      });
    }

    // ── Markdown Preview tabs ──────────────────────────────────────

    /** Escape HTML special chars */
    function esc(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    /** Inline formatting: bold, italic, code, links */
    function inline(s) {
      return s
        .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
    }

    /** Render YAML frontmatter as a styled block */
    function renderFrontmatter(lines) {
      const rows = lines.map(line => {
        const m = line.match(/^(\s*-?\s*)([^:]+):(.*)/);
        if (!m) return `<div>${esc(line)}</div>`;
        const indent = m[1].includes('-') ? 'margin-left:12px;' : '';
        return `<div style="${indent}"><span class="md-frontmatter-key">${esc(m[2])}</span>:<span class="md-frontmatter-value">${esc(m[3])}</span></div>`;
      }).join('');
      return `<div class="md-frontmatter"><div class="md-frontmatter-title">Frontmatter</div>${rows}</div>`;
    }

    /** Minimal Markdown → HTML renderer */
    function renderMarkdown(raw) {
      const lines = raw.split('\n');
      let html = '';
      let i = 0;

      // Detect and extract YAML frontmatter
      if (lines[0]?.trim() === '---') {
        const endIdx = lines.indexOf('---', 1);
        if (endIdx > 0) {
          html += renderFrontmatter(lines.slice(1, endIdx));
          i = endIdx + 1;
        }
      }

      let inUl = false, inOl = false, inPre = false, preLines = [];

      for (; i < lines.length; i++) {
        const raw_line = lines[i];
        const line = raw_line.trim();

        // Fenced code block
        if (line.startsWith('```')) {
          if (!inPre) {
            if (inUl) { html += '</ul>'; inUl = false; }
            if (inOl) { html += '</ol>'; inOl = false; }
            inPre = true; preLines = [];
          } else {
            html += `<pre><code>${esc(preLines.join('\n'))}</code></pre>`;
            inPre = false;
          }
          continue;
        }
        if (inPre) { preLines.push(raw_line); continue; }

        // Headings
        const hm = line.match(/^(#{1,6})\s+(.*)/);
        if (hm) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          const lvl = hm[1].length;
          html += `<h${lvl}>${inline(esc(hm[2]))}</h${lvl}>`;
          continue;
        }

        // HR
        if (/^---+$/.test(line) || /^\*\*\*+$/.test(line)) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          html += '<hr>';
          continue;
        }

        // Blockquote
        if (line.startsWith('> ')) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          html += `<blockquote>${inline(esc(line.slice(2)))}</blockquote>`;
          continue;
        }

        // Unordered list
        const ulm = line.match(/^[-*+]\s+(.*)/);
        if (ulm) {
          if (inOl) { html += '</ol>'; inOl = false; }
          if (!inUl) { html += '<ul>'; inUl = true; }
          html += `<li>${inline(esc(ulm[1]))}</li>`;
          continue;
        }

        // Ordered list
        const olm = line.match(/^\d+\.\s+(.*)/);
        if (olm) {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (!inOl) { html += '<ol>'; inOl = true; }
          html += `<li>${inline(esc(olm[1]))}</li>`;
          continue;
        }

        // Close open lists on blank line or paragraph
        if (line === '') {
          if (inUl) { html += '</ul>'; inUl = false; }
          if (inOl) { html += '</ol>'; inOl = false; }
          continue;
        }

        // Paragraph
        if (inUl) { html += '</ul>'; inUl = false; }
        if (inOl) { html += '</ol>'; inOl = false; }
        html += `<p>${inline(esc(line))}</p>`;
      }

      if (inUl) html += '</ul>';
      if (inOl) html += '</ol>';
      if (inPre) html += `<pre><code>${esc(preLines.join('\n'))}</code></pre>`;

      return html;
    }

    /** Detect if text is predominantly Hebrew/RTL */
    function detectDir(text) {
      const hebrewChars = (text.match(/[\u0590-\u05FF\uFB1D-\uFB4F]/g) || []).length;
      const latinChars  = (text.match(/[a-zA-Z]/g) || []).length;
      return hebrewChars > latinChars ? 'rtl' : 'ltr';
    }

    /** Add Source/Preview tabs to markdown code blocks */
    function addMarkdownPreview() {
      document.querySelectorAll('article pre[data-lang="markdown"], article pre[data-lang="md"]').forEach((pre) => {
        if (pre.dataset.hasPreview) return;
        const code = pre.querySelector('code');
        if (!code) return;

        pre.dataset.hasPreview = 'true';

        // Tab bar: language label + Source tab + Preview tab
        const tabBar = document.createElement('div');
        tabBar.className = 'md-tab-bar';
        tabBar.innerHTML = `
          <span class="md-lang-label">Markdown</span>
          <button class="md-tab md-tab-active" data-tab="source" type="button">Source</button>
          <button class="md-tab" data-tab="preview" type="button">Preview</button>
        `;

        // Preview container
        const previewDiv = document.createElement('div');
        previewDiv.className = 'md-preview';
        previewDiv.style.display = 'none';

        // Insert tab bar as first child, preview after code
        pre.insertBefore(tabBar, pre.firstChild);
        code.after(previewDiv);

        // Tab switching
        tabBar.addEventListener('click', (e) => {
          const btn = e.target.closest('.md-tab');
          if (!btn) return;
          const tab = btn.dataset.tab;

          tabBar.querySelectorAll('.md-tab').forEach(b => b.classList.remove('md-tab-active'));
          btn.classList.add('md-tab-active');

          if (tab === 'preview') {
            const content = code.textContent || '';
            previewDiv.setAttribute('dir', detectDir(content));
            previewDiv.innerHTML = renderMarkdown(content);
            code.style.display = 'none';
            previewDiv.style.display = 'block';
          } else {
            code.style.display = '';
            previewDiv.style.display = 'none';
          }
        });
      });
    }

    function reinitAll() {
      applyStoredCodeTheme();
      initCodeThemeToggle();
      addCopyButtons();
      lazyLoadImages();
      addMarkdownPreview();
      if (document.querySelector('.coderunner')) {
        initCodeRunners();
      }
      if (document.querySelector('.bash-block')) {
        initBashBlocks();
      }
    }

    // Code theme picker — syncs [data-code-theme] on <html> and toggle button.
    // Default is 'dark'. Stored in localStorage under 'code-theme'.
    function applyStoredCodeTheme() {
      let saved;
      try { saved = localStorage.getItem('code-theme'); } catch { saved = null; }
      const theme = saved === 'light' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-code-theme', theme);
    }

    function initCodeThemeToggle() {
      const btn = document.querySelector('[data-code-theme-toggle]');
      if (!btn || btn.dataset.initialized) return;
      btn.dataset.initialized = 'true';

      const syncLabel = () => {
        const current = document.documentElement.getAttribute('data-code-theme') || 'dark';
        btn.setAttribute('aria-pressed', current === 'light' ? 'true' : 'false');
        btn.dataset.theme = current;
      };
      syncLabel();

      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-code-theme') || 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-code-theme', next);
        try { localStorage.setItem('code-theme', next); } catch {}
        syncLabel();
      });
    }
    function initBashBlocks() {
      document.querySelectorAll('.bash-block').forEach((block) => {
        if (block.dataset.initialized) return;
        block.dataset.initialized = 'true';

        const copyBtn = block.querySelector('.bash-copy-btn');
        const body = block.querySelector('.bash-body');
        if (!copyBtn || !body) return;

        copyBtn.addEventListener('click', async () => {
          // Prefer the encoded code on the button's data-code; fall
          // back to body.dataset.code; last resort use text content.
          const codeData = copyBtn.dataset.code || body.dataset.code;
          const text = codeData ? decodeURIComponent(codeData) : (body.textContent || '');

          try {
            await navigator.clipboard.writeText(text);
            copyBtn.classList.add('copied');
            setTimeout(() => copyBtn.classList.remove('copied'), 1800);
          } catch (err) {
            console.error('Failed to copy bash command:', err);
          }
        });
      });
    }

    // ═══════════════════════════════════════════════════════════════════════
    // Pyodide Python Execution
    // ═══════════════════════════════════════════════════════════════════════

    

    let pyodide = null;
    let pyodideLoading = false;
    let pyodideReady = false;
    
    const PYODIDE_CDN = 'https://cdn.jsdelivr.net/pyodide/v0.25.0/full/';
    
    async function loadPyodide() {
      if (pyodide) return pyodide;
      if (pyodideLoading) {
        while (!pyodideReady) {
          await new Promise(r => setTimeout(r, 100));
        }
        return pyodide;
      }
      
      pyodideLoading = true;
      
      try {
        if (!window.loadPyodide) {
          await new Promise((resolve, reject) => {
            const script = document.createElement('script');
            script.src = PYODIDE_CDN + 'pyodide.js';
            script.onload = () => resolve();
            script.onerror = () => reject(new Error('Failed to load Pyodide'));
            document.head.appendChild(script);
          });
        }
        
        pyodide = await window.loadPyodide({
          indexURL: PYODIDE_CDN
        });
        
        await pyodide.runPython(`
import sys
from io import StringIO

class OutputCapture:
    def __init__(self):
        self.stdout = StringIO()
        self.stderr = StringIO()
        sys.stdout = self.stdout
        sys.stderr = self.stderr
        
    def get_output(self):
        return self.stdout.getvalue(), self.stderr.getvalue()
    
    def clear(self):
        self.stdout = StringIO()
        self.stderr = StringIO()
        sys.stdout = self.stdout
        sys.stderr = self.stderr

_output_capture = OutputCapture()
        `);
        
        pyodideReady = true;
        return pyodide;
        
      } catch (error) {
        pyodideLoading = false;
        throw error;
      }
    }
    
    async function runPythonCode(code) {
      const startTime = performance.now();
      const py = await loadPyodide();
      
      await py.runPython('_output_capture.clear()');
      
      try {
        const result = await py.runPython(code);
        const [stdout, stderr] = py.globals.get('_output_capture').get_output().toJs();
        const endTime = performance.now();
        
        let output = stdout || '';
        if (result !== undefined && result !== null && String(result) !== 'None') {
          output = output ? output + '\n' + String(result) : String(result);
        }
        
        return {
          output: output || 'Execution finished (no output)',
          error: stderr || null,
          time: endTime - startTime
        };
      } catch (error) {
        const endTime = performance.now();
        return {
          output: '',
          error: error.message || String(error),
          time: endTime - startTime
        };
      }
    }

    // Unified init for Python runners + view-only code blocks.
    // Both share .coderunner; the Run button is absent for view-only.
    function initCodeRunners() {
      document.querySelectorAll('.coderunner').forEach((block) => {
        if (block.dataset.initialized) return;
        block.dataset.initialized = 'true';

        const copyBtn = block.querySelector('.cr-copy-btn');
        const runBtn  = block.querySelector('.cr-run-btn');
        const gutter  = block.querySelector('.cr-gutter');
        const codeEl  = block.querySelector('.cr-code');
        const status  = block.querySelector('.cr-run-status');
        const outPanel = block.querySelector('.cr-output');
        const outText  = block.querySelector('.cr-output-text');
        const clearBtn = block.querySelector('.cr-output-clear');

        const encodedCode = block.dataset.code || '';
        const code = encodedCode ? decodeURIComponent(encodedCode) : '';

        // Keep line-number gutter in vertical sync with code scroll.
        if (codeEl && gutter) {
          codeEl.addEventListener('scroll', () => {
            gutter.scrollTop = codeEl.scrollTop;
          });
        }

        // Copy button
        copyBtn?.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code);
            copyBtn.classList.add('copied');
            setTimeout(() => copyBtn.classList.remove('copied'), 1800);
          } catch (err) {
            console.error('Failed to copy code:', err);
          }
        });

        // Run button (Python only — absent on view-only blocks)
        runBtn?.addEventListener('click', async () => {
          if (!code || !outPanel || !outText || !status) return;

          runBtn.disabled = true;
          runBtn.classList.add('running');
          status.textContent = 'Running';
          status.className = 'cr-status-item cr-status-right cr-run-status';
          outPanel.hidden = false;
          outText.textContent = 'Loading Python...';

          try {
            const result = await runPythonCode(code);
            if (result.error) {
              outText.innerHTML = `<span class="error">${escapeHtml(result.error)}</span>`;
              status.textContent = 'Error';
              status.className = 'cr-status-item cr-status-right cr-run-status error';
            } else {
              outText.innerHTML = `<span class="success">${escapeHtml(result.output)}</span>`;
              status.textContent = `Done in ${Math.round(result.time)}ms`;
              status.className = 'cr-status-item cr-status-right cr-run-status success';
            }
          } catch (err) {
            outText.innerHTML = `<span class="error">${escapeHtml(err.message || 'Unknown error')}</span>`;
            status.textContent = 'Pyodide error';
            status.className = 'cr-status-item cr-status-right cr-run-status error';
          } finally {
            runBtn.disabled = false;
            runBtn.classList.remove('running');
          }
        });

        // Clear output
        clearBtn?.addEventListener('click', () => {
          if (outPanel && outText) {
            outPanel.hidden = true;
            outText.textContent = '';
          }
          if (status) {
            status.textContent = 'Ready';
            status.className = 'cr-status-item cr-status-right cr-run-status';
          }
        });
      });
    }


    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function showCopyFeedback(message) {
      const feedback = document.createElement('div');
      feedback.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        padding: 0.75rem 1.5rem;
        background: #a6e3a1;
        color: #11111b;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        z-index: 10000;
        animation: fadeInOut 1500ms var(--ease-standard) forwards;
      `;
      feedback.textContent = message;
      document.body.appendChild(feedback);
      setTimeout(() => feedback.remove(), 1500);
    }

    reinitAll();
    // Astro View Transitions navigation
    document.addEventListener('astro:after-swap', reinitAll);
    // Fetch-based chapter navigation (TOC clicks)
    window.addEventListener('chapter-content-swapped', reinitAll);
  </script>
</BaseLayout>