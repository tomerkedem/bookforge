---
interface Props {
  title: string;
  lang?: 'he' | 'en';
  description?: string;
}

const { title, lang = 'he', description = '' } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;700&family=Heebo:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-yuval-text font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; }

  h1, h2, h3, h4 {
    font-family: 'Frank Ruhl Libre', Georgia, serif;
  }

  body {
    font-family: 'Heebo', system-ui, sans-serif;
    font-weight: 300;
    color: #1a1a1a;
    background: #ffffff;
  }

  /* Smooth scroll */
  html { scroll-behavior: smooth; }

  /* Reading typography */
  .prose-yuval p {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.85;
    color: #333333;
    margin-bottom: 24px;
  }

  .prose-yuval h1 {
    font-size: clamp(36px, 5vw, 72px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 40px;
  }

  .prose-yuval h2 {
    font-size: clamp(24px, 3vw, 42px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-top: 64px;
    margin-bottom: 40px;
  }

  .prose-yuval ul {
    list-style: none;
    padding: 0;
    margin-bottom: 24px;
  }

  .prose-yuval li::before {
    content: '—';
    margin-inline-end: 12px;
    color: #bbbbbb;
  }
</style>
