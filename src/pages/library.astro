---
/**
 * /library — Living Library, v1 skeleton.
 *
 * This page is a SAFETY-CHECK skeleton, not the final futuristic screen.
 * It exists to prove that the four foundations from Prompts 2–4 wire
 * together end-to-end:
 *
 *   • Data layer ........ src/utils/library-catalog.ts (mock-backed)
 *   • i18n layer ........ library.* keys via t() in he / en / es
 *   • Theme tokens ...... --yuval-galaxy-* under .library-dark-showcase
 *   • Routing ........... new /library route, no impact on / or /read
 *
 * Out of scope for this step (intentional — see Prompt 5 contract):
 *   – No orbit carousel, no glowing knowledge core, no animations
 *   – No working search, filter, sort, AI assistant
 *   – No card linking yet (mock hrefs include future routes that don't
 *     exist; rendering as non-clickable <article> avoids 404s)
 *   – No new component files; one page file is enough at this stage
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import type { Language } from '../types/index';
import type { LibraryItem, LibraryItemStatus, LibraryItemType } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t, type TranslationKey } from '../i18n';
import {
  getMockLibraryItems,
  getLibraryStats,
  getRecentlyUpdatedItems,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';

// ── Language resolution (matches the existing /index.astro pattern) ────────
interface Props {
  language?: Language;
}
const { language: propLanguage } = Astro.props;

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data (depends on the abstract utility surface, not the mock array) ─────
// SOLID-DI: when the real adapter replaces the mock source inside
// library-catalog.ts, this page does not change.
const items = getMockLibraryItems();
const stats = getLibraryStats(items);
const continueItem = getContinueReadingItem(items);
const recentItems = getRecentlyUpdatedItems(items, 6);
const recommendedItems = continueItem
  ? getRecommendedItems(items, continueItem.id, 6)
  : [];

// A small mixed showcase row so each major type appears at least once
// even if "recent" happens to skew toward one kind. Defensive: if a
// type is missing entirely from the mock, the slot is simply omitted.
const showcaseTypes: LibraryItemType[] = ['book', 'course', 'series', 'article'];
const showcaseItems: LibraryItem[] = showcaseTypes
  .map((type) => items.find((it) => it.type === type))
  .filter((it): it is LibraryItem => Boolean(it));

// ── Local helpers (small, single-purpose, page-scoped) ─────────────────────
// Open/Closed: every helper takes a value from the typed enum and
// composes a translation key — adding a new LibraryItemType later
// only requires adding the matching i18n key, not editing this page.

function localizedTitle(item: LibraryItem, lang: Language): string {
  return item.titles[lang] ?? item.titles.en ?? item.titles.he ?? item.slug;
}

function localizedSummary(item: LibraryItem, lang: Language): string {
  if (!item.summaries) return '';
  return item.summaries[lang] ?? item.summaries.en ?? item.summaries.he ?? '';
}

function typeLabelKey(type: LibraryItemType): TranslationKey {
  return `library.itemType.${type}` as TranslationKey;
}

function statusLabelKey(status: LibraryItemStatus): TranslationKey {
  return `library.status.${status}` as TranslationKey;
}

/** CSS variable name for a type's accent — matches galaxy.css tokens. */
function typeAccentVar(type: LibraryItemType): string {
  return `var(--yuval-galaxy-type-${type})`;
}

/** CSS variable name for a status colour — matches galaxy.css tokens. */
function statusAccentVar(status: LibraryItemStatus): string {
  return `var(--yuval-galaxy-status-${status})`;
}

/** Format an ISO date as a localized short date, defensively. */
function formatDate(iso: string | undefined, lang: Language): string {
  if (!iso) return '';
  const ts = Date.parse(iso);
  if (Number.isNaN(ts)) return '';
  try {
    return new Date(ts).toLocaleDateString(
      lang === 'he' ? 'he-IL' : lang === 'es' ? 'es-ES' : 'en-US',
      { year: 'numeric', month: 'short', day: 'numeric' },
    );
  } catch {
    return '';
  }
}
---

<BaseLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={false}
>
  {/*
    The .library-dark-showcase class is the LOCAL dark-scope mechanism
    defined in src/styles/galaxy.css (Prompt 4). It only redeclares
    --yuval-galaxy-* tokens within this subtree — it does NOT touch
    html.dark, the global theme preference, or any --yuval-* token used
    by the reading experience. Outside this <div>, the user's chosen
    light/dark/sepia mode continues to apply normally.

    v1 decision: lock /library to dark visuals. A future per-page theme
    toggle can replace this class with .galaxy-theme-light/dark without
    touching components — they read tokens, not selectors.
  */}
  <div class="library-dark-showcase library-root" lang={language} dir={isRtl ? 'rtl' : 'ltr'}>

    {/* ── Hero ────────────────────────────────────────────────────── */}
    <section class="library-hero" aria-label={t('library.a11y.mainRegion', language)}>
      <header class="library-hero-header">
        <p class="library-hero-eyebrow">{t('library.galaxy.welcome', language)}</p>
        <h1 class="library-hero-title">{t('library.galaxy.title', language)}</h1>
        <p class="library-hero-subtitle">{t('library.galaxy.subtitle', language)}</p>
      </header>

      {/* Search placeholder — readonly to make non-functional state honest */}
      <form class="library-search" role="search" onsubmit="return false;">
        <label for="library-search-input" class="sr-only">
          {t('library.a11y.searchInput', language)}
        </label>
        <input
          id="library-search-input"
          type="search"
          readonly
          placeholder={t('library.galaxy.searchPlaceholder', language)}
          aria-label={t('library.a11y.searchInput', language)}
          class="library-search-input"
        />
      </form>

      <div class="library-hero-ctas">
        <button type="button" class="library-cta library-cta-primary" disabled>
          {t('library.galaxy.primaryCta', language)}
        </button>
        <button type="button" class="library-cta library-cta-secondary" disabled>
          {t('library.galaxy.secondaryCta', language)}
        </button>
      </div>
    </section>

    {/* ── Body grid (mobile: vertical / desktop: 3-column) ─────────── */}
    <div class="library-body">

      {/* Left column on desktop: continue + stats */}
      <div class="library-col library-col-side">

        {continueItem && (
          <section class="library-panel" aria-label={t('library.a11y.continueReadingCard', language)}>
            <h2 class="library-panel-title">{t('library.continueReading.title', language)}</h2>
            <article
              class="library-card library-card-continue"
              style={`--card-accent: ${typeAccentVar(continueItem.type)};`}
            >
              <p class="library-card-type">{t(typeLabelKey(continueItem.type), language)}</p>
              <h3 class="library-card-title">{localizedTitle(continueItem, language)}</h3>
              {localizedSummary(continueItem, language) && (
                <p class="library-card-summary">{localizedSummary(continueItem, language)}</p>
              )}
              {continueItem.updatedAt && (
                <p class="library-card-meta">
                  {t('library.continueReading.lastOpened', language, {
                    when: formatDate(continueItem.updatedAt, language),
                  })}
                </p>
              )}
              <button type="button" class="library-cta library-cta-primary library-cta-inline" disabled>
                {t('library.continueReading.cta', language)}
              </button>
            </article>
          </section>
        )}

        <section class="library-panel" aria-label={t('library.a11y.libraryStatsPanel', language)}>
          <h2 class="library-panel-title">{t('library.stats.title', language)}</h2>
          <ul class="library-stats-list">
            <li>{t('library.stats.totalItems', language, { n: stats.total })}</li>
            <li>{t('library.stats.booksCount', language, { n: stats.byType.book ?? 0 })}</li>
            <li>{t('library.stats.coursesCount', language, { n: stats.byType.course ?? 0 })}</li>
            <li>{t('library.stats.seriesCount', language, { n: stats.byType.series ?? 0 })}</li>
            <li>{t('library.stats.articlesCount', language, { n: stats.byType.article ?? 0 })}</li>
            <li>{t('library.stats.readingMinutes', language, { n: stats.totalReadingMinutes })}</li>
            <li>{t('library.stats.words', language, { n: stats.totalWordCount })}</li>
          </ul>
        </section>

      </div>

      {/* Center column on desktop: showcase + recent grid */}
      <div class="library-col library-col-main">

        {showcaseItems.length > 0 && (
          <section class="library-panel">
            <h2 class="library-panel-title">{t('library.galaxy.welcome', language)}</h2>
            <div class="library-card-grid library-card-grid-mixed">
              {showcaseItems.map((item) => (
                <article
                  class="library-card"
                  style={`--card-accent: ${typeAccentVar(item.type)};`}
                  aria-label={localizedTitle(item, language)}
                >
                  <header class="library-card-header">
                    <p class="library-card-type">{t(typeLabelKey(item.type), language)}</p>
                    <span
                      class="library-card-status"
                      style={`color: ${statusAccentVar(item.status)}; border-color: ${statusAccentVar(item.status)};`}
                    >
                      {t(statusLabelKey(item.status), language)}
                    </span>
                  </header>
                  <h3 class="library-card-title">{localizedTitle(item, language)}</h3>
                  {localizedSummary(item, language) && (
                    <p class="library-card-summary">{localizedSummary(item, language)}</p>
                  )}
                </article>
              ))}
            </div>
          </section>
        )}

        <section class="library-panel">
          <h2 class="library-panel-title">{t('library.sort.recent', language)}</h2>
          <div class="library-card-grid">
            {recentItems.map((item) => (
              <article
                class="library-card"
                style={`--card-accent: ${typeAccentVar(item.type)};`}
                aria-label={localizedTitle(item, language)}
              >
                <header class="library-card-header">
                  <p class="library-card-type">{t(typeLabelKey(item.type), language)}</p>
                  <span
                    class="library-card-status"
                    style={`color: ${statusAccentVar(item.status)}; border-color: ${statusAccentVar(item.status)};`}
                  >
                    {t(statusLabelKey(item.status), language)}
                  </span>
                </header>
                <h3 class="library-card-title">{localizedTitle(item, language)}</h3>
                {localizedSummary(item, language) && (
                  <p class="library-card-summary">{localizedSummary(item, language)}</p>
                )}
                {typeof item.readingMinutes === 'number' && (
                  <p class="library-card-meta">
                    {t('library.stats.readingMinutes', language, { n: item.readingMinutes })}
                  </p>
                )}
              </article>
            ))}
          </div>
        </section>

      </div>

      {/* Right column on desktop: AI assistant placeholder */}
      <aside class="library-col library-col-aside" aria-label={t('library.a11y.openAssistant', language)}>
        <section class="library-panel">
          <h2 class="library-panel-title">{t('library.action.aiAssistant', language)}</h2>
          <ul class="library-actions-list">
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.askAboutItem', language)}
              </button>
            </li>
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.summarizeArticle', language)}
              </button>
            </li>
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.findRelated', language)}
              </button>
            </li>
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.whatNext', language)}
              </button>
            </li>
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.bookmarks', language)}
              </button>
            </li>
            <li>
              <button type="button" class="library-action-btn" disabled>
                {t('library.action.history', language)}
              </button>
            </li>
          </ul>
        </section>
      </aside>

    </div>

    {/* ── Recommendations strip ────────────────────────────────────── */}
    <section
      class="library-panel library-recs"
      aria-label={t('library.a11y.recommendationCarousel', language)}
    >
      <h2 class="library-panel-title">{t('library.recommendation.forYou', language)}</h2>
      {recommendedItems.length > 0 ? (
        <>
          <p class="library-recs-eyebrow">{t('library.recommendation.basedOnYourLibrary', language)}</p>
          <div class="library-card-strip">
            {recommendedItems.map((item) => (
              <article
                class="library-card library-card-rec"
                style={`--card-accent: ${typeAccentVar(item.type)};`}
                aria-label={localizedTitle(item, language)}
              >
                <p class="library-card-type">{t(typeLabelKey(item.type), language)}</p>
                <h3 class="library-card-title">{localizedTitle(item, language)}</h3>
                {localizedSummary(item, language) && (
                  <p class="library-card-summary">{localizedSummary(item, language)}</p>
                )}
              </article>
            ))}
          </div>
        </>
      ) : (
        <p class="library-empty-text">{t('library.recommendation.none', language)}</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────────
     /library v1 skeleton styles — phone-first.

     Hard rule: no hex colors here. Every visual color/effect is read
     from a --yuval-galaxy-* token defined in src/styles/galaxy.css.
     The wrapper carries .library-dark-showcase, which redeclares those
     tokens in the dark palette regardless of the user's global theme.

     RTL support: uses CSS Logical Properties (margin-inline-*, padding-
     inline-*, border-inline-*) so Hebrew flips automatically when the
     wrapper carries dir="rtl".
     ────────────────────────────────────────────────────────────────────── */

  .library-root {
    min-height: 100vh;
    width: 100%;
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1.5rem 1rem 5rem;
    box-sizing: border-box;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */
  .library-hero {
    max-width: 1200px;
    margin: 0 auto 2rem;
    padding: 1.5rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }

  .library-hero-eyebrow {
    font-size: 0.8125rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0 0 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .library-hero-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 0.75rem;
    color: var(--yuval-galaxy-text);
  }

  .library-hero-subtitle {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 1.25rem;
    max-width: 56ch;
  }

  /* Search placeholder — visually present, behaviorally inert */
  .library-search {
    margin: 0 0 1rem;
  }
  .library-search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text);
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: 999px;
    outline: none;
  }
  .library-search-input::placeholder {
    color: var(--yuval-galaxy-text-soft);
  }
  .library-search-input:focus-visible {
    border-color: var(--yuval-galaxy-border-glow);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }

  /* Hero CTAs */
  .library-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .library-cta {
    appearance: none;
    border: 1px solid var(--yuval-galaxy-border-strong);
    border-radius: 999px;
    padding: 0.625rem 1.125rem;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: not-allowed;
    transition: transform var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out),
                box-shadow var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .library-cta-primary {
    background-color: var(--yuval-galaxy-accent);
    color: var(--yuval-galaxy-text-inverse);
    border-color: transparent;
  }
  .library-cta-secondary {
    background-color: transparent;
    color: var(--yuval-galaxy-text);
  }
  .library-cta-inline {
    margin-block-start: 0.75rem;
  }
  .library-cta:disabled {
    opacity: 0.7;
  }
  .library-cta:focus-visible {
    box-shadow: var(--yuval-galaxy-glow-primary);
  }

  /* ── Body grid: mobile vertical, desktop 3-column ──────────────────── */
  .library-body {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .library-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  /* ── Panels (each section block) ──────────────────────────────────── */
  .library-panel {
    padding: 1.25rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }

  .library-panel-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.875rem;
    color: var(--yuval-galaxy-text);
  }

  /* ── Stats list ───────────────────────────────────────────────────── */
  .library-stats-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1rem;
  }
  .library-stats-list li {
    font-size: 0.875rem;
    color: var(--yuval-galaxy-text-muted);
    padding-block: 0.25rem;
  }

  /* ── Cards ───────────────────────────────────────────────────────── */
  .library-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  .library-card-grid-mixed {
    grid-template-columns: 1fr;
  }
  .library-card-strip {
    display: flex;
    gap: 0.875rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-block-end: 0.5rem;
    -webkit-overflow-scrolling: touch;
  }
  .library-card-strip > .library-card {
    flex: 0 0 80%;
    max-width: 320px;
    scroll-snap-align: start;
  }

  .library-card {
    --card-accent: var(--yuval-galaxy-accent);
    position: relative;
    padding: 1rem 1rem 1.125rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: calc(var(--yuval-galaxy-card-radius) - 4px);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
  }
  /* Accent stripe — uses the per-type token via --card-accent inline var. */
  .library-card::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    height: 2px;
    background-color: var(--card-accent);
    opacity: 0.85;
  }

  .library-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-block-end: 0.5rem;
  }
  .library-card-type {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0;
  }
  .library-card-status {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    border: 1px solid;
    background-color: transparent;
    white-space: nowrap;
  }
  .library-card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.375rem;
    color: var(--yuval-galaxy-text);
  }
  .library-card-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .library-card-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
  }

  /* ── AI actions rail ──────────────────────────────────────────────── */
  .library-actions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .library-action-btn {
    width: 100%;
    text-align: start;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    color: var(--yuval-galaxy-text);
    background-color: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: 12px;
    cursor: not-allowed;
  }
  .library-action-btn:disabled {
    opacity: 0.7;
  }

  /* ── Recommendations strip section ────────────────────────────────── */
  .library-recs {
    max-width: 1200px;
    margin: 1.5rem auto 0;
  }
  .library-recs-eyebrow {
    font-size: 0.8125rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0 0 0.75rem;
  }
  .library-empty-text {
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text-muted);
    margin: 0;
  }

  /* ── Tablet (≥640px): 2-up cards, wider stats ─────────────────────── */
  @media (min-width: 640px) {
    .library-root {
      padding: 2rem 1.5rem 5rem;
    }
    .library-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .library-card-grid-mixed {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .library-card-strip > .library-card {
      flex-basis: 45%;
    }
  }

  /* ── Desktop (≥1024px): 3-column body ─────────────────────────────── */
  @media (min-width: 1024px) {
    .library-body {
      grid-template-columns: minmax(240px, 1fr) minmax(0, 2fr) minmax(240px, 1fr);
      gap: 1.5rem;
    }
    .library-card-grid {
