---
/**
 * /library — Living Library, v1 composition.
 *
 * After Prompt 6 refactor, this page is composition-only:
 *  • picks language from URL / props
 *  • loads mock catalog data via the utility surface
 *  • lays out the page subtree under .library-dark-showcase
 *  • plugs in the small library/* components — no rendering logic here
 *
 * Card rendering, stats formatting, search chrome, and quick-action
 * placeholders all live in src/components/library/. Pure helpers
 * live in src/utils/library-display.ts. This page no longer knows
 * what a card looks like — it just knows where one goes.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueReadingCard from '../components/library/ContinueReadingCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import RecommendationStrip from '../components/library/RecommendationStrip.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';

import type { Language } from '../types/index';
import type { LibraryItem, LibraryItemType } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getMockLibraryItems,
  getLibraryStats,
  getRecentlyUpdatedItems,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';

// ── Language ──────────────────────────────────────────────────────────────
interface Props {
  language?: Language;
}
const { language: propLanguage } = Astro.props;

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Only this page touches the catalog utilities. Components below depend on
// LibraryItem / LibraryStats — never on the mock array directly (DI).
const items = getMockLibraryItems();
const stats = getLibraryStats(items);
const continueItem = getContinueReadingItem(items);
const recentItems = getRecentlyUpdatedItems(items, 6);
const recommendedItems = continueItem
  ? getRecommendedItems(items, continueItem.id, 6)
  : [];

// Showcase row — one of each major type when available, defensive otherwise.
const showcaseTypes: LibraryItemType[] = ['book', 'course', 'series', 'article'];
const showcaseItems: LibraryItem[] = showcaseTypes
  .map((type) => items.find((it) => it.type === type))
  .filter((it): it is LibraryItem => Boolean(it));
---

<BaseLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={false}
>
  {/*
    .library-dark-showcase scopes --yuval-galaxy-* dark tokens to this
    subtree only. It does not touch html.dark, the user's global theme
    preference, or any other route. See galaxy.css and Prompt 4 notes.
    Header above remains controlled by the global theme — by design,
    per the Prompt 6 contract.
  */}
  <div class="library-dark-showcase library-root" lang={language} dir={isRtl ? 'rtl' : 'ltr'}>

    <LibraryHero language={language} />

    <div class="library-body">

      <div class="library-col library-col-side">
        <ContinueReadingCard item={continueItem} language={language} />
        <LibraryStatsPanel stats={stats} language={language} />
      </div>

      <div class="library-col library-col-main">

        {showcaseItems.length > 0 && (
          <section class="library-section" aria-label={t('library.galaxy.welcome', language)}>
            <h2 class="library-section-title">{t('library.galaxy.welcome', language)}</h2>
            <div class="library-card-grid">
              {showcaseItems.map((item) => (
                <LibraryCard item={item} language={language} />
              ))}
            </div>
          </section>
        )}

        <section class="library-section">
          <h2 class="library-section-title">{t('library.sort.recent', language)}</h2>
          <div class="library-card-grid">
            {recentItems.map((item) => (
              <LibraryCard item={item} language={language} />
            ))}
          </div>
        </section>

      </div>

      <LibraryQuickActions language={language} />

    </div>

    <RecommendationStrip items={recommendedItems} language={language} />

  </div>
</BaseLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────────
     Page-level shell only. All component chrome (panels, cards, search,
     CTAs) lives inside the components — this file does not redeclare
     it. RTL flips automatically via CSS Logical Properties.
     ────────────────────────────────────────────────────────────────────── */

  .library-root {
    min-height: 100vh;
    width: 100%;
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1.5rem 1rem 5rem;
    box-sizing: border-box;
  }

  .library-body {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .library-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  /* Section wrapper — the two unnamed groups in the main column
     (showcase + recent). Components own their own panel chrome; this
     is just enough chrome for the inline groupings here. */
  .library-section {
    padding: 1.25rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }
  .library-section-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.875rem;
    color: var(--yuval-galaxy-text);
  }

  .library-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 640px) {
    .library-root { padding: 2rem 1.5rem 5rem; }
    .library-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .library-body {
      grid-template-columns: minmax(240px, 1fr) minmax(0, 2fr) minmax(240px, 1fr);
      gap: 1.5rem;
    }
    .library-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1280px) {
    .library-card-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
