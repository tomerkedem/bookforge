---
/**
 * /library — Living Library, premium-foundation composition.
 *
 * Page is composition-only:
 *  • picks language from URL / props
 *  • loads mock catalog data through the utility surface
 *  • lays out the page subtree under .library-dark-showcase
 *  • plugs in the small library/* components
 *
 * Visual upgrade in this prompt is mostly *inside* the components.
 * What this page contributes to the upgrade:
 *  - layered ambient backdrop (radial purple/blue + a soft top aurora)
 *  - clearer section rhythm and breathing room
 *  - a hairline divider between the hero band and the content body
 *
 * No carousel, no animation, no JS. Header stays controlled by the
 * global theme — out of scope for this step.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import ContinueReadingCard from '../components/library/ContinueReadingCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import RecommendationStrip from '../components/library/RecommendationStrip.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';

import type { Language } from '../types/index';
import type { LibraryItem, LibraryItemType } from '../types/library';
import { DEFAULT_LANGUAGE, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getMockLibraryItems,
  getLibraryStats,
  getRecentlyUpdatedItems,
  getContinueReadingItem,
  getRecommendedItems,
} from '../utils/library-catalog';

// ── Language ──────────────────────────────────────────────────────────────
interface Props {
  language?: Language;
}
const { language: propLanguage } = Astro.props;

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data (only this page touches catalog utilities — DI) ──────────────────
const items = getMockLibraryItems();
const stats = getLibraryStats(items);
const continueItem = getContinueReadingItem(items);
const recentItems = getRecentlyUpdatedItems(items, 6);
const recommendedItems = continueItem
  ? getRecommendedItems(items, continueItem.id, 6)
  : [];

const showcaseTypes: LibraryItemType[] = ['book', 'course', 'series', 'article'];
const showcaseItems: LibraryItem[] = showcaseTypes
  .map((type) => items.find((it) => it.type === type))
  .filter((it): it is LibraryItem => Boolean(it));
---

<BaseLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={['he', 'en', 'es']}
  allowClientLanguageOverride={true}
  showHeader={true}
  showProgress={false}
>
  {/*
    .library-dark-showcase scopes --yuval-galaxy-* dark tokens to this
    subtree only. It does not touch html.dark, the user's global theme
    preference, or any other route. Header above remains controlled by
    the global theme — by design, per Prompt 7 contract.
  */}
  <div class="library-dark-showcase library-root" lang={language} dir={isRtl ? 'rtl' : 'ltr'}>

    {/*
      Decorative ambient layer. Layered radial gradients drawn on a
      pseudo-element so they live behind everything, never block input,
      and stay token-based. aria-hidden via the wrapper's `aria-hidden`
      element below.
    */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-aurora"></div>
    </div>

    <LibraryHero language={language} />

    <div class="library-divider" aria-hidden="true"></div>

    <div class="library-body">

      <div class="library-col library-col-side">
        <ContinueReadingCard item={continueItem} language={language} />
        <LibraryStatsPanel stats={stats} language={language} />
      </div>

      <div class="library-col library-col-main">

        {showcaseItems.length > 0 && (
          <section class="library-section" aria-label={t('library.galaxy.welcome', language)}>
            <header class="library-section-header">
              <span class="library-section-dot" aria-hidden="true"></span>
              <h2 class="library-section-title">{t('library.galaxy.welcome', language)}</h2>
            </header>
            <div class="library-card-grid">
              {showcaseItems.map((item) => (
                <LibraryCard item={item} language={language} />
              ))}
            </div>
          </section>
        )}

        <section class="library-section">
          <header class="library-section-header">
            <span class="library-section-dot library-section-dot-alt" aria-hidden="true"></span>
            <h2 class="library-section-title">{t('library.sort.recent', language)}</h2>
          </header>
          <div class="library-card-grid">
            {recentItems.map((item) => (
              <LibraryCard item={item} language={language} />
            ))}
          </div>
        </section>

      </div>

      <LibraryQuickActions language={language} />

    </div>

    <RecommendationStrip items={recommendedItems} language={language} />

  </div>
</BaseLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────────
     Page-level shell only. Component chrome lives inside components.
     RTL flips automatically via CSS Logical Properties.
     ────────────────────────────────────────────────────────────────────── */

  .library-root {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background-color: var(--yuval-galaxy-bg);
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    padding: 1.5rem 1rem 5rem;
    box-sizing: border-box;
    isolation: isolate;
    overflow: hidden;
  }

  /* ── Ambient backdrop layer ───────────────────────────────────────── */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* "Aurora" — a wide soft band of cyan light at the upper third of
     the page. Gives the screen a sense of horizon and depth without
     adding particles or animation. */
  .library-aurora {
    position: absolute;
    inset-block-start: 8%;
    inset-inline-start: -10%;
    width: 120%;
    height: 280px;
    background: radial-gradient(ellipse at center,
      var(--yuval-galaxy-accent-cyan) 0%,
      transparent 65%);
    opacity: 0.10;
    filter: blur(60px);
  }

  /* All real content sits above the ambient layer. */
  .library-root > :not(.library-ambient) {
    position: relative;
    z-index: 1;
  }

  /* ── Divider between hero band and content body ───────────────────── */
  .library-divider {
    max-width: 1200px;
    margin: 0 auto 1.5rem;
    height: 1px;
    background: var(--yuval-galaxy-divider);
  }

  /* ── Body grid: mobile vertical, desktop 3-column ──────────────────── */
  .library-body {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .library-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  /* ── Section wrapper for inline groups in the main column ─────────── */
  .library-section {
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }
  .library-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .library-section-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent-cyan);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .library-section-dot-alt {
    background-color: var(--yuval-galaxy-accent-purple);
    box-shadow: var(--yuval-galaxy-glow-secondary);
  }
  .library-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }

  .library-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  /* ── Tablet (≥640px): 2-up cards, more outer padding ──────────────── */
  @media (min-width: 640px) {
    .library-root { padding: 2rem 1.5rem 5rem; }
    .library-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── Desktop (≥1024px): 3-column body, fuller rhythm ──────────────── */
  @media (min-width: 1024px) {
    .library-root { padding: 2.5rem 2rem 6rem; }
    .library-body {
      grid-template-columns: minmax(260px, 1fr) minmax(0, 2.2fr) minmax(260px, 1fr);
      gap: 1.5rem;
    }
    .library-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── Wide desktop (≥1280px): 3-up cards in main column ────────────── */
  @media (min-width: 1280px) {
    .library-card-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
