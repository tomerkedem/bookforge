---
/**
 * src/pages/sample-book/index.astro
 * Static-mode bilingual book index for "AI Developer Fitness".
 * Language (he/en) is resolved client-side from ?lang= query param.
 * Default language at build time: Hebrew.
 */
import Layout from '../../layouts/Layout.astro';

// Static build always uses Hebrew as the default lang.
// The client-side script below handles ?lang=en switching.
const lang = 'he' as const;
const pageTitle = 'AI Developer Fitness — BookForge';
---

<Layout title={pageTitle} lang={lang}>

  <!-- Hero -->
  <section class="mb-12 md:mb-16" aria-labelledby="book-title">
    <p class="mb-4 font-['Heebo'] text-xs font-medium uppercase tracking-[0.14em] text-[#bbbbbb]">
      BookForge
    </p>
    <h1
      id="book-title"
      class="font-['Frank_Ruhl_Libre'] text-4xl font-black leading-tight text-[#1a1a1a] md:text-6xl"
    >
      <span data-he>AI Developer Fitness</span>
      <span data-en class="hidden">AI Developer Fitness</span>
    </h1>
    <p class="mt-4 font-['Heebo'] text-lg font-light leading-relaxed text-[#888888]">
      <span data-he>בניית מערכות סוכנים עם Claude Code</span>
      <span data-en class="hidden">Building Agent Systems with Claude Code</span>
    </p>
    <div class="mt-8 h-px w-12 bg-[#e0ddd8]" aria-hidden="true"></div>
  </section>

  <!-- Chapter list -->
  <section>
    <h2 class="sr-only">
      <span data-he>תוכן עניינים</span>
      <span data-en class="hidden">Table of Contents</span>
    </h2>
    <ol class="space-y-px bg-[#e0ddd8]" role="list">

      <!-- Chapter 1 -->
      <li class="bg-[#fafaf8]">
        <a
          href="/sample-book/chapter-01"
          data-slug="chapter-01"
          class="group flex items-center gap-5 p-6 transition-colors hover:bg-[#f5f3ef] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1a1a1a] md:p-8"
        >
          <span class="w-10 shrink-0 font-['Heebo'] text-xs font-medium tracking-[0.12em] text-[#cccccc]" aria-hidden="true">01</span>
          <span class="flex-1 font-['Frank_Ruhl_Libre'] text-lg font-bold text-[#1a1a1a] md:text-xl">
            <span data-he>פרק הכנה: פרויקט ההדגמה והסביבה</span>
            <span data-en class="hidden">Preparation Chapter: The Demo Project and Environment</span>
          </span>
          <span class="shrink-0 font-['Heebo'] text-xs text-[#bbbbbb] opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true">
            <span data-he>← 5 דקות</span>
            <span data-en class="hidden">5 min →</span>
          </span>
        </a>
      </li>

      <!-- Chapter 2 -->
      <li class="bg-[#fafaf8]">
        <a
          href="/sample-book/chapter-02"
          data-slug="chapter-02"
          class="group flex items-center gap-5 p-6 transition-colors hover:bg-[#f5f3ef] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1a1a1a] md:p-8"
        >
          <span class="w-10 shrink-0 font-['Heebo'] text-xs font-medium tracking-[0.12em] text-[#cccccc]" aria-hidden="true">02</span>
          <span class="flex-1 font-['Frank_Ruhl_Libre'] text-lg font-bold text-[#1a1a1a] md:text-xl">
            <span data-he>פרק 1: שינוי מודל המנטלי</span>
            <span data-en class="hidden">Chapter 1: Shifting the Mental Model</span>
          </span>
          <span class="shrink-0 font-['Heebo'] text-xs text-[#bbbbbb] opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true">
            <span data-he>← 7 דקות</span>
            <span data-en class="hidden">7 min →</span>
          </span>
        </a>
      </li>

      <!-- Chapter 3 -->
      <li class="bg-[#fafaf8]">
        <a
          href="/sample-book/chapter-03"
          data-slug="chapter-03"
          class="group flex items-center gap-5 p-6 transition-colors hover:bg-[#f5f3ef] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1a1a1a] md:p-8"
        >
          <span class="w-10 shrink-0 font-['Heebo'] text-xs font-medium tracking-[0.12em] text-[#cccccc]" aria-hidden="true">03</span>
          <span class="flex-1 font-['Frank_Ruhl_Libre'] text-lg font-bold text-[#1a1a1a] md:text-xl">
            <span data-he>פרק 2: CLAUDE.md כארכיטקטורה</span>
            <span data-en class="hidden">Chapter 2: CLAUDE.md as Architecture</span>
          </span>
          <span class="shrink-0 font-['Heebo'] text-xs text-[#bbbbbb] opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true">
            <span data-he>← 10 דקות</span>
            <span data-en class="hidden">10 min →</span>
          </span>
        </a>
      </li>

      <!-- Chapter 4 -->
      <li class="bg-[#fafaf8]">
        <a
          href="/sample-book/chapter-04"
          data-slug="chapter-04"
          class="group flex items-center gap-5 p-6 transition-colors hover:bg-[#f5f3ef] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1a1a1a] md:p-8"
        >
          <span class="w-10 shrink-0 font-['Heebo'] text-xs font-medium tracking-[0.12em] text-[#cccccc]" aria-hidden="true">04</span>
          <span class="flex-1 font-['Frank_Ruhl_Libre'] text-lg font-bold text-[#1a1a1a] md:text-xl">
            <span data-he>פרק 3: Subagents, חלוקת עבודה נכונה</span>
            <span data-en class="hidden">Chapter 3: Subagents — Proper Division of Work</span>
          </span>
          <span class="shrink-0 font-['Heebo'] text-xs text-[#bbbbbb] opacity-0 transition-opacity group-hover:opacity-100" aria-hidden="true">
            <span data-he>← 15 דקות</span>
            <span data-en class="hidden">15 min →</span>
          </span>
        </a>
      </li>

    </ol>
  </section>

</Layout>

<script>
  // Client-side language switching for static Astro build.
  // Reads ?lang=en|he from the URL and shows/hides [data-he] / [data-en] elements.
  (function () {
    const params = new URLSearchParams(window.location.search);
    const lang = params.get('lang') === 'en' ? 'en' : 'he';
    if (lang === 'he') return; // Hebrew is the default rendered state

    // Switch to English: show [data-en], hide [data-he]
    document.querySelectorAll('[data-he]').forEach((el) => el.classList.add('hidden'));
    document.querySelectorAll('[data-en]').forEach((el) => el.classList.remove('hidden'));

    // Update <html> dir and lang for English
    document.documentElement.setAttribute('lang', 'en');
    document.documentElement.setAttribute('dir', 'ltr');

    // Update chapter links to preserve ?lang=en
    document.querySelectorAll<HTMLAnchorElement>('a[data-slug]').forEach((a) => {
      const slug = a.getAttribute('data-slug');
      if (slug) a.href = `/sample-book/${slug}?lang=en`;
    });
  })();
</script>
