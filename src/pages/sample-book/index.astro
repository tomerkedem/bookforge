---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { getBook, getChapters } from '../../lib/books';

const lang = (Astro.url.searchParams.get('lang') ?? 'he') as 'he' | 'en';
const dir = lang === 'he' ? 'rtl' : 'ltr';

const book = getBook('sample-book')!;
const chapters = getChapters('sample-book');
const title = lang === 'he' ? book.title.he : book.title.en;
const description = lang === 'he' ? book.description.he : book.description.en;
---

<Layout title={`${title} — Yuval`} lang={lang}>
  <Navigation lang={lang} currentPath="/sample-book/" />

  <!-- Hero -->
  <div dir={dir} class={`bg-gradient-to-br ${book.coverColor} text-white`}>
    <div class="max-w-4xl mx-auto px-4 py-16 md:py-24 flex flex-col gap-4">
      <p class="text-white/70 text-sm">
        <a href="/" class="hover:text-white transition-colors">
          {lang === 'he' ? 'הספרייה' : 'Library'}
        </a>
        {' / '}
        {title}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight">{title}</h1>
      <p class="text-white/80 text-lg max-w-xl leading-relaxed">{description}</p>

      <div class="flex items-center gap-4 mt-2 text-white/70 text-sm">
        <span>{book.totalChapters} {lang === 'he' ? 'פרקים' : 'chapters'}</span>
        <span>·</span>
        <span>{lang === 'he' ? 'עברית + אנגלית' : 'Hebrew + English'}</span>
      </div>

      <a
        href={`/sample-book/${chapters[0]?.id ?? 'chapter-01'}`}
        class="mt-4 self-start bg-white text-gray-900 font-semibold px-6 py-2.5 rounded-lg hover:bg-gray-100 transition-colors text-sm"
      >
        {lang === 'he' ? 'התחל לקרוא ←' : 'Start reading →'}
      </a>
    </div>
  </div>

  <!-- Chapter list -->
  <main dir={dir} class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold text-gray-900 mb-6">
      {lang === 'he' ? 'פרקי הספר' : 'Chapters'}
    </h2>

    <ol class="space-y-3">
      {chapters.map((ch, i) => {
        const chTitle = lang === 'he' ? ch.title.he : ch.title.en;
        return (
          <li>
            <a
              href={`/sample-book/${ch.id}`}
              class="flex items-center gap-4 p-4 rounded-xl border border-gray-100 hover:border-blue-300 hover:bg-blue-50 transition-all group"
            >
              <span class="text-2xl font-bold text-gray-200 group-hover:text-blue-200 transition-colors w-8 shrink-0 text-center">
                {i + 1}
              </span>
              <span class="text-gray-800 font-medium group-hover:text-blue-700 transition-colors">
                {chTitle}
              </span>
              <span class="ms-auto text-gray-300 group-hover:text-blue-400 transition-colors text-lg">
                {dir === 'rtl' ? '←' : '→'}
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </main>
</Layout>
