---
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import ReadingProgress from '../../components/sample-book/ReadingProgress.astro';
import TableOfContents from '../../components/sample-book/TableOfContents.astro';
import ChapterNav from '../../components/sample-book/ChapterNav.astro';

export async function getStaticPaths() {
  return [
    { params: { chapter: 'chapter-01' } },
    { params: { chapter: 'chapter-02' } },
    { params: { chapter: 'chapter-03' } },
  ];
}

const CHAPTERS = [
  { id: 'chapter-01', title: { he: 'פרק 1: מבוא לנושא', en: 'Chapter 1: Introduction' }, order: 1 },
  { id: 'chapter-02', title: { he: 'פרק 2: עקרונות מתקדמים', en: 'Chapter 2: Advanced Principles' }, order: 2 },
  { id: 'chapter-03', title: { he: 'פרק 3: סיכום ומסקנות', en: 'Chapter 3: Summary' }, order: 3 },
] as const;

const { chapter } = Astro.params;
if (!chapter) return Astro.redirect('/404');

const lang = (Astro.url.searchParams.get('lang') ?? 'he') as 'he' | 'en';
const dir = lang === 'he' ? 'rtl' : 'ltr';

const currentIndex = CHAPTERS.findIndex((c) => c.id === chapter);
const current = CHAPTERS[currentIndex];
const prevChapter = currentIndex > 0 ? CHAPTERS[currentIndex - 1] : undefined;
const nextChapter = currentIndex < CHAPTERS.length - 1 ? CHAPTERS[currentIndex + 1] : undefined;

const outputDir = join(process.cwd(), 'output', 'sample-book');
const filePath = join(outputDir, `${chapter}.${lang}.md`);

let rawContent = '';
try {
  rawContent = await readFile(filePath, 'utf-8');
} catch {
  rawContent = lang === 'he' ? 'הפרק לא נמצא.' : 'Chapter not found.';
}

// MD → HTML with prose-yuval classes
function mdToHtml(md: string): string {
  return md
    .split('\n')
    .map((line) => {
      if (line.startsWith('## ')) return `<h2>${line.slice(3)}</h2>`;
      if (line.startsWith('# '))  return `<h1>${line.slice(2)}</h1>`;
      if (line.startsWith('- '))  return `<li>${line.slice(2)}</li>`;
      if (line.trim() === '')     return '';
      return `<p>${line}</p>`;
    })
    .join('\n')
    .replace(/(<li>.*?<\/li>\n*)+/gs, (m) => `<ul>${m}</ul>`);
}

const htmlContent = mdToHtml(rawContent);
const pageTitle = (lang === 'he' ? current?.title.he : current?.title.en) ?? 'Yuval';
const chaptersForToc = CHAPTERS as unknown as Array<{ id: string; title: { he: string; en: string }; order: number }>;
---

<Layout title={`${pageTitle} — Yuval`} lang={lang}>
  <Navigation lang={lang} currentPath={`/sample-book/${chapter}`} />

  <ReadingProgress
    bookId="sample-book"
    chapterIndex={currentIndex}
    totalChapters={CHAPTERS.length}
  />

  <TableOfContents
    chapters={chaptersForToc}
    currentChapterId={chapter}
    lang={lang}
  />

  <!-- Reading area: max-width 680px, centered -->
  <main
    dir={dir}
    class="max-w-reading mx-auto prose-yuval"
    style="padding: 64px 48px 80px;"
  >
    <article set:html={htmlContent} />

    <ChapterNav
      prevChapter={prevChapter ? { id: prevChapter.id, title: lang === 'he' ? prevChapter.title.he : prevChapter.title.en } : undefined}
      nextChapter={nextChapter ? { id: nextChapter.id, title: lang === 'he' ? nextChapter.title.he : nextChapter.title.en } : undefined}
      lang={lang}
    />
  </main>
</Layout>
