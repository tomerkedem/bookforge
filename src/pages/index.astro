        visibility 0s linear 260ms;
    }
    .core-search-panel-glow {
      position: absolute;
      inset: -14px;
      border-radius: 999px;
      background: radial-gradient(
        ellipse at 50% 50%,
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent) 0%,
        transparent 70%);
      pointer-events: none;
      filter: blur(10px);
      opacity: 0.85;
    }
    .core-search-panel-icon {
      position: relative;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      color: var(--yuval-galaxy-accent, #5eead4);
      filter: drop-shadow(
        0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent));
    }
    .core-search-panel-icon svg {
      width: 100%;
      height: 100%;
    }
    .core-search-input {
      position: relative;
      flex: 1 1 auto;
      min-width: 0;
      padding: 0.25rem 0;
