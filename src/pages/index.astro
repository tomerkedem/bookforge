       height below the real 64px header and let the scene image reach the
       true viewport bottom. Desktop is unchanged. */
    .library-root {
      height: calc(100dvh - 64px);
    }

    :global(.lb-area-hero .lh) {
      padding: 1rem 0.5rem 0.75rem;
      background-color: transparent;
      border: 0;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow: none;
      overflow: visible;
      text-align: center;
    }
    :global(.lb-area-hero .lh-halo) {
      display: none;
    }
    :global(.lb-area-hero .lh-header) {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      margin-block-end: 0.25rem;
    }
    :global(.lb-area-hero .lh-text) {
      text-align: center;
    }
    :global(.lb-area-hero .lh-eyebrow) {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-transform: none;
      font-weight: 500;
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      margin-block-end: 0.3125rem;
      background: linear-gradient(
        90deg,
        var(--yuval-galaxy-accent-cyan) 0%,
        var(--yuval-galaxy-accent-purple) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    :global(.lb-area-hero .lh-title) {
      line-height: 1.05;
      margin-block-end: 0.375rem;
    }
    :global(.lb-area-hero .lh-subtitle) {
      margin-inline: auto;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    /* Mobile orbit: position:fixed so it always centres on the viewport's
       central book icon, regardless of how tall the hero text grew. */
    .lb-area-featured { display: block; }

    .library-galaxy {
      position: fixed;
      /* Lift the whole orbit composition up 60px on mobile so the carousel
         and the new Knowledge Space card at the bottom aren't cramped. The
         nav rail below references this same baseline and is shifted to match. */
      top: calc(50dvh - 60px);
      left: 50%;
      transform: translate(-50%, -50%);
      display: block;
      width: 100%;
      max-width: 100vw;
      min-height: clamp(440px, 95vw, 640px);
      margin: 0;
      overflow: visible;
      padding: 0;
      z-index: 1;
      /* `touch-action: none` is REQUIRED for drag-to-rotate. Without it,
         the browser claims horizontal swipes as pan/overscroll and our
         pointermove never fires on touch. */
      touch-action: none;
      /* Keep absolute positioning math direction-agnostic; per-card
         content picks up page direction via .galaxy-card below. */
      direction: ltr;
    }

    .galaxy-observatory {
      --obs-size: clamp(250px, 74vw, 380px);
      opacity: 0.5;
    }
    .obs-ring--outer,
    .obs-detail {
      display: none;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-observatory {
      opacity: 0.26;
    }

    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      --card-base-width: clamp(170px, 48vw, 240px);
      /* Single source of truth for the focused cover size. Counter-scales
         and the reading-entry panel width derive from this. */
      --center-card-w: min(64vw, 34.5dvh);
      width: var(--card-base-width);
      cursor: pointer;
      top: 50%;
      left: 50%;
      /* Focus Carousel, not an orbit: ry≈0 so visible stations sit on
         a near-horizontal line. rx tuned so side stations land ~55%
         on-screen at common phone widths. */
      --orbit-rx: clamp(200px, 62vw, 280px);
      --orbit-ry: clamp(0px, 1.5vh, 12px);
      /* Mobile-only +20° offset puts item #0 at exactly 270° (top).
         Without it, ORBIT_START_DEG=250° leaves two near-top cards
         instead of one dominant card. Desktop's calc is unchanged. */
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg) + 20deg);
      --orbit-depth: calc((1 - sin(var(--orbit-active-angle, 0deg))) / 2);
      --orbit-side: calc(
        cos(var(--orbit-active-angle, 0deg)) *
        cos(var(--orbit-active-angle, 0deg))
      );
      /* Focus Carousel ramps tuned so the cliff between "preview" and
         "hidden" falls between the N=7 ±51° and ±103° rings. Night uses
         the steeper html.dark opacity override below. */
      --slot-scale: clamp(0.55, calc(1.5 * var(--orbit-depth) - 0.4), 1.1);
      --slot-opacity: clamp(0, calc(1.73 * var(--orbit-depth) - 0.67), 1);
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform var(--orbit-motion-duration, 600ms)
                  var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
        opacity var(--orbit-motion-duration, 600ms)
                var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1));
      z-index: calc(1 + var(--orbit-depth) * 99);
      direction: var(--page-direction, ltr);
    }

    /* Mobile coverflow override. Same (0,1,0) specificity as the orbit
       transform above; wins by source order. Series mode (0,3,0) still
       wins for series members so the two carousels nest cleanly. */
    .galaxy-card {
      --mobile-step: clamp(100px, 28vw, 170px);
      --mobile-abs-rel: max(
        calc(var(--mobile-carousel-rel, 0) * -1),
        var(--mobile-carousel-rel, 0)
      );
      --mobile-row-x: calc(
        var(--mobile-carousel-rel, 0)
        * var(--mobile-step)
        * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translateX(var(--mobile-row-x))
        perspective(900px)
        rotateY(calc(
          var(--mobile-carousel-rel, 0)
          * -18deg
          * var(--galaxy-dir, 1)
        ))
        scale(calc(1.50 - var(--mobile-abs-rel) * 0.22));
      opacity: calc(1 - var(--mobile-abs-rel) * 0.32);
      z-index: calc(100 - var(--mobile-abs-rel));
      pointer-events: auto;
      /* REQUIRED: without backface-visibility, when rotateY pushes a
         card past 90° its mirrored text bleeds through on the
         inline-end edge as "leftover marks". */
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
    }

    /* Mobile nav wrapper — anchored snug under the visible side cards.
       Math (mirrors the focus-carousel transform in this same file):
         side-card visible half-height
           = card-base-width × 1.5 × side-scale(1.28) / 2
           = card-base-width × 0.96
         card-base-width = clamp(170px, 48vw, 240px)
         → half-height    ≈ clamp(163px, 46vw, 230px)
         → cards bottom    = 50dvh + that
         → nav top         = cards bottom + 4px breathing room

       This adapts per device width so the nav always lands ~4px
       below the lowest visible card edge — no dead space on tall
       phones (iPhone 12+), no overlap on short ones (iPhone SE).
       Leaves the bottom 20-25% of the viewport free for additional
       info cards stacked underneath.

       Visual stacking inside the wrapper (top→bottom):
         row 1  dots
         row 2  arrow rail  [prev]   counter   [next]

       !important on `display` / `position` is defensive — see the
       commit history for the prior "arrows above the card" regression
       caused by `display: contents` winning the cascade. */
    .galaxy-mobile-nav {
      display: flex !important;
      position: fixed !important;
      /* Push UP so the counter row sits flush at the visible bottom
         of the side cards (no breathing room). The 0px offset matches
         the side-card half-height math; the row visually touches the
         card edge. Tomer asked for "as snug as possible". */
      top: calc(50dvh + clamp(163px, 46vw, 230px) - 90px);
      inset-block-end: auto;
      inset-inline: 0;
      flex-direction: column;
      align-items: center;
      gap: 0;
      pointer-events: none;
      z-index: 40;
      transition: opacity 0.2s ease, visibility 0s linear 0s;
    }

    /* While a card is selected the nav is a fixed sibling OUTSIDE the
       stage, so it paints over the focused card's reading-entry panel
       and can't be pushed under it by z-index. JS sets data-focus-hidden
       on open and clears it on close, so the carousel chrome (counter +
       dots + rotate rail) fades out under the open card and returns when
       it closes. */
    .galaxy-mobile-nav[data-focus-hidden] {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.2s ease, visibility 0s linear 0.2s;
    }

    /* Slide-counter ("1 / 11") — small text, glued right above the
       dots row. Negative margin-bottom pulls it down so it visually
       hugs the top edge of the dots inside the arrow rail. */
    .galaxy-position-indicator {
      display: inline-flex !important;
      position: static;
      transform: none;
      align-items: baseline;
      gap: 0.2rem;
      padding: 0;
      margin: 0 0 -10px;
      min-width: 0;
      justify-content: center;
      background: transparent;
      border: 0;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55);
      pointer-events: none;
      line-height: 1;
    }
    :global(html:not(.dark)) .galaxy-position-indicator {
      color: rgba(22, 34, 60, 0.66);
      text-shadow: none;
    }
    [data-galaxy-position-current] {
      color: rgba(255, 255, 255, 0.98);
      font-weight: 600;
    }
    :global(html:not(.dark)) [data-galaxy-position-current] {
      color: rgba(22, 34, 60, 0.92);
    }
    .galaxy-position-sep {
      opacity: 0.4;
      font-weight: 400;
      margin-inline: 0.05rem;
    }

    /* Pagination dots — live INSIDE the arrow rail between the prev
       and next buttons. `space-between` on the rail pushes the dots
       container to the natural optical centre. Active dot stretches
       to a rounded pill in the Yuval accent blue. */
    .galaxy-position-dots {
      display: inline-flex !important;
      position: static;
      transform: none;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 0 8px;
      max-width: calc(100% - 96px);
      flex: 0 1 auto;
      flex-wrap: nowrap;
      overflow: hidden;
      pointer-events: none;
    }
    .galaxy-position-dot {
      flex: 0 0 auto;
      width: 5px;
      height: 5px;
      border-radius: 999px;
      /* Solid grays beat translucent over the bright cyan/white floor
         in day mode — the old 0.22 alpha vanished against the bg. */
      background: rgba(255, 255, 255, 0.55);
      transition:
        width 220ms cubic-bezier(0.22, 0.61, 0.36, 1),
        background-color 220ms ease,
        box-shadow 220ms ease;
    }
    .galaxy-position-dot[data-active] {
      width: 18px;
      background: var(--yuval-galaxy-accent-cyan, #22d3ee);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.55);
    }
    :global(html:not(.dark)) .galaxy-position-dot {
      background: rgba(34, 52, 92, 0.45);
    }
    :global(html:not(.dark)) .galaxy-position-dot[data-active] {
      background: #2563eb;
      box-shadow: 0 0 8px rgba(37, 99, 235, 0.40);
    }

    /* Re-states --slot-opacity at matching specificity (0,2,0) so it
       overrides the global light-mode floor (0.62) — without this the
       far mobile cards never fade to zero. */
    :global(html:not(.dark)) .galaxy-card {
      --slot-opacity: clamp(0, calc(1.73 * var(--orbit-depth) - 0.67), 1);
      filter:
        drop-shadow(0 3px 8px rgba(34, 52, 92, 0.16))
        drop-shadow(0 1px 2px rgba(34, 52, 92, 0.12));
    }

    :global(html.dark) .galaxy-card {
      --slot-opacity: clamp(0, calc(1.91 * var(--orbit-depth) - 0.91), 1);
    }

    /* Night-mode-only halo behind the carousel so the centred card
       reads cleanly when the bg's bright book icon sits behind it. */
    :global(html.dark) .library-galaxy::before {
      content: "";
      position: absolute;
      inset: -8vh -10vw;
      background: radial-gradient(
        ellipse 65% 45% at 50% 50%,
        rgba(0, 0, 16, 0.50) 0%,
        rgba(0, 0, 16, 0.30) 45%,
        transparent 85%
      );
      pointer-events: none;
      z-index: -1;
    }

    .galaxy-card[data-role="series"] {
      --card-base-width: clamp(195px, 54vw, 275px);
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }

    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="course"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
      cursor: grabbing;
    }

    /* Block the native image-drag ghost so pointermove stays smooth. */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* Mobile arrow rail — spans the full viewport width with the prev
       button anchored to the LEFT edge, the next button to the RIGHT
       edge, and the pagination DOTS centered between them.
       `justify-content: space-between` distributes naturally because
       both buttons share the same fixed width (44px), which places
       the dots container at the exact optical centre. The row resets
       every desktop-pill style so the wrapper's positioning fully
       owns layout on mobile. */
    .galaxy-orbit-controls {
      position: static !important;
      inset: auto !important;
      bottom: auto !important;
      top: auto;
      margin: 0;
      width: 100%;
      max-width: none;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding: 0 16px;
      border-radius: 0;
      background: transparent;
      border: 0;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      transform: none;
      direction: ltr;
      pointer-events: none;
    }
    :global(html:not(.dark)) .galaxy-orbit-controls {
      background: transparent;
      border: 0;
      box-shadow: none;
    }

    /* Mobile arrow button. The OUTER 44px box is the tap target (iOS
       HIG minimum); the visible chrome — a 38px white circle — is
       painted by ::before so the button stays touch-friendly while
       looking small and floating. Background on the button itself is
       transparent so only the inner circle reads as the control.

       z-index: 0 + ::before z-index: -1 keeps the visible circle
       below the SVG icon (z-index auto inside the flex line). Without
       the explicit `isolation: isolate`, the negative-z pseudo can
       escape the wrapper's stacking context on Safari. */
    .galaxy-orbit-btn {
      pointer-events: auto;
      position: relative;
      isolation: isolate;
      width: 44px;
      height: 44px;
      flex: 0 0 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: #1a2b4a;
      background: transparent;
      border: 0;
      box-shadow: none;
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-orbit-btn::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 38px;
      height: 38px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(34, 52, 92, 0.08);
      box-shadow:
        0 1px 2px rgba(15, 25, 50, 0.10),
        0 4px 12px rgba(15, 25, 50, 0.16);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: -1;
      transition: background-color 0.15s ease, border-color 0.15s ease,
                  box-shadow 0.15s ease;
    }
    :global(html:not(.dark)) .galaxy-orbit-btn {
      color: #1a2b4a;
      background: transparent;
      border: 0;
      box-shadow: none;
    }
    :global(html:not(.dark)) .galaxy-orbit-btn::before {
      background: #ffffff;
      border-color: rgba(34, 52, 92, 0.10);
      box-shadow:
        0 1px 2px rgba(30, 45, 80, 0.08),
        0 4px 10px rgba(30, 45, 80, 0.12);
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: #0f1c38;
      outline: none;
    }
    /* Same-specificity override (0,3,1) for the global light-mode hover
       at the top of the file — without this the 44px button paints a
       square halo behind the 38px circle. */
    :global(html:not(.dark)) .galaxy-orbit-btn:hover,
    :global(html:not(.dark)) .galaxy-orbit-btn:focus-visible {
      background: transparent;
      border: 0;
      box-shadow: none;
    }
    .galaxy-orbit-btn:hover::before,
    .galaxy-orbit-btn:focus-visible::before {
      background: #ffffff;
      border-color: rgba(34, 52, 92, 0.20);
      box-shadow:
        0 1px 3px rgba(15, 25, 50, 0.14),
        0 6px 16px rgba(15, 25, 50, 0.22);
    }
    .galaxy-orbit-btn:active {
      transform: scale(0.94);
    }
    .galaxy-orbit-btn svg {
      width: 16px;
      height: 16px;
      stroke-width: 2;
    }
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

    /* Course cards open larger than books/lessons on mobile — the
       series capsule is the centrepiece and earns more spotlight, and
       the glass action dock beneath it needs the extra room (mirrors
       the desktop course-only 80dvh enlargement). Only --center-card-w
       is bumped; the focused-card scale, the dock width and the dock
       anchor all derive from it, so cover + dock grow in lockstep. */
    .galaxy-card[data-kind="course"] {
      --center-card-w: min(74vw, 40dvh);
    }

    /* Focused mobile card flies up so its visible top lands flush with
       the hero subtitle bottom. `--mobile-focused-top` is set by
       initFocusedCardAnchor() at runtime (the 168px fallback is only
       used for the first frame). The 0.75*card_w term accounts for the
       cover's ~1:1.5 aspect so the visible-centre lands at the right
       offset after translation. */
    .galaxy-card[data-pos="center"] {
      transform:
        translateY(calc(
          var(--mobile-focused-top, 168px)
          - 50dvh
          + 0.75 * var(--center-card-w)
        ))
        translate(-50%, -50%)
        scale(calc(var(--center-card-w) / var(--card-base-width)));
      opacity: 1;
      /* Must sit ABOVE the coverflow neighbours. The mobile coverflow
         rule gives every card `z-index: calc(100 - abs-rel)`, so the
         immediate neighbours land at 99/98. Anything lower here (it was
         50) lets those neighbours paint OVER the focused card — its
         opaque cover PNG gets covered by the card behind it, which read
         as "the selected card is transparent". 101 keeps the focused
         card on top of the whole field while the neighbours still peek
         at the sides, exactly like the desktop focus state. */
      z-index: 101;
      cursor: default;
    }

    /* Mobile: no focus dimming. Tomer wants the carousel left exactly
       as it is when a card is selected — the neighbours keep their
       resting coverflow opacity/scale. The focused card simply rises
       above them via z-index (set above), so it reads fully opaque
       without the rest of the field having to recede. No opacity
       override here lets the base coverflow opacity stand. */
    .library-galaxy[data-galaxy-focused]
      .galaxy-card:not([data-pos="center"]) {
      filter: none;
      scale: 1;
    }

    @media (prefers-reduced-motion: reduce) {
      .library-galaxy[data-galaxy-focused]
        .galaxy-card:not([data-pos="center"]) {
        transition: none;
        scale: 1;
        filter: none;
        opacity: var(--slot-opacity);
      }
    }

    /* Series action dock (mobile) — a glass panel anchored directly
       below the opened course cover, holding the two series actions
       stacked vertically. It mirrors the book card's reading-entry
       panel anchoring (top:100% of the card box + counter-scale) so the
       dock hangs from the visible cover bottom and reads as part of the
       focused-card composition instead of two bare pills floating over
       the neighbour cards. The opened state hides the bottom nav
       (data-focus-hidden), so the dock owns the space below the cover.
       transform-origin top-center keeps it width-locked to the cover
       regardless of the card-grow scale. */
    .galaxy-cta {
      position: absolute;
      top: calc(100% - 28px);
      left: 50%;
      bottom: auto;
      right: auto;
      width: calc(var(--center-card-w) - 8px);
      max-width: none;
      box-sizing: border-box;
      /* Counter-scale against the focused card's --center-card-w/cbw
         scale so the dock renders at its authored size, width-locked to
         the visible cover. */
      transform:
        translate(-50%, 0)
        scale(calc(var(--card-base-width) / var(--center-card-w)));
      transform-origin: top center;
      display: flex;
      flex-direction: column;
      gap: 0;
      align-items: stretch;
      justify-content: flex-start;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.1s;
      z-index: 62;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
    }

    /* The action list IS the glass dock surface. Prefixed with
       [data-pos="center"] so it outranks the global (0,1,0) base rule
       further down the file, which is non-media and would otherwise win
       on source order at mobile widths. */
    .galaxy-card[data-pos="center"] .galaxy-cta-series-actions {
      flex-direction: column;
      gap: 0.45rem;
      align-items: stretch;
      margin: 0;
      padding: 0.6rem;
      border-radius: 18px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 60%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 82%, transparent) 100%
        );
      border: 1px solid color-mix(in srgb, white 12%, transparent);
      backdrop-filter: blur(16px) saturate(140%);
      -webkit-backdrop-filter: blur(16px) saturate(140%);
      box-shadow:
        0 18px 44px -18px rgba(0, 0, 0, 0.72),
        inset 0 1px 0 color-mix(in srgb, white 14%, transparent);
    }
    :global(html:not(.dark)) .galaxy-card[data-pos="center"] .galaxy-cta-series-actions {
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.84) 0%,
          rgba(255, 255, 255, 0.66) 100%);
      border-color: rgba(34, 52, 92, 0.14);
      box-shadow:
        0 18px 40px -18px rgba(30, 45, 80, 0.30),
        inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }
    .galaxy-card[data-pos="center"] .galaxy-cta-series-btn {
      width: 100%;
      justify-content: flex-start;
      padding: 0.55rem 0.8rem;
      font-size: 0.82rem;
      gap: 0.6rem;
      border-radius: 13px;
      letter-spacing: 0;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta-series-btn-icon {
      width: 28px;
      height: 28px;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta-series-btn-icon svg {
      width: 14px;
      height: 14px;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta-series-btn-label {
      font-size: 0.82rem;
    }

    [data-stage-mode="series"] .galaxy-card.is-active-series-member {
      --series-step: clamp(78px, 22vw, 130px);
      /* These three derive the coverflow position from the member's
         index. They MUST be defined here: the desktop rule that also
         defines them is gated behind @media (min-width:1024px), so at
         mobile widths they were undefined — which made the transform
         below invalid and collapsed every lesson onto the centre (the
         root cause of "show series books does nothing" on mobile).
         --series-active-index / --series-focused-index are set per-member
         by applyCourseFilter + the series-mode observer. */
      --series-rel: calc(
        var(--series-active-index, 0) - var(--series-focused-index, 0)
      );
      --series-abs-rel: max(
        calc(var(--series-rel) * -1),
        var(--series-rel)
      );
      --series-row-x: calc(
        var(--series-rel) * var(--series-step) * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        perspective(900px)
        rotateY(calc(var(--series-rel) * -16deg * var(--galaxy-dir, 1)))
        scale(calc(0.98 - var(--series-abs-rel) * 0.14));
      opacity: calc(1 - var(--series-abs-rel) * 0.34);
      /* Depth-sort by series distance so the focused lesson sits on top.
         Without this, members keep the orbit coverflow z-index (based on
         their orbit slot, not their series slot) and a neighbour can paint
         over the centred lesson. */
      z-index: calc(100 - var(--series-abs-rel, 0));
    }
    /* Filtered-series carousel (mobile): everything that is NOT an active
       member collapses out of the way so the lessons read as a clean
       coverflow. Desktop already hides these (rules in the ≥1024px block);
       the mobile block never had them, so the muted orbit + the course
       capsule were leaking through behind the lessons. */
    .library-galaxy[data-stage-mode="series"] .galaxy-card.is-muted,
    .library-galaxy[data-stage-mode="series"] .galaxy-card.is-active-series-capsule {
      opacity: 0 !important;
      pointer-events: none !important;
    }

    /* Mobile exit chip — only while the bottom nav is flagged series-mode
       by applyCourseFilter. In that state the orbit counter + dots track
       the wrong (orbit) set, so they hide and the chip takes their row. */
    .galaxy-mobile-nav[data-series-mode] .galaxy-position-indicator,
    .galaxy-mobile-nav[data-series-mode] .galaxy-position-dots {
      display: none !important;
    }
    /* Series counter takes the orbit counter's row + styling so the
       "3 / 6" reads identically to the orbit's "1 / 11". */
    .galaxy-mobile-nav[data-series-mode] .galaxy-series-position {
      display: inline-flex;
      align-items: baseline;
      gap: 0.2rem;
      margin: 0 0 2px;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 1px 4px rgba(0, 0, 0, 0.55);
      pointer-events: none;
      line-height: 1;
    }
    .galaxy-mobile-nav[data-series-mode] .galaxy-series-position [data-series-mobile-pos-current] {
      color: rgba(255, 255, 255, 0.98);
      font-weight: 600;
    }
    :global(html:not(.dark)) .galaxy-mobile-nav[data-series-mode] .galaxy-series-position {
      color: rgba(22, 34, 60, 0.66);
      text-shadow: none;
    }
    :global(html:not(.dark)) .galaxy-mobile-nav[data-series-mode] .galaxy-series-position [data-series-mobile-pos-current] {
      color: rgba(22, 34, 60, 0.92);
    }
    .galaxy-mobile-nav[data-series-mode] .galaxy-series-exit {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-block-start: 4px;
      pointer-events: auto;
      padding: 7px 15px;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(236, 236, 234, 0.92);
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 72%, transparent);
      border: 1px solid color-mix(in srgb, white 16%, transparent);
      backdrop-filter: blur(14px) saturate(140%);
      -webkit-backdrop-filter: blur(14px) saturate(140%);
      box-shadow:
        0 8px 20px -10px rgba(0, 0, 0, 0.6),
        inset 0 1px 0 color-mix(in srgb, white 12%, transparent);
      cursor: pointer;
      transition: transform 0.15s ease, background 0.15s ease;
    }
    .galaxy-mobile-nav[data-series-mode] .galaxy-series-exit svg {
      flex: 0 0 auto;
      opacity: 0.85;
    }
    .galaxy-mobile-nav[data-series-mode] .galaxy-series-exit:active {
      transform: scale(0.96);
    }
    :global(html:not(.dark)) .galaxy-mobile-nav[data-series-mode] .galaxy-series-exit {
      color: rgba(22, 34, 60, 0.88);
      background: rgba(255, 255, 255, 0.86);
      border-color: rgba(34, 52, 92, 0.14);
      box-shadow:
        0 6px 16px -8px rgba(30, 45, 80, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }

    /* Series carousel chevrons + position indicator are a desktop-only
       affordance. On mobile the focus carousel already exposes left/right
       focus via swipe + the bottom rotate chevrons, so the side chrome is
       redundant and was visually leaking through the cards. Selector
       includes `.library-galaxy` to bump specificity above the desktop
       reveal rule (0,2,0) — without it source order would let the desktop
       rule win since it appears later in the file. */
    .library-galaxy .series-carousel-nav,
    .library-galaxy .series-carousel-position,
    .library-galaxy[data-stage-mode="series"] .series-carousel-nav,
    .library-galaxy[data-stage-mode="series"] .series-carousel-position {
      display: none !important;
    }

    /* Mirror desktop's focused-state padding reset so the cover artwork
       pins to the card box edges. Without this the wrapper's resting
       padding stacks with the PNG's transparent glow and a visible gap
       appears between cards. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      padding: 0 !important;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      margin-block: 0 !important;
      margin-inline: 0 !important;
      /* LibraryCard's desktop focused rule scales the artwork; mobile
         already supplies the focus bump on the wrapper, so neutralise it. */
      transform: none !important;
      width: 100% !important;
    }

    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      /* Pull-up compensates for selected.png's transparent bottom padding
         so the panel top lands at the visible artwork bottom. */
      top: calc(100% - 30px);
      width: calc(var(--center-card-w) - 18px);
      max-width: none;
      height: 168px;
      border-radius: 22px;
      box-sizing: border-box;
      transform:
        translate(-50%, 0)
        scale(calc(var(--card-base-width) / var(--center-card-w)));
      transform-origin: top center;
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 60;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      z-index: 60;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    .reading-entry-main {
      position: absolute;
      inset: 0;
      display: block;
      border-radius: 22px;
      background: transparent;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
      z-index: 1;
      -webkit-tap-highlight-color: transparent;
    }
    .reading-entry-main:focus-visible {
      outline: none;
    }
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 22px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card1.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      z-index: 2;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: 32%;
      bottom: 12px;
      width: calc(100% - 32px);
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: center;
      text-align: center;
      pointer-events: none;
      z-index: 3;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }
    .reading-entry-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      width: 100%;
    }
    .reading-entry-cta {
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-width: 130px;
      max-width: calc(100% - 8px);
      height: 36px;
      padding: 0 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: rgba(6, 18, 40, 0.96);
      background:
        linear-gradient(180deg,
          rgba(220, 245, 255, 0.96) 0%,
          rgba(120, 215, 240, 0.96) 55%,
          rgba(34, 184, 216, 0.96) 100%);
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 18px rgba(34, 211, 238, 0.45),
        0 4px 12px rgba(8, 18, 40, 0.35);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.4);
    }
    .reading-entry-cta-label {
      line-height: 1;
    }
    .reading-entry-cta-arrow {
      width: 13px;
      height: 13px;
      flex-shrink: 0;
      stroke: currentColor;
    }
    [dir="rtl"] .reading-entry-cta-arrow {
      transform: scaleX(-1);
    }
    .reading-entry-summary-pill {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.03em;
      line-height: 1;
      color: rgba(190, 225, 250, 0.78);
      background: transparent;
      border: 1px solid transparent;
      text-decoration: none;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      cursor: pointer;
      transition:
        color 160ms ease,
        background 160ms ease,
        transform 160ms ease;
    }
    .reading-entry-summary-pill::after {
      content: '›';
      font-size: 13px;
      line-height: 1;
      opacity: 0.7;
      transform: translateY(-1px);
    }
    [dir="rtl"] .reading-entry-summary-pill::after {
      content: '‹';
    }
    .reading-entry-summary-pill:active {
      transform: scale(0.97);
      background: rgba(18, 32, 60, 0.55);
    }

    @media (max-width: 360px) {
      .reading-entry-overlay      { height: 159px; }
      .reading-entry-text         { top: 30%; }
      .reading-entry-cta          { min-width: 110px; height: 34px; font-size: 12.5px; padding: 0 14px; }
      .reading-entry-summary-pill { font-size: 10.5px; }
    }
    .reading-entry-overlay:has(.reading-entry-main:active) {
      transform:
        translate(-50%, 0)
        scale(calc((var(--card-base-width) / var(--center-card-w)) * 0.985));
      filter: brightness(1.04);
    }

  }

  .library-galaxy {
    --orbit-vertical-offset: 32px;
    --orbit-motion-duration: 720ms;
    --orbit-motion-ease: cubic-bezier(0.25, 1, 0.32, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .library-galaxy { --orbit-motion-duration: 1ms; }
  }

  @media (min-width: 640px) {
    .library-root { padding: 0.5rem 1.5rem 4rem; }
  }

  /* Desktop (≥1024px): one-viewport dashboard, no long scroll. */
  @media (min-width: 1024px) {
    .library-root {
      padding-block-start: 0.25rem;
      padding-block-end: 1.5rem;
      /* SYMMETRIC inline padding so .library-body (max-width + margin:0 auto)
         centres on the viewport; the clamp clears the inline-end edge. */
      padding-inline: clamp(60px, 8vw, 120px);
      min-height: var(--library-dashboard-min-height, 100dvh);
      background-image:
        var(--yuval-galaxy-bg-vignette),
        var(--yuval-galaxy-bg-radial-primary),
        var(--yuval-galaxy-bg-radial-secondary);
    }

    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    .lb-area-hero,
    .lb-area-featured,
    .lb-area-quick-mobile { order: initial; }

    .lb-area-featured     { display: block; }

    .library-body {
      display: block;
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0;
    }
    /* Galaxy stage still uses physical left/right for the absolute
       orbit slots so the TL/TR/ML/MR/BL/BR placement of the floating
       cards is language-independent (the slots target visual corners,
       not reading-flow corners). Cards inside re-apply page direction
       so Hebrew titles still read RTL. */
    .library-galaxy { direction: ltr; }
    .galaxy-card    { direction: var(--page-direction, ltr); }

    .lb-area-stage {
      gap: 0;
      min-width: 0;
      position: relative;
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 680px;
      margin-inline: auto;
      width: 100%;
    }
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }

    .lb-area-quick-mobile { display: none; }

    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 540px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
      /* Pushes the whole orbit scene down so rotated carousel items
         never overlap the hero strip above. */
      --orbit-vertical-offset: 50px;
      transform: translateY(var(--orbit-vertical-offset));
    }
    .library-galaxy::-webkit-scrollbar { height: auto; }

    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      width: 228px;
      cursor: pointer;
      top: 50%;
      left: 50%;
      --orbit-rx: clamp(360px, 42vw, 540px);
      --orbit-ry: clamp(160px, 22vh, 210px);
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg));
      /* Upper arc reads near/front (sin = -1 at top → depth = 1). */
      --orbit-depth: calc((1 - sin(var(--orbit-active-angle, 0deg))) / 2);
      /* cos² so cards drifting toward the inline edges fade out as if
         the orbit continues beyond the screen. */
      --orbit-side: calc(
        cos(var(--orbit-active-angle, 0deg)) *
        cos(var(--orbit-active-angle, 0deg))
      );
      --slot-scale: calc(0.62 + 0.36 * var(--orbit-depth) - 0.20 * var(--orbit-side));
      --slot-opacity: calc(0.40 + 0.60 * var(--orbit-depth) - 0.40 * var(--orbit-side));
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform var(--orbit-motion-duration, 600ms)
                  var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
        opacity var(--orbit-motion-duration, 600ms)
                var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1));
      z-index: calc(2 + var(--orbit-depth) * 8);
      will-change: transform, opacity;
    }

    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="course"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    /* drop-shadow on the artifact PNG (not box-shadow on a container)
       because the PNG has transparent margins — box-shadow would draw
       a rectangle far from the painted card edge. */
    .galaxy-card.is-linked-glow {
      z-index: 11;
    }
    :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
      animation: yuval-linked-glow 1.5s ease-in-out infinite;
    }
    @keyframes yuval-linked-glow {
      0%, 100% {
        filter:
          drop-shadow(0 0 2px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 8px  rgba(64, 224, 208, 0.85))
          drop-shadow(0 0 18px rgba(64, 224, 208, 0.55));
      }
      50% {
        filter:
          drop-shadow(0 0 3px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 12px rgba(64, 224, 208, 0.95))
          drop-shadow(0 0 26px rgba(64, 224, 208, 0.7));
      }
    }
    @media (prefers-reduced-motion: reduce) {
      :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
        animation: none;
        filter:
          drop-shadow(0 0 2px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 12px rgba(64, 224, 208, 0.55));
      }
    }

    .library-galaxy[data-galaxy-dragging],
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      cursor: grabbing;
      user-select: none;
      -webkit-user-select: none;
    }
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
    }
    /* Block native image/link drag so pointermove can track the cursor. */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* Series capsule. Built client-side when ≥2 visible items share a
       seriesName; clicking enters series mode. */
    .galaxy-card[data-role="series"] {
      cursor: pointer;
      /* Wider than a regular book card so shape alone signals
         "container, not item" — even
         before reading the badge or label. Scaled to keep the +10%
         ratio over the +20%-larger book card (228px → 252px). */
      width: 252px;
      /* Resolve series colour at the wrapper level so the deck pseudos
         (below) and the inner capsule both read the same value without
         each redefining it. */
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }
    /* Stacked deck — two ghost rectangles peeking out behind the capsule,
       narrower and offset downward so the capsule reads as a stack of
       grouped knowledge, not as a single tile. Pure decoration via
       wrapper pseudo-elements; muted/active state animations on the
       wrapper carry the deck along automatically. */
    .galaxy-card[data-role="series"]::before,
    .galaxy-card[data-role="series"]::after {
      content: "";
      position: absolute;
      pointer-events: none;
      border-radius: 18px;
      border-end-start-radius: 12px;
      background: color-mix(in srgb, var(--series-color-resolved) 8%, var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78)));
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      z-index: 0;
    }
    /* Middle layer — peeks 4 px below, narrower by 8 px each side. */
    .galaxy-card[data-role="series"]::after {
      inset-block-start: 4px;
      inset-block-end: -4px;
      inset-inline-start: 8px;
      inset-inline-end: 8px;
      opacity: 0.85;
    }
    /* Back layer — peeks 8 px below, narrower by 18 px each side. */
    .galaxy-card[data-role="series"]::before {
      inset-block-start: 7px;
      inset-block-end: -8px;
      inset-inline-start: 18px;
      inset-inline-end: 18px;
      opacity: 0.6;
    }
    .galaxy-card[data-role="series"]:focus-visible {
      outline: none;
    }
    .galaxy-card[data-role="series"]:focus-visible .galaxy-series-capsule {
      box-shadow:
        0 14px 38px -14px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        0 0 0 2px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
    }

    /* ── Series members —
          Every individual book inside a multi-item series is kept in
          the DOM as an orbit card, but tagged with data-series-member
          so it stays hidden in universe mode. Series mode reveals the
          members of the active series via .is-active-series-member
          (added by the hydrator JS). */
    .galaxy-card[data-series-member] {
      display: none;
    }

    /* ── Series mode — stage-level state.
          Activated by clicking a SeriesCapsule. The hydrator sets
          data-stage-mode="series" + data-active-series="<name>" on
          the stage element, then class-tags individual cards. */

    /* Mute every station that isn't the active series's books or
       the synthesized Other Knowledge pill. Premium fade — opacity
       and scale only, no jarring movement. */
    [data-stage-mode="series"] .galaxy-card.is-muted {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1) * 0.85),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry) * 0.85)
        )
        rotate(var(--tilt))
        scale(0.7);
    }

    [data-stage-mode="series"] .galaxy-card.is-active-series-capsule {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(0.85);
    }

    /* Coverflow: focused book centred, neighbours tilt back with depth
       fade. The hydrator sets --series-focused-index on every member;
       clicking a side book updates it and slides that book into focus. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-member {
      display: block;
      --series-step: clamp(140px, 17vw, 200px);
      --series-rel: calc(
        var(--series-active-index, 0) - var(--series-focused-index, 0)
      );
      --series-abs-rel: max(
        calc(var(--series-rel) * -1),
        var(--series-rel)
      );
      --series-row-x: calc(
        var(--series-rel) * var(--series-step) * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        perspective(1200px)
        rotateY(calc(var(--series-rel) * -22deg * var(--galaxy-dir, 1)))
        scale(calc(1.12 - var(--series-abs-rel) * 0.12));
      opacity: calc(1 - var(--series-abs-rel) * 0.28);
      z-index: calc(20 - var(--series-abs-rel));
      cursor: pointer;
      /* Required: defeats the mobile data-mobile-slot="hidden" rule
         that would block side-book clicks. */
      pointer-events: auto;
      transition:
        transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
        opacity 0.5s ease;
    }

    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:hover:not([data-pos="center"]),
    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        translateY(-6px)
        perspective(1200px)
        rotateY(calc(var(--series-rel) * -22deg * var(--galaxy-dir, 1)))
        scale(calc(1.16 - var(--series-abs-rel) * 0.10));
      opacity: calc(1 - var(--series-abs-rel) * 0.22);
    }

    /* SSR-rendered chrome — must stay in markup so Astro's scoped CSS
       attaches the scope-cid (JS-injected nodes lose scope). Revealed
       only when the stage is in series mode. */
    .series-carousel-nav {
      /* display:none + !important is required: opacity:0 alone leaves
         backdrop-blur "<" smudges pinned to the inline-start edge. */
      display: none !important;
      visibility: hidden;
      position: absolute;
      inset-block-start: 50%;
      width: 48px;
      height: 48px;
      place-items: center;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: var(--yuval-galaxy-text, #ececea);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.28),
        0 12px 26px rgba(0, 0, 0, 0.4);
      cursor: pointer;
      z-index: 30;
      transition:
        transform 0.2s ease,
        background 0.2s ease,
        border-color 0.2s ease;
    }
    .series-carousel-nav-prev {
      inset-inline-start: clamp(8px, 3vw, 32px);
      transform: translateY(-50%);
    }
    .series-carousel-nav-next {
      inset-inline-end: clamp(8px, 3vw, 32px);
      transform: translateY(-50%);
    }
    [data-stage-mode="series"] .series-carousel-nav {
      display: grid !important;
      visibility: visible;
    }
    .series-carousel-nav:hover:not(:disabled),
    .series-carousel-nav:focus-visible:not(:disabled) {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.4);
      outline: none;
    }
    .series-carousel-nav-prev:hover:not(:disabled),
    .series-carousel-nav-prev:focus-visible:not(:disabled) {
      transform: translateY(-50%) translateX(calc(var(--galaxy-dir, 1) * -2px));
    }
    .series-carousel-nav-next:hover:not(:disabled),
    .series-carousel-nav-next:focus-visible:not(:disabled) {
      transform: translateY(-50%) translateX(calc(var(--galaxy-dir, 1) * 2px));
    }
    .series-carousel-nav:disabled {
      opacity: 0.25;
      cursor: not-allowed;
    }
    [dir="rtl"] .series-carousel-nav svg { transform: scaleX(-1); }
    :global(html:not(.dark)) .series-carousel-nav {
      background: rgba(255, 253, 249, 0.82);
      border-color: rgba(34, 52, 92, 0.2);
      color: var(--yuval-galaxy-text, #1a1f3a);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.7),
        0 8px 20px rgba(30, 45, 80, 0.18);
    }
    :global(html:not(.dark)) .series-carousel-nav:hover:not(:disabled),
    :global(html:not(.dark)) .series-carousel-nav:focus-visible:not(:disabled) {
      background: rgba(255, 253, 249, 0.95);
      border-color: rgba(34, 52, 92, 0.35);
    }

    .series-carousel-position {
      /* Same display:none rationale as .series-carousel-nav above. */
      display: none !important;
      visibility: hidden;
      position: absolute;
      inset-block-end: clamp(8px, 3vh, 28px);
      inset-inline-start: 50%;
      transform: translateX(-50%);
      align-items: baseline;
      gap: 0.35rem;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: var(--yuval-galaxy-text, #ececea);
      font-size: 0.82rem;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.02em;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.22),
        0 8px 18px rgba(0, 0, 0, 0.3);
      z-index: 30;
      direction: ltr;
    }
    [data-stage-mode="series"] .series-carousel-position {
      display: inline-flex !important;
      visibility: visible;
    }
    .series-carousel-position-sep {
      opacity: 0.5;
      margin-inline: 0.1rem;
    }
    [data-series-pos-current] { font-weight: 600; }
    [data-series-pos-total] {
      opacity: 0.7;
      font-weight: 500;
    }
    :global(html:not(.dark)) .series-carousel-position {
      background: rgba(255, 253, 249, 0.82);
      border-color: rgba(34, 52, 92, 0.2);
      color: var(--yuval-galaxy-text, #1a1f3a);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.7),
        0 6px 14px rgba(30, 45, 80, 0.16);
    }

    /* Other Knowledge pill — synthesized by JS on series-mode entry.
       Clicking it exits series mode and restores the universe. */
    .galaxy-card[data-role="other-knowledge"] {
      top: 0;
      left: auto;
      inset-block-start: 12px;
      inset-inline-end: 12px;
      width: auto;
      transform: none;
      opacity: 0;
      cursor: pointer;
      z-index: 6;
      transition:
        opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .galaxy-card[data-role="other-knowledge"].is-visible {
      opacity: 1;
    }
    .galaxy-card[data-role="other-knowledge"]:hover .galaxy-other-knowledge,
    .galaxy-card[data-role="other-knowledge"]:focus-visible .galaxy-other-knowledge {
      border-color: color-mix(in srgb, var(--yuval-galaxy-text, #ececea) 30%, transparent);
      background: var(--yuval-galaxy-card-surface-hover, rgba(28, 30, 44, 0.82));
    }
    .galaxy-card[data-role="other-knowledge"]:focus-visible {
      outline: none;
    }

    .galaxy-other-knowledge {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 0.85rem 0.55rem 0.65rem;
      border-radius: 999px;
      background: var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 40%, transparent);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.5);
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .galaxy-other-knowledge-icon {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 20%, transparent),
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 8%, transparent)
      );
      color: var(--yuval-galaxy-text, #ececea);
      font-size: 1.15rem;
      line-height: 1;
      letter-spacing: 0.06em;
      font-weight: 600;
    }

    .galaxy-other-knowledge-text {
      display: flex;
      flex-direction: column;
      gap: 1px;
      line-height: 1.25;
      padding-inline-end: 0.15rem;
    }

    .galaxy-other-knowledge-label {
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: 0.005em;
    }

    .galaxy-other-knowledge-count {
      font-size: 0.66rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      letter-spacing: 0.02em;
    }

    .galaxy-other-knowledge-count strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-weight: 600;
      margin-inline-end: 0.2rem;
    }

    .galaxy-series-capsule {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      padding: 1.05rem 1.1rem 0.85rem;
      padding-inline-start: 1.2rem;
      border-radius: 22px;
      border-end-start-radius: 14px;
      background:
        radial-gradient(
          ellipse 70% 55% at 50% 0%,
          color-mix(in srgb, var(--series-color-resolved) 18%, transparent) 0%,
          transparent 65%
        ),
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--series-color-resolved) 11%, transparent) 0%,
          color-mix(in srgb, var(--series-color-resolved) 4%, transparent) 55%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 84%, transparent) 100%
        ),
        var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 36%, transparent);
      box-shadow:
        0 10px 26px -16px color-mix(in srgb, var(--series-color-resolved) 38%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 14%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      backdrop-filter: blur(14px) saturate(125%);
      -webkit-backdrop-filter: blur(14px) saturate(125%);
      transition:
        border-color 240ms ease,
        box-shadow 240ms ease;
    }

    .galaxy-series-capsule::before {
      content: "";
      position: absolute;
      inset-block: 16px;
      inset-inline-start: 0;
      width: 2px;
      border-radius: 0 2px 2px 0;
      background: var(--series-color-resolved);
      opacity: 0.75;
      box-shadow: 0 0 8px color-mix(in srgb, var(--series-color-resolved) 60%, transparent);
    }
    [dir="rtl"] .galaxy-series-capsule::before {
      border-radius: 2px 0 0 2px;
    }

    .galaxy-series-capsule::after {
      content: "";
      position: absolute;
      inset-block-start: 7px;
      inset-inline: 16px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 30%,
        color-mix(in srgb, var(--series-color-resolved) 65%, transparent) 50%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 70%,
        transparent 100%
      );
      opacity: 0.55;
    }

    .galaxy-card[data-role="series"]:hover .galaxy-series-capsule {
      border-color: color-mix(in srgb, var(--series-color-resolved) 52%, transparent);
      box-shadow:
        0 12px 30px -16px color-mix(in srgb, var(--series-color-resolved) 48%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 20%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 28%, transparent);
    }

    .galaxy-series-badge {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      padding: 2px 10px 2px 8px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--series-color-resolved) 18%, transparent);
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 55%, transparent);
      color: var(--series-color-resolved);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    .galaxy-series-badge::before {
      content: "";
      display: inline-block;
      width: 9px;
      height: 9px;
      margin-inline-end: 6px;
      background:
        linear-gradient(currentColor, currentColor) top center / 9px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) center      / 7px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) bottom center / 5px 1.4px no-repeat;
      vertical-align: -1px;
      opacity: 0.95;
    }

    .galaxy-series-name {
      margin: 0;
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 1.12rem;
      font-weight: 500;
      line-height: 1.2;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: -0.01em;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .galaxy-series-counts {
      display: flex;
      flex-direction: column;
      gap: 1px;
      margin-top: 2px;
    }

    .galaxy-series-count-line {
      font-size: 0.72rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      line-height: 1.45;
      letter-spacing: 0.005em;
    }

    .galaxy-series-count-line strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.95rem;
      font-weight: 500;
      font-feature-settings: 'tnum' 1, 'lnum' 1;
      margin-inline-end: 0.3rem;
    }

    .galaxy-series-count-available strong {
      color: var(--series-color-resolved);
    }

    .galaxy-series-stack {
      position: relative;
      display: flex;
      align-items: flex-end;
      gap: 3px;
      height: 18px;
      margin-block-start: 6px;
      margin-inline: -0.35rem;
      padding: 4px 0.5rem 5px;
      border-radius: 5px 5px 8px 8px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 22%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 42%, transparent) 100%
        );
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, #000 22%, transparent),
        inset 0 -1px 0 color-mix(in srgb, var(--series-color-resolved) 14%, transparent);
    }
    .galaxy-series-stack::after {
      content: "";
      position: absolute;
      inset-block-end: 1px;
      inset-inline: 8px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 60%, transparent) 50%,
        transparent 100%
      );
      opacity: 0.7;
    }
    /* Each spine = one book. Capped at 5 in the hydrator. Heights vary
       in a fixed, gentle rhythm — not random — so the row reads as
       "books on a shelf" without visual noise. */
    .galaxy-series-spine {
      display: block;
      width: 3px;
      border-radius: 1px 1px 0 0;
      background: color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      height: 11px;
    }
    .galaxy-series-spine:nth-child(2) { height: 13px; }
    .galaxy-series-spine:nth-child(3) { height: 12px; }
    .galaxy-series-spine:nth-child(4) { height: 14px; }
    .galaxy-series-spine:nth-child(5) { height: 12px; }
    .galaxy-series-spine.is-filled {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--series-color-resolved) 92%, white) 0%,
        var(--series-color-resolved) 100%
      );
      opacity: 0.85;
      box-shadow:
        inset 0 -1px 0 color-mix(in srgb, #000 25%, transparent);
    }

    /* Centered focus state — uniform fixed-size box anchored right
       below the hero subtitle "כל הידע שלך…".
       Switched from `position: absolute` + `transform: scale(1.5)` to
       `position: fixed` + explicit dimensions so every selection lands
       at the SAME viewport spot at the SAME visible size — independent
       of the orbit's --orbit-vertical-offset, the picked card's
       natural artwork aspect ratio, and any per-station tilt.
         - height: 45dvh           — 45% of the viewport height.
         - aspect-ratio: 2 / 3     — standard book-cover proportion;
                                     width = 30dvh on every screen.
         - top: var(--focused-card-top, calc(72px + 5rem))
                                     — the JS-measured viewport Y of
                                     the subtitle's actual bottom edge
                                     (`.lh-subtitle` getBoundingClientRect
                                     plus a 2px hairline). Re-measured
                                     on resize so the card always lands
                                     ממש צמוד ומתחת למילים, regardless
                                     of font-clamp variance, light/dark
                                     padding deltas, or zoom level.
                                     Fallback `calc(72px + 5rem)` covers
                                     the first paint before the script
                                     runs and SSR clients that disable JS.
         - left: 50%; translateX   — horizontally centred on the
                                     viewport regardless of where the
                                     fixed support panels sit.
       Inner-image rules below (`object-fit: contain`) keep the BOX
       size identical for every card while the artwork is contained
       inside its 2:3 frame. */
    .galaxy-card[data-pos="center"] {
      position: fixed;
      /* `.library-galaxy` has `transform: translateY(var(--orbit-vertical-offset))`,
         which makes IT the containing block for this fixed element —
         `top:` is measured from the galaxy's top, not the viewport.
         `--focused-card-top` is computed by `initFocusedCardAnchor()`
         in the script block (subtitle bottom in viewport Y minus galaxy
         top in viewport Y, +2px hairline), so the card always lands
         flush below the subtitle "כל הידע שלך…" regardless of clamp /
         theme / font-load reflow. Fallback `-1rem` covers the brief
         pre-JS paint: galaxy starts a little below the hero strip, so a
         small negative top lands the card near the subtitle bottom
         instead of deep in the orbit field. */
      top: var(--focused-card-top, -1rem);
      left: 50%;
      width: auto;
      /* Default focused-card box (books, lessons, articles, etc.) —
         restored to 50dvh × 2/3. Course cards get a larger override
         further down (see `.galaxy-card[data-pos="center"][data-kind="course"]`)
         since only courses surface the series action panel. */
      height: 50dvh;
      aspect-ratio: 2 / 3;
      transform: translateX(-50%);
      opacity: 1;
      z-index: 50;
      cursor: default;
    }

    /* Course-only enlargement —
       Only the AI Engineering Course capsule (data-kind="course")
       grows to a larger spotlight on open, so the action panel
       below it has space to read as the centrepiece it is. Books,
       lessons and articles keep the default 50dvh size above. */
    .galaxy-card[data-pos="center"][data-kind="course"] {
      height: 80dvh;
    }

    /* Uniform-size override — neutralise LibraryCard.astro's focused
       artifact transform so EVERY card renders at exactly the box
       size. Without this, the component applies `scale(1.5)` plus a
       `margin-block: 15%` (~4.5dvh on each side), which makes the
       visible artwork extend beyond the box symmetrically AND leaves
       a transparent band inside the box — so each cover's apparent
       size depends on its own PNG padding. Removing both pins the
       visible artwork to the box, end of story.

       The `.lc-orbit` zero-padding rule below is what actually closes
       the gap Tomer reported between the cover and the reading-entry
       panel: in resting orbit state `.lc-orbit` reserves ~1rem of
       inner padding all round so the cover sits inside a glass
       cushion. In focused state we don't want that cushion — the
       reading-entry overlay below is anchored to the .galaxy-card
       box edge, and any inner padding on `.lc-orbit` becomes a
       transparent gap between the visible cover bottom and the
       overlay's top. Zeroing the padding makes the artwork fill the
       box edge-to-edge so the overlay sits flush. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      padding: 0 !important;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      transform: none !important;
      margin-block: 0 !important;
      width: 100% !important;
      margin-inline: 0 !important;
    }

    /* Inner LibraryCard structure fills the fixed-size centred box so
       the visible artwork tracks the box (not its own intrinsic
       height).

       `object-fit: cover` makes EVERY card render at the same visible
       size as the 2:3 frame. Previously `contain` was used so the
       round AI Engineering Course capsule wouldn't stretch, but the
       side-effect was non-2:3 artwork sitting inside the frame with
       transparent margins — different visible sizes per card from the
       user's POV. Tomer asked for uniform visual size on every focus,
       so `cover` wins: the box is the unit, and any artwork that
       isn't 2:3 gets cropped at the top/bottom edges instead of
       shrinking. The crop is acceptable because the artwork's focal
       region almost always lives in the centre vertical band, and
       the `object-position: center` keeps that band in view. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      height: 100%;
      padding: 0;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      width: 100%;
      height: 100%;
      margin: 0;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front),
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-selected) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    /* Hover lift — small bump along the radial direction (cards move
       slightly further from center) plus a brightness/scale bump.
       Skipped when the card is focused to avoid double transforms. */
    .galaxy-card:hover:not([data-pos="center"]),
    .galaxy-card:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * (var(--orbit-rx) + 8px) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * (var(--orbit-ry) + 8px))
        )
        rotate(calc(var(--tilt) * 0.5))
        scale(calc(var(--slot-scale) * 1.04));
      opacity: 1;
      /* Lift above every depth-sorted resting card (max z 10) so a
         hovered card always comes forward, even from the back. */
      z-index: 11;
    }
    .galaxy-card:focus-visible {
      outline: none;
    }

    /* CTA overlay — hidden when card is in slot/queue; revealed only
       when data-pos="center". Children stop click propagation so the
       card-level handler never fires for Open/Close. */
    .galaxy-cta {
      position: absolute;
      /* Anchor inside the focused card at its visible bottom — the
         spot where the `.lc-orbit-author` byline used to sit before
         it was retired. Series action pills now read as part of the
         focused-card composition rather than as a side rail.
         Centering uses physical `left: 50%; transform: translateX(-50%)`
         (not logical inset-inline-*) so it stays centered in both
         RTL Hebrew and LTR English without writing-direction quirks. */
      top: 66%;
      left: 50%;
      bottom: auto;
      right: auto;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
      /* Above the scaled-up artwork (`transform: scale(1.5)` visually
         bleeds past the card's flow box bottom by ~25%). */
      z-index: 2;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
    }
    /* ── Reading-entry overlay: in-card image-based premium panel ──────
       The entry control sits INSIDE the centered book card (not below
       it). The visual is a textless PNG asset; all visible text is
       live, localized HTML rendered on top — the image never carries
       baked text.

       Stacking inside the overlay <a>:
         .reading-entry-asset  — background-image PNG (decorative)
         .reading-entry-text   — title + subtitle, live i18n

       The <a> itself is the hit area and preserves native link
       behavior (Ctrl/Cmd-click → new tab, middle-click → new tab,
       right-click → context menu). Plain left-click and Enter are
       intercepted by the launch handler in `universe-layout.ts` via
       the `data-reading-entry` attribute.

       Phase-3 launch animation: the overlay's two child layers
       (.reading-entry-asset + .reading-entry-text) fade out cleanly
       when `data-reading-entry-state="opening"` is set on the stage.
       Opacity-only fade keeps the link in the accessibility tree
       until the launch is committed. */
    /* Image-based reading-entry panel. The visual base IS the
       `reading-entry-card1.png` asset — it carries the icon (top
       center), the glass background, the border and the glow.
       Title, subtitle AND the lesson meta row all live INSIDE this
       single panel (not in a separate section below) so the CTA and
       its facts read as one premium glass surface.

       Sizing math: the centred card is now `position: fixed` with no
       transform scaling (uniform 45dvh × aspect 2/3 box). The earlier
       `width: calc(85% * 1.5)` + `scale(1/1.5)` counter-scale dance
       was needed only because the parent card was visually 1.5× its
       declared box. With that scale gone, this panel inherits its
       coordinates 1:1 from the parent and just renders at its
       declared size — width 100% of the card, no counter-scale. */
    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      /* Glue flush to the focused card's bottom edge. The cover-side
         artwork already pins to the box edges (see `.lc-orbit`
         padding/margin reset above), but the OVERLAY PNG
         (`reading-entry-card1.png`) carries ~30px of transparent halo
         ABOVE its visible blue border. With `top: 100%` that halo
         rendered as a visible gap between the cover bottom and the
         panel's actual top edge. Pull the overlay up by exactly that
         halo so the two visible borders meet without a seam. Centred
         card is `position: fixed` with no scaling here, so the value
         applies 1:1 in screen px. */
      top: calc(100% - 80px);
      width: 100%;
      max-width: 380px;
      min-width: 280px;
      /* Adaptive height — the centred composition is now
         152px (top) + 50dvh (card) + overlay + safe area for the
         bottom chevron rotate controls (~80px). With the card at
         exactly half the viewport, the overlay has the remaining
         (~50dvh − 152px − 96px) of room before it would hit the
         chevrons. The clamp ceiling stays at 220px so the overlay
         never grows to compete with the cover above. */
      height: clamp(170px, calc(100dvh - 152px - 50dvh - 96px), 220px);
      border-radius: 28px;
      box-sizing: border-box;
      transform: translate(-50%, 0);
      transform-origin: top center;
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 60;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      z-index: 60;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    /* Main click target — transparent <a> stretched over the panel
       so any click that isn't on the summary pill continues reading.
       Sits BELOW the asset visually (z-index handled by stacking
       order; `.reading-entry-asset` paints on top with pointer-
       events:none, so the link still receives clicks underneath). */
    .reading-entry-main {
      position: absolute;
      inset: 0;
      display: block;
      border-radius: 28px;
      background: transparent;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
      z-index: 1;
      -webkit-tap-highlight-color: transparent;
    }
    .reading-entry-main:focus-visible {
      outline: none;
    }
    .reading-entry-main:focus-visible ~ .reading-entry-asset {
      box-shadow:
        0 0 0 2px rgba(150, 200, 255, 0.45),
        0 0 22px rgba(112, 87, 255, 0.45);
    }

    /* The PNG IS the panel — painted edge-to-edge over the main link.
       `pointer-events: none` so the transparent `.reading-entry-main`
       below it still receives every click that isn't on the pill. */
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 28px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card1.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      z-index: 2;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }

    /* ─── Live content stack ─────────────────────────────────────────
       Container holds ONLY the action row now (chapter, progress, and
       facts were removed at Tomer's request). Positioned absolutely
       over the BOTTOM ~70% of the panel so the book icon baked into
       `reading-entry-card1.png` (top ~30%) stays clear. The container
       is `pointer-events:none` so empty space passes clicks through to
       `.reading-entry-main`; only the small secondary link re-opts
       back into hit-testing.

       `justify-content: center` puts the action pair in the vertical
       centre of the available area — no longer space-between because
       there's only one child. */
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: 32%;
      bottom: 14px;
      width: calc(100% - 36px);
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: center;
      text-align: center;
      pointer-events: none;
      z-index: 3;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }

    /* ── Action row — primary CTA + ghost secondary ──────────── */
    .reading-entry-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      width: 100%;
    }

    /* PRIMARY CTA — glowing cyan pill. Decorative: the real click
       target is the full-panel `.reading-entry-main` link. We keep
       this `pointer-events:none` so it never blocks that click.
       Hover styling is applied via `.reading-entry-overlay:has(.reading-entry-main:hover)`
       further down. */
    .reading-entry-cta {
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-width: 200px;
      height: 40px;
      padding: 0 22px;
      border-radius: 999px;
      font-size: 14.5px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: rgba(6, 18, 40, 0.96);
      background:
        linear-gradient(180deg,
          rgba(220, 245, 255, 0.96) 0%,
          rgba(120, 215, 240, 0.96) 55%,
          rgba(34, 184, 216, 0.96) 100%);
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 22px rgba(34, 211, 238, 0.45),
        0 6px 16px rgba(8, 18, 40, 0.40);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.4);
      transition:
        box-shadow 200ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 200ms ease;
    }
    .reading-entry-cta-label {
      line-height: 1;
    }
    .reading-entry-cta-arrow {
      width: 15px;
      height: 15px;
      flex-shrink: 0;
      stroke: currentColor;
    }
    /* In Hebrew (RTL) the arrow should point left = "forward". The icon
       is authored as a right-arrow; flip it for RTL via the inherited
       overlay dir. */
    [dir="rtl"] .reading-entry-cta-arrow {
      transform: scaleX(-1);
    }

    /* SECONDARY — tiny ghost text link with chevron. Lives just below
       the primary CTA so the hierarchy reads top-down: chapter →
       progress → facts → big button → tiny link. */
    .reading-entry-summary-pill {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.03em;
      line-height: 1;
      color: rgba(190, 225, 250, 0.78);
      background: transparent;
      border: 1px solid transparent;
      text-decoration: none;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      cursor: pointer;
      transition:
        color 160ms ease,
        background 160ms ease,
        border-color 160ms ease,
        transform 160ms ease;
    }
    .reading-entry-summary-pill::after {
      content: '›';
      font-size: 14px;
      line-height: 1;
      opacity: 0.7;
      transform: translateY(-1px);
    }
    [dir="rtl"] .reading-entry-summary-pill::after {
      content: '‹';
    }
    .reading-entry-summary-pill:hover {
      color: rgba(235, 250, 255, 1);
      background: rgba(18, 32, 60, 0.55);
      border-color: rgba(150, 200, 245, 0.45);
    }
    .reading-entry-summary-pill:active {
      transform: scale(0.97);
    }
    .reading-entry-summary-pill:focus-visible {
      outline: none;
      box-shadow:
        0 0 0 2px rgba(150, 200, 255, 0.45),
        0 0 14px rgba(112, 87, 255, 0.35);
    }

    /* Brighten the primary CTA when the main link is hovered so the
       whole panel reads as one interactive surface anchored by the
       glowing pill. */
    .reading-entry-overlay:has(.reading-entry-main:hover) .reading-entry-cta {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.95),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 28px rgba(34, 211, 238, 0.65),
        0 8px 20px rgba(8, 18, 40, 0.45);
      filter: brightness(1.06);
    }
    .reading-entry-overlay:has(.reading-entry-main:active) .reading-entry-cta {
      transform: translateY(1px);
    }

    /* Hover / active — brightness lift only. NO translate.

       Tomer asked for the panel to stay glued to the orbit card in
       every state. An earlier `translate(-50%, -2px)` on hover
       briefly detached the panel from the card above (the gap above
       grew, the gap below shrank), which read as the panel "lifting
       away" from its anchor. Hover now changes brightness only so
       the seam between the two surfaces never moves.

       NOTE: an even earlier `scale(1/1.5)` counter-scale also lived
       here from the era when the centered card was rendered at
       scale(1.5). The center card is now sized natively, so any
       scale() on hover would visibly shrink the panel by 33%. Hover
       stays both scale-free AND translate-free on purpose. */
    .reading-entry-overlay:has(.reading-entry-main:hover) {
      filter: brightness(1.08);
    }
    .reading-entry-overlay:has(.reading-entry-main:hover) .reading-entry-asset {
      filter: brightness(1.04) saturate(1.05);
    }
    .reading-entry-overlay:has(.reading-entry-main:active) {
      filter: none;
    }
    .reading-entry-overlay:has(.reading-entry-main:active) .reading-entry-asset {
      filter: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .reading-entry-overlay,
      .reading-entry-asset,
      .reading-entry-summary-pill {
        transition: none;
      }
      .reading-entry-overlay:has(.reading-entry-main:hover) {
        filter: none;
      }
    }

    /* ── Reading-entry confirmation ─────────────────────────────────
       Minimal confirmation transition for the reading-button click.
       The earlier cinematic portal (seam + aura + scan + neural nodes
       + scene/hero dim + camera push) was retired — Tomer asked for a
       mature, professional, fast handoff. What survives:
         1. The reading-entry pill fades out quickly (~100ms).
         2. The selected card gets a very subtle cyan halo + brightness
            lift (~200ms).
         3. JS navigates to the same href after ~200ms.

       Carousel focus (recede on non-centred cards, scale on centred)
       lives in its own block below and is independent — it runs on
       every card-centring event, not just on launch.

       Tunables on `:root` so JS and CSS share one source of truth.
       JS reads `--reading-entry-total` via getComputedStyle and uses
       it as the setTimeout delay before navigation. */
    :root {
      --reading-entry-total: 200ms;
      --reading-entry-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      --reading-entry-halo-color: rgba(120, 210, 255, 0.45);
    }

    /* Pill fade — the user just activated it, so its job is done.
       Opacity-only so the link itself stays in the accessibility tree
       until the navigation timer fires. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-asset,
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-text {
      opacity: 0;
      transition: opacity 100ms ease-out;
    }

    /* Subtle confirmation on the selected card — a small brightness
       lift plus a single cyan halo that traces the artifact's alpha
       silhouette via drop-shadow. Calibrated to read as "the AI heard
       you" within 200ms, without theatrics. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front) {
      filter:
        brightness(1.05)
        drop-shadow(0 0 8px var(--reading-entry-halo-color));
      transition: filter var(--reading-entry-total) var(--reading-entry-ease);
    }

    /* ── Carousel focus: non-centred cards recede ─────────────────────
       Trigger is `data-galaxy-focused` on the stage (set by
       universe-layout.ts whenever a card is centred), NOT the launch-
       state attribute. The recede is a NORMAL carousel-focus behaviour:
       pick any card via orbit navigation and the rest of the field
       recedes immediately — no reading-button click required.

       `scale` is the individual CSS property (not `transform: scale`)
       so it composes after the orbit's cos/sin transform without us
       having to recompute coordinates here. Transition runs at 0.4s
       to match the orbit's snappy focus pace. */
    .library-galaxy[data-galaxy-focused]
      .galaxy-card:not([data-pos="center"]) {
      filter: blur(3px) saturate(0.78);
      opacity: 0.28;
      scale: 0.86;
      transition:
        filter 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        scale 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Reduced motion: skip both the confirmation halo and the focus
       recede. JS short-circuits with location.assign before any state
       flip too, so these rules are belt-and-braces for any code path
       that sets the state without the JS guard. */
    @media (prefers-reduced-motion: reduce) {
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front) {
        filter: none;
        transition: none;
      }
      .library-galaxy[data-galaxy-focused]
        .galaxy-card:not([data-pos="center"]) {
        transition: none;
        scale: 1;
        filter: none;
        opacity: 1;
      }
    }

    /* Click-catcher only — covers the stage when a card is focused so
       a click anywhere outside the centered card closes the focus
       state. No visible fill / no blur layer: the focused card is its
       own focal point now (1.5× scale, larger artifact, layered text),
       and the wide blur was reading as a heavy panel behind the
       artifact rather than helping the focal lift. */
    .galaxy-backdrop {
      position: absolute;
      inset: 0;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      opacity: 0;
      pointer-events: none;
      z-index: 15;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-backdrop {
      /* Stays invisible — only its hitbox matters. opacity:1 just lets
         pointer-events register; it has nothing to render. */
      opacity: 1;
      pointer-events: auto;
    }
    /* Focus state used to dim the centered PNG so the focused card
       read as the new focal point. With the galaxy now rendered as
       a full-viewport scene background, the `.galaxy-backdrop` blur+
       darken layer above the orbit already provides that focal lift,
       so no extra dimming is wired here. */

    /* Orbit rotation controls — chevron pair pinned to the bottom of
       the viewport (not the stage), so they sit clear of the orbit
       cards at every breakpoint and remain a large, easy click target.
       Each click bumps --orbit-rotation on the stage by ±360°/N, and
       CSS interpolates the resulting transform on every card
       simultaneously. The wrapper is a flex pill so the two buttons
       read as one control. */
    .galaxy-orbit-controls {
      /* Always pinned to the very bottom of the viewport on desktop
         too. Only the safe-area-inset-bottom is honored on top —
         same hard-edge anchoring as the mobile rule above. */
      position: fixed !important;
      inset-block-end: auto;
      bottom: env(safe-area-inset-bottom, 0px) !important;
      left: 0;
      right: 0;
      margin-inline: auto;
      display: flex;
      width: max-content;
      gap: 0.5rem;
      padding: 0.3125rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.18),
        0 6px 18px rgba(0, 0, 0, 0.30);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      z-index: 40;
      direction: ltr;
    }
    .galaxy-orbit-btn {
      /* Compact rotate control — small pearl glass circle. Slightly
         brighter than the previous muted-surface version so the icons
         read clearly without competing with the book cards. */
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: rgba(255, 255, 255, 0.92);
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255, 255, 255, 0.22);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.28),
        0 2px 6px rgba(0, 0, 0, 0.24);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.36);
      transform: translateY(-1px);
      outline: none;
    }
    /* Mirror chevrons on RTL pages so "next" still points toward the
       direction reading flows. The stage itself is direction:ltr;
       only the icons need the manual flip. */
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

  }

  /* ── Wide desktop (≥1280px): wider orbit cards + larger orbit. ─── */
  @media (min-width: 1280px) {
    /* Larger orbit scene gets a deeper vertical offset so rotating
       cards along the wider ellipse still clear the page title.
       Wide desktop carries a slightly bigger orbit-ry (up to 250px
       vs the 1024-1279px tier's 230px), so the offset adds another
       +20px on top of the base desktop's new 90px to preserve the
       minimum ~20px top-card clearance Tomer requested.
       Reduced from 110→70 (paired with --orbit-ry shrinking by the
       same ~40px) so the orbit becomes shorter on wide desktops too
       while the TOP of the carousel stays at the same Y as before. */
    .library-galaxy {
      --orbit-vertical-offset: 70px;
    }
    .galaxy-card {
      /* 210px × 1.2 = 252px (Tomer's +20% bump). Orbit radii grown
         proportionally so the wider cards still distribute cleanly. */
      width: 252px;
      --orbit-rx: clamp(350px, 33vw, 480px);
      --orbit-ry: clamp(180px, 22vh, 235px);
    }
    /* Capsule stays one notch wider than a book card so the proportion
       contrast holds across breakpoints. 232 × 1.2 = 278px. */
    .galaxy-card[data-role="series"] {
      width: 278px;
    }
  }

  /* ── Series action panel — shown next to a focused series capsule ──
        Two pill buttons that ride along inside the existing
        `.galaxy-cta` slot. The slot's fade-in / pointer-events rule
        already gates visibility on `[data-pos="center"]`, so these
        buttons inherit the same focus-only reveal as the close button
        without any extra logic.
        Only the course card (`data-kind="course"`) ever renders the
        wrapper, so other cards remain unchanged. */
  /* ── Series action buttons —
        Two large futuristic capsules under the focused course card.
        Each is a glass plate with:
          • a layered prismatic conic-gradient border that drifts on
            hover (animation pauses to save paint when not interactive);
          • a circular accent badge wrapping the icon, with its own
            radial glow that intensifies on hover;
          • a diagonal shimmer sweep that crosses the surface once
            per hover/focus;
          • a soft halo (box-shadow) and a 2px lift on activation.
        The two buttons are colour-differentiated so they read as
        distinct actions even at a glance: the toggle uses
        cyan→purple (knowledge / discovery), the details uses
        gold→purple (info / metadata). aria-pressed on the toggle
        intensifies the conic border + halo without changing the
        layout, so the "open" state reads clearly. */
  .galaxy-cta-series-actions {
    display: flex;
    flex-direction: row;
    gap: 0.7rem;
    align-items: stretch;
    justify-content: center;
    margin-block-start: 0.5rem;
  }
  .galaxy-cta-series-btn {
    --series-btn-accent: var(--yuval-galaxy-accent-purple, #a78bfa);
    --series-btn-accent-2: var(--yuval-galaxy-accent-cyan, #22d3ee);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 1.05rem 0.65rem 0.65rem;
    border-radius: 16px;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--yuval-galaxy-text, #ececea);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 90%, transparent) 0%,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 72%, transparent) 100%
      );
    border: 1px solid transparent;
    cursor: pointer;
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    isolation: isolate;
    overflow: hidden;
    text-align: start;
    white-space: nowrap;
    box-shadow:
      0 8px 20px -10px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
    transition:
      transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 280ms ease,
      background 280ms ease;
  }
  /* Prismatic border — conic gradient projected onto a 1px-thick
     ring via mask-composite. The "fill" gradient slowly rotates so
     the border catches light like a hologram edge. */
  .galaxy-cta-series-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--series-btn-spin, 0deg),
      color-mix(in srgb, var(--series-btn-accent) 80%, transparent) 0%,
      color-mix(in srgb, var(--series-btn-accent-2) 70%, transparent) 25%,
      color-mix(in srgb, var(--yuval-galaxy-accent-gold, #f6c560) 55%, transparent) 50%,
      color-mix(in srgb, var(--series-btn-accent-2) 70%, transparent) 75%,
      color-mix(in srgb, var(--series-btn-accent) 80%, transparent) 100%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 280ms ease;
    z-index: 0;
  }
  /* Shimmer sweep — diagonal light slash that crosses the surface
     once per hover/focus. Sits above the background but below the
     icon + label (z-index dance below). */
  .galaxy-cta-series-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in srgb, white 22%, transparent) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
    pointer-events: none;
    z-index: 1;
    transition: transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .galaxy-cta-series-btn > * {
    position: relative;
    z-index: 2;
  }
  .galaxy-cta-series-btn:hover,
  .galaxy-cta-series-btn:focus-visible {
    outline: none;
    transform: translateY(-2px);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 78%, transparent) 0%,
        color-mix(in srgb, var(--series-btn-accent) 14%, var(--yuval-galaxy-bg, #00010d)) 100%
      );
    box-shadow:
      0 14px 32px -8px color-mix(in srgb, var(--series-btn-accent) 55%, transparent),
      0 0 0 1px color-mix(in srgb, var(--series-btn-accent) 25%, transparent) inset,
      inset 0 1px 0 color-mix(in srgb, white 18%, transparent);
  }
  .galaxy-cta-series-btn:hover::before,
  .galaxy-cta-series-btn:focus-visible::before {
    opacity: 1;
  }
  .galaxy-cta-series-btn:hover::after,
  .galaxy-cta-series-btn:focus-visible::after {
    transform: translateX(130%);
  }
  .galaxy-cta-series-btn[aria-pressed="true"] {
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--series-btn-accent) 25%, var(--yuval-galaxy-bg, #00010d)) 0%,
        color-mix(in srgb, var(--series-btn-accent-2) 18%, var(--yuval-galaxy-bg, #00010d)) 100%
      );
    box-shadow:
      0 10px 28px -8px color-mix(in srgb, var(--series-btn-accent) 60%, transparent),
      0 0 0 1px color-mix(in srgb, var(--series-btn-accent) 35%, transparent) inset,
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent);
  }
  .galaxy-cta-series-btn[aria-pressed="true"]::before {
    opacity: 1;
  }
  /* Icon badge — circular glass medallion with radial glow. */
  .galaxy-cta-series-btn-icon {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--series-btn-accent);
    background:
      radial-gradient(
        circle at 30% 30%,
        color-mix(in srgb, var(--series-btn-accent) 45%, transparent) 0%,
        color-mix(in srgb, var(--series-btn-accent) 18%, transparent) 55%,
        transparent 100%
      );
    border: 1px solid color-mix(in srgb, var(--series-btn-accent) 50%, transparent);
    flex: 0 0 auto;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent),
      0 0 14px -4px color-mix(in srgb, var(--series-btn-accent) 60%, transparent);
    transition:
      transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 280ms ease;
  }
  .galaxy-cta-series-btn-icon svg {
    width: 16px;
    height: 16px;
  }
  .galaxy-cta-series-btn:hover .galaxy-cta-series-btn-icon,
  .galaxy-cta-series-btn:focus-visible .galaxy-cta-series-btn-icon {
    transform: scale(1.1) rotate(-4deg);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 32%, transparent),
      0 0 22px -2px color-mix(in srgb, var(--series-btn-accent) 85%, transparent);
  }
  .galaxy-cta-series-btn-label {
    line-height: 1.1;
    font-size: 0.92rem;
    /* Subtle gradient text — same prismatic palette as the border,
       muted so the label still reads as a label, not a sign. */
    background: linear-gradient(
      120deg,
      var(--yuval-galaxy-text, #ececea) 0%,
      color-mix(in srgb, var(--series-btn-accent) 35%, var(--yuval-galaxy-text, #ececea)) 100%
    );
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
            color: transparent;
  }
  /* "Series details" button — gold accent variant so the two
     buttons read as different at a glance. */
  .galaxy-cta-series-btn[data-series-action="details"] {
    --series-btn-accent: var(--yuval-galaxy-accent-gold, #f6c560);
    --series-btn-accent-2: var(--yuval-galaxy-accent-purple, #a78bfa);
  }

  /* ── Local children fan — opens around the focused series capsule ──
        The fan is a horizontal row of small child cards positioned
        under the focused capsule. It lives inside the orbit stage as
        a positioned overlay so it never permanently mixes into the
        main universe. Hidden until the controller populates it; the
        controller also clears its contents on close so leftover state
        never lingers. */
  .series-children-fan[hidden] { display: none; }
  .series-children-fan {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 1.25rem;
    z-index: 25; /* above orbit cards (3), below focused card (30) */
    display: flex;
    justify-content: center;
    pointer-events: none;
    padding-inline: 1rem;
  }
  .series-children-list {
    list-style: none;
    margin: 0;
    padding: 0.625rem 0.875rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.625rem;
    pointer-events: auto;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 28%, transparent);
    border-radius: 1rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 12%, transparent) inset,
      0 18px 40px -16px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 40%, transparent);
    max-width: min(640px, 92%);
    animation: series-children-fade-in 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes series-children-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .series-children-empty {
    margin: 0;
    padding: 0.875rem 1.125rem;
    pointer-events: auto;
    color: var(--yuval-galaxy-text-soft);
    font-size: 0.8125rem;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 28%, transparent);
    border-radius: 999px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-align: center;
  }
  .series-child-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 96px;
    padding: 0.4375rem;
    border-radius: 0.625rem;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 65%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-border, rgba(120, 130, 165, 0.22)) 70%, transparent);
    transition: border-color 160ms ease, transform 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .series-child-card:hover {
    border-color: color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 55%, transparent);
    transform: translateY(-2px);
  }
  .series-child-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 0.5rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(
        circle at 50% 35%,
        color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 18%, transparent) 0%,
        transparent 70%
      ),
      var(--yuval-galaxy-surface-muted, #161a2c);
  }
  .series-child-visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }
  .series-child-visual-placeholder {
    flex-direction: column;
    gap: 0.25rem;
    color: color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 75%, var(--yuval-galaxy-text-soft, #c8c8c4));
  }
  .series-child-placeholder-glyph {
    display: inline-flex;
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 50%, transparent));
  }
  .series-child-placeholder-type {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--yuval-galaxy-text-soft, #c8c8c4);
    opacity: 0.85;
