          <button
            type="button"
            class="galaxy-orbit-btn"
            data-galaxy-rotate
            data-direction="prev"
            aria-label={t('library.galaxy.rotatePrev', language)}
          ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>

          {/* Pagination dots — between the chevrons. universe-layout.ts
              toggles [data-active] inside setPositionIndicator() so the
              active dot stays in lockstep with the counter and the
              focused carousel slot. */}
          <div
            class="galaxy-position-dots"
            data-galaxy-position-dots
            aria-hidden="true"
          >
            {orbitItems.map((_, i) => (
              <span
                class="galaxy-position-dot"
                data-galaxy-position-dot
                data-index={i}
              ></span>
            ))}
          </div>

          <button
            type="button"
            class="galaxy-orbit-btn"
            data-galaxy-rotate
            data-direction="next"
            aria-label={t('library.galaxy.rotateNext', language)}
          ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
        </div>

        {/* Exit chip for the mobile filtered-series carousel. Hidden by
            default; revealed only while the bottom nav carries
            [data-series-mode] (set by applyCourseFilter in
            universe-series-actions.ts). Tapping it calls clearCourseFilter
            to return to the full universe — a discoverable alternative to
            the document-click dismissal, which is hard to hit on a
            full-screen phone stage. */}
        <button
          type="button"
          class="galaxy-series-exit"
          data-series-exit
          aria-label={t('library.series.actions.hideItems', language)}
        >
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"></path></svg>
          <span>{t('library.series.actions.hideItems', language)}</span>
        </button>
      </div>
    )}


  </div>
</LibraryLayout>

