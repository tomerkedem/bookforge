        </div>

        {/* Series-carousel counter ("3 / 6"). Hidden by default; shown
            only while the bottom nav carries [data-series-mode]. The orbit
            counter above tracks the wrong (orbit) set in series mode and
            is hidden then, so this takes its place. universe-series-mode.ts
            refreshCarouselState() writes the live position into the two
            spans below. */}
        <div
          class="galaxy-series-position"
          data-galaxy-series-position
          role="status"
          aria-live="polite"
        >
          <span data-series-mobile-pos-current>1</span>
          <span class="galaxy-position-sep" aria-hidden="true">/</span>
          <span data-series-mobile-pos-total>0</span>
        </div>

