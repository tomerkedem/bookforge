<script>
  /**
   * Knowledge Universe — runtime orchestrator.
   *
   * Thin entry-point. The heavy work lives in dedicated modules:
   *
   *   universe-series-hydrator → reads editorial metadata, filters
   *     hidden items, groups multi-item series into capsules, and
   *     recomputes orbit angles. Returns the universe state.
   *
   *   universe-series-mode → registers click / keyboard / Esc
   *     handlers for series capsules and Other Knowledge. MUST be
   *     initialised BEFORE the layout module so its capture-phase
   *     click listener fires first and intercepts capsule clicks.
   *
   *   universe-layout → registers click-to-center, drag-to-rotate,
   *     chevron rotation, and progress-bar hydration. Skips cards
   *     with a [data-role] (capsule / other-knowledge) so it never
   *     accidentally click-to-centers a series capsule.
   */
  import { hydrateUniverse } from '../utils/library/universe-series-hydrator';
  import { initSeriesMode } from '../utils/library/universe-series-mode';
  import {
    initStageLayout,
    hydrateOrbitProgress,
  } from '../utils/library/universe-layout';
  import { initSeriesActions } from '../utils/library/universe-series-actions';
  import { initCoreEffects } from '../utils/library/universe-core-effects';
  import { initCoreSearch } from '../utils/library/core-search';
  // Phase 7 — `admin-series-hydrator` was removed along with all
  // browser-storage draft state. Series visibility, titles, and orbit
  // composition are decided entirely at SSR by the catalog store
  // (`library-catalog-store.ts`), so no client-side reconciliation is
  // needed and no draft mirroring runs after first paint.

  /**
   * Re-bind the orbit on every page-load — including the one that
   * happens after the user comes BACK from a book page via the
   * browser's back button. Astro's View Transitions swap in a fresh
   * DOM, so the listeners attached during the previous mount are
   * gone with the previous stage element; without re-running the
   * init the orbit cards just navigate directly via their inner <a>
   * (the click-to-center handler isn't there to swallow the click).
   *
   * `astro:page-load` fires once on first visit AND once after every
   * view-transition completes, so a single listener covers both
   * cases. Each fresh stage element gets exactly one init pass —
   * no double-binding, because old stages were removed from the DOM.
   */
  /**
   * Pulse linked book/lesson cards when the pointer enters a
   * series/course capsule.
   *
   * Mapping: every LibraryItem the catalog produces for a course
   * (type 'course') gets `seriesId = "course-<courseSlug>"`, and every
   * book/lesson with `courseSlug` gets the same `seriesId`. That value
   * is rendered as `data-series-id` on each `.galaxy-card`. To find
   * the linked siblings of a series-kind card, we simply match all
   * cards sharing its `data-series-id` and exclude the card itself.
   *
   * State management: each linked card stores its active hide-timer
   * id in `dataset.glowTimer`. Re-hovering the same capsule before
   * the previous pulse expires resets the timer so the user always
   * gets the full 3-second halo from the latest interaction.
   *
   * Performance: one delegated listener per stage. Removing the
   * class on timer expiry is idempotent — if the card was removed
   * by a transition we silently no-op via `?.remove()` semantics.
   */
  function initLinkedGlow(stage: HTMLElement) {
    const GLOW_MS = 3000;
    const escape = (v: string) => v.replace(/"/g, '\\"');

    // ── Hover handler ───────────────────────────────────────────
    // `data-series-name` and `data-series-id` arrive from SSR — the
    // catalog store resolves both from `catalog.json` and
    // `output/_editorial.json`, so the client no longer needs to read
    // any browser storage to build the linked-glow graph.
    // For each series capsule we match siblings by EITHER:
    //   - data-series-name (the admin-driven link the user described)
    //   - data-series-id   (auto-discovered course-lesson link from
    //                       the catalog, so lessons of a real course
    //                       glow even without the admin form filled)
    // Cards without either attribute on the capsule are skipped.
    const seriesCards = stage.querySelectorAll<HTMLElement>(
      '.galaxy-card[data-kind="course"]',
    );
    seriesCards.forEach((card) => {
      const seriesName = card.dataset.seriesName;
      const seriesId = card.dataset.seriesId;
      if (!seriesName && !seriesId) return;
      card.addEventListener('pointerenter', () => {
        const matchers: string[] = [];
        if (seriesName) {
          matchers.push(`.galaxy-card[data-series-name="${escape(seriesName)}"]`);
        }
        if (seriesId) {
          matchers.push(`.galaxy-card[data-series-id="${escape(seriesId)}"]`);
        }
        const linked = stage.querySelectorAll<HTMLElement>(matchers.join(','));
        console.log(
          '[linked-glow] hover slug=%s seriesName=%s → %d linked',
          card.dataset.slug,
          seriesName,
          linked.length - 1,
        );
        linked.forEach((sibling) => {
          if (sibling === card) return;
          const prev = sibling.dataset.glowTimer;
          if (prev) {
            window.clearTimeout(Number(prev));
          }
          sibling.classList.add('is-linked-glow');
          const t = window.setTimeout(() => {
            sibling.classList.remove('is-linked-glow');
            delete sibling.dataset.glowTimer;
          }, GLOW_MS);
          sibling.dataset.glowTimer = String(t);
        });
      });
    });
  }

  /**
   * Reading-entry launch handler (phase 2).
   *
   * Intercepts ONLY plain same-tab activations of the reading-entry
   * overlay. Plain = primary-button click with no modifier keys, or
   * Enter on a keyboard-focused overlay (which the browser dispatches
   * as a synthesized click with `button === 0` and no modifiers).
   *
   * Everything else falls through to the native <a href>:
   *   - Ctrl/Cmd-click       → open in new tab (browser default)
   *   - Shift-click          → open in new window
   *   - Alt-click            → save link as
   *   - Middle-click         → dispatched as `auxclick`, never seen here
   *   - Right-click          → dispatched as `contextmenu`, never seen here
   *   - "Copy link address"  → browser context-menu action, untouched
   *
   * Why on the STAGE (`stage.dataset.readingEntryState`) and not on
   * the card: only one launch can be in progress at a time, and the
   * existing focus state (`stage.dataset.galaxyFocused`) is already
   * stage-level — keeping the launch state next to it gives a single
   * source of truth, an obvious DevTools inspection point, and a
   * trivial `delete` for reset. Per-card state would scatter the
   * cleanup across N cards.
   *
   * Reset is driven by a MutationObserver on `data-pos` / `data-galaxy-
   * focused`. Any centering change (close button, backdrop, Esc,
   * different card centered, orbit rotation — all of them flip
   * `data-pos` on at least one card) clears the launch state if the
   * originally-launched card is no longer the centered one. This
   * decouples cleanup from the centering API in universe-layout.ts.
   */
  function initReadingEntryLaunch(stage: HTMLElement) {
    // Single source of truth lives in CSS: `:root { --reading-entry-total }`.
    // We read it at click time so a tuning change to the CSS variable
    // immediately retunes the JS navigation timing — no constant to
    // keep in sync. Fallback is 200ms (the simplified confirmation
    // window) in case the property is missing or unparseable.
    function readDurationMs(): number {
      const raw = getComputedStyle(document.documentElement)
        .getPropertyValue('--reading-entry-total')
        .trim();
      if (raw.endsWith('ms')) {
        const n = parseFloat(raw);
        return Number.isFinite(n) && n > 0 ? n : 200;
      }
      if (raw.endsWith('s')) {
        const n = parseFloat(raw);
        return Number.isFinite(n) && n > 0 ? n * 1000 : 200;
      }
      const n = parseFloat(raw);
      return Number.isFinite(n) && n > 0 ? n : 200;
    }

    function clearLaunchState(): void {
      delete stage.dataset.readingEntryState;
      delete stage.dataset.readingEntryHref;
      delete stage.dataset.readingEntrySlug;
      const pendingTimer = stage.dataset.readingEntryTimer;
      if (pendingTimer) {
        window.clearTimeout(Number(pendingTimer));
        delete stage.dataset.readingEntryTimer;
      }
    }

    function prefersReducedMotion(): boolean {
      return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function isPlainActivation(e: MouseEvent): boolean {
      // For real mouse clicks: `button === 0` is the primary button.
      // For Enter on a focused <a>: browsers dispatch a synthesized
      // click event with `button === 0` and `detail === 0`. Modifier
      // flags reflect what was held during Enter. The same predicate
      // covers both, so Enter activation lands here too.
      if (e.button !== 0) return false;
      if (e.ctrlKey || e.metaKey || e.shiftKey || e.altKey) return false;
      return true;
    }

    // Summary pill is a sibling of the main reading-entry <a>, not a
    // descendant — so DOM-level bubbling never reaches the main link.
    // We additionally stop the click from bubbling past the pill itself
    // in BUBBLE phase: the pill receives the click first (native <a>
    // nav fires), and only then do we halt propagation toward stage /
    // document / window. This guarantees that no ancestor handler can
    // ever confuse a pill click for a reading-entry launch. We do NOT
    // call preventDefault, so native href navigation still runs.
    stage.querySelectorAll<HTMLAnchorElement>(
      'a.reading-entry-summary-pill',
    ).forEach((pill) => {
      pill.addEventListener('click', (e: MouseEvent) => {
        e.stopPropagation();
      });
    });

    stage.addEventListener('click', (e: MouseEvent) => {
      // Drag-suppression from universe-layout.ts's capture-phase
      // handler runs preventDefault but not stopPropagation, so the
      // click still reaches us. Skip if that happened — we should not
      // start a launch from a swallowed drag-click.
      if (e.defaultPrevented) return;

      const target = e.target as Element | null;
      if (!target) return;
      const trigger = target.closest<HTMLAnchorElement>('[data-reading-entry]');
      if (!trigger) return;

      // Modifier / non-primary clicks → let native <a> behavior run.
      if (!isPlainActivation(e)) return;

      // CSS already hides non-centered overlays via `visibility:
      // hidden`, so this is a belt-and-braces check against
      // synthesized clicks dispatched at hidden elements.
      const card = trigger.closest<HTMLElement>('[data-galaxy-card]');
      if (!card || card.dataset.pos !== 'center') return;

      // Missing / empty href → don't start a launch. Unsafe href is
      // gated at SSR (`isSafeLibraryHref`) so an unsafe overlay never
      // exists in the DOM; defensive empty-href check covers the
      // theoretical case where the attribute was stripped at runtime.
      const href = trigger.getAttribute('href') ?? '';
      const slug = trigger.dataset.readingEntrySlug ?? '';
      if (!href) return;

      // Double-launch guard. We still call preventDefault so the second
      // click doesn't navigate either — without it, the browser would
      // honor the link's default action since this branch doesn't
      // start a new launch.
      if (stage.dataset.readingEntryState === 'opening') {
        e.preventDefault();
        console.log('[reading-entry] launch already in progress — ignored', { slug });
        return;
      }

      e.preventDefault();

      // Reduced motion: skip the confirmation entirely and navigate
      // immediately. We don't set the opening state at all so the
      // halo + pill fade never engage — the user gets a plain
      // navigation, which is what the OS-level preference asks for.
      if (prefersReducedMotion()) {
        console.log('[reading-entry] reduced motion — navigating immediately', { slug, href });
        window.location.assign(href);
        return;
      }

      // Stage-level state drives the pill fade-out and the subtle
      // halo on the selected card. Navigation fires when the timer
      // lands — see below.
      stage.dataset.readingEntryState = 'opening';
      stage.dataset.readingEntryHref = href;
      stage.dataset.readingEntrySlug = slug;
      console.log('[reading-entry] launch started', { slug, href });

      // Navigate after the confirmation window. Duration is read
      // from the CSS var so a tuning change in one place retunes
      // both the visual timing and the navigation moment. Store the
      // timer id on the stage so the MutationObserver-driven
      // clearLaunchState() can cancel it if centering changes mid-
      // animation (e.g. user taps backdrop / centers a different card).
      const durationMs = readDurationMs();
      const timerId = window.setTimeout(() => {
        delete stage.dataset.readingEntryTimer;
        window.location.assign(href);
      }, durationMs);
      stage.dataset.readingEntryTimer = String(timerId);
    });

    // Reset launch state on any centering change. We intentionally
    // watch the WHOLE subtree for `data-pos` flips rather than
    // patching universe-layout.ts's openCenter/closeCenter — this
    // keeps the launch feature decoupled from the centering API.
    const observer = new MutationObserver(() => {
      if (stage.dataset.readingEntryState !== 'opening') return;
      const launchedSlug = stage.dataset.readingEntrySlug;
      if (!launchedSlug) {
        clearLaunchState();
        return;
      }
      const launchedCard = stage.querySelector<HTMLElement>(
        `.galaxy-card[data-slug="${CSS.escape(launchedSlug)}"]`,
      );
      if (!launchedCard || launchedCard.dataset.pos !== 'center') {
        console.log('[reading-entry] launch cleared — centering changed', { slug: launchedSlug });
        clearLaunchState();
      }
    });
    observer.observe(stage, {
      attributes: true,
      attributeFilter: ['data-pos', 'data-galaxy-focused'],
      subtree: true,
    });
  }

  /**
   * Center-card extras hydrator.
   *
   * Walks every orbit card, reads its per-chapter reading-progress
   * entries from localStorage (same key scheme used by
   * `hydrateOrbitProgress` in universe-layout.ts:
   *   `yuval_reading_progress_{slug}_ch{N}` with a `.percentage` field)
   * and patches two pieces of the centered-card SSR markup:
   *
   *   1. The primary pill's label span (`[data-cc-primary-label]`)
   *      gets swapped from the SSR default "כניסה לקריאה" to
   *      "המשך · פרק N" — using the localized template carried on
   *      `data-continue-template` — when stored progress identifies a
   *      "current chapter". Current chapter = highest chapter index
   *      with any percentage > 0, capped at chapterCount. When every
   *      chapter is already 100%, we fall back to chapterCount itself
   *      so the label still reads "המשך · פרק <last>" instead of
   *      reverting to the start-of-book copy.
   *
   *   2. The metadata row's progress span (`[data-cc-meta-progress]`)
   *      is ALWAYS rendered (SSR ships "0% הושלם") so the chip row
   *      stays symmetric. The hydrator overwrites the value with the
   *      real average whenever localStorage has progress entries —
   *      including a real 0 — so it reflects actual state instead of
   *      a stale SSR default.
   *
   * Read-only against localStorage; never writes. Safe to run before
   * or after `hydrateOrbitProgress` (independent data fields).
   */
  function hydrateCenterCardExtras(): void {
    const cards = document.querySelectorAll<HTMLElement>('[data-galaxy-card]');
    cards.forEach((card) => {
      const slug = card.dataset.slug;
      if (!slug) return;

      // chapterCount comes from the orbit-progress bar emitted by
      // LibraryCard. Re-reading it here keeps the hydrator decoupled
      // from the SSR data shape — if the bar is absent (lesson card,
      // article, future content type without chapters) we simply skip.
      const progressBar = card.querySelector<HTMLElement>('[data-orbit-progress]');
      const total = Number(progressBar?.dataset.chapterCount || '0');
      if (!total || total <= 0) return;

      let sum = 0;
      let entries = 0;
      let highestWithProgress = 0;
      for (let i = 1; i <= total; i++) {
        const raw = localStorage.getItem(`yuval_reading_progress_${slug}_ch${i}`);
        if (!raw) continue;
        try {
          const parsed = JSON.parse(raw);
          if (typeof parsed.percentage === 'number') {
            const pct = parsed.percentage;
            sum += pct;
            entries += 1;
            if (pct > 0) highestWithProgress = i;
          }
        } catch {
          // Corrupt entry → skip silently, matches hydrateOrbitProgress.
        }
      }

      // Patch primary label + href when we have a current-chapter signal.
      // `highestWithProgress === 0` means every entry was 0% (or
      // unparseable) — treat as "no current chapter" and leave the
      // SSR "כניסה לקריאה" copy + `/read/{slug}/{firstChapterId}` href
      // in place. When a current chapter is found, we ALSO rewrite the
      // pill's `href` and `data-reading-entry-href` so the primary
      // action lands on the user's actual reading position — the SSR
      // first-chapter URL would otherwise reset them every visit.
      if (highestWithProgress > 0) {
        const labelEl = card.querySelector<HTMLElement>('[data-cc-primary-label]');
        const template = labelEl?.dataset.continueTemplate;
        if (labelEl && template) {
          labelEl.textContent = template.replace('__N__', String(highestWithProgress));
        }
        // Main reading-entry link lives inside the overlay container
        // (the outer overlay is a <div> since the addition of the
        // summary pill). Selector targets the inner <a> directly.
        const pill = card.querySelector<HTMLAnchorElement>('a.reading-entry-main[data-reading-entry]');
        if (pill) {
          const continueHref = `/read/${slug}/${highestWithProgress}`;
          pill.setAttribute('href', continueHref);
          pill.setAttribute('data-reading-entry-href', continueHref);
          // aria-label kept in sync with the visible chapter so screen
          // readers announce "המשך קריאה בפרק N" alongside the live
          // subtitle below.
          const ariaTmpl = pill.dataset.ariaTemplate;
          if (ariaTmpl) {
            pill.setAttribute('aria-label', ariaTmpl.replace('__N__', String(highestWithProgress)));
          }
        }
      }

      // Chapter subtitle below the main CTA label ("פרק N"). SSR ships
      // "פרק 1"; when stored progress identifies a higher chapter, swap
      // it in. Independent of the primary label patch above so that a
      // brand-new book still reads "פרק 1" instead of going blank.
      const chapterEl = card.querySelector<HTMLElement>('[data-cc-chapter-label]');
      const chapterTmpl = chapterEl?.dataset.chapterTemplate;
      if (chapterEl && chapterTmpl && highestWithProgress > 0) {
        chapterEl.textContent = chapterTmpl.replace('__N__', String(highestWithProgress));
      }

      // Patch the progress label + bar. Sum/total (not sum/entries)
      // mirrors hydrateOrbitProgress so a 50%-read single chapter in
      // a 10-chapter book reads as 5%, not 50% — consistent with the
      // existing orbit progress bar's interpretation. We rewrite even
      // when entries === 0 / avg === 0 so a brand-new book continues
      // to read "0%" instead of producing a stale value if SSR ever
      // changes its default.
      //
      // Two surfaces are updated together so the bar and the label
      // can never disagree:
      //   - `[data-cc-meta-progress]`     → the tiny "X%" text label.
      //   - `--re-progress` on `.reading-entry-text` → drives the
      //     `.reading-entry-progress-fill` width via CSS var. The
      //     redesigned panel uses an animated bar instead of a chip,
      //     and width: var(--re-progress) keeps the CSS source-of-
      //     truth co-located with the rest of the panel's styling.
      const avg = entries > 0 ? Math.round(sum / total) : 0;
      const progEl = card.querySelector<HTMLElement>('[data-cc-meta-progress]');
      const tmpl = progEl?.dataset.progressTemplate;
      if (progEl && tmpl) {
        progEl.textContent = tmpl.replace('__N__', String(avg));
      }
      const textEl = card.querySelector<HTMLElement>('.reading-entry-text');
      if (textEl) {
        textEl.style.setProperty('--re-progress', `${avg}%`);
      }
    });
  }

  /**
   * Anchor the focused-card TOP flush against the bottom of the hero
   * subtitle ("כל הידע שלך במרחב אחד חי ומתפתח") on BOTH mobile and
   * desktop.
   *
   * Why measurement: the hero's vertical height is a moving target —
   * `lh-title` uses a `clamp(...)` so it grows with viewport width,
   * `library-root` has different top padding in light vs dark mode,
   * and the user-agent root font-size can be overridden. Any static
   * `calc(72px + Xrem)` lands as a gap on some widths and an overlap
   * on others. Reading the subtitle's `getBoundingClientRect().bottom`
   * always returns the correct viewport Y on every breakpoint.
   *
   * Two output variables, both written to `.library-root` so they
   * inherit down to `.galaxy-card[data-pos="center"]`:
   *   - `--focused-card-top` (desktop): galaxy-LOCAL Y. Desktop card
   *     is `position: fixed`, and `.library-galaxy`'s `transform`
   *     makes IT the containing block for fixed descendants — so
   *     `top:` is measured from galaxy's top, not viewport. Compute
   *     subBottom (viewport) − galaxyTop (viewport).
   *   - `--mobile-focused-top` (mobile): viewport Y. Mobile card is
   *     `position: absolute` and its translateY formula
   *     (`calc(var(--mobile-focused-top) - 50dvh + 0.75*card_w)`)
   *     anchors the visible top edge AT this viewport Y, so pass
   *     subBottom directly.
   * 0px gap on both — card top sits flush against the subtitle's
   * line-height descender, reading as truly touching.
   * Re-measures on resize + after fonts load so font-swap reflow is
   * caught too.
   */
  function initFocusedCardAnchor(): void {
    const root = document.querySelector<HTMLElement>('.library-root');
    if (!root) return;
    const measure = () => {
      const sub = root.querySelector<HTMLElement>('.lh-subtitle');
      const galaxy = root.querySelector<HTMLElement>('.library-galaxy');
      if (!sub || !galaxy) return;
      const subBottom = sub.getBoundingClientRect().bottom;
      const galaxyTop = galaxy.getBoundingClientRect().top;
      const localTop = Math.round(subBottom - galaxyTop);
      const viewportTop = Math.round(subBottom);
      root.style.setProperty('--focused-card-top', `${localTop}px`);
      root.style.setProperty('--mobile-focused-top', `${viewportTop}px`);
    };
    // Defer one frame so the initial layout has settled before measuring.
    requestAnimationFrame(measure);
    window.addEventListener('resize', measure, { passive: true });
    // Web fonts shift the subtitle's metrics after first paint.
    if ('fonts' in document) {
      document.fonts.ready.then(measure).catch(() => {});
    }
  }

  function initOrbit() {
    initFocusedCardAnchor();
    document
      .querySelectorAll<HTMLElement>('[data-galaxy-stage]')
      .forEach((stage) => {
        // Defensive: skip stages that have already been wired in this
        // mount. The flag is on the element, so it dies with the DOM
        // when a new transition swaps in a fresh stage.
        if (stage.dataset.galaxyInit === 'true') return;
        const state = hydrateUniverse(stage);
        // Order matters: series-mode click handler must register BEFORE
        // the layout's card-click handler so it runs first in capture
        // phase. See architecture comments in universe-series-mode.ts.
        // We capture the handle so the action-panel button below can
        // drive the orbit's series-mode (filter to series-only
        // carousel) without duplicating the click wiring.
        const seriesMode = initSeriesMode(stage, state);
        initStageLayout(stage);
        // Series action panel + details drawer. Reads
        // `data-pos="center"` produced by the layout module above and
        // wires the SSR-rendered series buttons + drawer chrome. Safe
        // to register after the layout module because its own click
        // handler uses capture-phase + stopImmediatePropagation to
        // intercept the series-action buttons before the layout's
        // card-click handler closes the focused card.
        initSeriesActions(stage, seriesMode);
        // Lightning bolt from the central core to the hovered orbit
        // card. Injects a single SVG overlay into the stage; bolts
        // are short-lived path elements created on hover and removed
        // after their fade-out. No persistent loop.
        initCoreEffects(stage);
        // Linked-glow halo: hover a series/course capsule and every
        // linked book/lesson (same data-series-id) pulses through a
        // gold → orange → turquoise cycle for 3 seconds. CSS owns
        // the animation; this only toggles the class on/off.
        initLinkedGlow(stage);
        // Reading-entry launch (phase 2). Intercepts ONLY plain
        // left-clicks / Enter activations on the visible overlay and
        // moves the stage into a "opening" state. Modifier clicks,
        // middle-click, right-click and the keyboard context menu
        // still fall through to native <a> behavior — this handler
        // returns without preventDefault for those. Navigation and
        // animation are deliberately NOT triggered yet; phase 3 will
        // hook onto the state transition.
        initReadingEntryLaunch(stage);
        // Core Search Mode (mobile-only). Registers tap/input/clear/
        // close/Esc/swipe-down handlers against the SSR-shipped chrome
        // (`[data-core-search-*]`). On desktop the chrome is hidden by
        // CSS so this is a no-op visually; the runtime guard inside
        // the module also bails on `(min-width: 1024px)`.
        initCoreSearch(stage);
        stage.dataset.galaxyInit = 'true';
      });

    // Defer one frame so the layout pass settles before we paint the
    // progress fills — avoids a brief 0% → real% flash on slow boots.
    // Same frame batch: patch the centered-card secondary link + meta
    // row from localStorage. Both read the same per-chapter entries,
    // so coalescing them keeps the localStorage hit count flat.
    requestAnimationFrame(() => {
      hydrateOrbitProgress();
      hydrateCenterCardExtras();
    });
  }

  document.addEventListener('astro:page-load', initOrbit);
</script>
