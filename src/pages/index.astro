---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import BookCard from '../components/BookCard.astro';
import { BOOKS } from '../lib/books';

const lang = (Astro.url.searchParams.get('lang') ?? 'he') as 'he' | 'en';
const dir = lang === 'he' ? 'rtl' : 'ltr';
---

<Layout
  title={lang === 'he' ? 'Yuval — ספריית הקריאה' : 'Yuval — Reading Library'}
  lang={lang}
  description={lang === 'he' ? 'פלטפורמת קריאה דיגיטלית. ספרים בעברית ואנגלית.' : 'Digital reading platform. Books in Hebrew and English.'}
>
  <Navigation lang={lang} currentPath="/" />

  <main dir={dir}>
    <!-- Page header -->
    <div
      class="max-w-6xl mx-auto border-b border-yuval-border"
      style="padding: 64px 48px 48px;"
    >
      <p
        class="text-yuval-text-muted"
        style="font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 24px;"
      >
        {lang === 'he' ? 'ספרייה' : 'Library'}
      </p>

      <h1
        class="font-heading text-yuval-text"
        style="font-size: clamp(36px, 5vw, 72px); font-weight: 700; line-height: 1.05; letter-spacing: -0.02em; max-width: 10ch;"
      >
        {lang === 'he' ? 'הספרים\nשלנו.' : 'Our\nbooks.'}
      </h1>
    </div>

    <!-- Book grid — 1px gap on #f0ede8 background -->
    <div
      class="max-w-6xl mx-auto"
      style="padding: 1px 48px 48px; background: #f0ede8;"
    >
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
        style="gap: 1px; background: #f0ede8;"
      >
        {BOOKS.map((book, i) => (
          <BookCard book={book} index={i} lang={lang} />
        ))}
      </div>
    </div>
  </main>

  <footer dir={dir} class="border-t border-yuval-border">
    <div
      class="max-w-6xl mx-auto flex justify-between items-center flex-wrap gap-4"
      style="padding: 32px 48px; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: #bbbbbb;"
    >
      <span>Yuval</span>
      <span>Astro · Tailwind · RTL</span>
    </div>
  </footer>
</Layout>
