    color: var(--yuval-galaxy-text, #ececea);
  }
  .series-details-close {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 1.25rem;
    line-height: 1;
    color: var(--yuval-galaxy-text-muted);
    background: var(--yuval-galaxy-surface-muted);
    border: 1px solid var(--yuval-galaxy-border);
    cursor: pointer;
    padding: 0;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }
  .series-details-close:hover,
  .series-details-close:focus-visible {
    color: var(--yuval-galaxy-text);
    background: var(--yuval-galaxy-card-surface-hover);
    border-color: var(--yuval-galaxy-border-strong);
    outline: none;
  }
  .series-details-body {
    overflow-y: auto;
    padding: 1.125rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .series-details-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .series-details-summary {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text, #ececea);
    font-family: 'Spectral', 'Cardo', Georgia, serif;
  }
  .series-details-full {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--yuval-galaxy-text-muted);
