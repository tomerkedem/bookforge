  .series-child-title {
    margin: 0.4375rem 0 0;
    font-size: 0.6875rem;
    line-height: 1.25;
    color: var(--yuval-galaxy-text, #ececea);
    text-align: center;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Series details drawer — same-page modal ───────────────────────
        Right-anchored (logical inline-end) sliding drawer that opens
        when the user clicks "Series details" on a focused capsule.
        Uses a real <aside role="dialog" aria-modal="true"> so screen
        readers and keyboard users get a proper modal surface. The
        overlay is a sibling click-catcher; it does not blur to keep
        the cosmic backdrop visible. */
  .series-details-overlay[hidden],
  .series-details-drawer[hidden] { display: none !important; }
  .series-details-overlay {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 70%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 90;
    animation: series-details-overlay-in 220ms ease-out;
  }
  @keyframes series-details-overlay-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .series-details-drawer {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    inset-inline-start: auto;
    width: min(420px, 100vw);
    max-width: 100vw;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 92%, var(--yuval-galaxy-accent-purple, #a78bfa));
    border-inline-start: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 40%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 20%, transparent) inset,
      -24px 0 60px -10px color-mix(in srgb, #000 75%, transparent);
    color: var(--yuval-galaxy-text, #ececea);
    z-index: 100;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: series-details-drawer-in 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes series-details-drawer-in {
    from { transform: translateX(100%); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }
  [dir="rtl"] .series-details-drawer {
    animation-name: series-details-drawer-in-rtl;
  }
  @keyframes series-details-drawer-in-rtl {
    from { transform: translateX(-100%); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }
  .series-details-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--yuval-galaxy-border, rgba(120, 130, 165, 0.22)) 80%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 12%, transparent) 0%,
        transparent 100%
      );
  }
  .series-details-title {
    margin: 0;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
