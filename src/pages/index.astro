---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical discovery flow between the sticky
 *   global header and the page bottom (no fixed mobile footer yet):
 *     1. Compact hero (LibraryHero)
 *     2. Mobile discovery carousel (MobileGalaxyCarousel)
 *     3. Quick actions (LibraryQuickActions)
 *   ContinueLearningCard and LibraryStatsPanel are hidden on mobile
 *   from inside their own component CSS, so they do not participate in
 *   the mobile flow. (The FloatingSidebar tools rail was removed from
 *   the v1 carousel screen.)
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │ Library  │
 *     │ Learning │  Galaxy stage (core + cards) │ snapshot │
 *     │  card    │  — large negative space      │          │
 *     │          │    below the core            │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *   The two fixed support panels frame the carousel from opposite
 *   edges — ContinueLearningCard on the inline-start side, the
 *   compact LibraryStatsPanel snapshot on the inline-end side.
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import KnowledgeAtlas from '../components/library/KnowledgeAtlas.astro';
import ContinueLearningCard from '../components/library/ContinueLearningCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';
// FloatingSidebar (desktop left tools rail) is intentionally not rendered
// in the v1 carousel screen. The component file is kept for a later
// re-introduction — re-add the import + <FloatingSidebar/> block below.

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, LANGUAGE_CODES, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
} from '../utils/library-catalog';
import { getCourseProgressList } from '../utils/library-adapter';
import { discoverAllBooks } from '../utils/book-discovery';
import {
  isReadableLibraryItem,
  isSafeLibraryHref,
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
} from '../utils/library-display';
import { getEvenOrbitAngle } from '../utils/library/universe-angle-utils';
import {
  getKnowledgeCardAssets,
  getKnowledgeCardAssetsOrPlaceholder,
} from '../utils/library/knowledge-cards';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Primary source = real BookForge content (via library-adapter); falls
// back to mock when output/ is empty (CI / fresh checkout).
const items = getLibraryItems();
const stats = getLibraryStats(items);
// Per-course progress (X of Y lesson summaries available) — empty when
// no real catalog is in play (mock fallback returns []).
const courseProgress = getCourseProgressList();

// Continue ONLY considers readable items so that we never surface the
// synthetic ai-engineering course (no /courses route yet) as a
// clickable-looking suggestion.
const readableItems = items.filter(isReadableLibraryItem);
const continueItem = getContinueReadingItem(readableItems);

// ── Reading-page hrefs for the center-card primary button ────────────────
// LibraryItem.href points at the book/lesson SUMMARY page
// (`/books/{slug}`), which is the right destination for the
// "מה יש בספר?" secondary link. The center-card PRIMARY button needs
// the canonical reading URL instead — `/read/{slug}/{firstChapterId}` —
// so that "Continue · Chapter N" actually opens the reader.
//
// We reuse the existing build-time book discovery (no new route, no
// LibraryItem shape change) and produce a per-slug lookup of the
// first chapter id. The hydrator below upgrades this href in-place
// to the latest-progressed chapter when localStorage has progress
// for the slug. Lessons with non-numeric chapter ids (e.g. 'intro' /
// 'summary') get their first chapter id verbatim — the hydrator's
// numeric loop simply doesn't fire and the SSR href stays correct.
const firstChapterIdBySlug = new Map<string, string>();
for (const b of discoverAllBooks()) {
  if (Array.isArray(b.chapters) && b.chapters.length > 0) {
    firstChapterIdBySlug.set(b.slug, String(b.chapters[0].id));
  }
}

/** `/read/{slug}/{firstChapterId}` for books + lessons; falls back to
 *  `item.href` (the summary page) when no chapter data is available,
 *  so the button always has a real destination. */
const resolveReadingHref = (it: LibraryItem): string => {
  if (it.type !== 'book' && it.type !== 'course_lesson') return it.href;
  const firstCh = firstChapterIdBySlug.get(it.slug);
  return firstCh ? `/read/${it.slug}/${firstCh}` : it.href;
};

// ── Galaxy orbit — every item visible at once ────────────────────────────
// Every readable item sits on its own point along an elliptical orbit
// around the central glowing core. The arrangement is dynamic over
// `readableItems`: 7 items → 7 evenly-spaced angles, 12 items → 12.
// No carousel, no queue, no pager — adding a book to output/ simply
// adds a new station on the orbit.
//
// Books occupy the inline-start arc (visual-left in LTR, visual-right
// in RTL — matches the existing convention via --galaxy-dir).
// Lessons occupy the inline-end arc.
// Series sit at the top (12 o'clock), where the two arcs meet — they
// are organizing entities that bridge books and lessons and don't
// belong on either arc.
// Cards retain their type tint (gold for books, cyan for lessons,
// violet for series) so the groups stay visually distinguishable
// even without columns.
//
// Click-to-center still works: a clicked card flies to the middle and
// the rest dim under the backdrop.
//
// Orbit eligibility — two distinct gates:
//   1. Series capsules MUST have a real per-slug artifact. The series
//      capsule is the parent visual; replacing it with a placeholder
//      would hide the editorial identity of the series itself, so it's
//      gated on `hasOrbitArtifact`. (See `_placeholders/` rationale in
//      `knowledge-cards.ts`.)
//   2. Every other orbit card (books, lessons, generic content) is
//      allowed onto the orbit without a per-slug `front.png`. When the
//      asset is missing the shared placeholder
//      (`_placeholders/book-front.png`) is used — the title, type, and
//      metadata still come from the real LibraryItem, only the image
//      is generic. Visibility / readability rules are unchanged: an
//      item that fails `isReadableLibraryItem` is still excluded, so
//      hidden / archived / unrelated items never become visible just
//      because a placeholder exists.
// Mobile views (e.g. MobileGalaxyCarousel) keep their unfiltered
// `readableItems` source and are not affected by these filters.
const hasOrbitArtifact = (slug: string) => getKnowledgeCardAssets(slug) !== undefined;

// Visual-only orbit visibility predicate. Distinct from
// `isReadableLibraryItem` (which gates clickability for the rest of
// the page). Series bypass the readable-href requirement here;
// books/lessons still need it so links never 404.
const isOrbitVisible = (it: LibraryItem): boolean => {
  if (it.type === 'series') {
    // Series capsules require the real folder asset, never the
    // placeholder. A series with no asset is suppressed from the orbit.
    return hasOrbitArtifact(it.slug);
  }
  // Non-series items rely on the readability gate; their image will
  // come from `getKnowledgeCardAssetsOrPlaceholder` below, so a missing
  // per-slug front.png no longer disqualifies them from the orbit.
  return isReadableLibraryItem(it);
};
const orbitItemsSource = items.filter(isOrbitVisible);

/**
 * Resolve the artifact bundle to render on the orbit for `it`. Series
 * capsules MUST keep using their real folder asset — the placeholder
 * is never substituted for a series. Every other content type uses
 * the placeholder helper so a missing per-slug front.png falls back to
 * `_placeholders/book-front.png` instead of producing a no-art card.
 */
const resolveOrbitArtifact = (it: LibraryItem) =>
  it.type === 'series'
    ? getKnowledgeCardAssets(it.slug)
    : getKnowledgeCardAssetsOrPlaceholder(it.slug);

// Build-time match report — printed alongside the discovery report
// in `knowledge-cards.ts` so it's clear which catalog slugs landed
// on the orbit, which got the shared placeholder, and which were
// filtered out (currently: series capsules without a real folder).
console.log(
  `[knowledge-cards] orbit match report: ${orbitItemsSource.length} of ${readableItems.length} items on the orbit.`,
);
for (const it of readableItems) {
  const real = hasOrbitArtifact(it.slug);
  const onOrbit = isOrbitVisible(it);
  let status: string;
  if (real) status = 'MATCH       ';
  else if (it.type === 'series') status = 'no-match    ';
  else if (onOrbit) status = 'PLACEHOLDER ';
  else status = 'no-match    ';
  console.log(`[knowledge-cards]   [${status}] slug="${it.slug}" type=${it.type}`);
}
// One unified array fed to a single distribution pass. Item TYPE drives
// CSS only (badge colour, fallback artwork, click affordance) — never
// orbit position. Books, lessons, series and any future kinds share one
// global index space, so adding a single new item shifts everyone by a
// small even fraction instead of piling onto a per-type cluster.
//
// DOM order is preserved exactly as the catalog produced (books, then
// lessons, then series) so the natural source order remains stable
// across runs. Layout is driven by `--orbit-angle`, not by DOM order;
// the hydrator reapplies the same `getEvenOrbitAngle` over the live
// post-filter set so SSR and client always agree.
type OrbitItem = {
  item: typeof readableItems[number];
  angle: number;
  kind: 'book' | 'lesson' | 'course';
};
// `data-kind` is the orbit-render category, deliberately decoupled from
// LibraryItem.type. Only three kinds reach the orbit today: real books
// (`book`), course lessons (`course_lesson` → `lesson`), and the single
// `ai-engineering-series` overlay item. That overlay is typed `series`
// in the catalog, but on the orbit it IS the AI Engineering Course card
// — its real `course`-type sibling has no readable route yet — so it
// surfaces as a `course` station. A course is a top-level content type;
// rendering it as `data-kind="course"` lets the Knowledge Core "Courses"
// filter focus it directly.
const orbitKindOf = (it: typeof readableItems[number]): OrbitItem['kind'] =>
  it.type === 'book' ? 'book'
  : it.type === 'course_lesson' ? 'lesson'
  : 'course';
const orbitItems: OrbitItem[] = orbitItemsSource.map((item, i) => ({
  item,
  angle: getEvenOrbitAngle(i, orbitItemsSource.length),
  kind: orbitKindOf(item),
}));
// Rotate-orbit controls only make sense with at least 2 stations to
// rotate between. The shared step `360°/N` is computed in JS at click
// time from the live card count; CSS just animates --orbit-rotation.
const showOrbitControls = orbitItems.length > 1;

// ── Knowledge Atlas data ──────────────────────────────────────────────────
// The "all items" overlay browses the SAME set the orbit renders, so
// selecting an Atlas item can always focus a real carousel station by
// slug. Localized here, where the i18n helpers + `language` live.
const atlasItems = orbitItems.map(({ item, kind }) => ({
  slug: item.slug,
  kind,
  title: getItemTitle(item, language),
  subtitle: getItemSummary(item, language),
  typeLabel: t(getItemTypeLabelKey(item.type), language),
}));

// ── ContinueLearningCard data ─────────────────────────────────────────────
// Real values are derived from `continueItem` + `courseProgress`. Two modes:
//   - lesson mode: course title at top, "Lesson N" line, then the lesson
//     subtitle. Reached when continueItem is a course_lesson whose
//     courseSlug matches a known course in courseProgress.
//   - book mode: book title at top, blank metaLine1, subtitle as metaLine2.
// When continueItem is undefined (mock fallback), no props are passed and
// the component's own placeholder defaults render.
const isLesson =
  continueItem?.type === 'course_lesson' && Boolean(continueItem?.courseSlug);
const matchingCourse = isLesson
  ? courseProgress.find((c) => c.slug === continueItem!.courseSlug)
  : undefined;

let courseTitleForCard: string | undefined;
let metaLine1ForCard: string | undefined;
let metaLine2ForCard: string | undefined;

if (isLesson && matchingCourse && continueItem?.orderInSeries) {
  courseTitleForCard =
    matchingCourse.titles[language]
    ?? matchingCourse.titles.en
    ?? matchingCourse.titles.he
    ?? matchingCourse.slug;
  metaLine1ForCard = t('courses.lessonNumber', language, { n: continueItem.orderInSeries });
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
} else if (continueItem) {
  courseTitleForCard =
    continueItem.titles?.[language]
    ?? continueItem.titles?.en
    ?? continueItem.titles?.he;
  metaLine1ForCard = '';
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
}

---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={LANGUAGE_CODES}
  allowClientLanguageOverride={true}
  useGlobeLanguageSelector={true}
>
  <div
    class="library-dark-showcase library-root"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    style={`--page-direction: ${isRtl ? 'rtl' : 'ltr'};`}
  >

    {/* Cosmic scene background — full-viewport, behind every UI layer.
        Night (dark mode) renders the galaxy PNG. Day (light mode)
        renders the AI Researcher Workspace photographic scene; the
        <picture> swaps to the phone-cropped variant at <768px. The
        two images share the same absolute box; opacity rules in the
        stylesheet decide which one is visible per theme. */}
    <div class="knowledge-scene-background" aria-hidden="true">
      {/* Night scene — dark-mode background. */}
      <img
        class="knowledge-scene-img knowledge-scene-img--night"
        src="/assets/library/galaxy-stage-core-medium.png"
        alt=""
        decoding="async"
      />

      {/* Day scene — light-mode background. Mobile + desktop variants
          swapped via <picture media>; visibility toggled by the
          .knowledge-scene-img--day opacity rule. */}
      <picture>
        <source
          media="(min-width: 768px)"
          srcset="/assets/library/day/ai_researcher_workspace_day_bg.webp"
        />
        <img
          class="knowledge-scene-img knowledge-scene-img--day"
          src="/assets/library/day/ai_researcher_workspace_day_bg_mobile.webp"
          alt=""
          decoding="async"
        />
      </picture>

      <div class="knowledge-scene-overlay"></div>
    </div>

    {/* Decorative ambient backdrop — starfield on top of the cosmic
        scene background. Stars stay crisp because they're a CSS
        gradient pattern that doesn't scale with the bg image. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-starfield"></div>
    </div>

    <div class="library-body">

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        {/* MobileGalaxyCarousel was removed: the galaxy orbit below now
            renders on mobile too, matching CLAUDE.md's "same composition,
            scaled down" rule. A separate horizontal rail above the orbit
            duplicated the same items without series functionality, so
            removing it gives mobile feature parity with desktop. */}

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div
            class="library-galaxy"
            data-galaxy-stage
            data-series-badge={t('library.itemType.series', language)}
            data-series-items-label={t('library.series.itemsLabel', language)}
            data-series-available-label={t('library.series.availableLabel', language)}
            data-other-knowledge-label={t('library.series.otherKnowledge', language)}
            data-items-short-label={t('library.series.itemsShort', language)}
            data-close-label={t('library.galaxy.closeItem', language)}
            data-series-actions-show-items={t('library.series.actions.showItems', language)}
            data-series-actions-hide-items={t('library.series.actions.hideItems', language)}
            data-series-actions-details={t('library.series.actions.details', language)}
            data-series-details-title={t('library.series.details.title', language)}
            data-series-details-close={t('library.series.details.close', language)}
            data-series-details-short-description={t('library.series.details.shortDescription', language)}
            data-series-details-full-description={t('library.series.details.fullDescription', language)}
            data-series-details-assigned-items={t('library.series.details.assignedItems', language)}
            data-series-details-planned-items={t('library.series.details.plannedItems', language)}
            data-series-details-status={t('library.series.details.status', language)}
            data-series-details-asset-folder={t('library.series.details.assetFolder', language)}
            data-series-details-visible-in-universe={t('library.series.details.visibleInUniverse', language)}
            data-series-details-visible-yes={t('library.series.details.visibleYes', language)}
            data-series-details-visible-no={t('library.series.details.visibleNo', language)}
            data-series-details-no-description={t('library.series.details.noDescription', language)}
            data-series-details-no-assigned-items={t('library.series.details.noAssignedItems', language)}
            data-series-children-empty={t('library.series.children.empty', language)}
            data-series-children-region={t('library.series.children.region', language)}
            data-series-children-placeholder-type={t('library.series.children.placeholderType', language)}
            data-status-active={t('library.status.ready', language)}
            data-status-draft={t('library.status.new', language)}
            data-status-hidden={t('library.status.archived', language)}
            style={`--galaxy-dir: ${isRtl ? -1 : 1};`}
          >

            {/* The galaxy PNG used to sit centered here as the stage's
                visual core. It now lives at the page root as a
                full-viewport scene background (`.knowledge-scene-background`
                above), so the orbit stage holds only the floating
                cards + backdrop. */}

            {/* Knowledge Observatory — light-mode-only decorative rings.
                A passive SVG layer (concentric observatory ELLIPSES,
                tick marks and node dots) that sits BEHIND every orbit
                card and shares the orbit's coordinate space, so its
                center lands exactly on the carousel orbit center at
                every breakpoint. The rings are horizontal ellipses
                (ry = 0.52 x rx) so they read as orbital tracks seen in
                a more cinematic, low-angle perspective — echoing the
                carousel's elliptical orbit
                rather than a flat centered-circle diagram.
                pointer-events:none — it never affects card hit-testing,
                focus or routing. Hidden in dark mode (CSS display:none),
                so the dark showcase is byte-for-byte unchanged. Styling
                lives in `.galaxy-observatory` / `.obs-*` rules below. */}
            <div class="galaxy-observatory" aria-hidden="true">
              <svg
                class="obs-svg"
                viewBox="0 0 600 600"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                focusable="false"
                aria-hidden="true"
              >
                <!-- Solid hairline concentric ellipses (ry = 0.52 x rx) -->
                <ellipse class="obs-ring" cx="300" cy="300" rx="82" ry="42.64" />
                <ellipse class="obs-ring" cx="300" cy="300" rx="158" ry="82.16" />
                <ellipse class="obs-ring obs-ring--outer" cx="300" cy="300" rx="292" ry="151.84" />
                <!-- Accent dotted ellipse + cardinal node dots (kept on mobile) -->
                <ellipse class="obs-ring--accent" cx="300" cy="300" rx="234" ry="121.68" />
                <circle class="obs-dot" cx="300" cy="178.32" r="4" />
                <circle class="obs-dot" cx="300" cy="421.68" r="4" />
                <circle class="obs-dot" cx="534" cy="300" r="4" />
                <circle class="obs-dot" cx="66" cy="300" r="4" />
                <!-- Fine detail — hidden on mobile to keep rings subtle -->
                <g class="obs-detail">
                  <ellipse class="obs-ring--fine" cx="300" cy="300" rx="200" ry="104" />
                  <line class="obs-cross" x1="300" y1="217.84" x2="300" y2="178.32" />
                  <line class="obs-cross" x1="300" y1="382.16" x2="300" y2="421.68" />
                  <line class="obs-cross" x1="458" y1="300" x2="534" y2="300" />
                  <line class="obs-cross" x1="142" y1="300" x2="66" y2="300" />
                  <circle class="obs-dot--minor" cx="411.7" cy="241.9" r="2.6" />
                  <circle class="obs-dot--minor" cx="188.3" cy="241.9" r="2.6" />
                  <circle class="obs-dot--minor" cx="411.7" cy="358.1" r="2.6" />
                  <circle class="obs-dot--minor" cx="188.3" cy="358.1" r="2.6" />
                </g>
              </svg>
            </div>

            {/* Backdrop — appears only when a card is focused into the
                center. Click anywhere on it closes the focus state. */}
            <div class="galaxy-backdrop" data-galaxy-backdrop aria-hidden="true"></div>

            {/* ── Core Search Mode (mobile-only) ──────────────────────
                Tap-the-core search affordance. SSR ships the chrome
                unconditionally; CSS hides every node on desktop
                (≥1024px) so the existing dashboard composition is
                untouched. The runtime module
                (`src/utils/library/core-search.ts`) wires tap,
                input, clear, close, Esc, and swipe-down close — and
                tags matching orbit cards via
                `data-core-search-match="yes"|"no"` so the orbit
                itself becomes the result surface.

                Trigger: an honest <button> so keyboard focus +
                screen-reader semantics work without ARIA gymnastics.
                The hint capsule appears once on first visit; the
                panel expands from the trigger's centre when open. */}
            <button
              type="button"
              class="core-search-trigger"
              data-core-search-trigger
              aria-expanded="false"
              aria-controls="core-search-panel"
              data-i18n-aria-label="library.coreSearch.openAria"
              aria-label={t('library.coreSearch.openAria', language)}
            >
              <span class="core-search-trigger-glow" aria-hidden="true"></span>
              <span class="core-search-trigger-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
              </span>
            </button>

            <div
              class="core-search-hint"
              data-core-search-hint
              data-core-search-hint-state="hidden"
              aria-hidden="true"
            >
              <span data-i18n="library.coreSearch.hint">{t('library.coreSearch.hint', language)}</span>
            </div>

            <div
              id="core-search-panel"
              class="core-search-panel"
              data-core-search-panel
              role="search"
              aria-label={t('library.coreSearch.openAria', language)}
            >
              <span class="core-search-panel-glow" aria-hidden="true"></span>
              <span class="core-search-panel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
              </span>
              <input
                type="search"
                class="core-search-input"
                data-core-search-input
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
                enterkeyhint="search"
                data-i18n-placeholder="library.coreSearch.placeholder"
                placeholder={t('library.coreSearch.placeholder', language)}
                data-i18n-aria-label="library.coreSearch.placeholder"
                aria-label={t('library.coreSearch.placeholder', language)}
              />
              <button
                type="button"
                class="core-search-clear"
                data-core-search-clear
                hidden
                data-i18n-aria-label="library.coreSearch.clearAria"
                aria-label={t('library.coreSearch.clearAria', language)}
              >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18"></path>
                </svg>
              </button>
              <button
                type="button"
                class="core-search-close"
                data-core-search-close
                data-i18n-aria-label="library.coreSearch.closeAria"
                aria-label={t('library.coreSearch.closeAria', language)}
              >
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18"></path>
                </svg>
              </button>
              <p
                class="core-search-no-matches"
                data-i18n="library.coreSearch.noMatches"
                aria-live="polite"
              >{t('library.coreSearch.noMatches', language)}</p>
            </div>


            {/* Orbit cards — every readable item gets one station on
                the elliptical orbit around the central core. Position
                is set per-card via inline `--orbit-angle`; CSS handles
                the rest with cos()/sin(). No queue, no carousel —
                everything is on screen at once. */}
            {orbitItems.map(({ item, angle, kind }) => (
              <div
                class="galaxy-card"
                data-galaxy-card
                data-kind={kind}
                data-slug={item.slug}
                data-series-id={item.seriesId}
                data-series-name={item.seriesName}
                style={`--orbit-angle: ${angle}deg;`}
              >
                <LibraryCard
                  item={item}
                  language={language}
                  variant="orbit"
                  artifact={resolveOrbitArtifact(item)}
                  suppressOrbitCaption={isSafeLibraryHref(item.href)}
                />
                {/* Reading-entry overlay (image-based, in-card).
                    Premium glass-style asset (PNG, no baked text) sits
                    inside the centered card. All visible text is live,
                    localized HTML rendered on top — never embedded in
                    the image. The <a> preserves native link behavior
                    (Ctrl/Cmd-click, middle-click, right-click); plain
                    left-click and Enter are intercepted by the launch
                    handler in `universe-layout.ts` via the
                    `data-reading-entry` attribute. */}
                {isSafeLibraryHref(item.href) && (
                  <div class="reading-entry-overlay">
                    {/* Main click target. Covers the panel at inset:0 so
                        clicks anywhere on the glass surface (except the
                        summary pill) continue reading. Sibling of
                        `.reading-entry-text` — not an ancestor — so the
                        in-panel pill can stay an independent <a> without
                        nesting interactive elements. */}
                    <a
                      class="reading-entry-main"
                      href={resolveReadingHref(item)}
                      data-reading-entry
                      data-reading-entry-href={resolveReadingHref(item)}
                      data-reading-entry-slug={item.slug}
                      data-aria-template={t('library.readingEntry.continueChapterAria', language, { n: '__N__' })}
                      aria-label={
                        typeof item.chapterCount === 'number' && item.chapterCount > 0
                          ? t('library.readingEntry.continueChapterAria', language, { n: 1 })
                          : t('library.readingEntry.ariaLabel', language)
                      }
                    ></a>
                    {/* The reading-entry-card1.png artifact is the visual
                        base of the panel — painted via `background-image`
                        on this layer so the icon at the top center stays
                        baked into the asset. Live i18n text (title +
                        subtitle + summary pill + meta row) is rendered as
                        real HTML over the image so it stays crisp,
                        translatable and accessible. */}
                    <span class="reading-entry-asset" aria-hidden="true"></span>
                    <div class="reading-entry-text">
                      <span
                        class="reading-entry-title"
                        data-cc-primary-label
                        data-continue-template={t('library.readingEntry.continueReadingShort', language)}
