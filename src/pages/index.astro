      appearance: none;
    }
    .core-search-clear,
    .core-search-close {
      position: relative;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      padding: 0;
      border-radius: 50%;
      border: 1px solid
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 30%, transparent);
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 50%, transparent);
      color: var(--yuval-galaxy-text-soft, #b9c0d9);
      cursor: pointer;
      transition:
        color 160ms ease,
        background-color 160ms ease,
        border-color 160ms ease;
      -webkit-tap-highlight-color: transparent;
    }
    .core-search-clear:hover,
    .core-search-clear:focus-visible,
    .core-search-close:hover,
    .core-search-close:focus-visible {
      color: var(--yuval-galaxy-text, #ececea);
      background: color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent);
