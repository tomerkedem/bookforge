---
/**
 * /library — Living Library, dual layout.
 *
 *   MOBILE (<1024px) — vertical discovery flow between the sticky
 *   global header and the page bottom (no fixed mobile footer yet):
 *     1. Compact hero (LibraryHero)
 *     2. Mobile discovery carousel (MobileGalaxyCarousel)
 *     3. Quick actions (LibraryQuickActions)
 *   ContinueLearningCard and LibraryStatsPanel are hidden on mobile
 *   from inside their own component CSS, so they do not participate in
 *   the mobile flow. (The FloatingSidebar tools rail was removed from
 *   the v1 carousel screen.)
 *
 *   DESKTOP (≥1024px) — single immersive dashboard viewport.
 *     ┌──────────┬──────────────────────────────┬──────────┐
 *     │ Continue │  Hero (floats over galaxy)   │ Library  │
 *     │ Learning │  Galaxy stage (core + cards) │ snapshot │
 *     │  card    │  — large negative space      │          │
 *     │          │    below the core            │          │
 *     └──────────┴──────────────────────────────┴──────────┘
 *   The two fixed support panels frame the carousel from opposite
 *   edges — ContinueLearningCard on the inline-start side, the
 *   compact LibraryStatsPanel snapshot on the inline-end side.
 *
 *   Composition fits inside ~100dvh after the global header — no long
 *   stacked page on desktop.
 *
 * Same components, same data, same i18n. Only CSS varies by breakpoint.
 *
 * Featured items are filtered OUT of recent items so cards never appear
 * twice on a single screen.
 */

import LibraryLayout from '../layouts/LibraryLayout.astro';
import LibraryHero from '../components/library/LibraryHero.astro';
import LibraryStatsPanel from '../components/library/LibraryStatsPanel.astro';
import KnowledgeAtlas from '../components/library/KnowledgeAtlas.astro';
import ContinueLearningCard from '../components/library/ContinueLearningCard.astro';
import LibraryCard from '../components/library/LibraryCard.astro';
import LibraryQuickActions from '../components/library/LibraryQuickActions.astro';
// FloatingSidebar (desktop left tools rail) is intentionally not rendered
// in the v1 carousel screen. The component file is kept for a later
// re-introduction — re-add the import + <FloatingSidebar/> block below.

import type { Language } from '../types/index';
import type { LibraryItem } from '../types/library';
import { DEFAULT_LANGUAGE, LANGUAGE_CODES, getLanguageDirection, isValidLanguage } from '../utils/language';
import { t } from '../i18n';
import {
  getLibraryItems,
  getLibraryStats,
  getContinueReadingItem,
} from '../utils/library-catalog';
import { getCourseProgressList } from '../utils/library-adapter';
import { discoverAllBooks } from '../utils/book-discovery';
import {
  isReadableLibraryItem,
  isSafeLibraryHref,
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
} from '../utils/library-display';
import { getEvenOrbitAngle } from '../utils/library/universe-angle-utils';
import {
  getKnowledgeCardAssets,
  getKnowledgeCardAssetsOrPlaceholder,
} from '../utils/library/knowledge-cards';

// ── Language ──────────────────────────────────────────────────────────────
const { language: propLanguage } = Astro.props as { language?: Language };

const urlLang = Astro.url.searchParams.get('lang')?.trim().toLowerCase();
const requestedLanguage =
  (urlLang && isValidLanguage(urlLang))
    ? urlLang
    : (propLanguage && isValidLanguage(propLanguage) ? propLanguage : DEFAULT_LANGUAGE);
const language = requestedLanguage as Language;
const isRtl = getLanguageDirection(language) === 'rtl';

// ── Data ──────────────────────────────────────────────────────────────────
// Primary source = real BookForge content (via library-adapter); falls
// back to mock when output/ is empty (CI / fresh checkout).
const items = getLibraryItems();
const stats = getLibraryStats(items);
// Per-course progress (X of Y lesson summaries available) — empty when
// no real catalog is in play (mock fallback returns []).
const courseProgress = getCourseProgressList();

// Continue ONLY considers readable items so that we never surface the
// synthetic ai-engineering course (no /courses route yet) as a
// clickable-looking suggestion.
const readableItems = items.filter(isReadableLibraryItem);
const continueItem = getContinueReadingItem(readableItems);

// ── Reading-page hrefs for the center-card primary button ────────────────
// LibraryItem.href points at the book/lesson SUMMARY page
// (`/books/{slug}`), which is the right destination for the
// "מה יש בספר?" secondary link. The center-card PRIMARY button needs
// the canonical reading URL instead — `/read/{slug}/{firstChapterId}` —
// so that "Continue · Chapter N" actually opens the reader.
//
// We reuse the existing build-time book discovery (no new route, no
// LibraryItem shape change) and produce a per-slug lookup of the
// first chapter id. The hydrator below upgrades this href in-place
// to the latest-progressed chapter when localStorage has progress
// for the slug. Lessons with non-numeric chapter ids (e.g. 'intro' /
// 'summary') get their first chapter id verbatim — the hydrator's
// numeric loop simply doesn't fire and the SSR href stays correct.
const firstChapterIdBySlug = new Map<string, string>();
for (const b of discoverAllBooks()) {
  if (Array.isArray(b.chapters) && b.chapters.length > 0) {
    firstChapterIdBySlug.set(b.slug, String(b.chapters[0].id));
  }
}

/** `/read/{slug}/{firstChapterId}` for books + lessons; falls back to
 *  `item.href` (the summary page) when no chapter data is available,
 *  so the button always has a real destination. */
const resolveReadingHref = (it: LibraryItem): string => {
  if (it.type !== 'book' && it.type !== 'course_lesson') return it.href;
  const firstCh = firstChapterIdBySlug.get(it.slug);
  return firstCh ? `/read/${it.slug}/${firstCh}` : it.href;
};

// ── Galaxy orbit — every item visible at once ────────────────────────────
// Every readable item sits on its own point along an elliptical orbit
// around the central glowing core. The arrangement is dynamic over
// `readableItems`: 7 items → 7 evenly-spaced angles, 12 items → 12.
// No carousel, no queue, no pager — adding a book to output/ simply
// adds a new station on the orbit.
//
// Books occupy the inline-start arc (visual-left in LTR, visual-right
// in RTL — matches the existing convention via --galaxy-dir).
// Lessons occupy the inline-end arc.
// Series sit at the top (12 o'clock), where the two arcs meet — they
// are organizing entities that bridge books and lessons and don't
// belong on either arc.
// Cards retain their type tint (gold for books, cyan for lessons,
// violet for series) so the groups stay visually distinguishable
// even without columns.
//
// Click-to-center still works: a clicked card flies to the middle and
// the rest dim under the backdrop.
//
// Orbit eligibility — two distinct gates:
//   1. Series capsules MUST have a real per-slug artifact. The series
//      capsule is the parent visual; replacing it with a placeholder
//      would hide the editorial identity of the series itself, so it's
//      gated on `hasOrbitArtifact`. (See `_placeholders/` rationale in
//      `knowledge-cards.ts`.)
//   2. Every other orbit card (books, lessons, generic content) is
//      allowed onto the orbit without a per-slug `front.png`. When the
//      asset is missing the shared placeholder
//      (`_placeholders/book-front.png`) is used — the title, type, and
//      metadata still come from the real LibraryItem, only the image
//      is generic. Visibility / readability rules are unchanged: an
//      item that fails `isReadableLibraryItem` is still excluded, so
//      hidden / archived / unrelated items never become visible just
//      because a placeholder exists.
// Mobile views (e.g. MobileGalaxyCarousel) keep their unfiltered
// `readableItems` source and are not affected by these filters.
const hasOrbitArtifact = (slug: string) => getKnowledgeCardAssets(slug) !== undefined;

// Visual-only orbit visibility predicate. Distinct from
// `isReadableLibraryItem` (which gates clickability for the rest of
// the page). Series bypass the readable-href requirement here;
// books/lessons still need it so links never 404.
const isOrbitVisible = (it: LibraryItem): boolean => {
  if (it.type === 'series') {
    // Series capsules require the real folder asset, never the
    // placeholder. A series with no asset is suppressed from the orbit.
    return hasOrbitArtifact(it.slug);
  }
  // Non-series items rely on the readability gate; their image will
  // come from `getKnowledgeCardAssetsOrPlaceholder` below, so a missing
  // per-slug front.png no longer disqualifies them from the orbit.
  return isReadableLibraryItem(it);
};
const orbitItemsSource = items.filter(isOrbitVisible);

/**
 * Resolve the artifact bundle to render on the orbit for `it`. Series
 * capsules MUST keep using their real folder asset — the placeholder
 * is never substituted for a series. Every other content type uses
 * the placeholder helper so a missing per-slug front.png falls back to
 * `_placeholders/book-front.png` instead of producing a no-art card.
 */
const resolveOrbitArtifact = (it: LibraryItem) =>
  it.type === 'series'
    ? getKnowledgeCardAssets(it.slug)
    : getKnowledgeCardAssetsOrPlaceholder(it.slug);

// Build-time match report — printed alongside the discovery report
// in `knowledge-cards.ts` so it's clear which catalog slugs landed
// on the orbit, which got the shared placeholder, and which were
// filtered out (currently: series capsules without a real folder).
console.log(
  `[knowledge-cards] orbit match report: ${orbitItemsSource.length} of ${readableItems.length} items on the orbit.`,
);
for (const it of readableItems) {
  const real = hasOrbitArtifact(it.slug);
  const onOrbit = isOrbitVisible(it);
  let status: string;
  if (real) status = 'MATCH       ';
  else if (it.type === 'series') status = 'no-match    ';
  else if (onOrbit) status = 'PLACEHOLDER ';
  else status = 'no-match    ';
  console.log(`[knowledge-cards]   [${status}] slug="${it.slug}" type=${it.type}`);
}
// One unified array fed to a single distribution pass. Item TYPE drives
// CSS only (badge colour, fallback artwork, click affordance) — never
// orbit position. Books, lessons, series and any future kinds share one
// global index space, so adding a single new item shifts everyone by a
// small even fraction instead of piling onto a per-type cluster.
//
// DOM order is preserved exactly as the catalog produced (books, then
// lessons, then series) so the natural source order remains stable
// across runs. Layout is driven by `--orbit-angle`, not by DOM order;
// the hydrator reapplies the same `getEvenOrbitAngle` over the live
// post-filter set so SSR and client always agree.
type OrbitItem = {
  item: typeof readableItems[number];
  angle: number;
  kind: 'book' | 'lesson' | 'course';
};
// `data-kind` is the orbit-render category, deliberately decoupled from
// LibraryItem.type. Only three kinds reach the orbit today: real books
// (`book`), course lessons (`course_lesson` → `lesson`), and the single
// `ai-engineering-series` overlay item. That overlay is typed `series`
// in the catalog, but on the orbit it IS the AI Engineering Course card
// — its real `course`-type sibling has no readable route yet — so it
// surfaces as a `course` station. A course is a top-level content type;
// rendering it as `data-kind="course"` lets the Knowledge Core "Courses"
// filter focus it directly.
const orbitKindOf = (it: typeof readableItems[number]): OrbitItem['kind'] =>
  it.type === 'book' ? 'book'
  : it.type === 'course_lesson' ? 'lesson'
  : 'course';
const orbitItems: OrbitItem[] = orbitItemsSource.map((item, i) => ({
  item,
  angle: getEvenOrbitAngle(i, orbitItemsSource.length),
  kind: orbitKindOf(item),
}));
// Rotate-orbit controls only make sense with at least 2 stations to
// rotate between. The shared step `360°/N` is computed in JS at click
// time from the live card count; CSS just animates --orbit-rotation.
const showOrbitControls = orbitItems.length > 1;

// ── Knowledge Atlas data ──────────────────────────────────────────────────
// The "all items" overlay browses the SAME set the orbit renders, so
// selecting an Atlas item can always focus a real carousel station by
// slug. Localized here, where the i18n helpers + `language` live.
const atlasItems = orbitItems.map(({ item, kind }) => ({
  slug: item.slug,
  kind,
  title: getItemTitle(item, language),
  subtitle: getItemSummary(item, language),
  typeLabel: t(getItemTypeLabelKey(item.type), language),
}));

// ── ContinueLearningCard data ─────────────────────────────────────────────
// Real values are derived from `continueItem` + `courseProgress`. Two modes:
//   - lesson mode: course title at top, "Lesson N" line, then the lesson
//     subtitle. Reached when continueItem is a course_lesson whose
//     courseSlug matches a known course in courseProgress.
//   - book mode: book title at top, blank metaLine1, subtitle as metaLine2.
// When continueItem is undefined (mock fallback), no props are passed and
// the component's own placeholder defaults render.
const isLesson =
  continueItem?.type === 'course_lesson' && Boolean(continueItem?.courseSlug);
const matchingCourse = isLesson
  ? courseProgress.find((c) => c.slug === continueItem!.courseSlug)
  : undefined;

let courseTitleForCard: string | undefined;
let metaLine1ForCard: string | undefined;
let metaLine2ForCard: string | undefined;

if (isLesson && matchingCourse && continueItem?.orderInSeries) {
  courseTitleForCard =
    matchingCourse.titles[language]
    ?? matchingCourse.titles.en
    ?? matchingCourse.titles.he
    ?? matchingCourse.slug;
  metaLine1ForCard = t('courses.lessonNumber', language, { n: continueItem.orderInSeries });
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
} else if (continueItem) {
  courseTitleForCard =
    continueItem.titles?.[language]
    ?? continueItem.titles?.en
    ?? continueItem.titles?.he;
  metaLine1ForCard = '';
  metaLine2ForCard =
    continueItem.subtitles?.[language]
    ?? continueItem.subtitles?.en
    ?? continueItem.subtitles?.he
    ?? '';
}

---

<LibraryLayout
  title={t('library.galaxy.title', language)}
  description={t('library.galaxy.subtitle', language)}
  language={language}
  availableLanguages={LANGUAGE_CODES}
  allowClientLanguageOverride={true}
  useGlobeLanguageSelector={true}
>
  <div
    class="library-dark-showcase library-root"
    lang={language}
    dir={isRtl ? 'rtl' : 'ltr'}
    style={`--page-direction: ${isRtl ? 'rtl' : 'ltr'};`}
  >

    {/* Cosmic scene background — full-viewport, behind every UI layer.
        Night (dark mode) renders the galaxy PNG. Day (light mode)
        renders the AI Researcher Workspace photographic scene; the
        <picture> swaps to the phone-cropped variant at <768px. The
        two images share the same absolute box; opacity rules in the
        stylesheet decide which one is visible per theme. */}
    <div class="knowledge-scene-background" aria-hidden="true">
      {/* Night scene — dark-mode background. */}
      <img
        class="knowledge-scene-img knowledge-scene-img--night"
        src="/assets/library/galaxy-stage-core-medium.png"
        alt=""
        decoding="async"
      />

      {/* Day scene — light-mode background. Mobile + desktop variants
          swapped via <picture media>; visibility toggled by the
          .knowledge-scene-img--day opacity rule. */}
      <picture>
        <source
          media="(min-width: 768px)"
          srcset="/assets/library/day/ai_researcher_workspace_day_bg.webp"
        />
        <img
          class="knowledge-scene-img knowledge-scene-img--day"
          src="/assets/library/day/ai_researcher_workspace_day_bg_mobile.webp"
          alt=""
          decoding="async"
        />
      </picture>

      <div class="knowledge-scene-overlay"></div>
    </div>

    {/* Decorative ambient backdrop — starfield on top of the cosmic
        scene background. Stars stay crisp because they're a CSS
        gradient pattern that doesn't scale with the bg image. */}
    <div class="library-ambient" aria-hidden="true">
      <div class="library-starfield"></div>
    </div>

    <div class="library-body">

      {/* ── Center stage: hero floats over galaxy ── */}
      <main class="lb-area-stage">

        <div class="lb-area-hero">
          <LibraryHero language={language} />
        </div>

        {/* MobileGalaxyCarousel was removed: the galaxy orbit below now
            renders on mobile too, matching CLAUDE.md's "same composition,
            scaled down" rule. A separate horizontal rail above the orbit
            duplicated the same items without series functionality, so
            removing it gives mobile feature parity with desktop. */}

        <section class="lb-area-featured" aria-label={t('library.galaxy.welcome', language)}>
          <div
            class="library-galaxy"
            data-galaxy-stage
            data-series-badge={t('library.itemType.series', language)}
            data-series-items-label={t('library.series.itemsLabel', language)}
            data-series-available-label={t('library.series.availableLabel', language)}
            data-other-knowledge-label={t('library.series.otherKnowledge', language)}
            data-items-short-label={t('library.series.itemsShort', language)}
            data-close-label={t('library.galaxy.closeItem', language)}
            data-series-actions-show-items={t('library.series.actions.showItems', language)}
            data-series-actions-hide-items={t('library.series.actions.hideItems', language)}
            data-series-actions-details={t('library.series.actions.details', language)}
            data-series-details-title={t('library.series.details.title', language)}
            data-series-details-close={t('library.series.details.close', language)}
            data-series-details-short-description={t('library.series.details.shortDescription', language)}
            data-series-details-full-description={t('library.series.details.fullDescription', language)}
            data-series-details-assigned-items={t('library.series.details.assignedItems', language)}
            data-series-details-planned-items={t('library.series.details.plannedItems', language)}
            data-series-details-status={t('library.series.details.status', language)}
            data-series-details-asset-folder={t('library.series.details.assetFolder', language)}
            data-series-details-visible-in-universe={t('library.series.details.visibleInUniverse', language)}
            data-series-details-visible-yes={t('library.series.details.visibleYes', language)}
            data-series-details-visible-no={t('library.series.details.visibleNo', language)}
            data-series-details-no-description={t('library.series.details.noDescription', language)}
            data-series-details-no-assigned-items={t('library.series.details.noAssignedItems', language)}
            data-series-children-empty={t('library.series.children.empty', language)}
            data-series-children-region={t('library.series.children.region', language)}
            data-series-children-placeholder-type={t('library.series.children.placeholderType', language)}
            data-status-active={t('library.status.ready', language)}
            data-status-draft={t('library.status.new', language)}
            data-status-hidden={t('library.status.archived', language)}
            style={`--galaxy-dir: ${isRtl ? -1 : 1};`}
          >

            {/* The galaxy PNG used to sit centered here as the stage's
                visual core. It now lives at the page root as a
                full-viewport scene background (`.knowledge-scene-background`
                above), so the orbit stage holds only the floating
                cards + backdrop. */}

            {/* Knowledge Observatory — light-mode-only decorative rings.
                A passive SVG layer (concentric observatory ELLIPSES,
                tick marks and node dots) that sits BEHIND every orbit
                card and shares the orbit's coordinate space, so its
                center lands exactly on the carousel orbit center at
                every breakpoint. The rings are horizontal ellipses
                (ry = 0.52 x rx) so they read as orbital tracks seen in
                a more cinematic, low-angle perspective — echoing the
                carousel's elliptical orbit
                rather than a flat centered-circle diagram.
                pointer-events:none — it never affects card hit-testing,
                focus or routing. Hidden in dark mode (CSS display:none),
                so the dark showcase is byte-for-byte unchanged. Styling
                lives in `.galaxy-observatory` / `.obs-*` rules below. */}
            <div class="galaxy-observatory" aria-hidden="true">
              <svg
                class="obs-svg"
                viewBox="0 0 600 600"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                focusable="false"
                aria-hidden="true"
              >
                <!-- Solid hairline concentric ellipses (ry = 0.52 x rx) -->
                <ellipse class="obs-ring" cx="300" cy="300" rx="82" ry="42.64" />
                <ellipse class="obs-ring" cx="300" cy="300" rx="158" ry="82.16" />
                <ellipse class="obs-ring obs-ring--outer" cx="300" cy="300" rx="292" ry="151.84" />
                <!-- Accent dotted ellipse + cardinal node dots (kept on mobile) -->
                <ellipse class="obs-ring--accent" cx="300" cy="300" rx="234" ry="121.68" />
                <circle class="obs-dot" cx="300" cy="178.32" r="4" />
                <circle class="obs-dot" cx="300" cy="421.68" r="4" />
                <circle class="obs-dot" cx="534" cy="300" r="4" />
                <circle class="obs-dot" cx="66" cy="300" r="4" />
                <!-- Fine detail — hidden on mobile to keep rings subtle -->
                <g class="obs-detail">
                  <ellipse class="obs-ring--fine" cx="300" cy="300" rx="200" ry="104" />
                  <line class="obs-cross" x1="300" y1="217.84" x2="300" y2="178.32" />
                  <line class="obs-cross" x1="300" y1="382.16" x2="300" y2="421.68" />
                  <line class="obs-cross" x1="458" y1="300" x2="534" y2="300" />
                  <line class="obs-cross" x1="142" y1="300" x2="66" y2="300" />
                  <circle class="obs-dot--minor" cx="411.7" cy="241.9" r="2.6" />
                  <circle class="obs-dot--minor" cx="188.3" cy="241.9" r="2.6" />
                  <circle class="obs-dot--minor" cx="411.7" cy="358.1" r="2.6" />
                  <circle class="obs-dot--minor" cx="188.3" cy="358.1" r="2.6" />
                </g>
              </svg>
            </div>

            {/* Backdrop — appears only when a card is focused into the
                center. Click anywhere on it closes the focus state. */}
            <div class="galaxy-backdrop" data-galaxy-backdrop aria-hidden="true"></div>

            {/* ── Core Search Mode (mobile-only) ──────────────────────
                Tap-the-core search affordance. SSR ships the chrome
                unconditionally; CSS hides every node on desktop
                (≥1024px) so the existing dashboard composition is
                untouched. The runtime module
                (`src/utils/library/core-search.ts`) wires tap,
                input, clear, close, Esc, and swipe-down close — and
                tags matching orbit cards via
                `data-core-search-match="yes"|"no"` so the orbit
                itself becomes the result surface.

                Trigger: an honest <button> so keyboard focus +
                screen-reader semantics work without ARIA gymnastics.
                The hint capsule appears once on first visit; the
                panel expands from the trigger's centre when open. */}
            <button
              type="button"
              class="core-search-trigger"
              data-core-search-trigger
              aria-expanded="false"
              aria-controls="core-search-panel"
              data-i18n-aria-label="library.coreSearch.openAria"
              aria-label={t('library.coreSearch.openAria', language)}
            >
              <span class="core-search-trigger-glow" aria-hidden="true"></span>
              <span class="core-search-trigger-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
              </span>
            </button>

            <div
              class="core-search-hint"
              data-core-search-hint
              data-core-search-hint-state="hidden"
              aria-hidden="true"
            >
              <span data-i18n="library.coreSearch.hint">{t('library.coreSearch.hint', language)}</span>
            </div>

            <div
              id="core-search-panel"
              class="core-search-panel"
              data-core-search-panel
              role="search"
              aria-label={t('library.coreSearch.openAria', language)}
            >
              <span class="core-search-panel-glow" aria-hidden="true"></span>
              <span class="core-search-panel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="m20 20-3.5-3.5"></path>
                </svg>
              </span>
              <input
                type="search"
                class="core-search-input"
                data-core-search-input
                autocomplete="off"
                autocapitalize="off"
                spellcheck="false"
                enterkeyhint="search"
                data-i18n-placeholder="library.coreSearch.placeholder"
                placeholder={t('library.coreSearch.placeholder', language)}
                data-i18n-aria-label="library.coreSearch.placeholder"
                aria-label={t('library.coreSearch.placeholder', language)}
              />
              <button
                type="button"
                class="core-search-clear"
                data-core-search-clear
                hidden
                data-i18n-aria-label="library.coreSearch.clearAria"
                aria-label={t('library.coreSearch.clearAria', language)}
              >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18"></path>
                </svg>
              </button>
              <button
                type="button"
                class="core-search-close"
                data-core-search-close
                data-i18n-aria-label="library.coreSearch.closeAria"
                aria-label={t('library.coreSearch.closeAria', language)}
              >
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18"></path>
                </svg>
              </button>
              <p
                class="core-search-no-matches"
                data-i18n="library.coreSearch.noMatches"
                aria-live="polite"
              >{t('library.coreSearch.noMatches', language)}</p>
            </div>


            {/* Orbit cards — every readable item gets one station on
                the elliptical orbit around the central core. Position
                is set per-card via inline `--orbit-angle`; CSS handles
                the rest with cos()/sin(). No queue, no carousel —
                everything is on screen at once. */}
            {orbitItems.map(({ item, angle, kind }, idx) => (
              <div
                class="galaxy-card"
                data-galaxy-card
                data-kind={kind}
                data-slug={item.slug}
                data-series-id={item.seriesId}
                data-series-name={item.seriesName}
                data-mobile-slot={
                  /* Mobile-only 3-slot carousel hint, consumed by the
                     `.galaxy-card[data-mobile-slot=...]` CSS in the
                     mobile @media block and updated at runtime by
                     `updateMobileSlots()` in universe-layout.ts. SSR
                     assigns the natural rotation=0 layout so the first
                     paint already shows one centre + two side previews
                     instead of an orbit. Hidden on desktop via the
                     desktop CSS — the orbit-math rules win there. */
                  idx === 0 ? 'center'
                  : idx === 1 ? 'next'
                  : idx === orbitItems.length - 1 ? 'prev'
                  : 'hidden'
                }
                style={`--orbit-angle: ${angle}deg; --mobile-carousel-rel: ${
                  /* Mobile coverflow position relative to the centre
                     card. SSR ships the natural rotation=0 mapping:
                     idx 0 → 0 (centre), idx 1..⌊N/2⌋ → +idx (clockwise
                     side), idx > ⌊N/2⌋ → idx-N (counter-clockwise side).
                     universe-layout.ts's updateMobileSlots() rewrites
                     this on every rotation so the centre always lands
                     on the card closest to angular top. Wraparound
                     point is arbitrary because far cards fade to 0
                     opacity anyway. */
                  idx === 0
                    ? 0
                    : idx * 2 <= orbitItems.length
                      ? idx
                      : idx - orbitItems.length
                };`}
              >
                <LibraryCard
                  item={item}
                  language={language}
                  variant="orbit"
                  artifact={resolveOrbitArtifact(item)}
                  suppressOrbitCaption={isSafeLibraryHref(item.href)}
                />
                {/* Reading-entry overlay (image-based, in-card).
                    Premium glass-style asset (PNG, no baked text) sits
                    inside the centered card. All visible text is live,
                    localized HTML rendered on top — never embedded in
                    the image. The <a> preserves native link behavior
                    (Ctrl/Cmd-click, middle-click, right-click); plain
                    left-click and Enter are intercepted by the launch
                    handler in `universe-layout.ts` via the
                    `data-reading-entry` attribute. */}
                {isSafeLibraryHref(item.href) && (
                  <div class="reading-entry-overlay">
                    {/* Main click target. Covers the panel at inset:0 so
                        clicks anywhere on the glass surface (except the
                        summary pill) continue reading. Sibling of
                        `.reading-entry-text` — not an ancestor — so the
                        in-panel pill can stay an independent <a> without
                        nesting interactive elements. */}
                    <a
                      class="reading-entry-main"
                      href={resolveReadingHref(item)}
                      data-reading-entry
                      data-reading-entry-href={resolveReadingHref(item)}
                      data-reading-entry-slug={item.slug}
                      data-aria-template={t('library.readingEntry.continueChapterAria', language, { n: '__N__' })}
                      aria-label={
                        typeof item.chapterCount === 'number' && item.chapterCount > 0
                          ? t('library.readingEntry.continueChapterAria', language, { n: 1 })
                          : t('library.readingEntry.ariaLabel', language)
                      }
                    ></a>
                    {/* The reading-entry-card1.png artifact is the visual
                        base of the panel — painted via `background-image`
                        on this layer so the icon at the top center stays
                        baked into the asset. Live i18n text (title +
                        subtitle + summary pill + meta row) is rendered as
                        real HTML over the image so it stays crisp,
                        translatable and accessible. */}
                    <span class="reading-entry-asset" aria-hidden="true"></span>
                    {/* Live content stack — redesigned for a clear visual
                        hierarchy:
                          1. CHAPTER  — the focal headline ("פרק 1").
                          2. PROGRESS — thin animated bar + tiny %, driven by
                             the same hydrator that previously updated the
                             "X% הושלם" chip.
                          3. FACTS    — quiet inline strip ("11 פרקים · 113
                             דק קריאה") with middot separators, no chips.
                          4. ACTIONS  — a luminous primary CTA pill carrying
                             the "המשך קריאה" label (decorative; the actual
                             click target is `.reading-entry-main` above), plus
                             a small ghost "תקציר הספר" secondary link.

                        All hydration data attributes (`data-cc-primary-label`,
                        `data-cc-chapter-label`, `data-cc-meta-progress`, etc.)
                        are preserved on their new hosts so the existing
                        `hydrateCenterCardExtras` continues to work without
                        changes. The progress bar's width is driven by a new
                        `--re-progress` CSS var that the hydrator sets in the
                        same pass it updates the % label. */}
                    {/* Live content stack — stripped down to ONLY the two
                        actions at Tomer's request: primary "Continue
                        reading" CTA + tiny "Book summary" secondary link.
                        The chapter headline, progress bar, and facts strip
                        were removed because the orbit card above already
                        shows the book identity; this panel is purely the
                        action surface now.

                        Hydration hooks that lived on the removed rows
                        (`[data-cc-chapter-label]`, `[data-cc-meta-progress]`)
                        are gone too — the existing hydrator's `querySelector`
                        calls null-check and no-op when they're missing, so
                        no JS change is required. */}
                    <div class="reading-entry-text">
                      <div class="reading-entry-actions">
                        {/* Primary CTA — visually anchors the action. The
                            actual hit target is `.reading-entry-main` above;
                            this pill is `pointer-events:none` so it never
                            blocks that click. */}
                        {/* SSR default = "התחל קריאה" because the server
                            has no per-user reading state — a brand-new book
                            (or a fresh browser with no localStorage entries)
                            should invite the first read, not pretend to be
                            mid-stream. The hydrator in `hydrateCenterCardExtras`
                            swaps in the `data-continue-template` text
                            ("המשך קריאה") the moment any chapter shows
                            real progress > 0 in localStorage. */}
                        <span class="reading-entry-cta" aria-hidden="true">
                          <span
                            class="reading-entry-cta-label"
                            data-cc-primary-label
                            data-continue-template={t('library.readingEntry.continueReadingShort', language)}
                          >
                            {t('library.readingEntry.startReadingShort', language)}
                          </span>
                          <svg class="reading-entry-cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M5 12h14"></path>
                            <path d="M13 6l6 6-6 6"></path>
                          </svg>
                        </span>
                        {/* Secondary — opens the book summary page (not the
                            reader). `data-cc-secondary-link` makes the stage
                            click handler bail out without closing the focused
                            card, preserving native <a> behavior. */}
                        <a
                          class="reading-entry-summary-pill"
                          href={item.href}
                          data-cc-secondary-link
                          aria-label={t('library.centerCard.bookSummaryPillAria', language)}
                        >
                          {t('library.centerCard.bookSummaryPill', language)}
                        </a>
                      </div>
                    </div>
                  </div>
                )}
                {/* `.galaxy-cta` slot is now only rendered for series
                    capsules — the open-orb (`.galaxy-cta-open`) was
                    superseded by `.reading-entry-overlay`, and the X
                    close button was retired in favour of backdrop-tap
                    and Esc-key closing. Books / lessons / articles
                    therefore emit no `.galaxy-cta` markup at all. */}
                {kind === 'course' && (
                  <div class="galaxy-cta">
                    <div class="galaxy-cta-series-actions" data-series-action-panel>
                      <button
                        type="button"
                        class="galaxy-cta-series-btn"
                        data-series-action="toggle-items"
                        aria-pressed="false"
                        aria-label={t('library.series.actions.showItems', language)}
                      >
                        <span class="galaxy-cta-series-btn-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="6" width="6" height="12" rx="1"></rect>
                            <rect x="11" y="4" width="5" height="14" rx="1"></rect>
                            <rect x="18" y="8" width="3" height="10" rx="1"></rect>
                          </svg>
                        </span>
                        <span class="galaxy-cta-series-btn-label" data-series-action-label="toggle-items">
                          {t('library.series.actions.showItems', language)}
                        </span>
                      </button>
                      <button
                        type="button"
                        class="galaxy-cta-series-btn"
                        data-series-action="details"
                        aria-label={t('library.series.actions.details', language)}
                      >
                        <span class="galaxy-cta-series-btn-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="M12 8h.01"></path>
                            <path d="M11 12h1v4h1"></path>
                          </svg>
                        </span>
                        <span class="galaxy-cta-series-btn-label">
                          {t('library.series.actions.details', language)}
                        </span>
                      </button>
                    </div>
                  </div>
                )}
              </div>
            ))}

            {/* Local children fan — created and populated by JS when a
                focused series capsule's "Show items" button is clicked.
                Lives inside the stage so it positions naturally relative
                to the centered capsule. Hidden until populated; nothing
                permanently mixes into the main universe. */}
            <div
              class="series-children-fan"
              data-series-children-fan
              role="region"
              aria-label={t('library.series.children.region', language)}
              hidden
            ></div>

            {/* Series carousel chevrons + position pill —
                SSR-rendered chrome that flanks the coverflow carousel
                inside series mode. Hidden by default; revealed via
                `[data-stage-mode="series"] .series-carousel-nav` /
                `.series-carousel-position` in the stylesheet below.
                Click handlers are attached directly to the buttons in
                universe-series-mode.ts (not delegated) so the click
                path is independent of capture-phase ordering. */}
            <button
              type="button"
              class="series-carousel-nav series-carousel-nav-prev"
              data-series-carousel-nav="prev"
              aria-label="Previous book"
            ><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
            <button
              type="button"
              class="series-carousel-nav series-carousel-nav-next"
              data-series-carousel-nav="next"
              aria-label="Next book"
            ><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
            <div
              class="series-carousel-position"
              data-series-carousel-position
              aria-live="polite"
            >
              <span data-series-pos-current>1</span>
              <span class="series-carousel-position-sep" aria-hidden="true">/</span>
              <span data-series-pos-total>0</span>
            </div>

          </div>
        </section>

      </main>

      {/* ── Mobile-only quick-actions panel ──
            Desktop has no quick-actions surface in v1 (the FloatingSidebar
            tools rail was removed). On mobile this aside stays as
            `display: contents` and contributes its child as a flex item
            of `.library-body` at order 6. */}
      <aside class="lb-area-right">
        <div class="lb-area-quick lb-area-quick-mobile">
          <LibraryQuickActions language={language} />
        </div>
      </aside>

    </div>

    {/* ── Desktop fixed support panels (≥1024px) ──
          Both panels are `position: fixed` from inside their own
          component CSS and FRAME the carousel from opposite edges:
            - ContinueLearningCard → inline-start edge
              (visual-right in RTL Hebrew, visual-left in LTR).
            - LibraryStatsPanel → inline-end edge
              (visual-left in RTL Hebrew, visual-right in LTR).
          Both anchor at the same `top` (header offset + 20px). Hidden
          at ≤1023px from inside each component. Live outside
          `.library-body` so they never claim a column or contribute
          to the grid. */}
    <ContinueLearningCard
      language={language}
      courseTitle={courseTitleForCard}
      metaLine1={metaLine1ForCard}
      metaLine2={metaLine2ForCard}
      lessonsAvailable={isLesson ? courseProgress[0]?.available : undefined}
      lessonsTotal={isLesson ? courseProgress[0]?.total : undefined}
      href={continueItem?.href}
      readableBooks={readableItems
        .filter((it) => (it.chapterCount ?? 0) > 0)
        .map((it) => ({
          slug: it.slug,
          title:
            it.titles?.[language]
            ?? it.titles?.en
            ?? it.titles?.he
            ?? it.slug,
          subtitle:
            it.subtitles?.[language]
            ?? it.subtitles?.en
            ?? it.subtitles?.he
            ?? '',
          href: it.href,
          chapterCount: it.chapterCount ?? 0,
        }))}
    />
    <LibraryStatsPanel stats={stats} language={language} courseProgress={courseProgress} />

    {/* ── Desktop floating tools rail — removed in v1 ──
          The left vertical tools rail (<FloatingSidebar>: AI assistant,
          bookmarks, history) is intentionally not rendered on the v1
          carousel screen. It lived outside the grid as `position: fixed`,
          so removing it changes no grid column and no carousel logic.
          To bring it back, restore the import above and re-add:
            <FloatingSidebar language={language}
              aiAssistantHref="#ai-assistant"
              bookmarksHref="#bookmarks" historyHref="#history" /> */}

    {/* ── Series details drawer ──
          Same-page modal/drawer that opens when the focused series
          capsule's "Series details" action is clicked. The body fields
          are filled in by the JS controller from SeriesMetadata; static
          labels come straight from i18n via `t()` so SSR ships the right
          chrome in every language. The drawer stays hidden via [hidden]
          until the controller opens it. */}
    <div
      class="series-details-overlay"
      data-series-details-overlay
      hidden
      aria-hidden="true"
    ></div>
    <aside
      class="series-details-drawer"
      data-series-details-drawer
      role="dialog"
      aria-modal="true"
      aria-labelledby="series-details-title"
      dir={isRtl ? 'rtl' : 'ltr'}
      hidden
    >
      <header class="series-details-header">
        <h2 id="series-details-title" class="series-details-title" data-series-details-name>
          {t('library.series.details.title', language)}
        </h2>
        <button
          type="button"
          class="series-details-close"
          data-series-details-close
          aria-label={t('library.series.details.close', language)}
        >×</button>
      </header>
      <div class="series-details-body">
        <section class="series-details-section">
          <p class="series-details-summary" data-series-details-summary></p>
          <p class="series-details-full" data-series-details-full></p>
        </section>
        <dl class="series-details-meta">
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.assignedItems', language)}</dt>
            <dd data-series-details-assigned-count>0</dd>
          </div>
          <div class="series-details-meta-row" data-series-details-planned-row hidden>
            <dt>{t('library.series.details.plannedItems', language)}</dt>
            <dd data-series-details-planned-count></dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.status', language)}</dt>
            <dd data-series-details-status-value></dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.assetFolder', language)}</dt>
            <dd>
              <code data-series-details-asset-folder></code>
            </dd>
          </div>
          <div class="series-details-meta-row">
            <dt>{t('library.series.details.visibleInUniverse', language)}</dt>
            <dd data-series-details-visible></dd>
          </div>
        </dl>
        <section class="series-details-section">
          <h3 class="series-details-list-title">{t('library.series.details.assignedItems', language)}</h3>
          <ul class="series-details-list" data-series-details-list></ul>
        </section>
      </div>
    </aside>

    {/* ── Knowledge Atlas ──
          Alternative full-screen "all items" view, opened by the
          Knowledge Core widget's `data-library-view="all"` action. It is
          self-contained (own script for open/close/filter/search);
          selecting an item bridges back to the carousel through
          universe-layout's `[data-library-focus]` listener. Rendered at
          page level so it can cover the whole stage. */}
    <KnowledgeAtlas items={atlasItems} language={language} />

    {/* Mobile-only carousel position indicator (e.g. "3 / 10").
        Pinned just above the bottom chevron pill so the user sees
        BOTH the position and the navigation controls in one glance —
        a clear signal that there are more books on the carousel.
        Defaults to hidden globally (see `.galaxy-position-indicator`
        rule below); the mobile @media block enables it.
        `updateMobileSlots()` in universe-layout.ts updates the
        current/total numbers in lockstep with every rotation. */}
    {showOrbitControls && (
      <div
        class="galaxy-position-indicator"
        data-galaxy-position-indicator
        role="status"
        aria-live="polite"
      >
        <span data-galaxy-position-current>1</span>
        <span class="galaxy-position-sep" aria-hidden="true">/</span>
        <span data-galaxy-position-total>{orbitItems.length}</span>
      </div>
    )}

    {/* Orbit rotation controls — chevron pair pinned to the bottom of
        the viewport, OUTSIDE the orbit stage so they never overlap the
        focused card. The click handler in universe-layout.ts attaches
        a document-level delegate for [data-galaxy-rotate], so the
        buttons stay functional even though they live outside the stage. */}
    {showOrbitControls && (
      <div class="galaxy-orbit-controls" aria-hidden="false">
        <button
          type="button"
          class="galaxy-orbit-btn"
          data-galaxy-rotate
          data-direction="prev"
          aria-label={t('library.galaxy.rotatePrev', language)}
        ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
        <button
          type="button"
          class="galaxy-orbit-btn"
          data-galaxy-rotate
          data-direction="next"
          aria-label={t('library.galaxy.rotateNext', language)}
        ><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
      </div>
    )}


  </div>
</LibraryLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────
     /library — page shell + galaxy stage geometry
     Hard rules:
       - All colour/effect via --yuval-galaxy-*  (no hex anywhere)
       - All visible text via t()
       - RTL via inset-inline-* (logical properties)
     ────────────────────────────────────────────────────────────────── */

  /* ── Page-level lock: dark cosmic shell + no scroll ────────────────
     Two intentions in one rule:
       1. The body / html background-color is forced to match the
          cosmic floor `#00010d`, so iOS Safari rubber-band and
          URL-bar morph never expose a cream sliver above the dark
          header.
       2. `overflow: hidden` + `height: 100dvh` lock the page to the
          viewport in BOTH axes on every device. Per the user's
          request this screen never scrolls — the orbit dashboard
          (desktop) and the cleared hero+orbit-placeholder (mobile)
          are designed to fit inside a single viewport. Anything
          beyond is intentionally clipped rather than scrollable.
     Scoped via `:global()` + the page-root class so every other
     route keeps its native scroll. `:has()` is widely supported
     (Safari 15.4+, Chrome 105+, Firefox 121+); older engines fall
     back to normal page scroll. */
  :global(html:has(.library-dark-showcase)),
  :global(body:has(.library-dark-showcase)) {
    background-color: #00010d;
    height: 100dvh;
    overflow: hidden;
  }

  .library-root {
    position: relative;
    /* Hard viewport lock — the dashboard is sized to EXACTLY the area
       below the global header (`--library-dashboard-min-height` is
       defined by LibraryLayout as calc(100dvh - 72px)). Using `height`
       (not min-height) means library-root can never grow past the
       viewport, no matter how tall its inner content gets, so the page
       cannot scroll under any condition — even when the html/body
       `:has()` lock fails (older browsers, View Transition wrappers
       on iOS Safari). The calc() fallback covers the rare case where
       the layout var doesn't load. 100dvh inside the calc still tracks
       the dynamic viewport so the iOS URL-bar collapse doesn't leave a
       cosmic-bg strip uncovered. */
    height: var(--library-dashboard-min-height, calc(100dvh - 72px));
    width: 100%;
    /* Whole-screen unified backdrop. Mobile uses the two main layers;
       desktop adds side accents + vignette so the entire dashboard
       (sidebar + center + rail + recs) reads as one cosmic field.

       Background-color sampled directly from the dark outer pixels of
       galaxy-stage-core-medium.png (corners read RGB(0,1,13)). The
       earlier #0a0a1f estimate was ~3× brighter than reality and left
       a visible seam between the image edges and the page. With the
       sampled value, the image's outer dark pixels are continuous
       with the page bg. Scoped to .library-root via Astro style
       scoping — does not affect any other route. */
    background-color: #00010d;
    background-image:
      var(--yuval-galaxy-bg-radial-primary),
      var(--yuval-galaxy-bg-radial-secondary);
    color: var(--yuval-galaxy-text);
    /* Top padding kept tight (0.25rem) so the hero text sits close to
       the header line, per the user's preference. Side + bottom keep
       their original breathing room. Tablet + desktop overrides below
       follow the same rule — small top, generous sides/bottom. */
    padding: 0.25rem 1rem 4rem;
    box-sizing: border-box;
    isolation: isolate;
    /* `overflow: hidden` on BOTH axes — was `overflow-x: hidden` only,
       which let tall inner content (e.g. mobile flex column at the
       sticky-header offset) scroll vertically inside the root even
       when html/body had `overflow: hidden`. With the `height` cap
       above + this overflow lock, nothing can produce a scroll bar or
       a touch-scroll on any breakpoint. */
    overflow: hidden;
  }

  /* ── Cosmic scene background — full-page scene layer ────────────
     This is the global "knowledge universe" canvas. It is sized to
     `.library-root` and stacks behind every UI layer, which sit on
     top via `position: relative; z-index: 1` (see the
     `.library-root > :not(...)` rule below). */
  .knowledge-scene-background {
    /* `position: absolute`, NOT `fixed`. As a fixed layer this would
       re-base to the `<main transition:animate>` ancestor for the
       ~0.4s the page's View Transition runs on reload, then snap back
       to the viewport — a visible vertical jump (diagnosed live).
       Absolute keeps the containing block stable: it resolves to
       `.library-root`, the always-`position: relative` parent, which
       no view-transition machinery ever re-bases. `top` still reaches
       above .library-root's edge so the image tucks under the opaque
       header, which covers that strip. */
    position: absolute;
    top: calc(4rem - 130px);
    inset-inline: 0;
    bottom: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .knowledge-scene-background img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;          /* equivalent of background-size: cover   */
    object-position: center center; /* equivalent of background-position: center */
    /* Shift the scene 50px DOWN. Applied to the <img>, not the
       container, so the container box is unchanged: the 50px that
       overflows its bottom is clipped by the container's
       `overflow: hidden`, and the 50px gap opened at the top sits
       behind the opaque header. No container resize, no scrollbar. */
    transform: translateY(50px);
    user-select: none;
    -webkit-user-drag: none;
  }
  /* ── Theme-aware scene swap ──────────────────────────────────────
     The night galaxy is the default — dark mode renders the night
     PNG and hides the day photograph. Light mode (<html> without
     `.dark`) inverts both opacities so the day image fades in and
     the night image fades out. Both layers share the same absolute
     box so the swap is a pure cross-fade — no layout shift. */
  .knowledge-scene-img {
    transition: opacity var(--yuval-galaxy-motion-slow, 520ms)
                var(--yuval-galaxy-ease-soft, ease);
  }
  :global(html:not(.dark)) .knowledge-scene-img--night {
    opacity: 0;
  }
  .knowledge-scene-img--day {
    opacity: 0;
  }
  :global(html:not(.dark)) .knowledge-scene-img--day {
    opacity: 1;
  }
  /* Day image — responsive fit strategy.
     ─ Mobile (<768px): inherits the shared `.knowledge-scene-background
       img` rule → object-fit: cover with the phone-cropped asset, which
       is already framed for portrait so cover loses nothing important.
     ─ Tablet + desktop (≥768px): override the shared rule's
       `width:100%; height:100%` so the image spans the full container
       width (= full viewport width) with its native ~16:9 aspect
       preserved via `height: auto`. The image is anchored to the top
       of `.knowledge-scene-background` (which itself sits 130px above
       library-root's top, so the top edge tucks behind the opaque
       header just like the night image does). On 16:9 displays the
       image fills both axes exactly. On taller viewports a band of
       the light-mode `.library-root` ivory gradient shows below the
       image as a soft sky-toned fallback. On ultra-wide viewports
       the container's `overflow: hidden` clips a small slice off the
       bottom — kept minimal by choosing top-anchor + aspect height
       rather than centring the image vertically.
     Specificity (0,2,2) outranks the generic `.knowledge-scene-
     background img` (0,1,1). Night mode is untouched — the selector
     only matches `--day`. */
  @media (min-width: 768px) {
    .knowledge-scene-background img.knowledge-scene-img--day {
      width: 100%;
      height: auto;
      /* Bottom-anchored: image's bottom edge sticks to the bottom of
         the visible viewport so the workspace details near the floor
         are always on screen. On 16:9 displays the image fills end-to-
         end. On taller viewports (16:10, 4:3) a small light gradient
         band appears between the header and the image's top edge —
         intentional, reads as ambient sky. On ultra-wide viewports a
         slice of the image's TOP (ceiling area) is clipped, never the
         informative bottom half. */
      inset: auto 0 0 0;
      object-fit: unset;
      object-position: unset;
      transform: none;
    }
  }

  /* Soft radial vignette — keeps the central glow untouched and
     darkens only the edges so floating cards + side panels read
     cleanly against the bg without losing the cosmic atmosphere. */
  .knowledge-scene-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      transparent 35%,
      rgba(0, 0, 0, 0.45) 80%,
      rgba(0, 0, 0, 0.65) 100%);
  }
  /* Light-mode overlay — the dark vignette above would muddy the bright
     day scene, so in light mode it becomes a soft warm-ivory veil:
     fully clear through the center (the luminous core and the focused
     book card stay dominant) and lifting gently toward the edges so the
     floating cards never compete with the image's rings and labels.
     Kept subtle so the scene never washes out the cards or text. */
  :global(html:not(.dark)) .knowledge-scene-overlay {
    background: radial-gradient(
      ellipse at center,
      rgba(255, 253, 247, 0) 0%,
      rgba(255, 253, 247, 0) 46%,
      rgba(255, 253, 247, 0.20) 80%,
      rgba(255, 253, 247, 0.34) 100%);
  }

  /* ════════════════════════════════════════════════════════════════
     LIGHT-MODE TUNING — page-level surfaces the galaxy tokens cannot
     reach: hardcoded dark page fills and a few light-on-dark text
     colors. All rules are gated on `html:not(.dark)`; dark mode never
     matches them, so the dark showcase stays byte-for-byte unchanged.
     (Coherent panel/header/glow theming is handled by the token block
     in galaxy.css scoped to `:root:not(.dark) .library-dark-showcase`.)
     ════════════════════════════════════════════════════════════════ */

  /* Page base — minimal clean day-mode fallback. With the day scene
     image system removed, the page reads as a soft warm-blue gradient
     at the centre fading into a cool near-white field. The body/html
     bg uses the same near-white edge so iOS rubber-band, the URL-bar
     morph, and any layout sliver around the root all stay coherent. */
  :global(html:not(.dark):has(.library-dark-showcase)),
  :global(html:not(.dark) body:has(.library-dark-showcase)) {
    background-color: #eef5ff;
  }
  :global(html:not(.dark)) .library-root {
    background:
      radial-gradient(circle at 50% 38%, rgba(210, 235, 255, 0.55), transparent 42%),
      linear-gradient(180deg, #ffffff 0%, #f7f9ff 48%, #eef5ff 100%);
    /* Light mode adds breathing room below the (now light-glass)
       header so the hero "ברוך הבא" eyebrow + "מרחב הידע" title never
       read as clipped or squeezed against the header line. Specificity
       (0,2,1) outranks the plain `.library-root` padding shorthand in
       the responsive @media blocks, so this wins at every breakpoint.
       Dark mode keeps the locked tight 0.25rem top padding. */
    padding-top: 1.1rem;
  }

  /* Starfield — navy dots on a bright sky read as dust, and the day
     asset already carries its own constellation of nodes. Fade the
     CSS starfield right back so it stays a whisper, never clutter. */
  :global(html:not(.dark)) .library-starfield {
    opacity: 0.10;
  }

  /* Center-card secondary link + metadata — authored in light-on-dark
     colors that vanish on the ivory scene. Repaint them in navy/slate
     so they stay readable directly beneath the focused book card. */
  :global(html:not(.dark)) .cc-secondary-link {
    color: #46556f;
    text-decoration-color: rgba(34, 52, 92, 0.32);
  }
  :global(html:not(.dark)) .cc-secondary-link:hover,
  :global(html:not(.dark)) .cc-secondary-link:focus-visible {
    color: #16223c;
    text-decoration-color: rgba(34, 52, 92, 0.70);
  }
  :global(html:not(.dark)) .cc-secondary-link:focus-visible {
    box-shadow: 0 0 0 2px rgba(34, 52, 92, 0.40);
  }
  /* The chips now live INSIDE the dark image panel, so they read the
     same in both themes — no light-mode chip override needed. The
     standalone extras wrapper, section label and secondary link are
     all display:none in the new image-panel design, so their
     light-mode rules above are dead but kept for back-compat in case
     a future theme un-hides them.

     Reading-entry image-based CTA focus ring — the dark neon double
     glow is too loud on the bright day scene. Soften to a calm navy
     hairline that traces the image's actual rounded-rect shape. */
  :global(html:not(.dark)) .reading-entry-overlay:focus-visible .reading-entry-asset {
    box-shadow:
      0 0 0 2px rgba(34, 52, 92, 0.38),
      0 6px 18px rgba(30, 45, 80, 0.20);
  }
  /* Card-selection confirmation halo — soften the cyan flash to a
     muted slate so the click feedback never sparks neon on daylight. */
  :global(html:not(.dark)) .library-root {
    --reading-entry-halo-color: rgba(70, 105, 150, 0.40);
  }

  /* Lightning overlay — SVG injected by `universe-core-effects.ts`.
     Each strike draws a multi-layer jagged bolt with branching forks
     from stage centre to the hovered card's centre.

     z-index: 25 — sits ABOVE orbit cards (z-index 3) so the bolt
     reaches the card's centre visibly, but BELOW the focused card
     (z-index 30) so a click-to-centered card never gets struck.

     mix-blend-mode: screen — the bolt is additive over whatever
     paints below it. White cores stay punchy on the dark cosmic
     scene, and accent-coloured glow tints (rather than overwrites)
     the card content it crosses. Stays non-interactive (clicks fall
     through to the cards underneath). */
  .library-galaxy svg[data-core-lightning] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 25;
    mix-blend-mode: screen;
  }

  /* ── Light-mode lightning → subtle scientific connection line ──────
     The card→core bolt is built by universe-core-effects.ts as a
     triple-stroke jagged path (halo + mid + white-hot core) plus
     spark/flash circles, glowing through SVG blur filters and
     composited with `mix-blend-mode: screen`. That recipe is tuned
     for the dark cosmic stage; on the bright Knowledge Observatory it
     reads as loud, neon and game-like.

     This block re-skins ONLY light mode into a calm connection line.
     It is pure CSS over the JS-built nodes — the script is untouched:
     - every rule is gated on `html:not(.dark)`, so dark mode is
       byte-for-byte unchanged;
     - `stroke-width` / `filter` / the core's `stroke` are SVG
       presentation attributes → overridden by plain CSS;
     - `style.stroke` on the halo/mid layers is inline → needs
       `!important`; element `opacity` is deliberately left alone so
       the JS fade-out keeps working — the whole overlay is dimmed at
       the `<svg>` level instead, which the per-element fade scales.
     The effect stays hover-triggered and transient exactly as before
     — this changes how it looks, never when it fires.

     GOTCHA — each selector below is wrapped WHOLE in `:global(...)`.
     universe-core-effects.ts builds the bolt with `createElementNS`,
     so the <svg>, <path> and <circle> carry NO Astro scope hash. A
     normally-scoped rule (even one only prefixed with `:global(html
     ...)`) makes Astro append `[data-astro-cid-*]` to `.library-galaxy
     / svg / path / circle` — which then matches NOTHING. Wrapping the
     entire selector in `:global()` keeps it unscoped so it actually
     reaches the runtime-built nodes. */
  :global(html:not(.dark) .library-galaxy svg[data-core-lightning]) {
    /* Significant overall opacity cut. `screen` blend would make a
       mid-tone line vanish on a light surface, so it composites
       normally here. */
    opacity: 0.42;
    mix-blend-mode: normal;
  }
  /* Strokes — soft blue-gray instead of electric neon; thin, uniform,
     SVG glow filters removed, so it reads as a drawn connection line
     rather than a bolt. Blue-gray harmonises with the navy observatory
     ellipses instead of competing with them. */
  :global(html:not(.dark) .library-galaxy svg[data-core-lightning] path) {
    stroke: #7b8aa3 !important;
    stroke-width: 1.1;
    filter: none;
  }
  /* Spark + impact-flash circles are the most game-like part — drop
     them entirely in light mode so only the calm line remains. */
  :global(html:not(.dark) .library-galaxy svg[data-core-lightning] circle) {
    display: none;
  }

  /* Ambient backdrop — sits ABOVE the scene background, BELOW the UI.
     Self-contained starfield. */
  .library-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  /* `.library-aurora` and `.library-nebula-*` rules removed: their
     markup nodes were retired when the unified page-level backdrop
     system in `.library-root` took over atmospheric coloring. */
  /* Starfield — a CSS-only matrix of tiny bright pixels rendered as
     a single repeating radial-gradient pattern. No DOM nodes, no JS.
     Two layers (small + medium) at slightly different offsets for
     parallax-like depth. */
  .library-starfield {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 12%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 65% 24%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 38%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 82% 47%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 12% 58%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 73% 67%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 28% 78%, var(--yuval-galaxy-text) 50%, transparent 100%),
      radial-gradient(1px 1px at 88% 88%, var(--yuval-galaxy-text) 50%, transparent 100%),
      /* Accent stars — all violet now. Cyan accents were swapped to
         purple to align with the page's violet-led palette and avoid
         out-of-key cyan dots on the cosmic field. */
      radial-gradient(1.5px 1.5px at 50% 18%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 92% 32%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 8% 72%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 58% 92%, var(--yuval-galaxy-accent-purple) 50%, transparent 100%);
    opacity: 0.40;
  }
  .library-root > :not(.library-ambient):not(.knowledge-scene-background) {
    position: relative;
    z-index: 1;
  }

  /* ── Knowledge Observatory — light-mode-only decorative rings ──────
     Passive SVG layer: concentric "observatory" ellipses + tick marks
     (ry = 0.52 x rx, so they read as orbital tracks in a low-angle
     perspective and echo the carousel's elliptical orbit), centered on the carousel
     orbit center. It lives INSIDE
     `.library-galaxy`, so `top/left: 50%` + `translate(-50%, -50%)`
     resolves against the very same box the orbit cards center on
     (`.galaxy-card { top: 50%; left: 50% }`). The ring center therefore
     tracks the carousel center automatically at every breakpoint —
     desktop (relative stage + vertical offset) and mobile (fixed,
     viewport-centered stage) alike. No coordinate math is duplicated.

     Layering — z-index 0 within `.library-galaxy`:
       observatory (0) < orbit cards (2) < focus backdrop (15)
       < lightning (25) < focused card (30).
     The rings always sit behind the cards and the cards stay visually
     dominant. `pointer-events: none` keeps every click, hover, focus
     and route landing on the cards — never the rings — so the carousel
     logic is untouched.

     Light-mode only: `display: none` by default, flipped to `block`
     solely when <html> has no `.dark` class. Dark mode renders nothing,
     so the dark showcase is byte-for-byte unchanged. */
  .galaxy-observatory {
    --obs-size: clamp(460px, 56vw, 700px);
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--obs-size);
    height: var(--obs-size);
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    display: none;
    opacity: 0.85;
    transition: opacity var(--yuval-galaxy-motion-normal, 280ms)
                var(--yuval-galaxy-ease-soft, ease);
  }
  :global(html:not(.dark)) .galaxy-observatory {
    /* Hidden in light mode — the photographic day scene
       (`ai_researcher_workspace_day_bg.webp`) carries its own ambient
       depth, so this SVG ring layer would compete with it. Kept in
       the DOM so dark mode (which never matches `:not(.dark)`) is
       unaffected and the markup-driven aria layer stays stable. */
    display: none;
  }
  .obs-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  /* Solid hairline rings — crisp at any scale via non-scaling-stroke. */
  .obs-ring {
    fill: none;
    stroke: rgba(34, 52, 92, 0.16);
    stroke-width: 1.5px;
    vector-effect: non-scaling-stroke;
  }
  .obs-ring--outer { stroke: rgba(34, 52, 92, 0.09); }
  /* Accent + fine rings are dotted (round-capped dashes); their stroke
     is allowed to scale so the dots read proportionally with the ring. */
  .obs-ring--accent {
    fill: none;
    stroke: rgba(14, 116, 144, 0.30);
    stroke-width: 2.4px;
    stroke-linecap: round;
    stroke-dasharray: 0.5 17;
  }
  .obs-ring--fine {
    fill: none;
    stroke: rgba(34, 52, 92, 0.22);
    stroke-width: 1.9px;
    stroke-linecap: round;
    stroke-dasharray: 0.5 13;
  }
  .obs-cross {
    stroke: rgba(34, 52, 92, 0.20);
    stroke-width: 1.5px;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }
  .obs-dot        { fill: rgba(14, 116, 144, 0.42); }
  .obs-dot--minor { fill: rgba(34, 52, 92, 0.30); }
  /* When a card is focused the rings fade back so they never clutter
     the area behind the enlarged center card. `data-galaxy-focused` is
     the existing flag set by universe-layout.ts — no JS is touched. */
  .library-galaxy[data-galaxy-focused] .galaxy-observatory {
    opacity: 0.42;
  }

  /* ── Light-mode carousel polish — card depth + motion ─────────────
     A focused polish pass for the orbit carousel in light mode only.
     Every rule here is scoped under `html:not(.dark)`, so the dark
     showcase is byte-for-byte unchanged. Three things are tuned:

       1. Card depth — light-mode book covers were reading as "pasted
          onto" the ivory background. A soft blue-gray drop-shadow plus
          a faint cyan edge light grounds each card in the space. The
          shadow follows the PNG alpha silhouette because the filter
          sits on the un-masked `.galaxy-card` wrapper, not a box.
       2. Position depth — the resting orbit reads as more spatial:
          the slot scale + opacity ramps are widened so front/near
          stations sit forward and far stations recede, without
          hiding content.
       3. Motion — the rotation transition swaps the mechanical
          Material curve for a smoother, gently inertial premium curve.

     The base-card drop-shadow is constant (not position-dependent) so
     the filtered layer rasterizes once and merely translates during a
     drag; depth separation is carried by the scale/opacity ramp. */
  :global(html:not(.dark)) .galaxy-card {
    /* Light mode lifts the depth opacity floor — far cards stay a
       touch more present against the bright ivory field than in dark
       mode (0.62 vs 0.55). Scale + z-index depth come from the
       per-breakpoint base rule and are shared with dark mode. */
    --slot-opacity: calc(0.62 + 0.38 * var(--orbit-depth, 0.5));
    /* Soft blue-gray shadow (contact + ambient) + barely-there cyan
       edge light. Constant, so the filtered layer rasterizes once;
       the depth opacity ramp above fades the shadow on far cards for
       free (a lower element opacity dims its own drop-shadow). No
       heavy blur — the cards stay crisp. */
    filter:
      drop-shadow(0 5px 12px rgba(34, 52, 92, 0.15))
      drop-shadow(0 1px 3px rgba(34, 52, 92, 0.12))
      drop-shadow(0 0 2px rgba(14, 116, 144, 0.14));
  }
  /* Focused (centered) card stays dominant — a slightly deeper soft
     shadow and a touch more cyan edge glow. Values are intentionally
     moderate: the centered card is transform-scaled, which enlarges
     the rendered shadow along with it. */
  :global(html:not(.dark)) .galaxy-card[data-pos="center"] {
    filter:
      drop-shadow(0 6px 16px rgba(34, 52, 92, 0.18))
      drop-shadow(0 1px 4px rgba(34, 52, 92, 0.13))
      drop-shadow(0 0 2px rgba(14, 116, 144, 0.20));
  }

  /* ── Light-mode navigation controls — glass rotate pill ───────────
     The bottom rotate arrows read as soft glass controls in daylight:
     translucent warm-white fill, hairline border, soft shadow and a
     dark-navy icon. Scoped to light mode; the dark control styling in
     the media-query blocks below is untouched. */
  :global(html:not(.dark)) .galaxy-orbit-controls {
    background: rgba(255, 253, 249, 0.62);
    border-color: rgba(34, 52, 92, 0.14);
    box-shadow: 0 4px 16px -6px rgba(30, 45, 80, 0.22);
  }
  :global(html:not(.dark)) .galaxy-orbit-btn {
    color: var(--yuval-galaxy-text);
    background: rgba(255, 255, 255, 0.70);
    border-color: rgba(34, 52, 92, 0.12);
    box-shadow: 0 1px 3px rgba(30, 45, 80, 0.12);
  }
  :global(html:not(.dark)) .galaxy-orbit-btn:hover,
  :global(html:not(.dark)) .galaxy-orbit-btn:focus-visible {
    color: var(--yuval-galaxy-text);
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(34, 52, 92, 0.24);
    box-shadow: 0 2px 8px -2px rgba(30, 45, 80, 0.20);
  }

  /* ── Day-mode chrome cleanup — kill dark-mode leftovers ───────────
     A few pieces of chrome were styled with hard black drop shadows
     that belong to the dark showcase and read as "stuck-on" panels in
     the bright observatory. Re-cast their shadows as the same soft
     blue-gray used by the cards and the rotate pill. Light mode only;
     every other surface keeps its theme-aware tokens. */
  :global(html:not(.dark)) .galaxy-other-knowledge {
    box-shadow: 0 8px 22px -10px rgba(30, 45, 80, 0.22);
  }
  :global(html:not(.dark)) .series-details-drawer {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 20%, transparent) inset,
      -24px 0 60px -10px rgba(30, 45, 80, 0.22);
  }

  /* ── Mobile baseline: linear stack, ordered to the spec.
        The desktop wrapper aside/main elements are passthrough on mobile —
        their children unfurl in the natural document order, then `order:`
        re-shuffles them into the discovery sequence. ─────────────────── */
  .library-body {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* On mobile the wrapper aside/main elements are not layout containers;
     reset their flex behaviour and let their children act as siblings. */
  .lb-area-stage,
  .lb-area-right {
    display: contents;
  }

  /* ── Mobile content area ──────────────────────────────────────────
     `.lb-area-featured` (galaxy orbit stage) is visible on mobile too,
     scaled down proportionally — see CLAUDE.md "same orbit composition
     on mobile". The mobile-specific orbit sizing lives in the
     `@media (max-width: 1023px)` block further below.
     `.lb-area-quick-mobile` is a legacy slot for an AI assistant /
     quick-actions row that is currently suppressed. */
  .lb-area-quick-mobile {
    display: none;
  }

  /* ── LibraryHero — strip the legacy card chrome ─────────────────
     The legacy mobile + tablet LibraryHero rendered as a discrete
     card with border, panel background, blur and overflow:hidden
     (which clipped the nowrap title when the central area got
     narrow and a fixed side panel encroached on the right edge).
     The user wants only the welcome text (eyebrow + title +
     subtitle) framed by the cosmic page, not by a panel — the same
     identity as the desktop hero strip. Override applies at every
     viewport below the desktop dashboard (≤1023px). Desktop
     (≥1024px) strips chrome via LibraryHero's own @media rule. */
  /* ── Series glow pulse ────────────────────────────────────────────
        One-shot 3-second multi-colour border + halo applied to every
        card that belongs to a series. Triggered (1) when the user
        clicks "Show series items" inside the focused series capsule,
        and (2) when the user hovers a series capsule in the resting
        orbit without focusing it. Works on every viewport because the
        keyframes live outside any @media block. */
  @keyframes yuval-series-glow {
    0%, 100% {
      box-shadow: var(--yuval-galaxy-card-shadow);
      border-color: var(--yuval-galaxy-card-border);
    }
    12% {
      box-shadow:
        0 0 0 2px rgba(250, 204, 21, 0.95),
        0 0 28px 6px rgba(250, 204, 21, 0.55);
      border-color: rgba(250, 204, 21, 0.95);
    }
    37% {
      box-shadow:
        0 0 0 2px rgba(34, 197, 94, 0.95),
        0 0 28px 6px rgba(34, 197, 94, 0.55);
      border-color: rgba(34, 197, 94, 0.95);
    }
    62% {
      box-shadow:
        0 0 0 2px rgba(168, 85, 247, 0.95),
        0 0 28px 6px rgba(168, 85, 247, 0.55);
      border-color: rgba(168, 85, 247, 0.95);
    }
    87% {
      box-shadow:
        0 0 0 2px rgba(249, 115, 22, 0.95),
        0 0 28px 6px rgba(249, 115, 22, 0.55);
      border-color: rgba(249, 115, 22, 0.95);
    }
  }
  .galaxy-card.is-series-glow :global(.lc) {
    animation: yuval-series-glow 3s ease-out 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .galaxy-card.is-series-glow :global(.lc) { animation: none; }
  }

  /* Mobile-only carousel position indicator — defaults to hidden at
     every breakpoint. The mobile @media block below enables it as an
     inline-flex pill pinned above the rotate chevrons. Desktop never
     overrides this default, so the indicator stays out of the desktop
     dashboard composition. */
  .galaxy-position-indicator { display: none; }

  @media (max-width: 1023px) {
    :global(.lb-area-hero .lh) {
      /* No top padding — the hero text should land right under the
         header line. Side + bottom paddings keep modest breathing
         around the text block. */
      padding: 0 0.5rem 0.75rem;
      background-color: transparent;
      border: 0;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow: none;
      overflow: visible;
      text-align: center;
    }
    :global(.lb-area-hero .lh-halo) {
      display: none;
    }
    :global(.lb-area-hero .lh-header) {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      margin-block-end: 0.25rem;
    }
    :global(.lb-area-hero .lh-text) {
      text-align: center;
    }
    /* Eyebrow: cyan→violet gradient text in mixed case, matching the
       desktop hero. Overrides the mobile baseline (uppercase + grey)
       which clashed with the cosmic look once the panel chrome was
       removed. */
    :global(.lb-area-hero .lh-eyebrow) {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-transform: none;
      font-weight: 500;
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      margin-block-end: 0.3125rem;
      background: linear-gradient(
        90deg,
        var(--yuval-galaxy-accent-cyan) 0%,
        var(--yuval-galaxy-accent-purple) 100%);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    :global(.lb-area-hero .lh-title) {
      line-height: 1.05;
      margin-block-end: 0.375rem;
    }
    :global(.lb-area-hero .lh-subtitle) {
      margin-inline: auto;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    /* ── Mobile orbit — same composition as desktop, scaled down ─────
       The user asked for the SAME orbit (every readable item on its
       own station around the central core) on phone + tablet, just
       smaller. We re-show the featured section (hidden globally by the
       base reset), then re-declare the orbit positioning rules with
       smaller card width + smaller ellipse radii. The math is identical
       to the desktop rule inside `@media (min-width: 1024px)`. */
    /* Orbit always centered on the viewport's central book icon.
       The icon lives in `.knowledge-scene-background` (position:fixed)
       and sits a few pixels above the viewport's exact middle. To
       guarantee the orbit center (`.galaxy-card { top: 50% }` of
       `.library-galaxy`) lands ON that icon at EVERY screen size, we
       pin the galaxy box to the viewport with position:fixed and
       center it with top:50% + transform translate(-50%, -50%). The
       orbit cards are inside this fixed box, so they automatically
       sit in concentric ellipses around the icon — regardless of how
       tall the hero text grew or what other content stacks above. */
    .lb-area-featured {
      display: block;
      /* This wrapper no longer needs to host the orbit — it just
         remains in flow as a placeholder so the hero text spacing
         doesn't collapse. The actual galaxy lives in a fixed layer. */
    }

    .library-galaxy {
      position: fixed;
      /* Mobile carousel vertical anchor — 60dvh, balanced between the
         hero text (which ends ~25dvh) and the bottom rotate-controls
         pill (which pins to env(safe-area-inset-bottom), ~95dvh on
         most phones). The previous 2/3-viewport (66.66dvh) anchor
         was tuned for the old radial-orbit-on-mobile design, where
         upper stations sat in the middle third and lower stations in
         the bottom third. With the flat Focus Carousel orbit (ry≈0),
         every visible station collapses onto a single horizontal
         line at this anchor — so 60dvh now centres that line in the
         available content band, putting equal ~22dvh breathing room
         above and below the visible cards. */
      top: 50dvh;
      left: 50%;
      transform: translate(-50%, -50%);
      display: block;
      width: 100%;
      max-width: 100vw;
      min-height: clamp(440px, 95vw, 640px);
      margin: 0;
      overflow: visible;
      padding: 0;
      z-index: 1;
      /* Drag-to-rotate uses pointermove on the stage. Without
         `touch-action: none` the browser keeps ownership of horizontal
         swipes (treats them as pan / overscroll), and pointermove never
         fires on touch devices — so rotating cards by dragging silently
         fails on mobile. The page is overflow:hidden anyway, so we lose
         nothing by claiming the gesture for JS. Taps/clicks still fire
         normally on the cards and rotate buttons. */
      touch-action: none;
      /* The orbit math (cos/sin) is direction-agnostic via --galaxy-dir
         (set inline on the element in markup). Setting `direction: ltr`
         here keeps absolute positioning consistent; per-card content
         still picks up page direction via `.galaxy-card { direction: var(--page-direction, ltr); }` below. */
      direction: ltr;
    }

    /* ── Observatory — phone tuning ───────────────────────────────────
       Smaller footprint, dimmer strokes, and the fine-detail group +
       the faint outer ring dropped entirely. Keeps the rings a subtle
       whisper behind the orbit and clear of the focused card and the
       bottom rotate controls (CLAUDE.md: "reduce observatory detail,
       keep rings subtle" on mobile). */
    .galaxy-observatory {
      --obs-size: clamp(250px, 74vw, 380px);
      opacity: 0.5;
    }
    .obs-ring--outer,
    .obs-detail {
      display: none;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-observatory {
      opacity: 0.26;
    }

    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      /* Card width shrinks proportionally to viewport. Sized 25% larger
         than the previous mobile values so the cover artwork reads
         clearly without an overlay label. Floor: 120px (legible on
         360px phones). Cap: 175px (still safely under the desktop
         190px peer at 1024px).
         Exposed as `--card-base-width` so the focused-state scale rule
         below can target an exact visible size (`--center-card-w`)
         without re-deriving the clamp by hand. The series capsule
         overrides this variable for its slightly wider footprint. */
      --card-base-width: clamp(170px, 48vw, 240px);
      /* Centered-state visible width. Clamped by BOTH inline (vw) and
         block (dvh) so the focused `selected.png` cover (intrinsic
         ~1:1.5 aspect — see LibraryCard's "selected.png is ~50% taller
         than front.png" comment) never overflows the carousel band on
         short phones, tablets in landscape, or any viewport where vw
         alone would let the cover bleed past the rotate-controls pill
         at the bottom. Bumped 15% (56→64vw, 30→34.5dvh) so the cover
         reads larger; the cover height (= width × 1.5) grows by the
         same 15% since aspect is preserved. Single source of truth —
         every counter-scale and the reading-entry panel width below
         derive their value from this. */
      --center-card-w: min(64vw, 34.5dvh);
      width: var(--card-base-width);
      cursor: pointer;
      top: 50%;
      left: 50%;
      /* Mobile Focus Carousel — true focus model, NOT a flat orbit.
         Three visible slots: one main centered card, two clearly
         readable side previews peeking past the screen edges,
         everything else fully hidden via the ramps below.
         orbit-rx widened (was 170-250 / 52vw → now 200-280 / 62vw)
         so side stations land ~55% on-screen at common phone widths
         (was ~80%, which read as "small orbit of three near-equal
         cards" rather than "main card with previews from the next /
         previous slots"). On 390px → side-card centre ≈ 189px, just
         past the screen half (195px), so ~55% of the side card sits
         inside the viewport and ~45% beyond the edge — visibly
         "another card waiting." orbit-ry stays near-zero (0-12px)
         so every visible station sits on the same near-horizontal
         line — the carousel reads as a row, not an ellipse. */
      --orbit-rx: clamp(200px, 62vw, 280px);
      --orbit-ry: clamp(0px, 1.5vh, 12px);
      /* Mobile-only +20° offset aligns one station to EXACTLY 270°
         (top). ORBIT_START_DEG is 250° — chosen for desktop where
         item #0 must stay clear of the page title — so without the
         offset item #0 lands 20° left of top and item #1 ~31° right,
         giving TWO near-top cards (depth ≈ 0.94 and 0.93) instead of
         one dominant card. The +20° rotation puts item #0 at 270°
         (depth = 1) and item #1 / item #N-1 at exactly ±360°/N from
         top — those become the true side previews. Pure CSS, mobile-
         only by virtue of being inside @media (max-width: 1023px), so
         desktop's --orbit-active-angle calc (which lives in the
         min-width: 1024px block) is byte-for-byte unchanged.
         Chevron / drag / arrow / Atlas rotation still moves in
         360°/N steps, so after every step a NEW station lands at
         270° — navigation stays exactly as before. */
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg) + 20deg);
      /* Upper arc = near/front, lower arc = far/back (`1 - sin`), same
         inverted depth model as desktop. */
      --orbit-depth: calc((1 - sin(var(--orbit-active-angle, 0deg))) / 2);
      /* Side prominence — 0 at top/bottom, 1 at the inline extremes.
         Same cos² formulation as desktop so cards drifting to the
         visual edges fade into the cosmic field. */
      --orbit-side: calc(
        cos(var(--orbit-active-angle, 0deg)) *
        cos(var(--orbit-active-angle, 0deg))
      );
      /* Focus Carousel ramps — three-tier model:
           main   (depth ≈ 1   ): scale 1.10, opacity 1.00
           preview(depth ≈ 0.81): scale 0.82, opacity 0.73 (day)
                                  / 0.64 (night)
           hidden (depth ≤ 0.39): scale 0.55 (floor), opacity 0.00
         Slopes are intentionally steep so the cliff between
         "preview" and "hidden" lands between the N=7 ±51.43° ring
         (depth=0.812) and the next ring at ±102.86° (depth=0.389).
         Day opacity uses slope 1.73 — at depth=1 the un-clamped
         result (1.06) clamps to 1.0 (main), at depth=0.812 it
         lands at 0.73 (preview, well inside the 0.68-0.78 target),
         at depth=0.389 it lands at ~0.003 (preview cliff → next
         ring fully invisible). Night opacity uses a steeper slope
         (1.91) anchored so depth=1 lands at exactly 1.0 and
         depth=0.812 at 0.64 (within 0.58-0.70 target). Steeper
         night slope keeps far cards quieter on the dark cosmic
         scene while preserving the main station's full readability.
         Scale uses slope 1.5 / offset -0.4 so depth=0.812 lands at
         0.82 (in 0.78-0.86 target) and the floor 0.55 catches every
         farther ring. The 1.10 scale ceiling gives the main card a
         deliberate "pop" past 1× so it reads as dominant against
         the 0.82 side previews.
         --orbit-side is declared above for parity with desktop but
         intentionally unused on mobile — the focus carousel is a
         depth-only model.
         Day-mode opacity is the default below; the html.dark
         override after this rule tightens night-mode side previews. */
      --slot-scale: clamp(0.55, calc(1.5 * var(--orbit-depth) - 0.4), 1.1);
      --slot-opacity: clamp(0, calc(1.73 * var(--orbit-depth) - 0.67), 1);
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform var(--orbit-motion-duration, 600ms)
                  var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
        opacity var(--orbit-motion-duration, 600ms)
                var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1));
      /* Focus Carousel stacking — wider z-index range so the focused
         card (z≈100 at depth=1) decisively layers above the side
         previews (~z=82 at depth=0.815) and far cards (z≤1 at
         depth=0). Spec explicitly calls for separation by tier. */
      z-index: calc(1 + var(--orbit-depth) * 99);
      direction: var(--page-direction, ltr);
    }

    /* ── Mobile coverflow carousel ─────────────────────────────────
       Same coverflow rig the series-mode carousel uses, applied to
       the main universe orbit on phones. Every card carries a
       `--mobile-carousel-rel` CSS variable — 0 for the card closest
       to angular top (centre), +1/+2/… for clockwise siblings,
       -1/-2/… for counter-clockwise. SSR ships the natural
       rotation=0 mapping; universe-layout.ts's updateMobileSlots()
       rewrites it on every rotation so the centre always lands on
       the card closest to top.

       This rule has the same (0,1,0) specificity as the base
       .galaxy-card orbit transform above; it wins by being later
       in source. The series-mode carousel selector
       (`[data-stage-mode="series"] .galaxy-card.is-active-series-member`,
       specificity 0,3,0) still wins for series members so the two
       carousels nest cleanly. */
    .galaxy-card {
      --mobile-step: clamp(100px, 28vw, 170px);
      --mobile-abs-rel: max(
        calc(var(--mobile-carousel-rel, 0) * -1),
        var(--mobile-carousel-rel, 0)
      );
      --mobile-row-x: calc(
        var(--mobile-carousel-rel, 0)
        * var(--mobile-step)
        * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translateX(var(--mobile-row-x))
        perspective(900px)
        rotateY(calc(
          var(--mobile-carousel-rel, 0)
          * -18deg
          * var(--galaxy-dir, 1)
        ))
        scale(calc(1.50 - var(--mobile-abs-rel) * 0.22));
      opacity: calc(1 - var(--mobile-abs-rel) * 0.32);
      /* Centre wins z-stack so its reading-entry overlay sits on
         top of side cards. 100 matches the previous 3-slot ceiling. */
      z-index: calc(100 - var(--mobile-abs-rel));
      /* Defensive: keep side cards clickable so users can tap any
         visible book to bring it to centre. */
      pointer-events: auto;
      /* Hide the back of the card when its rotateY pushes past 90°
         (cards with |rel| >= 5 are rotated to ±90°+). Without this
         the card's title / subtitle text bleeds through mirrored on
         the inline-end edge, reading as "leftover marks". Modern
         engines need both the standard and -webkit- form for the
         transform to flatten correctly inside the 3D context. */
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
    }

    /* ── Carousel position indicator pill ────────────────────────────
       Pinned just above the bottom chevron pill (which itself sits at
       env(safe-area-inset-bottom)). Tabular-nums keeps the "3 / 10"
       numerals on a stable grid as they change. role=status +
       aria-live=polite on the wrapper announces position changes to
       screen readers without stealing focus. The pill is purely
       informational — pointer-events: none lets touches drop through
       to anything that might briefly underlap it. */
    .galaxy-position-indicator {
      display: inline-flex;
      position: fixed;
      /* Stacks just above the lifted arrows pill (~50px tall sitting
         at safe-area + 14px). 8px gap keeps indicator + arrows reading
         as one cluster instead of two unrelated chips. */
      inset-block-end: calc(env(safe-area-inset-bottom, 0px) + 72px);
      left: 50%;
      transform: translateX(-50%);
      align-items: center;
      gap: 0.4rem;
      padding: 0.34rem 0.95rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.42);
      border: 1px solid rgba(255, 255, 255, 0.18);
      color: rgba(255, 255, 255, 0.96);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      font-variant-numeric: tabular-nums;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.14),
        0 4px 12px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      pointer-events: none;
      z-index: 40;
    }
    :global(html:not(.dark)) .galaxy-position-indicator {
      background: rgba(255, 253, 249, 0.86);
      border-color: rgba(34, 52, 92, 0.20);
      color: rgba(22, 34, 60, 0.92);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.65),
        0 2px 6px rgba(30, 45, 80, 0.10);
    }
    .galaxy-position-sep {
      opacity: 0.5;
      font-weight: 400;
    }

    /* Light-mode phone tuning — a lighter card shadow than desktop:
       smaller blur, no cyan edge, to keep compositing cheap and the
       bright scene uncluttered. Overrides the non-media light-mode
       `.galaxy-card` filter above (same specificity, declared later
       and inside a matching media query).
       Also re-applies the mobile Focus Carousel --slot-opacity formula:
       the global light-mode block at the top of this stylesheet sets a
       0.62 opacity floor (desktop-orbit polish), which would otherwise
       win by specificity (0,2,0 vs the plain mobile `.galaxy-card` at
       0,1,0) and prevent far cards from fading to zero on phones.
       Restating it inside this matching-specificity block keeps day
       mode aligned with the aggressive depth ramp the Focus Carousel
       needs — main card 1.0, side previews ~0.73, far cards 0.0. */
    :global(html:not(.dark)) .galaxy-card {
      --slot-opacity: clamp(0, calc(1.73 * var(--orbit-depth) - 0.67), 1);
      filter:
        drop-shadow(0 3px 8px rgba(34, 52, 92, 0.16))
        drop-shadow(0 1px 2px rgba(34, 52, 92, 0.12));
    }

    /* Night-mode Focus Carousel tightening — side previews sit dimmer
       than day mode and far cards fall to zero just past the side
       ring, so the night orbit reads calmer and deeper without neon
       overload. Slope 1.91 anchored so depth=1 → opacity 1.00 exactly
       and depth=0.812 → opacity 0.64 (in the 0.58-0.70 user target).
       Far rings (depth ≤ 0.389) un-clamp to negative and clamp to 0.
       Specificity (0,2,1) beats the plain `.galaxy-card` rule
       (0,2,0), so this override wins on html.dark and is ignored on
       html:not(.dark) (the day path above). */
    :global(html.dark) .galaxy-card {
      --slot-opacity: clamp(0, calc(1.91 * var(--orbit-depth) - 0.91), 1);
    }

    /* Night-mode-only subtle dark halo behind the carousel area, so
       the main centred card stands out cleanly even when the cosmic
       background image's bright book icon happens to sit directly
       behind it. Painted as a soft radial gradient inside the stage's
       own ::before, sized comfortably past the orbit so the falloff
       blends into the bg without a visible seam. Static — no
       animation, no transition, no interaction with cards or input.
       Day mode skips this entirely: the AI Researcher Workspace scene
       already gives high contrast to the cards. */
    :global(html.dark) .library-galaxy::before {
      content: "";
      position: absolute;
      inset: -8vh -10vw;
      background: radial-gradient(
        ellipse 65% 45% at 50% 50%,
        rgba(0, 0, 16, 0.50) 0%,
        rgba(0, 0, 16, 0.30) 45%,
        transparent 85%
      );
      pointer-events: none;
      z-index: -1;
    }

    /* Series capsule a touch wider than a book card, same ratio as desktop.
       Scaled 25% alongside the book/lesson cards above. Overrides
       `--card-base-width` so the focused-scale math below uses the
       series footprint rather than the book/lesson one. */
    .galaxy-card[data-role="series"] {
      --card-base-width: clamp(195px, 54vw, 275px);
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }

    /* Per-kind accent tint — books gold, lessons cyan, course violet.
       Sets a CSS variable that the inner LibraryCard reads for its
       accent strip; same contract as desktop. */
    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="course"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    /* Drag-to-rotate: kill the transform transition while a drag is
       in flight so the carousel tracks the cursor in real time. */
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
      cursor: grabbing;
    }

    /* Block the browser's native image-drag ghost on every card and
       on its descendant artwork so pointermove tracking stays smooth. */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* Galaxy orbit controls (rotate ←/→ buttons) on mobile — pinned
       to the bottom of the viewport so they stay clear of the orbit /
       carousel and remain easy to tap. Self-contained pill styling
       (flex + background + border + blur) lives here because the
       desktop @media block below isn't reached on phones; without it
       the wrapper falls back to display:block and stretches across
       the viewport. z-index sits above the focused card (z:30) so the
       buttons never get covered by an enlarged centered card. */
    .galaxy-orbit-controls {
      /* Lifted 14px off the screen edge so the controls read as an
         intentional pill belonging to the carousel rather than chrome
         pinned to the viewport floor. The indicator pill stacks
         directly above (safe-area + 72px), so the two land as a
         single visual cluster anchored beneath the carousel. */
      position: fixed !important;
      inset-block-end: auto;
      bottom: calc(env(safe-area-inset-bottom, 0px) + 14px) !important;
      left: 0;
      right: 0;
      margin-inline: auto;
      display: flex;
      width: max-content;
      align-items: center;
      gap: 0.625rem;
      padding: 0.375rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.22),
        0 8px 22px rgba(0, 0, 0, 0.34);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      z-index: 40;
      direction: ltr;
    }
    :global(html:not(.dark)) .galaxy-orbit-controls {
      background: rgba(255, 253, 249, 0.78);
      border-color: rgba(34, 52, 92, 0.18);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.65),
        0 6px 16px rgba(30, 45, 80, 0.12);
    }
    .galaxy-orbit-btn {
      /* Rotate control — pearl glass circle sized for a comfortable
         touch target (38px button + 6px pill padding ≈ 50px tactile
         area, clears the 44px minimum). */
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: rgba(255, 255, 255, 0.94);
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.26);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.32),
        0 2px 6px rgba(0, 0, 0, 0.26);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease,
                  border-color 0.15s ease, transform 0.15s ease;
    }
    :global(html:not(.dark)) .galaxy-orbit-btn {
      color: rgba(22, 34, 60, 0.88);
      background: rgba(255, 255, 255, 0.55);
      border-color: rgba(34, 52, 92, 0.20);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        0 1px 3px rgba(30, 45, 80, 0.10);
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.36);
      outline: none;
    }
    .galaxy-orbit-btn svg {
      width: 16px;
      height: 16px;
    }
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

    /* ── Mobile focus state (mirror of desktop) ────────────────────
       All the focus-state CSS — centered card scaling, galaxy CTA
       slot, reading-entry overlay panel — lives inside the desktop
       `@media (min-width: 1024px)` block below, so on mobile none of
       those rules apply. Without this duplication a tap on a mobile
       orbit card doesn't visibly scale it, and the reading-entry
       `<a>` + close `<button>` render at default styling, polluting
       the screen with their text under every card.

       This block replays just enough of the desktop rules to give
       mobile the same "tap card → scales up, X close button appears,
       reading-entry panel sits flush below the cover" behavior. */

    /* Focused card flies UP out of the orbit and lands flush against
       the hero subtitle ("כל הידע שלך במרחב אחד חי ומתפתח"), per
       Tomer's request: "טופ הכרטיס במובייל יתחיל ממש בצמוד למלל…".
       Geometry:
         - The hero strip is content-driven (eyebrow + title +
           subtitle + paddings), so its bottom edge lands at a near-
           constant pixel offset (~188px) below the global header on
           every phone — NOT a fixed dvh ratio. Pixel-anchored target
           is therefore more reliable than a dvh translate.
         - `.galaxy-card`'s pre-translate centre sits at 50dvh of the
           viewport (the orbit container is `top: 50dvh; translate
           (-50%, -50%)`, and the card itself is `top: 50%` of that
           container — so the card centre pre-translate = 50dvh).
         - To put the card's VISIBLE top at `--mobile-focused-top` we
           need the visible centre at `top + visible_height/2`. The
           visible height = `--center-card-w * 1.5` (the ~1:1.5
           `selected.png` aspect). So translateY must shift the
           centre from 50dvh to (--mobile-focused-top + 0.75 * card_w).
         - The expression below evaluates dynamically — no per-phone
           tuning needed. As `--center-card-w` clamps differently on
           short vs tall vs wide viewports the translateY recomputes
           so the top edge always lands at `--mobile-focused-top`.
       The existing `transition: transform 600ms …` on `.galaxy-card`
       drives the animation between orbit position and this resting
       spot — no JS change required.
       Counter-scaled descendants (`.reading-entry-overlay`,
       `.galaxy-cta`) multiply by `cbw / --center-card-w` to hold
       their authored size; they're unaffected by the outer
       translateY since translation is uniform, not magnified by
       scale. */
    /* `--mobile-focused-top` is NOT hardcoded here. The
       `initFocusedCardAnchor()` script sets it on `.library-root`
       (viewport Y of `.lh-subtitle`'s bottom) so the focused card
       top lands FLUSH against the hero subtitle on every viewport,
       independent of font-clamp variance / theme / DPR. The 168px
       fallback in the var() below only matters for the brief frame
       before the script runs. */
    .galaxy-card[data-pos="center"] {
      transform:
        translateY(calc(
          var(--mobile-focused-top, 168px)
          - 50dvh
          + 0.75 * var(--center-card-w)
        ))
        translate(-50%, -50%)
        scale(calc(var(--center-card-w) / var(--card-base-width)));
      opacity: 1;
      z-index: 30;
      cursor: default;
    }

    /* Mobile non-centre recede — the desktop counterpart at
       `.library-galaxy[data-galaxy-focused] .galaxy-card:not([data-pos="center"])`
       lives inside `@media (min-width: 1024px)` so it never reaches
       phones. Duplicated here with gentler values: mobile cards sit
       closer to the viewport edges and aggressive blur/dim reads as
       harsh on a small screen.

       Specificity (0, 4, 0) wins over the mobile `.galaxy-card` (0, 1, 0)
       opacity rule, so `var(--slot-opacity)` is correctly overridden.
       `scale` is the individual CSS property (not `transform: scale`)
       so it composes with the orbit's cos/sin transform without us
       having to recompute coordinates. Trigger is `data-galaxy-focused`,
       set by universe-layout.ts when any card is centred — same flag
       as desktop, no carousel-logic changes. */
    .library-galaxy[data-galaxy-focused]
      .galaxy-card:not([data-pos="center"]) {
      filter: blur(2px) saturate(0.85);
      opacity: 0.42;
      scale: 0.9;
      transition:
        filter 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        scale 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Reduced motion: skip the recede entirely on mobile too. The
       desktop reduced-motion guard at line ~3077 lives inside the
       desktop media block, so phones need their own. */
    @media (prefers-reduced-motion: reduce) {
      .library-galaxy[data-galaxy-focused]
        .galaxy-card:not([data-pos="center"]) {
        transition: none;
        scale: 1;
        filter: none;
        opacity: var(--slot-opacity);
      }
    }

    /* On mobile we drop the open-orb + X-close cluster — Tomer asked to
       remove the X next to the focused card. Closing is handled by
       tapping outside the card / tapping another orbit station. The
       `.galaxy-cta` wrapper itself stays visible so its only remaining
       contents — the series action pills (Show items / Details) — can
       sit at the bottom of the focused series card on mobile too. */
    .galaxy-cta-open,
    .galaxy-cta-open-label,
    .galaxy-cta-close {
      display: none !important;
    }
    /* Mobile placement for the series action pills — mirrors the desktop
       rules at the bottom of this stylesheet so the wrapper has the same
       positioning context on every viewport. Lifted into the mobile block
       because the desktop `.galaxy-cta` rule lives inside
       `@media (min-width: 1024px)` and would otherwise leave the mobile
       wrapper unstyled (in-flow, always visible). */
    .galaxy-cta {
      position: absolute;
      top: 66%;
      left: 50%;
      bottom: auto;
      right: auto;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
      z-index: 2;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
      /* Counter-scale against the focused card's mobile scale
         (`scale(var(--center-card-w) / var(--card-base-width))`).
         Without this the pills inherit the card magnification and
         render oversized. Multiplying by the inverse keeps the pills
         at their authored visual size on every phone. */
      transform: translate(-50%, -50%) scale(calc(var(--card-base-width) / var(--center-card-w)));
    }
    /* Mobile-only shrink for the series action pills. The counter-scale
       above keeps them at authored size, but authored is still too tall
       for a phone (Tomer reported huge / out-of-proportion buttons on
       mobile). Tighten padding, font and icon dimensions specifically
       inside the mobile block so the pills read as compact chips under
       the focused series card. */
    .galaxy-cta-series-actions { gap: 0.4rem; flex-direction: row; }
    .galaxy-cta-series-btn {
      padding: 0.35rem 0.7rem 0.35rem 0.35rem;
      font-size: 0.72rem;
      gap: 0.4rem;
      border-radius: 12px;
      letter-spacing: 0;
    }
    .galaxy-cta-series-btn-icon {
      width: 22px;
      height: 22px;
    }
    .galaxy-cta-series-btn-icon svg {
      width: 12px;
      height: 12px;
    }
    .galaxy-cta-series-btn-label {
      font-size: 0.72rem;
    }

    /* ── Mobile series-mode coverflow override ─────────────────────
       The desktop coverflow step (clamp(140px, 17vw, 200px)) puts
       far books well past a phone's viewport edge. Tune the same
       transform for mobile: tighter step, gentler 3D rotation,
       quicker depth fade so 5 books fit comfortably in a 360-420px
       viewport. The base selector wins over the mobile 3-slot rules
       on specificity; this override just retunes the math without
       changing the structural pattern.

       Also explicitly suppresses the mobile-slot transform/opacity/
       z-index/pointer-events on series members — the mobile-slot
       writer in universe-layout.ts can still tag them during a
       rotation that fires while series mode is active. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-member {
      --series-step: clamp(78px, 22vw, 130px);
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        perspective(900px)
        rotateY(calc(var(--series-rel) * -16deg * var(--galaxy-dir, 1)))
        scale(calc(0.98 - var(--series-abs-rel) * 0.14));
      opacity: calc(1 - var(--series-abs-rel) * 0.34);
    }
    /* Position the carousel chevrons closer to the focused card on
       mobile so they don't drift to the unreachable screen edges. */
    [data-stage-mode="series"] .series-carousel-nav {
      width: 40px;
      height: 40px;
    }
    [data-stage-mode="series"] .series-carousel-nav-prev {
      inset-inline-start: clamp(4px, 2vw, 16px);
    }
    [data-stage-mode="series"] .series-carousel-nav-next {
      inset-inline-end: clamp(4px, 2vw, 16px);
    }
    [data-stage-mode="series"] .series-carousel-nav svg {
      width: 16px;
      height: 16px;
    }
    /* Position pill — slightly smaller padding on mobile, lifted
       higher so it doesn't collide with the bottom orbit chrome. */
    [data-stage-mode="series"] .series-carousel-position {
      font-size: 0.74rem;
      padding: 0.3rem 0.7rem;
      inset-block-end: clamp(56px, 9vh, 88px);
    }

    /* Image-based reading-entry panel — mobile equivalent of the
       desktop CTA. The visual base IS `reading-entry-card1.png`. The
       title, subtitle, summary pill and meta row all live INSIDE the
       panel. FULL counter-scale (cbw/--center-card-w) neutralises the
       focused card's --center-card-w/cbw scale so spec px values map
       1:1 to visible pixels. */
    /* On mobile the centered card keeps `.lc-orbit`'s resting padding
       (~1.125rem bottom). The desktop branch zeroes this for the
       focused state (see `:global(.lc-orbit)` rules in the desktop
       media block) — mobile had no equivalent rule, so the cover sat
       ~18px inside the card box and stacked with both PNGs' transparent
       glow to produce the visible gap between cards. Mirror the desktop
       fix here so the cover artwork pins to the box edges. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      padding: 0 !important;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      margin-block: 0 !important;
      margin-inline: 0 !important;
      /* LibraryCard's desktop focused rule applies
         `transform: scale(1.5)` + `width: calc(100% + 1.5rem)` to the
         cover artwork, which on top of `.galaxy-card`'s own
         center-state scale blows the visible cover to ~93vw — exactly
         the overflow Tomer reported. On mobile the wrapper's
         `--center-card-w` scale already supplies the focus bump; the
         artwork itself should sit at 1:1 inside the card, no inline
         bleed. Override here with `!important` to win against the
         LibraryCard rule's higher selector specificity. */
      transform: none !important;
      width: 100% !important;
    }

    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      /* Sit DIRECTLY BELOW the cover — no overlap onto its content
         (Tomer: "כרטיס התחל קריאה לא אמור לדרוס את תוכן כרטיס
         הספר שמעליו"). But 8px pull-up was too tight — `selected.png`
         carries transparent padding at its bottom edge, so the
         visible artwork ends BEFORE the wrapper's `100%` mark and a
         visible gap appears between the cover's painted bottom and
         the panel's top.
         30 logical px (~40 screen px after the wrapper's 1.3× scale)
         pulls the panel up just enough to land its top edge at the
         visible artwork's bottom, NOT into the title / author text
         which sits well above the artwork's bottom edge. If the
         transparent padding in `selected.png` is ever re-trimmed,
         this value can come back down. */
      top: calc(100% - 30px);
      /* Width is derived from `--center-card-w` so the panel always
         sits visibly NARROWER than the cover card above it (Tomer:
         "כפתור המשך קריאה — רוחבו צריך להיות קצר מרוחב הכרטיס").
         The 18px subtraction leaves a 9px gap on each side so the
         panel reads as a smaller nested block rather than a chrome
         layer competing with the card outline. `max-width: none`
         overrides the previous 390px cap which would otherwise let
         the panel exceed the card on phones where the card is
         narrower than 390. Net rendered width = CSS width (parent
         scale × child counter-scale = 1), so the formula yields
         exactly `--center-card-w - 18px` on screen. */
      width: calc(var(--center-card-w) - 18px);
      max-width: none;
      /* Height reduced 15% then a further 10% (220 → 187 → 168)
         per Tomer's tuning passes — the action row + summary pill
         still render cleanly at this tight budget and the panel
         reads as a compact nested block under the cover. */
      height: 168px;
      border-radius: 22px;
      box-sizing: border-box;
      transform:
        translate(-50%, 0)
        scale(calc(var(--card-base-width) / var(--center-card-w)));
      transform-origin: top center;
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 30;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    .reading-entry-main {
      position: absolute;
      inset: 0;
      display: block;
      border-radius: 22px;
      background: transparent;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
      z-index: 1;
      -webkit-tap-highlight-color: transparent;
    }
    .reading-entry-main:focus-visible {
      outline: none;
    }
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 22px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card1.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      z-index: 2;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }
    /* ─── Mobile content stack ─────────────────────────────────────
       Holds ONLY the action row (primary CTA + secondary link). Same
       positioning rules as desktop, tightened for phone widths.
       `justify-content: center` centres the single child vertically
       in the available area below the baked-in book icon. */
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: 32%;
      bottom: 12px;
      width: calc(100% - 32px);
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: center;
      text-align: center;
      pointer-events: none;
      z-index: 3;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }
    .reading-entry-chapter {
      font-size: 23px;
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: rgba(255, 255, 255, 0.98);
      text-shadow:
        0 0 12px rgba(120, 200, 255, 0.32),
        0 2px 4px rgba(0, 0, 0, 0.55);
      margin: 0;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .reading-entry-progress {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
    }
    .reading-entry-progress-track {
      flex: 1 1 auto;
      position: relative;
      height: 4px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      overflow: hidden;
      box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.35);
    }
    .reading-entry-progress-fill {
      display: block;
      width: var(--re-progress, 0%);
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #b8e6ff 0%, #22d3ee 60%, #0ea5e9 100%);
      box-shadow:
        0 0 6px rgba(34, 211, 238, 0.55),
        0 0 2px rgba(184, 230, 255, 0.85);
      transition: width 480ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reading-entry-progress-pct {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: rgba(170, 230, 255, 0.92);
      white-space: nowrap;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      min-width: 32px;
      text-align: end;
    }
    .reading-entry-facts {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(220, 235, 250, 0.62);
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
      line-height: 1.2;
    }
    .reading-entry-fact {
      white-space: nowrap;
    }
    .reading-entry-fact + .reading-entry-fact::before {
      content: '·';
      margin: 0 6px;
      opacity: 0.65;
    }
    .reading-entry-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      width: 100%;
    }
    .reading-entry-cta {
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      /* min-width relaxed from 170 → 130 so the button still fits
         when the panel is sized off `--center-card-w - 14px` on
         narrower phones (e.g. 320×568 → card 170px → panel 156px).
         At 130px + 16px text padding the "המשך קריאה ←" label still
         renders comfortably without wrapping. */
      min-width: 130px;
      max-width: calc(100% - 8px);
      height: 36px;
      padding: 0 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: rgba(6, 18, 40, 0.96);
      background:
        linear-gradient(180deg,
          rgba(220, 245, 255, 0.96) 0%,
          rgba(120, 215, 240, 0.96) 55%,
          rgba(34, 184, 216, 0.96) 100%);
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 18px rgba(34, 211, 238, 0.45),
        0 4px 12px rgba(8, 18, 40, 0.35);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.4);
    }
    .reading-entry-cta-label {
      line-height: 1;
    }
    .reading-entry-cta-arrow {
      width: 13px;
      height: 13px;
      flex-shrink: 0;
      stroke: currentColor;
    }
    [dir="rtl"] .reading-entry-cta-arrow {
      transform: scaleX(-1);
    }
    .reading-entry-summary-pill {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.03em;
      line-height: 1;
      color: rgba(190, 225, 250, 0.78);
      background: transparent;
      border: 1px solid transparent;
      text-decoration: none;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      cursor: pointer;
      transition:
        color 160ms ease,
        background 160ms ease,
        transform 160ms ease;
    }
    .reading-entry-summary-pill::after {
      content: '›';
      font-size: 13px;
      line-height: 1;
      opacity: 0.7;
      transform: translateY(-1px);
    }
    [dir="rtl"] .reading-entry-summary-pill::after {
      content: '‹';
    }
    .reading-entry-summary-pill:active {
      transform: scale(0.97);
      background: rgba(18, 32, 60, 0.55);
    }

    /* Very small phones (≤360px): tighten the inner content (font
       sizes, button height) so nothing clips. Overlay width is no
       longer overridden here — it's derived from `--center-card-w`
       and naturally shrinks with the card on small phones. */
    @media (max-width: 360px) {
      .reading-entry-overlay      { height: 159px; }
      .reading-entry-text         { top: 30%; }
      .reading-entry-chapter      { font-size: 21px; }
      .reading-entry-facts        { font-size: 11px; }
      .reading-entry-cta          { min-width: 110px; height: 34px; font-size: 12.5px; padding: 0 14px; }
      .reading-entry-summary-pill { font-size: 10.5px; }
    }
    /* Hover is desktop-only per the spec — mobile keeps just the
       press-in scale + brightness so taps still feel responsive. */
    .reading-entry-overlay:has(.reading-entry-main:active) {
      transform:
        translate(-50%, 0)
        scale(calc((var(--card-base-width) / var(--center-card-w)) * 0.985));
      filter: brightness(1.04);
    }

    /* Standalone extras wrapper, secondary link and legacy meta-row
       classes are retired in this design — the meta strip is now
       `.reading-entry-facts` (styled above). The classes still appear
       in the DOM as dead-cohabitant hooks; nothing paints. */
    .center-card-extras,
    .cc-secondary-link,
    .cc-meta-label {
      display: none;
    }
  }

  /* Small-screen baseline for the orbit scene's vertical offset. The
     orbit itself is hidden below 1024px (see `.lb-area-featured` above),
     but the variable is defined here so the responsive ladder
     (32 → 56 → 72) is complete at every breakpoint. The transform is
     applied on `.library-galaxy` inside the 1024+ query, so a parent
     transform never affects mobile layout. */
  .library-galaxy {
    --orbit-vertical-offset: 32px;
    /* Carousel rotation motion — calmer, longer ease so stations glide
       through the knowledge space rather than snapping between positions.
       The curve is a smooth ease-out (no bounce, no overshoot) sitting
       at the slow end of the user-spec range (550-850ms) so movement
       reads as premium and easy to track without losing orientation.
       Consumed by the orbit-card transform + opacity transition in
       both light and dark mode. */
    --orbit-motion-duration: 720ms;
    --orbit-motion-ease: cubic-bezier(0.25, 1, 0.32, 1);
  }
  /* Reduced motion: collapse the rotation duration so depth changes
     apply instantly. The global theme.css rule already neutralises the
     transition property; this keeps the token itself consistent for
     anything that reads it inside a calc(). */
  @media (prefers-reduced-motion: reduce) {
    .library-galaxy { --orbit-motion-duration: 1ms; }
  }

  /* ── Tablet (≥640px): same mobile flow, more inline padding ──
        Top padding kept tight so the hero text remains close to the
        header line. Inline + bottom paddings grow for breathing
        room around the wider viewport. */
  @media (min-width: 640px) {
    .library-root { padding: 0.5rem 1.5rem 4rem; }
  }

  /* ── Desktop (≥1024px): ONE viewport dashboard, no long scroll ───── */
  @media (min-width: 1024px) {
    .library-root {
      /* Block padding owns top/bottom rhythm. Inline padding is
         SYMMETRIC so `.library-body` (max-width + margin: 0 auto)
         centers ITSELF on the viewport — that gives the galaxy core
         (which sits at the visual center of the body) a perfectly
         viewport-centered anchor. The clamp value also clears the
         FloatingSidebar at the inline-end side (rail width ~92px
         + ~16px gap from edge). Independent from this: the two
         support panels (ContinueLearningCard + LibraryStatsPanel)
         are `position: fixed` from inside their own components and
         anchor directly to the viewport edge via `inset-inline-start: 20px`,
         so their 20px gap stays constant regardless of this padding. */
      /* Top padding tightened (1.25rem → 0.25rem) so the desktop
         hero strip sits right under the sticky header line — same
         preference applied on mobile. The galaxy stage below the
         hero now picks up the freed vertical space and the central
         core's vertical position is governed by --orbit-vertical-
         offset rather than by this padding. */
      padding-block-start: 0.25rem;
      padding-block-end: 1.5rem;
      padding-inline: clamp(60px, 8vw, 120px);
      /* Viewport math is owned by LibraryLayout — the layout sets
         --library-dashboard-min-height = calc(100dvh - --library-header-offset)
         on the slot wrapper, so the page does not have to know the
         header's pixel height. */
      min-height: var(--library-dashboard-min-height, 100dvh);
      /* Desktop layered backdrop, FIRST listed = TOP of the stack.
         Calibrated to the sampled asset palette: every layer either
         uses one of the sampled navy tones or stays a small violet
         accent centered on the stage. Hero + side accents were
         removed (asset isn't violet there).
         1. vignette        — corner darkening with sampled #000010
         2. primary accent  — small violet halo at the stage center
         3. secondary fade  — bottom navy continuation (#000010)
         The base color var(--yuval-galaxy-bg) (#01051b) sits beneath. */
      background-image:
        var(--yuval-galaxy-bg-vignette),
        var(--yuval-galaxy-bg-radial-primary),
        var(--yuval-galaxy-bg-radial-secondary);
    }

    /* Full-page atmospheric underlay removed: it placed a blurred copy
       of the asset under the whole page, which created a non-uniform
       halo right under where the central image sits — the eye then
       read the contrast between halo-area and rest as a rectangle
       outline, even after the asset's edges were faded. The flat
       page-bg color (#0a0a1f on .library-root above) plus the
       existing radial gradients + vignette are now the only
       atmospheric layers. */

    /* Re-enable real flex container on the center stage main.
       `.lb-area-right` stays as `display: contents` (inherited from the
       mobile baseline) — its only child `.lb-area-quick-mobile` is
       `display: none` on desktop, so the aside contributes nothing
       to the grid. The desktop floating rail lives outside the grid
       entirely (`<FloatingSidebar>` with `position: fixed`). The two
       support panels (ContinueLearningCard + LibraryStatsPanel) also
       live outside the grid via `position: fixed` from inside their
       own components. */
    .lb-area-stage {
      display: flex;
      flex-direction: column;
    }

    /* Reset mobile order — explicit grid placement takes over. */
    .lb-area-hero,
    .lb-area-featured,
    .lb-area-quick-mobile { order: initial; }

    /* Restore the orbit stage that the mobile baseline hid above.
       `.lb-area-hero` no longer needs an explicit restore here
       because the mobile baseline keeps it visible (the hero text
       is shown on mobile too — see the override block below). */
    .lb-area-featured     { display: block; }

    /* 2-column dashboard with LANGUAGE-AWARE column placement:
         column 1 = inline-start  → outer support sidebar (continue +
                                    stats), on the side WHERE reading
                                    starts (visual-right in RTL Hebrew,
                                    visual-left in LTR English)
         column 2 = inline-end    → galaxy stage (center of the page),
                                    on the side opposite to where the
                                    document flow starts
       The narrow rail no longer claims a grid column — the desktop
       FloatingSidebar lives outside the grid as `position: fixed`,
       pinned to the inline-end edge of the viewport. The body adds
       a `padding-inline-end` gutter so the support sidebar doesn't
       collide with the floating rail.
       In LTR: support is visual-left, floating rail is visual-right
               (stage sits between sidebar and rail).
       In RTL: support is visual-right, floating rail is visual-left
               (same relationship, mirrored).
       No physical-direction lock. Grid resolves natively to the
       page's `dir` attribute. */
    .library-body {
      /* Single-column body — the two support panels are taken OUT of
         the body's flow (each is `position: fixed` from inside its
         own component CSS). No inline padding here: the SYMMETRIC
         inline padding lives on `.library-root` instead, so the body's
         max-width + margin: 0 auto centers it perfectly on the
         viewport. The galaxy core (image centered at left:50% of
         `.library-galaxy` inside the body) thus lands exactly at the
         viewport's center — independent of where the fixed support
         panels sit. */
      display: block;
      min-height: calc(var(--library-dashboard-min-height, 100dvh) - 2.75rem);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0;
    }
    /* Galaxy stage still uses physical left/right for the absolute
       orbit slots so the TL/TR/ML/MR/BL/BR placement of the floating
       cards is language-independent (the slots target visual corners,
       not reading-flow corners). Cards inside re-apply page direction
       so Hebrew titles still read RTL. */
    .library-galaxy { direction: ltr; }
    .galaxy-card    { direction: var(--page-direction, ltr); }

    /* The two support panels (ContinueLearningCard + LibraryStatsPanel)
       are anchored individually via `position: fixed` from inside
       their own component CSS — ContinueLearningCard on the
       inline-start edge, LibraryStatsPanel on the inline-end edge,
       both at top: header-offset + 20px. They frame the carousel
       from opposite sides. No wrapper needed here. */

    /* ── Center stage: hero + galaxy ──────────────────────────────── */
    .lb-area-stage {
      /* Zero stage-gap: the hero now lives as the title strip of the
         galaxy, not a separate block. .galaxy-stage provides its own
         interior padding for the orbits. */
      gap: 0;
      min-width: 0;
      position: relative;
      /* No background layer here. The page-level unified system
         (--yuval-galaxy-bg-radial-primary on .library-root) is centered
         right under this column and provides the violet field for both
         hero and stage. Adding a column-level layer here used to
         compound the violet and produce a "block within a block" feel. */
    }
    .lb-area-hero {
      flex: 0 0 auto;
      max-width: 680px;
      margin-inline: auto;
      width: 100%;
    }
    /* Galaxy stage takes the remaining vertical space — with the
       recommendations strip removed, the orbit owns the entire lower
       half of the viewport so the central knowledge core can breathe. */
    .lb-area-featured {
      flex: 1 1 auto;
      min-height: 0;
      position: relative;
    }

    /* ── Mobile quick-actions aside: hidden on desktop ──
       The aside stays as `display: contents` (mobile baseline). Its
       only child `.lb-area-quick-mobile` is `display: none` on desktop,
       so the aside contributes nothing visible to the grid. The
       desktop floating rail is `<FloatingSidebar>` rendered outside
       `.library-body` with `position: fixed`. */
    .lb-area-quick-mobile { display: none; }

    /* Galaxy stage on desktop: absolute canvas anchored to the stage.
       Min-height bumped to 540 so the ML/MR orbit cards have enough
       vertical room not to overlap the central core at the narrowest
       desktop widths (1024-1199px).

       Background tuned to match the asset palette: a soft violet
       radial glow at the center fading to the page's deep navy at
       the edges. This is the primary fix for the "rectangle pasted
       in" look — the stage no longer has hard color contrast where
       the asset ends; the violet center seamlessly continues the
       asset's own glow, and the dark edges seamlessly continue the
       page background. */
    .library-galaxy {
      position: relative;
      display: block;
      height: 100%;
      min-height: 540px;
      margin: 0;
      overflow: visible;
      flex-direction: initial;
      scroll-snap-type: none;
      padding: 0;
      scrollbar-width: auto;
      scrollbar-color: auto;
      /* Vertical offset of the entire orbit scene (rings, central core,
         floating cards, glow, rotation controls) so rotated carousel
         items never overlap the page title above. Lives on the orbit
         container only — page title, breadcrumb, side panels and grid
         shell are unaffected. Responsive steps below override the value
         per breakpoint; the transform itself stays the same.
         Bumped to 90px (was 36px) so the TOP of the top-of-orbit cards
         always has at least ~20px of breathing room from the hero
         subtitle on every common 1024px+ viewport.
         Reduced from 90→50 (paired with --orbit-ry shrinking by the
         same ~40px) so the orbit becomes shorter on desktop while the
         TOP of the carousel stays at the same Y as before. */
      --orbit-vertical-offset: 50px;
      transform: translateY(var(--orbit-vertical-offset));
    }
    /* The earlier `.library-galaxy::before` underlay halo and
       `.galaxy-stage-veil` overlay were experimental edge-blending
       layers. Both removed: the new full-page actual-asset underlay
       on `.library-root::before` propagates the asset's visual
       language across the entire screen, so per-asset edge blending
       layers are no longer necessary. */
    .library-galaxy::-webkit-scrollbar { height: auto; }

    /* `.galaxy-core` and its child rules (.galaxy-core-pool,
       .galaxy-core-aura) were removed alongside their markup nodes:
       they were sized for a 240×240 CSS-rendered core, but the asset
       is 760-820px wide and covered them entirely. They contributed
       nothing visible. The asset + page-level unified backdrop is
       the entire central composition. */

    /* The galaxy PNG no longer lives inside the orbit stage; it is
       now rendered once at the page root as `.knowledge-scene-background`
       (full-viewport fixed). Edge mask, max-width, focus-dim and
       reduced-motion rules that targeted `.galaxy-stage-image` were
       removed alongside the markup. */

    /* ── Floating cards: elliptical orbit.
          Every readable item has its own station along an ellipse around
          the central area. Position is computed in CSS via cos()/sin()
          from each card's `--orbit-angle` (set inline per card in the
          markup). --galaxy-dir mirrors the X axis so the inline-start
          arc stays visual-left in LTR and visual-right in RTL.
          Depth is angle-derived: cards on the upper arc of the orbit
          (sin < 0) read as nearer (larger, fully opaque); cards on the
          lower arc read as farther (smaller, dimmed). All cards are
          visible at once — no carousel, no queue. */
    .galaxy-card {
      position: absolute;
      flex: initial;
      max-width: none;
      /* 190px × 1.2 = 228px (Tomer asked for +20% on desktop). The orbit
         radii below were nudged proportionally so the larger cards don't
         crowd the orbit center or the rotate-controls. */
      width: 228px;
      cursor: pointer;
      top: 50%;
      left: 50%;
      /* Ellipse radii — clamped so the orbit shrinks gracefully on
         narrow desktop widths and grows on wide ones. Widened (was
         310/34vw/410) so the carousel spreads out across the
         viewport: side cards drift toward the screen edges, leaving
         the central knowledge-core area open and signalling that
         the orbit continues beyond the visible frame. */
      --orbit-rx: clamp(360px, 42vw, 540px);
      --orbit-ry: clamp(160px, 22vh, 210px);
      /* Effective angle = base angle (set inline per card) + the
         stage-level rotation that the rotate-orbit controls drive.
         All trigonometry below reads from this so a single CSS-var
         change on the stage moves every card around the ellipse in
         lockstep, animated via the existing transform transition. */
      --orbit-active-angle: calc(var(--orbit-angle, 0deg) + var(--orbit-rotation, 0deg));
      /* Depth from angle: --orbit-depth ranges 0 (lower arc, farthest)
         to 1 (upper arc, nearest). sin(angle) is -1 at the top of the
         orbit and +1 at the bottom; `1 - sin` remaps so the UPPER arc
         reads as the near/front side and the lower arc recedes. */
      --orbit-depth: calc((1 - sin(var(--orbit-active-angle, 0deg))) / 2);
      /* Side prominence — 0 at the top/bottom of the orbit (12 / 6
         o'clock), 1 at the inline extremes (3 / 9 o'clock). Used to
         subtract a small extra opacity/scale from cards sitting at
         the visual edges so they read as "continuing beyond the
         screen" rather than as crowded peers of the near stations.
         Implemented as cos² (cos × cos) rather than abs(cos) so the
         math relies only on cos() — same browser support as the
         existing sin()/cos() orbit transforms — and gives a smoother
         curve through the side-arc transition. */
      --orbit-side: calc(
        cos(var(--orbit-active-angle, 0deg)) *
        cos(var(--orbit-active-angle, 0deg))
      );
      /* Spatial depth ramp — front/near stations sit forward
         (scale ~0.98, full opacity, highest z-index), far/back
         stations recede (scale ~0.62, ~0.40 opacity, lowest z-index).
         Inline-edge stations get an additional reduction (~0.20
         scale / ~0.40 opacity at the extremes) so the orbit fades
         out toward the viewport edges as if it continues beyond the
         screen rather than ending at the visible cards. Light mode
         lifts the opacity floor via the override block higher up.
           top    (depth=1, side=0): scale 0.98, opacity 1.00
           bottom (depth=0, side=0): scale 0.62, opacity 0.40
           side   (depth=0.5,side=1): scale 0.60, opacity 0.30 */
      --slot-scale: calc(0.62 + 0.36 * var(--orbit-depth) - 0.20 * var(--orbit-side));
      --slot-opacity: calc(0.40 + 0.60 * var(--orbit-depth) - 0.40 * var(--orbit-side));
      /* Subtle perpendicular tilt: cards on the inline-start arc
         (cos < 0 in default LTR, after dir flip) lean inward. */
      --tilt: calc(cos(var(--orbit-active-angle, 0deg)) * 4deg * var(--galaxy-dir, 1) * -1);
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(var(--slot-scale));
      opacity: var(--slot-opacity);
      transition:
        transform var(--orbit-motion-duration, 600ms)
                  var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1)),
        opacity var(--orbit-motion-duration, 600ms)
                var(--orbit-motion-ease, cubic-bezier(0.22, 0.61, 0.36, 1));
      /* Depth-sorted stacking: nearer cards layer above farther ones so
         overlaps read correctly. calc() resolves to a rounded integer,
         2 (back) .. 10 (front). Hover / linked-glow / focus sit above. */
      z-index: calc(2 + var(--orbit-depth) * 8);
      will-change: transform, opacity;
    }

    /* Type tint — books pick the gold accent rotation, lessons the
       cyan one, the course station the violet one. Keeps the groups
       visually distinct on the orbit without needing column-based
       layout. The course card picks up the purple accent already
       defined in the cosmic palette so it reads as part of the family
       without competing with the gold/cyan pairing of books and
       lessons. */
    .galaxy-card[data-kind="book"]   { --card-accent-slot: var(--yuval-galaxy-accent-gold); }
    .galaxy-card[data-kind="lesson"] { --card-accent-slot: var(--yuval-galaxy-accent-cyan); }
    .galaxy-card[data-kind="course"] { --card-accent-slot: var(--yuval-galaxy-accent-purple); }

    /* Linked-glow halo ─────────────────────────────────────────────
       The artifact PNG (the visible book-card art) has transparent
       margins around the painted card pixels, so `box-shadow` on
       any container draws a rectangle far from the visible card
       edge. Solution: `filter: drop-shadow` on the artifact image
       itself — drop-shadow follows the alpha channel and lands on
       the actual painted silhouette of the card, regardless of the
       transparent padding around it.

       Three stacked drop-shadows per keyframe — a tight inner ring
       plus two soft outer blooms — produce a luminous halo that
       reads as a deliberate accent rather than a hard outline.
       Single-color turquoise pulse: the halo fades between a calm
       and an intensified state on a 1.5s loop, signalling the
       linked group without the multi-hue rotation. z-index on the
       wrapper rises during the pulse so highlighted cards float
       above neighbours.
       */
    .galaxy-card.is-linked-glow {
      /* Above every depth-sorted resting card (max z 10). */
      z-index: 11;
    }
    :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
      animation: yuval-linked-glow 1.5s ease-in-out infinite;
    }
    @keyframes yuval-linked-glow {
      0%, 100% {
        filter:
          drop-shadow(0 0 2px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 8px  rgba(64, 224, 208, 0.85))
          drop-shadow(0 0 18px rgba(64, 224, 208, 0.55));
      }
      50% {
        filter:
          drop-shadow(0 0 3px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 12px rgba(64, 224, 208, 0.95))
          drop-shadow(0 0 26px rgba(64, 224, 208, 0.7));
      }
    }
    @media (prefers-reduced-motion: reduce) {
      :global(.galaxy-card.is-linked-glow .lc-orbit-artifact-face-front) {
        animation: none;
        filter:
          drop-shadow(0 0 2px  rgba(64, 224, 208, 1))
          drop-shadow(0 0 12px rgba(64, 224, 208, 0.55));
      }
    }

    /* Drag-to-rotate — while the user is actively dragging the orbit
       we drop the transform transition so the carousel tracks the
       cursor in real time (no easing lag). The transition is restored
       the moment the drag ends, which lets the snap-to-station read
       as a smooth animated move. The grabbing cursor + user-select
       reset prevent accidental text selection mid-drag. */
    .library-galaxy[data-galaxy-dragging],
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      cursor: grabbing;
      user-select: none;
      -webkit-user-select: none;
    }
    .library-galaxy[data-galaxy-dragging] .galaxy-card {
      transition: none;
    }
    /* Block the browser's native image/link drag on every card and on
       its descendant images. Without this, mousedown on the inner <a>
       starts a drag-and-drop "ghost" that prevents our pointermove
       handler from tracking the cursor. The pointerdown handler also
       calls preventDefault, but the CSS hint catches stragglers (e.g.
       SVG/IMG nodes that opt themselves into drag separately). */
    .galaxy-card,
    .galaxy-card *,
    .galaxy-card img,
    .galaxy-card svg {
      -webkit-user-drag: none;
    }

    /* ── Series capsule —
          Built client-side as a separate node when ≥2 visible items
          share a seriesName. The wrapper .galaxy-card carries the
          orbit positioning machinery so the capsule lives at a real
          station on the ellipse, exactly like a single-book card.
          Capsules are clickable: they enter series mode, expanding
          the series's books into a carousel and collapsing the rest
          of the universe into "Other Knowledge". */
    .galaxy-card[data-role="series"] {
      cursor: pointer;
      /* A capsule is wider than a regular book card on the orbit so the
         shape proportions alone signal "container, not item" — even
         before reading the badge or label. Scaled to keep the +10%
         ratio over the +20%-larger book card (228px → 252px). */
      width: 252px;
      /* Resolve series colour at the wrapper level so the deck pseudos
         (below) and the inner capsule both read the same value without
         each redefining it. */
      --series-color-resolved: var(--series-color, var(--yuval-galaxy-accent-gold, #c9a96e));
    }
    /* Stacked deck — two ghost rectangles peeking out behind the capsule,
       narrower and offset downward so the capsule reads as a stack of
       grouped knowledge, not as a single tile. Pure decoration via
       wrapper pseudo-elements; muted/active state animations on the
       wrapper carry the deck along automatically. */
    .galaxy-card[data-role="series"]::before,
    .galaxy-card[data-role="series"]::after {
      content: "";
      position: absolute;
      pointer-events: none;
      border-radius: 18px;
      border-end-start-radius: 12px;
      background: color-mix(in srgb, var(--series-color-resolved) 8%, var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78)));
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      z-index: 0;
    }
    /* Middle layer — peeks 4 px below, narrower by 8 px each side. */
    .galaxy-card[data-role="series"]::after {
      inset-block-start: 4px;
      inset-block-end: -4px;
      inset-inline-start: 8px;
      inset-inline-end: 8px;
      opacity: 0.85;
    }
    /* Back layer — peeks 8 px below, narrower by 18 px each side. */
    .galaxy-card[data-role="series"]::before {
      inset-block-start: 7px;
      inset-block-end: -8px;
      inset-inline-start: 18px;
      inset-inline-end: 18px;
      opacity: 0.6;
    }
    .galaxy-card[data-role="series"]:focus-visible {
      outline: none;
    }
    .galaxy-card[data-role="series"]:focus-visible .galaxy-series-capsule {
      box-shadow:
        0 14px 38px -14px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        0 0 0 2px color-mix(in srgb, var(--series-color-resolved) 70%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
    }

    /* ── Series members —
          Every individual book inside a multi-item series is kept in
          the DOM as an orbit card, but tagged with data-series-member
          so it stays hidden in universe mode. Series mode reveals the
          members of the active series via .is-active-series-member
          (added by the hydrator JS). */
    .galaxy-card[data-series-member] {
      display: none;
    }

    /* ── Series mode — stage-level state.
          Activated by clicking a SeriesCapsule. The hydrator sets
          data-stage-mode="series" + data-active-series="<name>" on
          the stage element, then class-tags individual cards. */

    /* Mute every station that isn't the active series's books or
       the synthesized Other Knowledge pill. Premium fade — opacity
       and scale only, no jarring movement. */
    [data-stage-mode="series"] .galaxy-card.is-muted {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1) * 0.85),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry) * 0.85)
        )
        rotate(var(--tilt))
        scale(0.7);
    }

    /* The active series's own capsule is replaced by its books, so
       hide the capsule in series mode. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-capsule {
      opacity: 0;
      pointer-events: none;
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * var(--orbit-rx) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * var(--orbit-ry))
        )
        rotate(var(--tilt))
        scale(0.85);
    }

    /* Members of the active series — revealed and laid out as a
       coverflow-style carousel: the focused book sits centred and
       enlarged, neighbouring books tilt back in 3D with depth fade.
       The hydrator sets --series-active-index per card (its own
       position) and --series-focused-index on every member (which
       index is currently in focus). Clicking a side book updates
       --series-focused-index, sliding that book into the centre. */
    [data-stage-mode="series"] .galaxy-card.is-active-series-member {
      display: block;
      --series-step: clamp(140px, 17vw, 200px);
      --series-rel: calc(
        var(--series-active-index, 0) - var(--series-focused-index, 0)
      );
      /* CSS abs() via max(neg, pos) — works without browser-version
         gating and keeps the math inline. */
      --series-abs-rel: max(
        calc(var(--series-rel) * -1),
        var(--series-rel)
      );
      --series-row-x: calc(
        var(--series-rel) * var(--series-step) * var(--galaxy-dir, 1)
      );
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        perspective(1200px)
        rotateY(calc(var(--series-rel) * -22deg * var(--galaxy-dir, 1)))
        scale(calc(1.12 - var(--series-abs-rel) * 0.12));
      opacity: calc(1 - var(--series-abs-rel) * 0.28);
      /* Focused book wins the z-stack so its overlay/CTA sits on top
         of side cards. z-index 20 sits above the orbit max (10). */
      z-index: calc(20 - var(--series-abs-rel));
      cursor: pointer;
      /* Defeat the mobile 3-slot `data-mobile-slot="hidden"` rule
         which sets `pointer-events: none` and prevents side-book
         clicks from registering on phones. Selector specificity
         (0,3,0) wins over the slot rule (0,2,0), but only when the
         property is explicitly set on our rule. */
      pointer-events: auto;
      transition:
        transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
        opacity 0.5s ease;
    }

    /* Hover lift on a non-focused carousel book — preserves the
       depth tilt and just bumps the card up + scales a touch. */
    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:hover:not([data-pos="center"]),
    [data-stage-mode="series"]
      .galaxy-card.is-active-series-member:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translateX(var(--series-row-x))
        translateY(-6px)
        perspective(1200px)
        rotateY(calc(var(--series-rel) * -22deg * var(--galaxy-dir, 1)))
        scale(calc(1.16 - var(--series-abs-rel) * 0.10));
      opacity: calc(1 - var(--series-abs-rel) * 0.22);
    }

    /* ── Series carousel chevrons —
          Rendered statically in the SSR markup inside the stage
          (so Astro's scoped CSS naturally matches them — JS-injected
          nodes silently lose scope-cid attribution). Hidden in
          universe mode via opacity:0 + pointer-events:none, revealed
          only while the stage is in series mode. JS owns click +
          disabled-state updates; CSS owns visibility, position and
          look. Pearl glass + blur to match the rest of the
          universe chrome. */
    .series-carousel-nav {
      /* Completely out of layout outside series mode — opacity:0
         alone wasn't enough on phones, the button's backdrop blur
         and border were still leaving faint "<" marks pinned to
         the inline-start edge of the stage. display:none removes
         them from the render tree entirely; visibility:hidden +
         !important is belt-and-braces in case any later cascade
         (theme override, autoprefixer artifact, dev-server cache)
         flips display back. */
      display: none !important;
      visibility: hidden;
      position: absolute;
      inset-block-start: 50%;
      width: 48px;
      height: 48px;
      place-items: center;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: var(--yuval-galaxy-text, #ececea);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.28),
        0 12px 26px rgba(0, 0, 0, 0.4);
      cursor: pointer;
      /* z above the focused carousel book (max 20) so the buttons
         always sit on top of the coverflow row in series mode. */
      z-index: 30;
      transition:
        transform 0.2s ease,
        background 0.2s ease,
        border-color 0.2s ease;
    }
    .series-carousel-nav-prev {
      inset-inline-start: clamp(8px, 3vw, 32px);
      transform: translateY(-50%);
    }
    .series-carousel-nav-next {
      inset-inline-end: clamp(8px, 3vw, 32px);
      transform: translateY(-50%);
    }
    /* Reveal in series mode — the only state that should expose
       the carousel-navigation affordance. */
    [data-stage-mode="series"] .series-carousel-nav {
      display: grid !important;
      visibility: visible;
    }
    .series-carousel-nav:hover:not(:disabled),
    .series-carousel-nav:focus-visible:not(:disabled) {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.4);
      outline: none;
    }
    .series-carousel-nav-prev:hover:not(:disabled),
    .series-carousel-nav-prev:focus-visible:not(:disabled) {
      transform: translateY(-50%) translateX(calc(var(--galaxy-dir, 1) * -2px));
    }
    .series-carousel-nav-next:hover:not(:disabled),
    .series-carousel-nav-next:focus-visible:not(:disabled) {
      transform: translateY(-50%) translateX(calc(var(--galaxy-dir, 1) * 2px));
    }
    .series-carousel-nav:disabled {
      opacity: 0.25;
      cursor: not-allowed;
    }
    /* Flip the chevron glyphs in RTL — same trick the
       .galaxy-orbit-btn uses, so the visual direction always
       matches the inline-direction of the page. */
    [dir="rtl"] .series-carousel-nav svg { transform: scaleX(-1); }
    :global(html:not(.dark)) .series-carousel-nav {
      background: rgba(255, 253, 249, 0.82);
      border-color: rgba(34, 52, 92, 0.2);
      color: var(--yuval-galaxy-text, #1a1f3a);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.7),
        0 8px 20px rgba(30, 45, 80, 0.18);
    }
    :global(html:not(.dark)) .series-carousel-nav:hover:not(:disabled),
    :global(html:not(.dark)) .series-carousel-nav:focus-visible:not(:disabled) {
      background: rgba(255, 253, 249, 0.95);
      border-color: rgba(34, 52, 92, 0.35);
    }

    /* ── Series carousel position pill —
          Compact "current / total" indicator anchored below the
          coverflow row so the user always knows where they are in
          the series. Hidden in universe mode, revealed only in
          series mode (same pattern as the chevrons above). */
    .series-carousel-position {
      /* display:none keeps the pill fully out of layout outside
         series mode — opacity:0 alone wasn't enough, the pill's
         backdrop blur was still leaving a faint "0 / 0" mark
         visible above the bottom orbit chrome on phones.
         !important + visibility:hidden as belt-and-braces. */
      display: none !important;
      visibility: hidden;
      position: absolute;
      inset-block-end: clamp(8px, 3vh, 28px);
      inset-inline-start: 50%;
      transform: translateX(-50%);
      align-items: baseline;
      gap: 0.35rem;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: var(--yuval-galaxy-text, #ececea);
      font-size: 0.82rem;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.02em;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.22),
        0 8px 18px rgba(0, 0, 0, 0.3);
      z-index: 30;
      direction: ltr;
    }
    [data-stage-mode="series"] .series-carousel-position {
      display: inline-flex !important;
      visibility: visible;
    }
    .series-carousel-position-sep {
      opacity: 0.5;
      margin-inline: 0.1rem;
    }
    [data-series-pos-current] { font-weight: 600; }
    [data-series-pos-total] {
      opacity: 0.7;
      font-weight: 500;
    }
    :global(html:not(.dark)) .series-carousel-position {
      background: rgba(255, 253, 249, 0.82);
      border-color: rgba(34, 52, 92, 0.2);
      color: var(--yuval-galaxy-text, #1a1f3a);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.7),
        0 6px 14px rgba(30, 45, 80, 0.16);
    }

    /* ── Other Knowledge capsule —
          Synthesized by JS on series-mode entry, removed on exit.
          Sits at the inline-end top of the stage as a compact pill
          summarising "everything else". Clicking it exits series
          mode and restores the universe. */
    .galaxy-card[data-role="other-knowledge"] {
      /* Reset the orbit-card absolute geometry. */
      top: 0;
      left: auto;
      inset-block-start: 12px;
      inset-inline-end: 12px;
      width: auto;
      transform: none;
      opacity: 0;
      cursor: pointer;
      z-index: 6;
      transition:
        opacity 0.32s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .galaxy-card[data-role="other-knowledge"].is-visible {
      opacity: 1;
    }
    .galaxy-card[data-role="other-knowledge"]:hover .galaxy-other-knowledge,
    .galaxy-card[data-role="other-knowledge"]:focus-visible .galaxy-other-knowledge {
      border-color: color-mix(in srgb, var(--yuval-galaxy-text, #ececea) 30%, transparent);
      background: var(--yuval-galaxy-card-surface-hover, rgba(28, 30, 44, 0.82));
    }
    .galaxy-card[data-role="other-knowledge"]:focus-visible {
      outline: none;
    }

    .galaxy-other-knowledge {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 0.85rem 0.55rem 0.65rem;
      border-radius: 999px;
      background: var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 40%, transparent);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.5);
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .galaxy-other-knowledge-icon {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 20%, transparent),
        color-mix(in srgb, var(--yuval-galaxy-text-muted, #6e6e6c) 8%, transparent)
      );
      color: var(--yuval-galaxy-text, #ececea);
      font-size: 1.15rem;
      line-height: 1;
      letter-spacing: 0.06em;
      font-weight: 600;
    }

    .galaxy-other-knowledge-text {
      display: flex;
      flex-direction: column;
      gap: 1px;
      line-height: 1.25;
      padding-inline-end: 0.15rem;
    }

    .galaxy-other-knowledge-label {
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: 0.005em;
    }

    .galaxy-other-knowledge-count {
      font-size: 0.66rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      letter-spacing: 0.02em;
    }

    .galaxy-other-knowledge-count strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-weight: 600;
      margin-inline-end: 0.2rem;
    }

    .galaxy-series-capsule {
      position: relative;
      /* Stacked above the wrapper's deck pseudo-elements. */
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      padding: 1.05rem 1.1rem 0.85rem;
      padding-inline-start: 1.2rem;
      /* Restrained asymmetry — the inline-start/block-end corner is
         tighter so the capsule reads as a grounded container, not as
         a floating chip. Logical so RTL flips automatically. */
      border-radius: 22px;
      border-end-start-radius: 14px;
      background:
        /* Atmospheric inner glow from the top, painted with the series
           color. Lives in the background stack (not a pseudo-element)
           so children render above it without z-index gymnastics. */
        radial-gradient(
          ellipse 70% 55% at 50% 0%,
          color-mix(in srgb, var(--series-color-resolved) 18%, transparent) 0%,
          transparent 65%
        ),
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--series-color-resolved) 11%, transparent) 0%,
          color-mix(in srgb, var(--series-color-resolved) 4%, transparent) 55%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 84%, transparent) 100%
        ),
        var(--yuval-galaxy-card-surface, rgba(20, 22, 36, 0.78));
      /* Two-layer luminous border — hairline outer ring + a slightly
         stronger inner edge — for a refined, lit-from-within feel. */
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 36%, transparent);
      box-shadow:
        0 10px 26px -16px color-mix(in srgb, var(--series-color-resolved) 38%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 14%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      backdrop-filter: blur(14px) saturate(125%);
      -webkit-backdrop-filter: blur(14px) saturate(125%);
      transition:
        border-color 240ms ease,
        box-shadow 240ms ease;
    }

    /* Capsule edge indicator — a thin luminous bar along the inline-start
       side, painted in the series color. Echoes the series swatch on
       /admin so the same color identifies the same series everywhere. */
    .galaxy-series-capsule::before {
      content: "";
      position: absolute;
      inset-block: 16px;
      inset-inline-start: 0;
      width: 2px;
      border-radius: 0 2px 2px 0;
      background: var(--series-color-resolved);
      opacity: 0.75;
      box-shadow: 0 0 8px color-mix(in srgb, var(--series-color-resolved) 60%, transparent);
    }
    [dir="rtl"] .galaxy-series-capsule::before {
      border-radius: 2px 0 0 2px;
    }

    /* Binder ridge — a hairline horizontal line tucked into the empty
       strip above the badge, like the metal clip at the top of a binder.
       Reads as "container surface" rather than "card top edge". */
    .galaxy-series-capsule::after {
      content: "";
      position: absolute;
      inset-block-start: 7px;
      inset-inline: 16px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 30%,
        color-mix(in srgb, var(--series-color-resolved) 65%, transparent) 50%,
        color-mix(in srgb, var(--series-color-resolved) 50%, transparent) 70%,
        transparent 100%
      );
      opacity: 0.55;
    }

    /* Restrained hover — slightly lift the border luminosity and the
       inner edge, no large bloom. The universe should feel calm. */
    .galaxy-card[data-role="series"]:hover .galaxy-series-capsule {
      border-color: color-mix(in srgb, var(--series-color-resolved) 52%, transparent);
      box-shadow:
        0 12px 30px -16px color-mix(in srgb, var(--series-color-resolved) 48%, transparent),
        0 0 0 1px color-mix(in srgb, var(--series-color-resolved) 20%, transparent),
        inset 0 1px 0 color-mix(in srgb, var(--series-color-resolved) 28%, transparent);
    }

    .galaxy-series-badge {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      padding: 2px 10px 2px 8px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--series-color-resolved) 18%, transparent);
      border: 1px solid color-mix(in srgb, var(--series-color-resolved) 55%, transparent);
      color: var(--series-color-resolved);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    /* Stacked-bars glyph rendered purely in CSS — three short horizontal
       lines tucked before the badge text. Reinforces the "stacked
       knowledge" semantic without adding markup. */
    .galaxy-series-badge::before {
      content: "";
      display: inline-block;
      width: 9px;
      height: 9px;
      margin-inline-end: 6px;
      background:
        linear-gradient(currentColor, currentColor) top center / 9px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) center      / 7px 1.4px no-repeat,
        linear-gradient(currentColor, currentColor) bottom center / 5px 1.4px no-repeat;
      vertical-align: -1px;
      opacity: 0.95;
    }

    .galaxy-series-name {
      margin: 0;
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 1.12rem;
      font-weight: 500;
      line-height: 1.2;
      color: var(--yuval-galaxy-text, #ececea);
      letter-spacing: -0.01em;
      /* Allow up to 2 lines — series names tend to be longer than book titles. */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .galaxy-series-counts {
      display: flex;
      flex-direction: column;
      gap: 1px;
      margin-top: 2px;
    }

    .galaxy-series-count-line {
      font-size: 0.72rem;
      color: var(--yuval-galaxy-text-secondary, var(--yuval-galaxy-text-muted, #a8a8a4));
      line-height: 1.45;
      letter-spacing: 0.005em;
    }

    .galaxy-series-count-line strong {
      color: var(--yuval-galaxy-text, #ececea);
      font-family: 'Spectral', 'Cardo', Georgia, serif;
      font-size: 0.95rem;
      font-weight: 500;
      font-feature-settings: 'tnum' 1, 'lnum' 1;
      margin-inline-end: 0.3rem;
    }

    .galaxy-series-count-available strong {
      color: var(--series-color-resolved);
    }

    /* Shelf — the spine row sits in a recessed compartment with a
       luminous bottom edge, so the spines read as "books on a shelf"
       rather than as a chart. Margin pulls the shelf to the inline
       edges of the capsule's inner padding so it spans the full width. */
    .galaxy-series-stack {
      position: relative;
      display: flex;
      align-items: flex-end;
      gap: 3px;
      height: 18px;
      margin-block-start: 6px;
      margin-inline: -0.35rem;
      padding: 4px 0.5rem 5px;
      border-radius: 5px 5px 8px 8px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 22%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 42%, transparent) 100%
        );
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, #000 22%, transparent),
        inset 0 -1px 0 color-mix(in srgb, var(--series-color-resolved) 14%, transparent);
    }
    /* Luminous shelf line — the surface the books are resting on. */
    .galaxy-series-stack::after {
      content: "";
      position: absolute;
      inset-block-end: 1px;
      inset-inline: 8px;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--series-color-resolved) 60%, transparent) 50%,
        transparent 100%
      );
      opacity: 0.7;
    }
    /* Each spine = one book. Capped at 5 in the hydrator. Heights vary
       in a fixed, gentle rhythm — not random — so the row reads as
       "books on a shelf" without visual noise. */
    .galaxy-series-spine {
      display: block;
      width: 3px;
      border-radius: 1px 1px 0 0;
      background: color-mix(in srgb, var(--series-color-resolved) 22%, transparent);
      height: 11px;
    }
    .galaxy-series-spine:nth-child(2) { height: 13px; }
    .galaxy-series-spine:nth-child(3) { height: 12px; }
    .galaxy-series-spine:nth-child(4) { height: 14px; }
    .galaxy-series-spine:nth-child(5) { height: 12px; }
    .galaxy-series-spine.is-filled {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--series-color-resolved) 92%, white) 0%,
        var(--series-color-resolved) 100%
      );
      opacity: 0.85;
      box-shadow:
        inset 0 -1px 0 color-mix(in srgb, #000 25%, transparent);
    }

    /* Centered focus state — uniform fixed-size box anchored right
       below the hero subtitle "כל הידע שלך…".
       Switched from `position: absolute` + `transform: scale(1.5)` to
       `position: fixed` + explicit dimensions so every selection lands
       at the SAME viewport spot at the SAME visible size — independent
       of the orbit's --orbit-vertical-offset, the picked card's
       natural artwork aspect ratio, and any per-station tilt.
         - height: 45dvh           — 45% of the viewport height.
         - aspect-ratio: 2 / 3     — standard book-cover proportion;
                                     width = 30dvh on every screen.
         - top: var(--focused-card-top, calc(72px + 5rem))
                                     — the JS-measured viewport Y of
                                     the subtitle's actual bottom edge
                                     (`.lh-subtitle` getBoundingClientRect
                                     plus a 2px hairline). Re-measured
                                     on resize so the card always lands
                                     ממש צמוד ומתחת למילים, regardless
                                     of font-clamp variance, light/dark
                                     padding deltas, or zoom level.
                                     Fallback `calc(72px + 5rem)` covers
                                     the first paint before the script
                                     runs and SSR clients that disable JS.
         - left: 50%; translateX   — horizontally centred on the
                                     viewport regardless of where the
                                     fixed support panels sit.
       Inner-image rules below (`object-fit: contain`) keep the BOX
       size identical for every card while the artwork is contained
       inside its 2:3 frame. */
    .galaxy-card[data-pos="center"] {
      position: fixed;
      /* `.library-galaxy` has `transform: translateY(var(--orbit-vertical-offset))`,
         which makes IT the containing block for this fixed element —
         `top:` is measured from the galaxy's top, not the viewport.
         `--focused-card-top` is computed by `initFocusedCardAnchor()`
         in the script block (subtitle bottom in viewport Y minus galaxy
         top in viewport Y, +2px hairline), so the card always lands
         flush below the subtitle "כל הידע שלך…" regardless of clamp /
         theme / font-load reflow. Fallback `-1rem` covers the brief
         pre-JS paint: galaxy starts a little below the hero strip, so a
         small negative top lands the card near the subtitle bottom
         instead of deep in the orbit field. */
      top: var(--focused-card-top, -1rem);
      left: 50%;
      width: auto;
      /* Default focused-card box (books, lessons, articles, etc.) —
         restored to 50dvh × 2/3. Course cards get a larger override
         further down (see `.galaxy-card[data-pos="center"][data-kind="course"]`)
         since only courses surface the series action panel. */
      height: 50dvh;
      aspect-ratio: 2 / 3;
      transform: translateX(-50%);
      opacity: 1;
      z-index: 30;
      cursor: default;
    }

    /* Course-only enlargement —
       Only the AI Engineering Course capsule (data-kind="course")
       grows to a larger spotlight on open, so the action panel
       below it has space to read as the centrepiece it is. Books,
       lessons and articles keep the default 50dvh size above. */
    .galaxy-card[data-pos="center"][data-kind="course"] {
      height: 80dvh;
    }

    /* Uniform-size override — neutralise LibraryCard.astro's focused
       artifact transform so EVERY card renders at exactly the box
       size. Without this, the component applies `scale(1.5)` plus a
       `margin-block: 15%` (~4.5dvh on each side), which makes the
       visible artwork extend beyond the box symmetrically AND leaves
       a transparent band inside the box — so each cover's apparent
       size depends on its own PNG padding. Removing both pins the
       visible artwork to the box, end of story.

       The `.lc-orbit` zero-padding rule below is what actually closes
       the gap Tomer reported between the cover and the reading-entry
       panel: in resting orbit state `.lc-orbit` reserves ~1rem of
       inner padding all round so the cover sits inside a glass
       cushion. In focused state we don't want that cushion — the
       reading-entry overlay below is anchored to the .galaxy-card
       box edge, and any inner padding on `.lc-orbit` becomes a
       transparent gap between the visible cover bottom and the
       overlay's top. Zeroing the padding makes the artwork fill the
       box edge-to-edge so the overlay sits flush. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      padding: 0 !important;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      transform: none !important;
      margin-block: 0 !important;
      width: 100% !important;
      margin-inline: 0 !important;
    }

    /* Inner LibraryCard structure fills the fixed-size centred box so
       the visible artwork tracks the box (not its own intrinsic
       height).

       `object-fit: cover` makes EVERY card render at the same visible
       size as the 2:3 frame. Previously `contain` was used so the
       round AI Engineering Course capsule wouldn't stretch, but the
       side-effect was non-2:3 artwork sitting inside the frame with
       transparent margins — different visible sizes per card from the
       user's POV. Tomer asked for uniform visual size on every focus,
       so `cover` wins: the box is the unit, and any artwork that
       isn't 2:3 gets cropped at the top/bottom edges instead of
       shrinking. The crop is acceptable because the artwork's focal
       region almost always lives in the centre vertical band, and
       the `object-position: center` keeps that band in view. */
    .galaxy-card[data-pos="center"] :global(.lc-orbit) {
      height: 100%;
      padding: 0;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact) {
      width: 100%;
      height: 100%;
      margin: 0;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front),
    .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-selected) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    /* Hover lift — small bump along the radial direction (cards move
       slightly further from center) plus a brightness/scale bump.
       Skipped when the card is focused to avoid double transforms. */
    .galaxy-card:hover:not([data-pos="center"]),
    .galaxy-card:focus-visible:not([data-pos="center"]) {
      transform:
        translate(-50%, -50%)
        translate(
          calc(cos(var(--orbit-active-angle, 0deg)) * (var(--orbit-rx) + 8px) * var(--galaxy-dir, 1)),
          calc(sin(var(--orbit-active-angle, 0deg)) * (var(--orbit-ry) + 8px))
        )
        rotate(calc(var(--tilt) * 0.5))
        scale(calc(var(--slot-scale) * 1.04));
      opacity: 1;
      /* Lift above every depth-sorted resting card (max z 10) so a
         hovered card always comes forward, even from the back. */
      z-index: 11;
    }
    .galaxy-card:focus-visible {
      outline: none;
    }

    /* CTA overlay — hidden when card is in slot/queue; revealed only
       when data-pos="center". Children stop click propagation so the
       card-level handler never fires for Open/Close. */
    .galaxy-cta {
      position: absolute;
      /* Anchor inside the focused card at its visible bottom — the
         spot where the `.lc-orbit-author` byline used to sit before
         it was retired. Series action pills now read as part of the
         focused-card composition rather than as a side rail.
         Centering uses physical `left: 50%; transform: translateX(-50%)`
         (not logical inset-inline-*) so it stays centered in both
         RTL Hebrew and LTR English without writing-direction quirks. */
      top: 66%;
      left: 50%;
      bottom: auto;
      right: auto;
      transform: translate(-50%, -50%);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease 0.15s;
      /* Above the scaled-up artwork (`transform: scale(1.5)` visually
         bleeds past the card's flow box bottom by ~25%). */
      z-index: 2;
    }
    .galaxy-card[data-pos="center"] .galaxy-cta {
      opacity: 1;
      pointer-events: auto;
    }
    /* ── Knowledge activation orb ─────────────────────────────────────
          Compact circular CTA that replaces the previous pill — feels
          native to the holographic knowledge-card universe rather than
          a generic web button. Layered structure:
            .galaxy-cta-open        — the orb body (translucent glass)
            .galaxy-cta-open-core   — inner radial light
            .galaxy-cta-open-ring   — outer dashed ring (rotates on hover)
            .galaxy-cta-open-icon   — the open/access glyph
            .galaxy-cta-open-label  — hover/focus tooltip
          Real <a> element with `aria-label`, so keyboard + screen-reader
          paths work exactly like the previous button (Enter/Space follow
          the link, focus-visible draws the same activated state). */
    .galaxy-cta-open {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 64px;
      border-radius: 50%;
      color: var(--yuval-galaxy-accent, #5eead4);
      cursor: pointer;
      text-decoration: none;
      /* Translucent glass body — inner glow rooted on the accent,
         fading into the page background colour at the edges. The
         core layer (::core span below) handles the brighter centre. */
      background:
        radial-gradient(
          circle at 50% 38%,
          color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 24%, transparent) 0%,
          color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 8%, transparent) 55%,
          transparent 100%
        ),
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 55%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent) inset,
        0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 50%, transparent) inset,
        0 0 18px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms cubic-bezier(0.4, 0, 0.2, 1),
        border-color 220ms cubic-bezier(0.4, 0, 0.2, 1);
      /* Subtle continuous breathing — the orb feels alive even at rest. */
      animation: galaxy-cta-open-pulse 3.6s ease-in-out infinite;
    }
    @keyframes galaxy-cta-open-pulse {
      0%, 100% {
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 18%, transparent) inset,
          0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 50%, transparent) inset,
          0 0 18px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      }
      50% {
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 26%, transparent) inset,
          0 0 8px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 60%, transparent) inset,
          0 0 24px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 45%, transparent);
      }
    }
    /* Inner core highlight — small luminous spot toward the upper-left
       of the orb, like a glass marble's reflected light source. */
    .galaxy-cta-open-core {
      position: absolute;
      inset: 18%;
      border-radius: 50%;
      background: radial-gradient(
        circle at 38% 30%,
        color-mix(in srgb, white 35%, transparent) 0%,
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 22%, transparent) 28%,
        transparent 70%
      );
      pointer-events: none;
    }
    /* Outer dashed ring — sits just outside the orb. Rotates slowly
       on hover/focus; static + slightly dimmer at rest. */
    .galaxy-cta-open-ring {
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 1px dashed
        color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 45%, transparent);
      opacity: 0.7;
      pointer-events: none;
      transition: opacity 220ms ease;
    }
    @keyframes galaxy-cta-open-ring-rotate {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    /* Open/access glyph — chevron into the inline-end direction. RTL
       mirroring is handled below so "→" stays reading-flow forward. */
    .galaxy-cta-open-icon {
      position: relative;
      width: 22px;
      height: 22px;
      z-index: 1;
      filter: drop-shadow(
        0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 65%, transparent));
      transition: opacity 180ms ease;
    }
    [dir="rtl"] .galaxy-cta-open-icon { transform: scaleX(-1); }

    /* Hover label — floats to the PHYSICAL RIGHT of the orb,
       vertically centered on the orb. Physical `left` + `top` (not
       `inset-inline-*`) so the side stays the same in both RTL and
       LTR — the user explicitly asked for visual-right. The 4px
       inward initial translation gives a small slide-in entry. */
    .galaxy-cta-open-label {
      position: absolute;
      top: 50%;
      left: calc(100% + 0.5rem);
      bottom: auto;
      right: auto;
      inset-block-start: auto;
      inset-block-end: auto;
      inset-inline-start: auto;
      inset-inline-end: auto;
      transform: translateY(-50%) translateX(-4px);
      padding: 0.25rem 0.625rem;
      border-radius: 999px;
      font-family: 'Assistant', system-ui, sans-serif;
      font-size: 0.78125rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: var(--yuval-galaxy-text, #ececea);
      background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 82%, transparent);
      border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 28%, transparent);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      transition:
        opacity 180ms ease,
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .galaxy-cta-open:hover,
    .galaxy-cta-open:focus-visible {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 80%, transparent);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 30%, transparent) inset,
        0 0 8px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 70%, transparent) inset,
        0 0 28px -2px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 55%, transparent),
        0 0 14px color-mix(in srgb, var(--yuval-galaxy-accent, #5eead4) 35%, transparent);
      outline: none;
      /* Pause the rest pulse — hover/focus drives its own glow now. */
      animation-play-state: paused;
    }
    .galaxy-cta-open:hover .galaxy-cta-open-ring,
    .galaxy-cta-open:focus-visible .galaxy-cta-open-ring {
      opacity: 1;
      animation: galaxy-cta-open-ring-rotate 12s linear infinite;
    }
    /* Icon stays visible on hover — the label is its own bubble
       above the orb now, no swap needed. */
    .galaxy-cta-open:hover .galaxy-cta-open-label,
    .galaxy-cta-open:focus-visible .galaxy-cta-open-label {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
    .galaxy-cta-open:active {
      transform: translateY(0);
      transition-duration: 80ms;
    }

    @media (prefers-reduced-motion: reduce) {
      .galaxy-cta-open,
      .galaxy-cta-open-icon,
      .galaxy-cta-open-label,
      .galaxy-cta-open-ring { transition: none; animation: none; }
      .galaxy-cta-open:hover .galaxy-cta-open-ring,
      .galaxy-cta-open:focus-visible .galaxy-cta-open-ring { animation: none; }
    }
    .galaxy-cta-close {
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      font-size: 1.125rem;
      line-height: 1;
      color: var(--yuval-galaxy-text-muted);
      background: var(--yuval-galaxy-surface-muted);
      border: 1px solid var(--yuval-galaxy-border);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .galaxy-cta-close:hover,
    .galaxy-cta-close:focus-visible {
      color: var(--yuval-galaxy-text);
      background: var(--yuval-galaxy-card-surface-hover);
      border-color: var(--yuval-galaxy-border-strong);
      outline: none;
    }

    /* ── Reading-entry overlay (phase 1) ─────────────────────────────
       Internal premium panel that appears ONLY when the card is
       centered (`[data-pos="center"]`). Sits absolutely over the card
       surface, between the LibraryCard art and the close button.
       Routing is not wired yet — the click handler in
       `initReadingEntry()` (see the page script block) logs slug + href.

       The original side open orb (`.galaxy-cta-open`) is hidden via
       the `display: none` rule below; the underlying <a href> is left
       in the DOM so we keep the link target for future use. */
    .galaxy-cta-open {
      display: none !important;
    }

    /* ── Reading-entry overlay: in-card image-based premium panel ──────
       The entry control sits INSIDE the centered book card (not below
       it). The visual is a textless PNG asset; all visible text is
       live, localized HTML rendered on top — the image never carries
       baked text.

       Stacking inside the overlay <a>:
         .reading-entry-asset  — background-image PNG (decorative)
         .reading-entry-text   — title + subtitle, live i18n

       The <a> itself is the hit area and preserves native link
       behavior (Ctrl/Cmd-click → new tab, middle-click → new tab,
       right-click → context menu). Plain left-click and Enter are
       intercepted by the launch handler in `universe-layout.ts` via
       the `data-reading-entry` attribute.

       Phase-3 launch animation: the overlay's two child layers
       (.reading-entry-asset + .reading-entry-text) fade out cleanly
       when `data-reading-entry-state="opening"` is set on the stage.
       Opacity-only fade keeps the link in the accessibility tree
       until the launch is committed. */
    /* Image-based reading-entry panel. The visual base IS the
       `reading-entry-card1.png` asset — it carries the icon (top
       center), the glass background, the border and the glow.
       Title, subtitle AND the lesson meta row all live INSIDE this
       single panel (not in a separate section below) so the CTA and
       its facts read as one premium glass surface.

       Sizing math: the centred card is now `position: fixed` with no
       transform scaling (uniform 45dvh × aspect 2/3 box). The earlier
       `width: calc(85% * 1.5)` + `scale(1/1.5)` counter-scale dance
       was needed only because the parent card was visually 1.5× its
       declared box. With that scale gone, this panel inherits its
       coordinates 1:1 from the parent and just renders at its
       declared size — width 100% of the card, no counter-scale. */
    .reading-entry-overlay {
      position: absolute;
      left: 50%;
      /* Glue flush to the focused card's bottom edge. The cover-side
         artwork already pins to the box edges (see `.lc-orbit`
         padding/margin reset above), but the OVERLAY PNG
         (`reading-entry-card1.png`) carries ~30px of transparent halo
         ABOVE its visible blue border. With `top: 100%` that halo
         rendered as a visible gap between the cover bottom and the
         panel's actual top edge. Pull the overlay up by exactly that
         halo so the two visible borders meet without a seam. Centred
         card is `position: fixed` with no scaling here, so the value
         applies 1:1 in screen px. */
      top: calc(100% - 80px);
      width: 100%;
      max-width: 380px;
      min-width: 280px;
      /* Adaptive height — the centred composition is now
         152px (top) + 50dvh (card) + overlay + safe area for the
         bottom chevron rotate controls (~80px). With the card at
         exactly half the viewport, the overlay has the remaining
         (~50dvh − 152px − 96px) of room before it would hit the
         chevrons. The clamp ceiling stays at 220px so the overlay
         never grows to compete with the cover above. */
      height: clamp(170px, calc(100dvh - 152px - 50dvh - 96px), 220px);
      border-radius: 28px;
      box-sizing: border-box;
      transform: translate(-50%, 0);
      transform-origin: top center;
      display: block;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 30;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 240ms;
    }
    .galaxy-card[data-pos="center"] .reading-entry-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition:
        transform 180ms ease,
        filter 180ms ease,
        opacity 240ms cubic-bezier(0.4, 0, 0.2, 1),
        visibility 0s linear 0s;
    }
    /* Main click target — transparent <a> stretched over the panel
       so any click that isn't on the summary pill continues reading.
       Sits BELOW the asset visually (z-index handled by stacking
       order; `.reading-entry-asset` paints on top with pointer-
       events:none, so the link still receives clicks underneath). */
    .reading-entry-main {
      position: absolute;
      inset: 0;
      display: block;
      border-radius: 28px;
      background: transparent;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
      z-index: 1;
      -webkit-tap-highlight-color: transparent;
    }
    .reading-entry-main:focus-visible {
      outline: none;
    }
    .reading-entry-main:focus-visible ~ .reading-entry-asset {
      box-shadow:
        0 0 0 2px rgba(150, 200, 255, 0.45),
        0 0 22px rgba(112, 87, 255, 0.45);
    }

    /* The PNG IS the panel — painted edge-to-edge over the main link.
       `pointer-events: none` so the transparent `.reading-entry-main`
       below it still receives every click that isn't on the pill. */
    .reading-entry-asset {
      position: absolute;
      inset: 0;
      border-radius: 28px;
      background-image: url('/assets/ui/reading-entry/reading-entry-card1.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      pointer-events: none;
      z-index: 2;
      transition:
        transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 220ms ease,
        filter 220ms ease;
    }

    /* ─── Live content stack ─────────────────────────────────────────
       Container holds ONLY the action row now (chapter, progress, and
       facts were removed at Tomer's request). Positioned absolutely
       over the BOTTOM ~70% of the panel so the book icon baked into
       `reading-entry-card1.png` (top ~30%) stays clear. The container
       is `pointer-events:none` so empty space passes clicks through to
       `.reading-entry-main`; only the small secondary link re-opts
       back into hit-testing.

       `justify-content: center` puts the action pair in the vertical
       centre of the available area — no longer space-between because
       there's only one child. */
    .reading-entry-text {
      position: absolute;
      left: 50%;
      top: 32%;
      bottom: 14px;
      width: calc(100% - 36px);
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: center;
      text-align: center;
      pointer-events: none;
      z-index: 3;
      font-family:
        'Heebo', 'Inter', system-ui, -apple-system,
        'Segoe UI', 'Noto Sans Hebrew', sans-serif;
    }

    /* ── 1. Chapter headline — the focal element ─────────────────── */
    .reading-entry-chapter {
      font-size: 26px;
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.01em;
      white-space: nowrap;
      color: rgba(255, 255, 255, 0.98);
      text-shadow:
        0 0 14px rgba(120, 200, 255, 0.35),
        0 2px 6px rgba(0, 0, 0, 0.55);
      margin: 0;
    }

    /* ── 2. Progress row — thin animated bar + tiny % label ──────── */
    .reading-entry-progress {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
    }
    .reading-entry-progress-track {
      flex: 1 1 auto;
      position: relative;
      height: 4px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      overflow: hidden;
      box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.35);
    }
    .reading-entry-progress-fill {
      display: block;
      width: var(--re-progress, 0%);
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #b8e6ff 0%, #22d3ee 60%, #0ea5e9 100%);
      box-shadow:
        0 0 8px rgba(34, 211, 238, 0.55),
        0 0 2px rgba(184, 230, 255, 0.85);
      transition: width 480ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reading-entry-progress-pct {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: rgba(170, 230, 255, 0.92);
      white-space: nowrap;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      min-width: 36px;
      text-align: end;
    }

    /* ── 3. Facts strip — quiet inline text, middot separators ──── */
    .reading-entry-facts {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0;
      font-size: 12.5px;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: rgba(220, 235, 250, 0.62);
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
      line-height: 1.2;
    }
    .reading-entry-fact {
      white-space: nowrap;
    }
    .reading-entry-fact + .reading-entry-fact::before {
      content: '·';
      margin: 0 8px;
      opacity: 0.65;
    }

    /* ── 4. Action row — primary CTA + ghost secondary ──────────── */
    .reading-entry-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      width: 100%;
    }

    /* PRIMARY CTA — glowing cyan pill. Decorative: the real click
       target is the full-panel `.reading-entry-main` link. We keep
       this `pointer-events:none` so it never blocks that click.
       Hover styling is applied via `.reading-entry-overlay:has(.reading-entry-main:hover)`
       further down. */
    .reading-entry-cta {
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-width: 200px;
      height: 40px;
      padding: 0 22px;
      border-radius: 999px;
      font-size: 14.5px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: rgba(6, 18, 40, 0.96);
      background:
        linear-gradient(180deg,
          rgba(220, 245, 255, 0.96) 0%,
          rgba(120, 215, 240, 0.96) 55%,
          rgba(34, 184, 216, 0.96) 100%);
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.85),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 22px rgba(34, 211, 238, 0.45),
        0 6px 16px rgba(8, 18, 40, 0.40);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.4);
      transition:
        box-shadow 200ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 200ms ease;
    }
    .reading-entry-cta-label {
      line-height: 1;
    }
    .reading-entry-cta-arrow {
      width: 15px;
      height: 15px;
      flex-shrink: 0;
      stroke: currentColor;
    }
    /* In Hebrew (RTL) the arrow should point left = "forward". The icon
       is authored as a right-arrow; flip it for RTL via the inherited
       overlay dir. */
    [dir="rtl"] .reading-entry-cta-arrow {
      transform: scaleX(-1);
    }

    /* SECONDARY — tiny ghost text link with chevron. Lives just below
       the primary CTA so the hierarchy reads top-down: chapter →
       progress → facts → big button → tiny link. */
    .reading-entry-summary-pill {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.03em;
      line-height: 1;
      color: rgba(190, 225, 250, 0.78);
      background: transparent;
      border: 1px solid transparent;
      text-decoration: none;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
      cursor: pointer;
      transition:
        color 160ms ease,
        background 160ms ease,
        border-color 160ms ease,
        transform 160ms ease;
    }
    .reading-entry-summary-pill::after {
      content: '›';
      font-size: 14px;
      line-height: 1;
      opacity: 0.7;
      transform: translateY(-1px);
    }
    [dir="rtl"] .reading-entry-summary-pill::after {
      content: '‹';
    }
    .reading-entry-summary-pill:hover {
      color: rgba(235, 250, 255, 1);
      background: rgba(18, 32, 60, 0.55);
      border-color: rgba(150, 200, 245, 0.45);
    }
    .reading-entry-summary-pill:active {
      transform: scale(0.97);
    }
    .reading-entry-summary-pill:focus-visible {
      outline: none;
      box-shadow:
        0 0 0 2px rgba(150, 200, 255, 0.45),
        0 0 14px rgba(112, 87, 255, 0.35);
    }

    /* Brighten the primary CTA when the main link is hovered so the
       whole panel reads as one interactive surface anchored by the
       glowing pill. */
    .reading-entry-overlay:has(.reading-entry-main:hover) .reading-entry-cta {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.95),
        inset 0 -1px 0 rgba(8, 60, 90, 0.30),
        0 0 28px rgba(34, 211, 238, 0.65),
        0 8px 20px rgba(8, 18, 40, 0.45);
      filter: brightness(1.06);
    }
    .reading-entry-overlay:has(.reading-entry-main:active) .reading-entry-cta {
      transform: translateY(1px);
    }

    /* Hover / active — brightness lift only. NO translate.

       Tomer asked for the panel to stay glued to the orbit card in
       every state. An earlier `translate(-50%, -2px)` on hover
       briefly detached the panel from the card above (the gap above
       grew, the gap below shrank), which read as the panel "lifting
       away" from its anchor. Hover now changes brightness only so
       the seam between the two surfaces never moves.

       NOTE: an even earlier `scale(1/1.5)` counter-scale also lived
       here from the era when the centered card was rendered at
       scale(1.5). The center card is now sized natively, so any
       scale() on hover would visibly shrink the panel by 33%. Hover
       stays both scale-free AND translate-free on purpose. */
    .reading-entry-overlay:has(.reading-entry-main:hover) {
      filter: brightness(1.08);
    }
    .reading-entry-overlay:has(.reading-entry-main:hover) .reading-entry-asset {
      filter: brightness(1.04) saturate(1.05);
    }
    .reading-entry-overlay:has(.reading-entry-main:active) {
      filter: none;
    }
    .reading-entry-overlay:has(.reading-entry-main:active) .reading-entry-asset {
      filter: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .reading-entry-overlay,
      .reading-entry-asset,
      .reading-entry-summary-pill {
        transition: none;
      }
      .reading-entry-overlay:has(.reading-entry-main:hover) {
        filter: none;
      }
    }

    /* The standalone `.center-card-extras` wrapper was retired — the
       meta row now lives INSIDE the reading-entry panel itself. The
       wrapper, secondary link and section label are still defined in
       the DOM/CSS only as dead cohabitants of the panel block; both
       are pinned to display:none below so they never paint. */
    .center-card-extras,
    .cc-secondary-link,
    .cc-meta-label {
      display: none;
    }

    /* Legacy `.cc-meta` / `.cc-meta-item` chip styling retired with the
       redesign — the meta row is now `.reading-entry-facts` (quiet
       inline text + middots, styled higher up). The classes still
       appear in the DOM as dead-cohabitant hooks (the hydrator queries
       `[data-cc-meta-progress]`, kept on the new % label inside the
       progress bar) but no painted ruleset remains. */

    /* ── Reading-entry confirmation ─────────────────────────────────
       Minimal confirmation transition for the reading-button click.
       The earlier cinematic portal (seam + aura + scan + neural nodes
       + scene/hero dim + camera push) was retired — Tomer asked for a
       mature, professional, fast handoff. What survives:
         1. The reading-entry pill fades out quickly (~100ms).
         2. The selected card gets a very subtle cyan halo + brightness
            lift (~200ms).
         3. JS navigates to the same href after ~200ms.

       Carousel focus (recede on non-centred cards, scale on centred)
       lives in its own block below and is independent — it runs on
       every card-centring event, not just on launch.

       Tunables on `:root` so JS and CSS share one source of truth.
       JS reads `--reading-entry-total` via getComputedStyle and uses
       it as the setTimeout delay before navigation. */
    :root {
      --reading-entry-total: 200ms;
      --reading-entry-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      --reading-entry-halo-color: rgba(120, 210, 255, 0.45);
    }

    /* Pill fade — the user just activated it, so its job is done.
       Opacity-only so the link itself stays in the accessibility tree
       until the navigation timer fires. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-asset,
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"]
      .reading-entry-text {
      opacity: 0;
      transition: opacity 100ms ease-out;
    }

    /* Subtle confirmation on the selected card — a small brightness
       lift plus a single cyan halo that traces the artifact's alpha
       silhouette via drop-shadow. Calibrated to read as "the AI heard
       you" within 200ms, without theatrics. */
    .library-galaxy[data-reading-entry-state="opening"]
      .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front) {
      filter:
        brightness(1.05)
        drop-shadow(0 0 8px var(--reading-entry-halo-color));
      transition: filter var(--reading-entry-total) var(--reading-entry-ease);
    }

    /* ── Carousel focus: non-centred cards recede ─────────────────────
       Trigger is `data-galaxy-focused` on the stage (set by
       universe-layout.ts whenever a card is centred), NOT the launch-
       state attribute. The recede is a NORMAL carousel-focus behaviour:
       pick any card via orbit navigation and the rest of the field
       recedes immediately — no reading-button click required.

       `scale` is the individual CSS property (not `transform: scale`)
       so it composes after the orbit's cos/sin transform without us
       having to recompute coordinates here. Transition runs at 0.4s
       to match the orbit's snappy focus pace. */
    .library-galaxy[data-galaxy-focused]
      .galaxy-card:not([data-pos="center"]) {
      filter: blur(3px) saturate(0.78);
      opacity: 0.28;
      scale: 0.86;
      transition:
        filter 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        scale 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Reduced motion: skip both the confirmation halo and the focus
       recede. JS short-circuits with location.assign before any state
       flip too, so these rules are belt-and-braces for any code path
       that sets the state without the JS guard. */
    @media (prefers-reduced-motion: reduce) {
      .library-galaxy[data-reading-entry-state="opening"]
        .galaxy-card[data-pos="center"] :global(.lc-orbit-artifact-face-front) {
        filter: none;
        transition: none;
      }
      .library-galaxy[data-galaxy-focused]
        .galaxy-card:not([data-pos="center"]) {
        transition: none;
        scale: 1;
        filter: none;
        opacity: 1;
      }
    }

    /* Click-catcher only — covers the stage when a card is focused so
       a click anywhere outside the centered card closes the focus
       state. No visible fill / no blur layer: the focused card is its
       own focal point now (1.5× scale, larger artifact, layered text),
       and the wide blur was reading as a heavy panel behind the
       artifact rather than helping the focal lift. */
    .galaxy-backdrop {
      position: absolute;
      inset: 0;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      opacity: 0;
      pointer-events: none;
      z-index: 15;
    }
    .library-galaxy[data-galaxy-focused] .galaxy-backdrop {
      /* Stays invisible — only its hitbox matters. opacity:1 just lets
         pointer-events register; it has nothing to render. */
      opacity: 1;
      pointer-events: auto;
    }
    /* Focus state used to dim the centered PNG so the focused card
       read as the new focal point. With the galaxy now rendered as
       a full-viewport scene background, the `.galaxy-backdrop` blur+
       darken layer above the orbit already provides that focal lift,
       so no extra dimming is wired here. */

    /* Orbit rotation controls — chevron pair pinned to the bottom of
       the viewport (not the stage), so they sit clear of the orbit
       cards at every breakpoint and remain a large, easy click target.
       Each click bumps --orbit-rotation on the stage by ±360°/N, and
       CSS interpolates the resulting transform on every card
       simultaneously. The wrapper is a flex pill so the two buttons
       read as one control. */
    .galaxy-orbit-controls {
      /* Always pinned to the very bottom of the viewport on desktop
         too. Only the safe-area-inset-bottom is honored on top —
         same hard-edge anchoring as the mobile rule above. */
      position: fixed !important;
      inset-block-end: auto;
      bottom: env(safe-area-inset-bottom, 0px) !important;
      left: 0;
      right: 0;
      margin-inline: auto;
      display: flex;
      width: max-content;
      gap: 0.5rem;
      padding: 0.3125rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.18),
        0 6px 18px rgba(0, 0, 0, 0.30);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      z-index: 40;
      direction: ltr;
    }
    .galaxy-orbit-btn {
      /* Compact rotate control — small pearl glass circle. Slightly
         brighter than the previous muted-surface version so the icons
         read clearly without competing with the book cards. */
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: rgba(255, 255, 255, 0.92);
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255, 255, 255, 0.22);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.28),
        0 2px 6px rgba(0, 0, 0, 0.24);
      cursor: pointer;
      padding: 0;
      transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }
    .galaxy-orbit-btn:hover,
    .galaxy-orbit-btn:focus-visible {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.36);
      transform: translateY(-1px);
      outline: none;
    }
    /* Mirror chevrons on RTL pages so "next" still points toward the
       direction reading flows. The stage itself is direction:ltr;
       only the icons need the manual flip. */
    [dir="rtl"] .galaxy-orbit-btn svg { transform: scaleX(-1); }

  }

  /* ── Wide desktop (≥1280px): wider orbit cards + larger orbit. ─── */
  @media (min-width: 1280px) {
    /* Larger orbit scene gets a deeper vertical offset so rotating
       cards along the wider ellipse still clear the page title.
       Wide desktop carries a slightly bigger orbit-ry (up to 250px
       vs the 1024-1279px tier's 230px), so the offset adds another
       +20px on top of the base desktop's new 90px to preserve the
       minimum ~20px top-card clearance Tomer requested.
       Reduced from 110→70 (paired with --orbit-ry shrinking by the
       same ~40px) so the orbit becomes shorter on wide desktops too
       while the TOP of the carousel stays at the same Y as before. */
    .library-galaxy {
      --orbit-vertical-offset: 70px;
    }
    .galaxy-card {
      /* 210px × 1.2 = 252px (Tomer's +20% bump). Orbit radii grown
         proportionally so the wider cards still distribute cleanly. */
      width: 252px;
      --orbit-rx: clamp(350px, 33vw, 480px);
      --orbit-ry: clamp(180px, 22vh, 235px);
    }
    /* Capsule stays one notch wider than a book card so the proportion
       contrast holds across breakpoints. 232 × 1.2 = 278px. */
    .galaxy-card[data-role="series"] {
      width: 278px;
    }
  }

  /* ── Series action panel — shown next to a focused series capsule ──
        Two pill buttons that ride along inside the existing
        `.galaxy-cta` slot. The slot's fade-in / pointer-events rule
        already gates visibility on `[data-pos="center"]`, so these
        buttons inherit the same focus-only reveal as the close button
        without any extra logic.
        Only the course card (`data-kind="course"`) ever renders the
        wrapper, so other cards remain unchanged. */
  /* ── Series action buttons —
        Two large futuristic capsules under the focused course card.
        Each is a glass plate with:
          • a layered prismatic conic-gradient border that drifts on
            hover (animation pauses to save paint when not interactive);
          • a circular accent badge wrapping the icon, with its own
            radial glow that intensifies on hover;
          • a diagonal shimmer sweep that crosses the surface once
            per hover/focus;
          • a soft halo (box-shadow) and a 2px lift on activation.
        The two buttons are colour-differentiated so they read as
        distinct actions even at a glance: the toggle uses
        cyan→purple (knowledge / discovery), the details uses
        gold→purple (info / metadata). aria-pressed on the toggle
        intensifies the conic border + halo without changing the
        layout, so the "open" state reads clearly. */
  .galaxy-cta-series-actions {
    display: flex;
    flex-direction: row;
    gap: 0.7rem;
    align-items: stretch;
    justify-content: center;
    margin-block-start: 0.5rem;
  }
  .galaxy-cta-series-btn {
    --series-btn-accent: var(--yuval-galaxy-accent-purple, #a78bfa);
    --series-btn-accent-2: var(--yuval-galaxy-accent-cyan, #22d3ee);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 1.05rem 0.65rem 0.65rem;
    border-radius: 16px;
    font-family: 'Spectral', 'Cardo', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--yuval-galaxy-text, #ececea);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 90%, transparent) 0%,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 72%, transparent) 100%
      );
    border: 1px solid transparent;
    cursor: pointer;
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    isolation: isolate;
    overflow: hidden;
    text-align: start;
    white-space: nowrap;
    box-shadow:
      0 8px 20px -10px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
    transition:
      transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 280ms ease,
      background 280ms ease;
  }
  /* Prismatic border — conic gradient projected onto a 1px-thick
     ring via mask-composite. The "fill" gradient slowly rotates so
     the border catches light like a hologram edge. */
  .galaxy-cta-series-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--series-btn-spin, 0deg),
      color-mix(in srgb, var(--series-btn-accent) 80%, transparent) 0%,
      color-mix(in srgb, var(--series-btn-accent-2) 70%, transparent) 25%,
      color-mix(in srgb, var(--yuval-galaxy-accent-gold, #f6c560) 55%, transparent) 50%,
      color-mix(in srgb, var(--series-btn-accent-2) 70%, transparent) 75%,
      color-mix(in srgb, var(--series-btn-accent) 80%, transparent) 100%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 280ms ease;
    z-index: 0;
  }
  /* Shimmer sweep — diagonal light slash that crosses the surface
     once per hover/focus. Sits above the background but below the
     icon + label (z-index dance below). */
  .galaxy-cta-series-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in srgb, white 22%, transparent) 50%,
      transparent 70%
    );
    transform: translateX(-130%);
    pointer-events: none;
    z-index: 1;
    transition: transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .galaxy-cta-series-btn > * {
    position: relative;
    z-index: 2;
  }
  .galaxy-cta-series-btn:hover,
  .galaxy-cta-series-btn:focus-visible {
    outline: none;
    transform: translateY(-2px);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 78%, transparent) 0%,
        color-mix(in srgb, var(--series-btn-accent) 14%, var(--yuval-galaxy-bg, #00010d)) 100%
      );
    box-shadow:
      0 14px 32px -8px color-mix(in srgb, var(--series-btn-accent) 55%, transparent),
      0 0 0 1px color-mix(in srgb, var(--series-btn-accent) 25%, transparent) inset,
      inset 0 1px 0 color-mix(in srgb, white 18%, transparent);
  }
  .galaxy-cta-series-btn:hover::before,
  .galaxy-cta-series-btn:focus-visible::before {
    opacity: 1;
  }
  .galaxy-cta-series-btn:hover::after,
  .galaxy-cta-series-btn:focus-visible::after {
    transform: translateX(130%);
  }
  .galaxy-cta-series-btn[aria-pressed="true"] {
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--series-btn-accent) 25%, var(--yuval-galaxy-bg, #00010d)) 0%,
        color-mix(in srgb, var(--series-btn-accent-2) 18%, var(--yuval-galaxy-bg, #00010d)) 100%
      );
    box-shadow:
      0 10px 28px -8px color-mix(in srgb, var(--series-btn-accent) 60%, transparent),
      0 0 0 1px color-mix(in srgb, var(--series-btn-accent) 35%, transparent) inset,
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent);
  }
  .galaxy-cta-series-btn[aria-pressed="true"]::before {
    opacity: 1;
  }
  /* Icon badge — circular glass medallion with radial glow. */
  .galaxy-cta-series-btn-icon {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--series-btn-accent);
    background:
      radial-gradient(
        circle at 30% 30%,
        color-mix(in srgb, var(--series-btn-accent) 45%, transparent) 0%,
        color-mix(in srgb, var(--series-btn-accent) 18%, transparent) 55%,
        transparent 100%
      );
    border: 1px solid color-mix(in srgb, var(--series-btn-accent) 50%, transparent);
    flex: 0 0 auto;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent),
      0 0 14px -4px color-mix(in srgb, var(--series-btn-accent) 60%, transparent);
    transition:
      transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 280ms ease;
  }
  .galaxy-cta-series-btn-icon svg {
    width: 16px;
    height: 16px;
  }
  .galaxy-cta-series-btn:hover .galaxy-cta-series-btn-icon,
  .galaxy-cta-series-btn:focus-visible .galaxy-cta-series-btn-icon {
    transform: scale(1.1) rotate(-4deg);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 32%, transparent),
      0 0 22px -2px color-mix(in srgb, var(--series-btn-accent) 85%, transparent);
  }
  .galaxy-cta-series-btn-label {
    line-height: 1.1;
    font-size: 0.92rem;
    /* Subtle gradient text — same prismatic palette as the border,
       muted so the label still reads as a label, not a sign. */
    background: linear-gradient(
      120deg,
      var(--yuval-galaxy-text, #ececea) 0%,
      color-mix(in srgb, var(--series-btn-accent) 35%, var(--yuval-galaxy-text, #ececea)) 100%
    );
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
            color: transparent;
  }
  /* "Series details" button — gold accent variant so the two
     buttons read as different at a glance. */
  .galaxy-cta-series-btn[data-series-action="details"] {
    --series-btn-accent: var(--yuval-galaxy-accent-gold, #f6c560);
    --series-btn-accent-2: var(--yuval-galaxy-accent-purple, #a78bfa);
  }

  /* ── Local children fan — opens around the focused series capsule ──
        The fan is a horizontal row of small child cards positioned
        under the focused capsule. It lives inside the orbit stage as
        a positioned overlay so it never permanently mixes into the
        main universe. Hidden until the controller populates it; the
        controller also clears its contents on close so leftover state
        never lingers. */
  .series-children-fan[hidden] { display: none; }
  .series-children-fan {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 1.25rem;
    z-index: 25; /* above orbit cards (3), below focused card (30) */
    display: flex;
    justify-content: center;
    pointer-events: none;
    padding-inline: 1rem;
  }
  .series-children-list {
    list-style: none;
    margin: 0;
    padding: 0.625rem 0.875rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.625rem;
    pointer-events: auto;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 28%, transparent);
    border-radius: 1rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 12%, transparent) inset,
      0 18px 40px -16px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 40%, transparent);
    max-width: min(640px, 92%);
    animation: series-children-fade-in 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes series-children-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .series-children-empty {
    margin: 0;
    padding: 0.875rem 1.125rem;
    pointer-events: auto;
    color: var(--yuval-galaxy-text-soft);
    font-size: 0.8125rem;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 75%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 28%, transparent);
    border-radius: 999px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-align: center;
  }
  .series-child-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 96px;
    padding: 0.4375rem;
    border-radius: 0.625rem;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 65%, transparent);
    border: 1px solid color-mix(in srgb, var(--yuval-galaxy-border, rgba(120, 130, 165, 0.22)) 70%, transparent);
    transition: border-color 160ms ease, transform 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .series-child-card:hover {
    border-color: color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 55%, transparent);
    transform: translateY(-2px);
  }
  .series-child-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 0.5rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(
        circle at 50% 35%,
        color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 18%, transparent) 0%,
        transparent 70%
      ),
      var(--yuval-galaxy-surface-muted, #161a2c);
  }
  .series-child-visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }
  .series-child-visual-placeholder {
    flex-direction: column;
    gap: 0.25rem;
    color: color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 75%, var(--yuval-galaxy-text-soft, #c8c8c4));
  }
  .series-child-placeholder-glyph {
    display: inline-flex;
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 50%, transparent));
  }
  .series-child-placeholder-type {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--yuval-galaxy-text-soft, #c8c8c4);
    opacity: 0.85;
  }
  .series-child-title {
    margin: 0.4375rem 0 0;
    font-size: 0.6875rem;
    line-height: 1.25;
    color: var(--yuval-galaxy-text, #ececea);
    text-align: center;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Series details drawer — same-page modal ───────────────────────
        Right-anchored (logical inline-end) sliding drawer that opens
        when the user clicks "Series details" on a focused capsule.
        Uses a real <aside role="dialog" aria-modal="true"> so screen
        readers and keyboard users get a proper modal surface. The
        overlay is a sibling click-catcher; it does not blur to keep
        the cosmic backdrop visible. */
  .series-details-overlay[hidden],
  .series-details-drawer[hidden] { display: none !important; }
  .series-details-overlay {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 70%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 90;
    animation: series-details-overlay-in 220ms ease-out;
  }
  @keyframes series-details-overlay-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .series-details-drawer {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    inset-inline-start: auto;
    width: min(420px, 100vw);
    max-width: 100vw;
    background: color-mix(in srgb, var(--yuval-galaxy-bg, #00010d) 92%, var(--yuval-galaxy-accent-purple, #a78bfa));
    border-inline-start: 1px solid color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 40%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--yuval-galaxy-accent-purple, #a78bfa) 20%, transparent) inset,
      -24px 0 60px -10px color-mix(in srgb, #000 75%, transparent);
    color: var(--yuval-galaxy-text, #ececea);
    z-index: 100;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: series-details-drawer-in 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes series-details-drawer-in {
    from { transform: translateX(100%); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }
  [dir="rtl"] .series-details-drawer {
    animation-name: series-details-drawer-in-rtl;
  }
  @keyframes series-details-drawer-in-rtl {
    from { transform: translateX(-100%); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }
  .series-details-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.125rem 1.25rem;
