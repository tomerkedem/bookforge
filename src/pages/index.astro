                        </span>
                      </div>
                    </div>
                  </div>
                )}
                {/* `.galaxy-cta` slot is now only rendered for series
                    capsules — the open-orb (`.galaxy-cta-open`) was
                    superseded by `.reading-entry-overlay`, and the X
                    close button was retired in favour of backdrop-tap
                    and Esc-key closing. Books / lessons / articles
                    therefore emit no `.galaxy-cta` markup at all. */}
                {kind === 'course' && (
                  <div class="galaxy-cta">
                    <div class="galaxy-cta-series-actions" data-series-action-panel>
                      <button
                        type="button"
                        class="galaxy-cta-series-btn"
                        data-series-action="toggle-items"
                        aria-pressed="false"
