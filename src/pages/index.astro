    {showOrbitControls && (
      <div class="galaxy-mobile-nav" data-galaxy-mobile-nav>
        {/* Mobile layout:
              row 1  counter "1 / 11"            (closest to carousel)
              row 2  [prev]   • • • • • •   [next]   (single row;
                                                     dots centered)
            Counter is its own row above the arrow rail; dots live
            INSIDE the arrow rail so the row reads as one composition.
