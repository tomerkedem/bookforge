---
import type { Book } from '../lib/books';

interface Props {
  book: Book;
  index: number;
  lang?: 'he' | 'en';
}

const { book, index, lang = 'he' } = Astro.props;
const title = lang === 'he' ? book.title.he : book.title.en;
const description = lang === 'he' ? book.description.he : book.description.en;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const num = String(index + 1).padStart(2, '0');
---

<article dir={dir} class="group relative bg-white transition-colors duration-200 hover:bg-yuval-bg-secondary">
  <a
    href={book.available ? `/${book.slug}/` : undefined}
    class:list={['block h-full', { 'cursor-not-allowed': !book.available }]}
    aria-label={`${title}${!book.available ? (lang === 'he' ? ' — בקרוב' : ' — Coming soon') : ''}`}
    tabindex={book.available ? 0 : -1}
  >
    <div style="padding: 40px;">
      <!-- Sequential number -->
      <p
        class="text-yuval-text-muted"
        style="font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 32px;"
      >
        {num}
      </p>

      <!-- Title -->
      <h2 class="font-heading text-yuval-text" style="font-size: 24px; font-weight: 700; line-height: 1.2; margin-bottom: 16px;">
        {title}
      </h2>

      <!-- Description -->
      <p class="text-yuval-text-tertiary" style="font-size: 14px; font-weight: 300; line-height: 1.7;">
        {description}
      </p>

      <!-- Footer row -->
      <div class="flex items-center justify-between mt-8">
        <div style="font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;" class="text-yuval-text-muted">
          {book.available
            ? `${book.totalChapters} ${lang === 'he' ? 'פרקים' : 'chapters'}`
            : (lang === 'he' ? 'בקרוב' : 'Coming soon')}
        </div>

        <!-- Arrow — hidden by default, visible on hover -->
        {book.available && (
          <span
            class="text-yuval-text opacity-0 group-hover:opacity-100 transition-opacity duration-200"
            aria-hidden="true"
            style="font-size: 18px;"
          >
            {dir === 'rtl' ? '←' : '→'}
          </span>
        )}
      </div>
    </div>
  </a>
</article>
