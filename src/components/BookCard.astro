---
import type { Book } from '../lib/books';

interface Props {
  book: Book;
  lang?: 'he' | 'en';
}

const { book, lang = 'he' } = Astro.props;
const title = lang === 'he' ? book.title.he : book.title.en;
const description = lang === 'he' ? book.description.he : book.description.en;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const href = `/${book.slug}/`;
---

<article
  dir={dir}
  class:list={[
    'group relative flex flex-col rounded-2xl overflow-hidden border border-gray-100',
    'shadow-sm hover:shadow-xl transition-all duration-300',
    !book.available && 'opacity-70',
  ]}
>
  <!-- Cover -->
  <div class={`bg-gradient-to-br ${book.coverColor} h-44 flex items-end p-5 relative`}>
    {!book.available && (
      <span class="absolute top-3 end-3 bg-black/40 text-white text-xs font-medium px-2 py-1 rounded-full">
        {lang === 'he' ? 'בקרוב' : 'Coming soon'}
      </span>
    )}
    <h2 class="text-white text-xl font-bold leading-tight drop-shadow-sm line-clamp-2">
      {title}
    </h2>
  </div>

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 bg-white gap-3">
    <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <div class="flex items-center justify-between gap-2 pt-1">
      <div class="flex items-center gap-2">
        {book.available ? (
          <span class="text-xs bg-green-50 text-green-700 border border-green-100 px-2 py-0.5 rounded-full font-medium">
            {book.totalChapters} {lang === 'he' ? 'פרקים' : 'chapters'}
          </span>
        ) : (
          <span class="text-xs bg-gray-50 text-gray-400 border border-gray-100 px-2 py-0.5 rounded-full">
            {lang === 'he' ? 'בפיתוח' : 'In progress'}
          </span>
        )}
        <span class="text-xs text-gray-300">
          {book.lang === 'he' ? 'עב׳' : 'EN'} + {book.lang === 'he' ? 'EN' : 'עב׳'}
        </span>
      </div>

      {book.available && (
        <a
          href={href}
          class="text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors group-hover:underline"
          aria-label={`${lang === 'he' ? 'קרא את' : 'Read'} ${title}`}
        >
          {lang === 'he' ? 'קרא עכשיו ←' : 'Read now →'}
        </a>
      )}
    </div>
  </div>
</article>
