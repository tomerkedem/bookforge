---
/**
 * LibraryCard — generic card for any LibraryItem.
 *
 * Liskov: every LibraryItemType renders through this same component.
 * Type-specific styling enters only via CSS variables (--card-accent,
 * status colour token), never via per-type if-branches.
 *
 * Safe-link policy (see src/utils/library-display.ts:isSafeLibraryHref):
 *   - href starts with /read/ or /books/  → render as <a> (real navigation)
 *   - any other href, or none             → render as non-clickable <article>
 *
 * Variants:
 *   - 'default'  type + status badge + title + summary + meta line
 *   - 'compact'  type + title + summary  (used by RecommendationStrip)
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
  getItemStatusLabelKey,
  getTypeAccentVar,
  getStatusAccentVar,
  formatLibraryDate,
  formatReadingMinutes,
  isSafeLibraryHref,
} from '../../utils/library-display';

interface Props {
  item: LibraryItem;
  language: Language;
  variant?: 'default' | 'compact';
}
const { item, language, variant = 'default' } = Astro.props;

const title = getItemTitle(item, language);
const summary = getItemSummary(item, language);
const typeLabel = t(getItemTypeLabelKey(item.type), language);
const statusLabel = t(getItemStatusLabelKey(item.status), language);
const minutes = formatReadingMinutes(item.readingMinutes);
const dateString = formatLibraryDate(item.updatedAt, language);
const wordCount = typeof item.wordCount === 'number' ? item.wordCount : undefined;

const accentStyle = `--card-accent: ${getTypeAccentVar(item.type)};`;
const statusStyle = `color: ${getStatusAccentVar(item.status)}; border-color: ${getStatusAccentVar(item.status)};`;

const showStatus = variant === 'default';
const showMeta = variant === 'default';

const isSafe = isSafeLibraryHref(item.href);
const wrapperClass = ['lc', `lc-${variant}`, isSafe ? 'lc-link' : 'lc-static'].join(' ');
---

{isSafe ? (
  <a
    class={wrapperClass}
    href={item.href}
    style={accentStyle}
    aria-label={title}
  >
    <header class="lc-header">
      <p class="lc-type">{typeLabel}</p>
      {showStatus && (
        <span class="lc-status" style={statusStyle}>{statusLabel}</span>
      )}
    </header>
    <h3 class="lc-title">{title}</h3>
    {summary && <p class="lc-summary">{summary}</p>}
    {showMeta && (minutes !== undefined || wordCount !== undefined || dateString) && (
      <p class="lc-meta">
        {minutes !== undefined && (
          <span>{t('library.stats.readingMinutes', language, { n: minutes })}</span>
        )}
        {wordCount !== undefined && (
          <span>{t('library.stats.words', language, { n: wordCount })}</span>
        )}
        {dateString && (
          <span>{t('library.stats.updatedRecently', language, { when: dateString })}</span>
        )}
      </p>
    )}
  </a>
) : (
  <article
    class={wrapperClass}
    style={accentStyle}
    aria-label={title}
    aria-disabled="true"
  >
    <header class="lc-header">
      <p class="lc-type">{typeLabel}</p>
      {showStatus && (
        <span class="lc-status" style={statusStyle}>{statusLabel}</span>
      )}
    </header>
    <h3 class="lc-title">{title}</h3>
    {summary && <p class="lc-summary">{summary}</p>}
    {showMeta && (minutes !== undefined || wordCount !== undefined || dateString) && (
      <p class="lc-meta">
        {minutes !== undefined && (
          <span>{t('library.stats.readingMinutes', language, { n: minutes })}</span>
        )}
        {wordCount !== undefined && (
          <span>{t('library.stats.words', language, { n: wordCount })}</span>
        )}
        {dateString && (
          <span>{t('library.stats.updatedRecently', language, { when: dateString })}</span>
        )}
      </p>
    )}
  </article>
)}

<style>
  .lc {
    --card-accent: var(--yuval-galaxy-accent);
    position: relative;
    display: block;
    padding: 1rem 1rem 1.125rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: calc(var(--yuval-galaxy-card-radius) - 4px);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
  }
  .lc::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    height: 2px;
    background-color: var(--card-accent);
    opacity: 0.85;
  }

  /* Link variant — interactive cues. */
  .lc-link {
    cursor: pointer;
    transition:
      transform var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out),
      box-shadow var(--yuval-galaxy-motion-normal) var(--yuval-galaxy-ease-out),
      background-color var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .lc-link:hover {
    background-color: var(--yuval-galaxy-card-surface-hover);
  }
  .lc-link:focus-visible {
    outline: none;
    box-shadow: var(--yuval-galaxy-card-shadow), var(--yuval-galaxy-glow-soft);
  }

  /* Static variant — make it visually clear nothing happens on click. */
  .lc-static {
    cursor: default;
  }

  /* Compact variant — a touch tighter, used in the recommendations strip. */
  .lc-compact {
    padding: 0.875rem 0.875rem 1rem;
  }

  .lc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-block-end: 0.5rem;
  }
  .lc-type {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0;
  }
  .lc-status {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    border: 1px solid;
    background-color: transparent;
    white-space: nowrap;
  }
  .lc-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.375rem;
    color: var(--yuval-galaxy-text);
  }
  .lc-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lc-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.875rem;
  }
</style>
