---
import type { Language } from '../../types/index';
import { t } from '../../i18n';
import { getLanguageDirection } from '../../utils/language';

/**
 * Lightweight per-book descriptor used by the client-side hydrator to
 * resolve the user's last-opened book against `yuval_reading_progress_*`
 * localStorage entries. Kept minimal on purpose — only what's needed to
 * render the card and deep-link the CTA.
 */
export interface ContinueLearningBook {
  slug: string;
  title: string;
  subtitle?: string;
  href: string;
  chapterCount: number;
}

interface Props {
  language: Language;
  courseTitle?: string;
  metaLine1?: string;
  metaLine2?: string;
  /**
   * SSR-known progress percentage. Defaults to 0 because the server has
   * no per-user reading state — the hydrator below replaces it with the
   * real value computed from localStorage.
   */
  progress?: number;
  href?: string;
  class?: string;
  /** Available lesson summaries already published for this course. */
  lessonsAvailable?: number;
  /** Total planned lesson summaries for this course. */
  lessonsTotal?: number;
  /**
   * Catalog of books the hydrator may swap into the card when a real
   * "last opened" entry is found in localStorage. Empty / undefined ⇒
   * SSR placeholder stays as-is.
   */
  readableBooks?: ContinueLearningBook[];
}

const {
  language,
  courseTitle = 'AI Engineering',
  metaLine1 = 'Series · Chapter 8',
  metaLine2 = 'Agentic Workflows',
  progress = 0,
  href = '#',
  class: className = '',
  lessonsAvailable,
  lessonsTotal,
  readableBooks = [],
} = Astro.props;

const hasLessonAvailability =
  typeof lessonsAvailable === 'number' &&
  typeof lessonsTotal === 'number' &&
  lessonsTotal > 0;

const direction = getLanguageDirection(language);
const safeProgress = Math.max(0, Math.min(100, progress));

const RADIUS = 34;
const CIRCUMFERENCE = 2 * Math.PI * RADIUS;
const dashLength = (safeProgress / 100) * CIRCUMFERENCE;

// Escape `</` so a stray `</script>` in any user-supplied book title or
// subtitle can't break out of the inline JSON payload below.
const hydratorPayload = JSON.stringify({
  circumference: CIRCUMFERENCE,
  books: readableBooks,
}).replace(/<\//g, '<\\/');
---

<article
  class={`continue-learning-card ${className}`}
  dir={direction}
  aria-label={t('library.a11y.continueReadingCard', language)}
  data-continue-learning-card
>
  {/* Holographic HUD layer — abstract AI interface visuals (thin neural
      lines, glowing nodes, a tiny HUD ring fragment and a delicate data
      graph) painted at very low opacity so the smart-glass body reads
      as alive without competing with the carousel. No readable text. */}
  <div class="continue-learning-card__bg" aria-hidden="true">
    <svg
      class="continue-learning-card__hud"
      viewBox="0 0 200 280"
      preserveAspectRatio="xMidYMid slice"
      fill="none"
      focusable="false"
      xmlns="http://www.w3.org/2000/svg"
    >
      <g class="continue-learning-card__hud-net">
        <line x1="20"  y1="36"  x2="68"  y2="64" />
        <line x1="68"  y1="64"  x2="34"  y2="112" />
        <line x1="68"  y1="64"  x2="142" y2="50" />
        <line x1="142" y1="50"  x2="180" y2="98" />
        <line x1="34"  y1="112" x2="180" y2="98" />
        <line x1="180" y1="98"  x2="158" y2="186" />
        <line x1="34"  y1="112" x2="92"  y2="216" />
        <line x1="158" y1="186" x2="92"  y2="216" />
      </g>
      <g class="continue-learning-card__hud-nodes">
        <circle cx="20"  cy="36"  r="1.4" />
        <circle cx="68"  cy="64"  r="2"   />
        <circle cx="142" cy="50"  r="1.6" />
        <circle cx="34"  cy="112" r="1.6" />
        <circle cx="180" cy="98"  r="2.2" />
        <circle cx="158" cy="186" r="1.6" />
        <circle cx="92"  cy="216" r="1.4" />
      </g>
      <g class="continue-learning-card__hud-ring">
        <circle cx="176" cy="26" r="18" />
        <circle cx="176" cy="26" r="10" />
        <path   d="M176 8 A18 18 0 0 1 194 26" />
        <circle cx="176" cy="26" r="1.8" class="continue-learning-card__hud-ring-core" />
      </g>
      <g class="continue-learning-card__hud-graph">
        <polyline points="14,254 28,244 40,250 52,234 66,242 78,226 92,232" />
        <line class="continue-learning-card__hud-graph-axis" x1="14" y1="262" x2="100" y2="262" />
        <line class="continue-learning-card__hud-graph-tick" x1="14" y1="262" x2="14"  y2="222" />
      </g>
    </svg>
  </div>

  <header class="continue-learning-card__header">
    <span class="continue-learning-card__header-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5c.6 3 1.5 4.5 4.5 5-3 .5-3.9 2-4.5 5-.6-3-1.5-4.5-4.5-5 3-.5 3.9-2 4.5-5z"></path>
        <path d="M19 14l.5 1.5L21 16l-1.5.5L19 18l-.5-1.5L17 16l1.5-.5z"></path>
        <path d="M5 4l.4 1.2L6.6 5.6 5.4 6 5 7.2 4.6 6 3.4 5.6 4.6 5.2z"></path>
      </svg>
    </span>
    <h3 class="continue-learning-card__title">
      {t('library.continueReading.title', language)}
    </h3>
  </header>

  {/* Glassy reading capsule — donut + book info live inside one
      luminous inset surface so the card reads as a "reading capsule",
      not a flat progress row. */}
  <div class="continue-learning-card__body">
    <div
      class="continue-learning-card__progress"
      role="img"
      aria-label={`${safeProgress}%`}
    >
      <svg class="continue-learning-card__ring" viewBox="0 0 80 80" width="84" height="84">
        <defs>
          {/* Stop colours come from CSS so the gradient follows the
              galaxy accent tokens in both dark and light modes. */}
          <linearGradient id="cl-donut-progress" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" class="continue-learning-card__grad-from" />
            <stop offset="100%" class="continue-learning-card__grad-to" />
          </linearGradient>
        </defs>
        <circle
          class="continue-learning-card__ring-track"
          cx="40"
          cy="40"
          r={RADIUS}
          fill="none"
          stroke-width="5"
        />
        <circle
          class="continue-learning-card__ring-arc"
          cx="40"
          cy="40"
          r={RADIUS}
          fill="none"
          stroke="url(#cl-donut-progress)"
          stroke-width="5"
          stroke-linecap="round"
          stroke-dasharray={`${dashLength} ${CIRCUMFERENCE}`}
          transform="rotate(-90 40 40)"
          data-clc-progress-arc
        />
      </svg>
      <span class="continue-learning-card__percent" data-clc-percent>{safeProgress}%</span>
    </div>

    {/* `dir="auto"` lets the browser auto-detect each line's direction
        from its first strong character: a Latin book title ("AI
        Developer Fitness") resolves LTR → `text-align: start` aligns it
        left even on this RTL card, while a Hebrew title stays RTL. The
        attribute re-evaluates whenever the hydrator swaps `textContent`,
        so it covers both the SSR placeholder and the real book. */}
    <div class="continue-learning-card__info">
      <p class="continue-learning-card__course-title" data-clc-title dir="auto">{courseTitle}</p>
      <p class="continue-learning-card__meta" data-clc-meta1 dir="auto">{metaLine1}</p>
      {metaLine2 && <p class="continue-learning-card__meta" data-clc-meta2 dir="auto">{metaLine2}</p>}
      {hasLessonAvailability && (
        <p class="continue-learning-card__meta continue-learning-card__lessons">
          {t('library.continueReading.lessonsAvailable', language, {
            available: lessonsAvailable!,
            total: lessonsTotal!,
          })}
        </p>
      )}
    </div>
  </div>

  <a class="continue-learning-card__cta" href={href} data-clc-cta>
    <span class="continue-learning-card__cta-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h6a4 4 0 0 1 4 4v12a3 3 0 0 0-3-3H4z"></path>
        <path d="M20 4h-6a4 4 0 0 0-4 4v12a3 3 0 0 1 3-3h7z"></path>
      </svg>
    </span>
    <span>{t('library.continueReading.cta', language)}</span>
  </a>

  <script
    type="application/json"
    data-clc-payload
    is:inline
    set:html={hydratorPayload}
  ></script>
</article>

<script>
  /**
   * Hydrate the Continue Learning card from real reading state.
   *
   * Reading progress is stored per-chapter as
   *   yuval_reading_progress_{slug}_ch{n}
   * with `{ percentage?, scrollPosition?, lastUpdated? }` (see
   * scripts/progress-tracker.ts). This script:
   *
   *   1. Picks the most-recently-updated entry → "last opened book".
   *   2. Computes a book-level percentage as the average across all
   *      [1..chapterCount] chapters (missing chapters count as 0%) —
   *      same algo as `hydrateOrbitProgress` in universe-layout.ts so
   *      the card and the orbit cards stay in agreement.
   *   3. Updates donut stroke-dasharray, percent label, title, meta,
   *      and deep-links the CTA to /read/{slug}/{lastChapter}.
   *
   * If no reading entries exist the SSR placeholder stays visible (the
   * "recommended starting point" book) but the percentage stays at 0%
   * — never the old hardcoded 68%.
   */
  (function () {
    const card = document.querySelector<HTMLElement>('[data-continue-learning-card]');
    if (!card) return;
    const payloadEl = card.querySelector<HTMLElement>('[data-clc-payload]');
    if (!payloadEl) return;

    type Book = {
      slug: string;
      title: string;
      subtitle?: string;
      href: string;
      chapterCount: number;
    };
    type Payload = { circumference: number; books: Book[] };

    let payload: Payload;
    try {
      payload = JSON.parse(payloadEl.textContent || '{}');
    } catch {
      return;
    }
    const { circumference, books } = payload;
    if (!Array.isArray(books) || books.length === 0) return;

    const bySlug = new Map<string, Book>();
    for (const b of books) bySlug.set(b.slug, b);

    let bestSlug = '';
    let bestUpdated = 0;
    let bestChapter = 1;
    const slugStats = new Map<string, { sum: number; latest: number; latestCh: number }>();

    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (!key) continue;
      const m = key.match(/^yuval_reading_progress_(.+?)_ch(\d+)$/);
      if (!m) continue;
      const slug = m[1];
      const ch = Number(m[2]);
      if (!bySlug.has(slug)) continue;

      let parsed: { percentage?: number; scrollPosition?: number; lastUpdated?: number };
      try {
        parsed = JSON.parse(localStorage.getItem(key) || '{}');
      } catch {
        continue;
      }

      let pct = Number(parsed.percentage);
      if (!Number.isFinite(pct) || pct <= 0) {
        const sp = Number(parsed.scrollPosition);
        pct = Number.isFinite(sp) && sp > 200
          ? Math.min(95, Math.round((sp / 3000) * 100))
          : 0;
      }
      pct = Math.max(0, Math.min(100, pct));
      const updated = Number(parsed.lastUpdated) || 0;

      const stat = slugStats.get(slug) || { sum: 0, latest: 0, latestCh: 1 };
      stat.sum += pct;
      if (updated > stat.latest) {
        stat.latest = updated;
        stat.latestCh = ch;
      }
      slugStats.set(slug, stat);

      if (updated > bestUpdated) {
        bestUpdated = updated;
        bestSlug = slug;
        bestChapter = ch;
      }
    }

    if (!bestSlug) return;

    const book = bySlug.get(bestSlug)!;
    const stat = slugStats.get(bestSlug)!;
    const total = book.chapterCount > 0 ? book.chapterCount : 1;
    const avg = Math.round(stat.sum / total);
    const safeAvg = Math.max(0, Math.min(100, avg));

    const titleEl = card.querySelector<HTMLElement>('[data-clc-title]');
    const meta1El = card.querySelector<HTMLElement>('[data-clc-meta1]');
    const meta2El = card.querySelector<HTMLElement>('[data-clc-meta2]');
    const pctEl = card.querySelector<HTMLElement>('[data-clc-percent]');
    const arc = card.querySelector<SVGCircleElement>('[data-clc-progress-arc]');
    const cta = card.querySelector<HTMLAnchorElement>('[data-clc-cta]');

    if (titleEl) titleEl.textContent = book.title;
    if (meta1El) meta1El.textContent = book.subtitle || '';
    if (meta2El) meta2El.remove();
    if (pctEl) pctEl.textContent = `${safeAvg}%`;
    if (arc) {
      const dash = (safeAvg / 100) * circumference;
      arc.setAttribute('stroke-dasharray', `${dash} ${circumference}`);
    }
    if (cta) cta.href = `/read/${book.slug}/${stat.latestCh || bestChapter}`;
  })();
</script>

<style>
  /* Mobile + tablet (≤1023px): the dashboard switches to its phone flow
     (compact hero → continue carousel → stats list → etc.). The fixed
     floating card has no place there and would overlap the content.
     1023px matches library.astro's own mobile/tablet reset breakpoint
     so the entire mobile composition flips in lockstep. */
  @media (max-width: 1023px) {
    .continue-learning-card { display: none !important; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     THEME LAYER — dark values are the default; the light block re-paints
     only the `--clc-*` tokens. One markup tree, two value sets — same
     pattern the Knowledge Core and Knowledge Atlas use.
     ═══════════════════════════════════════════════════════════════════ */
  .continue-learning-card {
    /* Outer panel surface / chrome — refined pearl frosted glass.
       Mostly white/pearl with a whisper of ice-blue. A thin pearl edge
       carries the glass identity; an outer cyan rim is barely there. */
    --clc-surface:
      radial-gradient(ellipse 100% 50% at 50% 0%,
        rgba(255, 255, 255, 0.10) 0%, transparent 70%),
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.09) 0%,
        rgba(240, 248, 255, 0.06) 100%);
    --clc-border: rgba(255, 255, 255, 0.20);
    --clc-shadow:
      /* Pearl glass edge — thin top + bottom highlights */
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(255, 255, 255, 0.10),
      /* Faint cyan rim light on the outer edge */
      0 0 20px rgba(180, 220, 255, 0.16),
      /* Soft drop shadow — separation from the background */
      0 18px 38px rgba(0, 0, 0, 0.28),
      0 6px 16px rgba(0, 0, 0, 0.18);

    /* HUD palette — whisper-faint ice-blue glass texture only */
    --clc-hud-line: rgba(210, 225, 245, 0.10);
    --clc-hud-node: rgba(225, 235, 250, 0.36);
    --clc-hud-node-glow: rgba(180, 210, 240, 0.22);
    --clc-hud-ring: rgba(200, 220, 240, 0.16);
    --clc-hud-graph: rgba(210, 225, 245, 0.18);
    --clc-hud-graph-axis: rgba(210, 225, 245, 0.10);

    /* Floor reflection — gentle pearl/ice-blue puddle */
    --clc-floor: rgba(180, 220, 255, 0.16);
    --clc-floor-soft: rgba(255, 255, 255, 0.06);

    /* Inner reading capsule — slightly milkier pearl so it reads as a
       nested glass surface inside the outer panel. */
    --clc-capsule:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.08) 0%,
        rgba(240, 248, 255, 0.05) 100%);
    --clc-capsule-border: rgba(255, 255, 255, 0.16);
    --clc-capsule-inset:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 0 14px rgba(255, 255, 255, 0.04);

    /* Progress ring — pearl-to-cyan, no purple */
    --clc-ring-track: rgba(255, 255, 255, 0.14);
    --clc-ring-from: #e8f4ff;
    --clc-ring-to: var(--yuval-galaxy-accent-cyan, #22d3ee);
    --clc-ring-glow: rgba(34, 211, 238, 0.32);
    --clc-percent-disc: rgba(200, 220, 240, 0.18);

    /* CTA — pearl glass button */
    --clc-cta-bg:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.12) 0%,
        rgba(240, 248, 255, 0.08) 100%);
    --clc-cta-border: rgba(255, 255, 255, 0.20);
    --clc-cta-border-hover: rgba(200, 230, 255, 0.55);
    --clc-cta-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 4px 14px rgba(0, 0, 0, 0.18);
    --clc-cta-glow: 0 0 18px -4px rgba(150, 200, 255, 0.45);
  }

  /* ── Light mode — pearl frosted glass ────────────────────────────────
     Daylight variant: clean pearl body with a soft pearl edge and a
     calm cool drop shadow. No strong purple, no saturated blue.
     Dark mode never matches `html:not(.dark)`, so it stays untouched. */
  :global(html:not(.dark)) .continue-learning-card {
    --clc-surface:
      radial-gradient(ellipse 100% 50% at 50% 0%,
        rgba(255, 255, 255, 0.55) 0%, transparent 72%),
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.42) 0%,
        rgba(245, 250, 255, 0.36) 100%);
    --clc-border: rgba(255, 255, 255, 0.65);
    --clc-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      inset 0 -1px 0 rgba(255, 255, 255, 0.45),
      0 0 18px rgba(150, 195, 235, 0.18),
      0 14px 32px rgba(30, 45, 80, 0.10),
      0 4px 12px rgba(30, 45, 80, 0.06);

    --clc-hud-line: rgba(60, 95, 140, 0.10);
    --clc-hud-node: rgba(60, 95, 140, 0.30);
    --clc-hud-node-glow: rgba(120, 170, 220, 0.22);
    --clc-hud-ring: rgba(120, 170, 220, 0.18);
    --clc-hud-graph: rgba(60, 95, 140, 0.22);
    --clc-hud-graph-axis: rgba(60, 95, 140, 0.10);

    --clc-floor: rgba(150, 195, 235, 0.20);
    --clc-floor-soft: rgba(255, 255, 255, 0.30);

    --clc-capsule:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.55) 0%,
        rgba(245, 250, 255, 0.48) 100%);
    --clc-capsule-border: rgba(255, 255, 255, 0.60);
    --clc-capsule-inset:
      inset 0 1px 0 rgba(255, 255, 255, 0.78),
      inset 0 0 12px rgba(255, 255, 255, 0.18);

    --clc-ring-track: rgba(34, 52, 92, 0.12);
    --clc-ring-from: #b8dcf2;
    --clc-ring-to: #0e7490;
    --clc-ring-glow: rgba(14, 116, 144, 0.22);
    --clc-percent-disc: rgba(14, 116, 144, 0.10);

    --clc-cta-bg:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.62) 0%,
        rgba(245, 250, 255, 0.55) 100%);
    --clc-cta-border: rgba(255, 255, 255, 0.65);
    --clc-cta-border-hover: rgba(14, 116, 144, 0.40);
    --clc-cta-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 4px 12px rgba(30, 45, 80, 0.10);
    --clc-cta-glow: 0 4px 14px -4px rgba(14, 116, 144, 0.30);
  }

  /* ═══════════════════════════════════════════════════════════════════
     OUTER PANEL — fixed support card framing the carousel
     ═══════════════════════════════════════════════════════════════════ */
  .continue-learning-card {
    /* Fixed positioning — pinned to the inline-start edge of the
       viewport (right in RTL, left in LTR), 20px below the global
       Header. Stays visible during scroll. */
    position: fixed;
    top: calc(var(--library-header-offset, 72px) + 20px);
    /* Comfortable gap from the viewport edge — kept identical to
       LibraryStatsPanel's `inset-inline-end` so the two panels frame
       the carousel symmetrically and neither glues to the edge. */
    inset-inline-start: clamp(16px, 1.8vw, 32px);
    inset-inline-end: auto;
    z-index: 30;
    width: var(--floating-card-width);
    padding: 20px;
    border: 1px solid var(--clc-border);
    border-radius: var(--yuval-galaxy-panel-radius, 22px);
    background: var(--clc-surface);
    box-shadow: var(--clc-shadow);
    /* Slightly heavier blur than other panels so the holographic body
       reads as smart glass instead of a flat translucent rectangle. */
    backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur, 18px) + 6px)) saturate(115%);
    -webkit-backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur, 18px) + 6px)) saturate(115%);
    isolation: isolate;
    color: var(--yuval-galaxy-text);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Floor reflection — soft cyan/pearl puddle below the panel ──────
     A faint elongated glow placed just below the bottom edge so the
     panel reads as floating above a reflective floor. No mirrored
     content, no hard line — only ambient light. */
  .continue-learning-card::after {
    content: "";
    position: absolute;
    left: 50%;
    top: calc(100% + 6px);
    width: 86%;
    height: 28px;
    transform: translateX(-50%);
    background:
      radial-gradient(ellipse 65% 100% at 50% 0%,
        var(--clc-floor) 0%, transparent 70%),
      radial-gradient(ellipse 100% 100% at 50% 0%,
        var(--clc-floor-soft) 0%, transparent 85%);
    filter: blur(6px);
    opacity: 0.85;
    pointer-events: none;
  }

  /* ── Holographic HUD layer — abstract AI interface visuals ──────────
     SVG sits behind every functional element (z-index:-1 inside the
     card's isolated stacking context). Very low opacity overall so it
     never competes with the carousel or the panel's own content. */
  .continue-learning-card__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    overflow: hidden;
    pointer-events: none;
  }
  .continue-learning-card__hud {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* Whisper-faint glass texture — never visible decoration. The HUD
       reads as subtle depth rather than a graphic element. */
    opacity: 0.22;
  }
  .continue-learning-card__hud-net line {
    stroke: var(--clc-hud-line);
    stroke-width: 0.6;
  }
  .continue-learning-card__hud-nodes circle {
    fill: var(--clc-hud-node);
    filter: drop-shadow(0 0 2.5px var(--clc-hud-node-glow));
  }
  .continue-learning-card__hud-ring circle,
  .continue-learning-card__hud-ring path {
    stroke: var(--clc-hud-ring);
    stroke-width: 0.7;
    fill: none;
  }
  .continue-learning-card__hud-ring-core {
    fill: var(--clc-hud-ring);
    stroke: none;
  }
  .continue-learning-card__hud-graph polyline {
    stroke: var(--clc-hud-graph);
    stroke-width: 0.9;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .continue-learning-card__hud-graph-axis,
  .continue-learning-card__hud-graph-tick {
    stroke: var(--clc-hud-graph-axis);
    stroke-width: 0.5;
  }

  /* ═══════════════════════════════════════════════════════════════════
     HEADER — section eyebrow
