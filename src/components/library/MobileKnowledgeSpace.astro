---
/**
 * MobileKnowledgeSpace — mobile-only "Knowledge Space" summary card.
 * ────────────────────────────────────────────────────────────────────────────
 * A compact premium glass card that sits below the mobile carousel. It is the
 * phone counterpart of the desktop Knowledge Core widget (LibraryStatsPanel),
 * which is `display:none` ≤1023px. The card surfaces the four real catalog
 * counts (total / books / courses / articles) and a single CTA that opens the
 * all-items bottom sheet (MobileAllItemsSheet).
 *
 * Counts are passed in from index.astro and originate from
 * `getLibraryStats(getLibraryItems())` — the same source the desktop
 * Knowledge Core uses. Nothing here is hardcoded; the card updates
 * automatically when catalog/output data changes.
 *
 * Theme: dark/light come entirely from the global `--yuval-galaxy-*`
 * tokens. RTL/LTR follow the page `dir`; logical properties only.
 *
 * The CTA carries `data-mobile-allitems-open`; the bottom sheet's own
 * script listens for clicks on that selector. No event bus, no coupling.
 */
import type { Language } from '../../types/index';
import { t } from '../../i18n';
import { getLanguageDirection } from '../../utils/language';

interface Props {
  language: Language;
  /** stats.readable — the count of openable items (matches Knowledge Core). */
  total: number;
  /** stats.byType['book'] — never hardcoded. */
  books: number;
  /** stats.byType['course']. */
  courses: number;
  /** stats.byType['article']. */
  articles: number;
}

const { language, total, books, courses, articles } = Astro.props;
const direction = getLanguageDirection(language);

/* The three stat cells. `count` is the real per-type figure; labels are i18n.
   Rendered even at 0 so the card composition stays stable. */
const cells: Array<{ key: 'books' | 'courses' | 'articles'; count: number; labelKey: string }> = [
  { key: 'books',    count: books,    labelKey: 'knowledgeSpace.books' },
  { key: 'courses',  count: courses,  labelKey: 'knowledgeSpace.courses' },
  { key: 'articles', count: articles, labelKey: 'knowledgeSpace.articles' },
];
---

<section
  class="mks"
  dir={direction}
  aria-label={t('knowledgeSpace.title', language)}
>
  <header class="mks__header">
    <span class="mks__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="2.6"></circle>
        <ellipse cx="12" cy="12" rx="10" ry="4.3"></ellipse>
        <ellipse cx="12" cy="12" rx="10" ry="4.3" transform="rotate(60 12 12)"></ellipse>
      </svg>
    </span>
    <h2 class="mks__title">{t('knowledgeSpace.title', language)}</h2>
  </header>

  <div class="mks__body">
    {/* Large total on one side. */}
    <div class="mks__total">
      <span class="mks__total-num">{total}</span>
      <span class="mks__total-label">{t('knowledgeSpace.connectedItems', language)}</span>
    </div>

    {/* Three compact stat cells. */}
    <div class="mks__cells" role="group" aria-label={t('knowledgeSpace.title', language)}>
      {cells.map((c) => (
        <div class="mks__cell" data-type={c.key}>
          <span class="mks__cell-num">{c.count}</span>
          <span class="mks__cell-label">{t(c.labelKey, language)}</span>
        </div>
      ))}
    </div>
  </div>

  <button
    type="button"
    class="mks__cta"
    data-mobile-allitems-open
    aria-haspopup="dialog"
  >
    <span class="mks__cta-label">{t('knowledgeSpace.viewAll', language)}</span>
    <span class="mks__cta-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="M13 6l6 6-6 6"></path>
      </svg>
    </span>
  </button>
</section>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     MOBILE-ONLY. On desktop the Knowledge Core widget already covers
     this role, so the card is fully hidden ≥1024px.
     ═══════════════════════════════════════════════════════════════════ */
  .mks { display: none; }

  @media (max-width: 1023px) {
    .mks {
      /* Anchored to the free bottom zone of the cinematic mobile screen,
         below the fixed carousel + its nav rail. The carousel and nav are
         position:fixed; this card joins them as a bottom strip. */
      position: fixed;
      inset-inline: 0;
      inset-block-end: max(env(safe-area-inset-bottom, 0px), 0.5rem);
      z-index: 35;

      display: flex;
      flex-direction: column;
      gap: 0.75rem;

      /* calc(100% - safe horizontal padding); capped to the mobile content
         width so it never stretches edge-to-edge on tablets. */
      width: calc(100% - 1.5rem);
      max-width: 28rem;
      margin-inline: auto;
      padding: 0.875rem 1rem 1rem;
      box-sizing: border-box;

      border: 1px solid var(--yuval-galaxy-border-strong);
      border-radius: var(--yuval-galaxy-panel-radius, 20px);
      background:
        radial-gradient(ellipse 120% 80% at 50% 0%,
          color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 8%, transparent) 0%,
          transparent 70%),
        var(--yuval-galaxy-surface);
      box-shadow:
        inset 0 1px 0 var(--yuval-galaxy-border-glow, rgba(255, 255, 255, 0.12)),
        0 -2px 24px -8px color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 22%, transparent),
        0 12px 32px -10px rgba(2, 6, 20, 0.45);
      backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur, 14px) + 4px)) saturate(116%);
      -webkit-backdrop-filter: blur(calc(var(--yuval-galaxy-card-blur, 14px) + 4px)) saturate(116%);
      color: var(--yuval-galaxy-text);
      isolation: isolate;
    }
  }

  /* Light mode: airier, ice-blue glass rather than a simple invert. */
  :global(html:not(.dark)) .mks {
    background:
      radial-gradient(ellipse 120% 80% at 50% 0%,
        rgba(210, 235, 255, 0.55) 0%, transparent 72%),
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.92) 0%,
        rgba(245, 250, 255, 0.88) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 -2px 20px -10px rgba(14, 116, 144, 0.20),
      0 12px 30px -12px rgba(30, 45, 80, 0.16);
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .mks__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mks__icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--yuval-galaxy-accent-cyan);
  }
  .mks__icon svg { width: 100%; height: 100%; }
  .mks__title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--yuval-galaxy-text);
  }

  /* ── Body: big total + three cells ───────────────────────────────────── */
  .mks__body {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
  }

  .mks__total {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding-inline-end: 0.75rem;
    border-inline-end: 1px solid var(--yuval-galaxy-border);
    min-width: 4.5rem;
  }
  .mks__total-num {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--yuval-galaxy-text);
  }
  .mks__total-label {
    margin-block-start: 0.25rem;
    font-size: 0.6875rem;
    line-height: 1.2;
    color: var(--yuval-galaxy-text-soft);
  }

  .mks__cells {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4375rem;
    min-width: 0;
  }
  .mks__cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.125rem;
    padding: 0.5rem 0.25rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: 12px;
    background: var(--yuval-galaxy-surface-muted);
  }
  .mks__cell[data-type="books"]    { --mks-accent: var(--yuval-galaxy-type-book); }
  .mks__cell[data-type="courses"]  { --mks-accent: var(--yuval-galaxy-type-course); }
  .mks__cell[data-type="articles"] { --mks-accent: var(--yuval-galaxy-type-article); }
  .mks__cell-num {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1;
    color: var(--mks-accent, var(--yuval-galaxy-text));
  }
  .mks__cell-label {
    font-size: 0.625rem;
    line-height: 1.1;
    color: var(--yuval-galaxy-text-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .mks__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    min-height: 46px;
    padding: 0.625rem 1rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--yuval-galaxy-text-inverse, #fff);
    background: linear-gradient(
      135deg,
      var(--yuval-galaxy-accent-cyan) 0%,
      var(--yuval-galaxy-accent-purple) 100%);
    border: 0;
    border-radius: 13px;
    cursor: pointer;
    box-shadow: 0 6px 18px -6px color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 55%, transparent);
    transition:
      transform var(--yuval-galaxy-motion-normal, 220ms) var(--yuval-galaxy-ease-out, ease),
      box-shadow var(--yuval-galaxy-motion-normal, 220ms) var(--yuval-galaxy-ease-out, ease);
  }
  .mks__cta:hover {
    box-shadow: 0 8px 22px -6px color-mix(in srgb, var(--yuval-galaxy-accent-cyan) 65%, transparent);
  }
  .mks__cta:active { transform: translateY(1px); }
  .mks__cta:focus-visible {
    outline: 2px solid var(--yuval-galaxy-accent-cyan);
    outline-offset: 3px;
  }
  .mks__cta-arrow {
    display: inline-flex;
    width: 17px;
    height: 17px;
    flex-shrink: 0;
  }
  .mks__cta-arrow svg { width: 100%; height: 100%; }
  /* Arrow points "forward" in both directions. */
  :global([dir="rtl"]) .mks__cta-arrow { transform: scaleX(-1); }

  @media (prefers-reduced-motion: reduce) {
    .mks__cta { transition: none !important; }
    .mks__cta:active { transform: none; }
  }
</style>
