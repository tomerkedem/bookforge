---
/**
 * ContinueReadingCard — single "resume where you left off" card,
 * with a clean empty state when there is no active item.
 *
 * Behavior:
 *   - item provided   → render the resume card
 *   - item undefined  → render the "nothing in progress" empty state
 *
 * The CTA button stays disabled at v1; navigation will be wired in
 * once we decide whether to follow item.href (subject to the safe-link
 * policy in src/utils/library-display.ts).
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
  getTypeAccentVar,
  formatLibraryDate,
} from '../../utils/library-display';

interface Props {
  item?: LibraryItem;
  language: Language;
}
const { item, language } = Astro.props;
---

<section class="crc" aria-label={t('library.a11y.continueReadingCard', language)}>
  <h2 class="crc-title">{t('library.continueReading.title', language)}</h2>

  {item ? (
    <article
      class="crc-card"
      style={`--card-accent: ${getTypeAccentVar(item.type)};`}
    >
      <p class="crc-card-type">{t(getItemTypeLabelKey(item.type), language)}</p>
      <h3 class="crc-card-title">{getItemTitle(item, language)}</h3>
      {getItemSummary(item, language) && (
        <p class="crc-card-summary">{getItemSummary(item, language)}</p>
      )}
      {item.updatedAt && (
        <p class="crc-card-meta">
          {t('library.continueReading.lastOpened', language, {
            when: formatLibraryDate(item.updatedAt, language),
          })}
        </p>
      )}
      <button type="button" class="crc-cta" disabled>
        {t('library.continueReading.cta', language)}
      </button>
    </article>
  ) : (
    <div class="crc-empty">
      <p class="crc-empty-text">{t('library.continueReading.noActive', language)}</p>
      <button type="button" class="crc-cta" disabled>
        {t('library.continueReading.startLearning', language)}
      </button>
    </div>
  )}
</section>

<style>
  .crc {
    padding: 1.25rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-card-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
  }
  .crc-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.875rem;
    color: var(--yuval-galaxy-text);
  }
  .crc-card {
    --card-accent: var(--yuval-galaxy-accent);
    position: relative;
    padding: 1rem 1rem 1.125rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: calc(var(--yuval-galaxy-card-radius) - 4px);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
  }
  .crc-card::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    height: 2px;
    background-color: var(--card-accent);
    opacity: 0.85;
  }
  .crc-card-type {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0 0 0.5rem;
  }
  .crc-card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.375rem;
    color: var(--yuval-galaxy-text);
  }
  .crc-card-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .crc-card-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
  }
  .crc-empty { padding: 0.5rem 0; }
  .crc-empty-text {
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.75rem;
  }
  .crc-cta {
    appearance: none;
    margin-block-start: 0.75rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--yuval-galaxy-text-inverse);
    background-color: var(--yuval-galaxy-accent);
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: not-allowed;
    transition: box-shadow var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .crc-cta:disabled { opacity: 0.7; }
  .crc-cta:focus-visible { box-shadow: var(--yuval-galaxy-glow-primary); }
</style>
