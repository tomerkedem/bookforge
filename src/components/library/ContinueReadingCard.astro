---
/**
 * ContinueReadingCard — primary anchor of the /library experience.
 *
 * Visual upgrade (Prompt 7):
 *   - Larger panel radius and tighter typographic rhythm.
 *   - Halo glow behind the inner card using --yuval-galaxy-glow-core
 *     so this panel reads as the page's main "active" surface.
 *   - Honest "activity indicator" line at the bottom — a static gradient
 *     bar rooted on the type accent. It signals "this item is alive"
 *     without faking real progress (we don't have progress data yet).
 *   - Title eyebrow with a small dot glyph as a calm visual anchor.
 *
 * Defensive: empty state remains a clear "nothing in progress" panel.
 * CTA stays disabled until safe-link routing is wired.
 */
import type { Language } from '../../types/index';
import type { LibraryItem } from '../../types/library';
import { t } from '../../i18n';
import {
  getItemTitle,
  getItemSummary,
  getItemTypeLabelKey,
  getTypeAccentVar,
  formatLibraryDate,
} from '../../utils/library-display';

interface Props {
  item?: LibraryItem;
  language: Language;
}
const { item, language } = Astro.props;

const cardStyle = item
  ? `--card-accent: ${getTypeAccentVar(item.type)};`
  : '';
---

<section class="crc" aria-label={t('library.a11y.continueReadingCard', language)}>
  <header class="crc-header">
    <span class="crc-dot" aria-hidden="true"></span>
    <h2 class="crc-title">{t('library.continueReading.title', language)}</h2>
  </header>

  {item ? (
    <article class="crc-card" style={cardStyle}>
      <div class="crc-card-glow" aria-hidden="true"></div>
      <p class="crc-card-type">{t(getItemTypeLabelKey(item.type), language)}</p>
      <h3 class="crc-card-title">{getItemTitle(item, language)}</h3>
      {getItemSummary(item, language) && (
        <p class="crc-card-summary">{getItemSummary(item, language)}</p>
      )}
      {item.updatedAt && (
        <p class="crc-card-meta">
          {t('library.continueReading.lastOpened', language, {
            when: formatLibraryDate(item.updatedAt, language),
          })}
        </p>
      )}
      <div class="crc-card-activity" aria-hidden="true"></div>
      <button type="button" class="crc-cta" disabled aria-disabled="true">
        {t('library.continueReading.cta', language)}
      </button>
    </article>
  ) : (
    <div class="crc-empty">
      <p class="crc-empty-text">{t('library.continueReading.noActive', language)}</p>
      <button type="button" class="crc-cta" disabled aria-disabled="true">
        {t('library.continueReading.startLearning', language)}
      </button>
    </div>
  )}
</section>

<style>
  .crc {
    position: relative;
    padding: 1.375rem;
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius);
    background-color: var(--yuval-galaxy-surface);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur));
    box-shadow: var(--yuval-galaxy-glow-card);
    overflow: hidden;
    isolation: isolate;
  }

  .crc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.875rem;
  }
  .crc-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--yuval-galaxy-accent);
    box-shadow: var(--yuval-galaxy-glow-soft);
  }
  .crc-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
    color: var(--yuval-galaxy-text-muted);
  }

  .crc-card {
    --card-accent: var(--yuval-galaxy-accent);
    position: relative;
    padding: 1.125rem 1.125rem 1.25rem;
    border: 1px solid var(--yuval-galaxy-card-border);
    border-radius: calc(var(--yuval-galaxy-panel-radius) - 6px);
    background-color: var(--yuval-galaxy-card-surface);
    box-shadow: var(--yuval-galaxy-card-shadow);
    overflow: hidden;
    isolation: isolate;
  }
  /* Halo behind the card — uses the core glow token so this panel
     visually outranks the side panels. */
  .crc-card-glow {
    position: absolute;
    inset-block-start: -50%;
    inset-inline-end: -30%;
    width: 90%;
    aspect-ratio: 1;
    background: radial-gradient(circle,
      var(--card-accent) 0%,
      transparent 65%);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .crc-card > *:not(.crc-card-glow) { position: relative; z-index: 1; }

  .crc-card-type {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin: 0 0 0.5rem;
  }
  .crc-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--yuval-galaxy-text);
  }
  .crc-card-summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .crc-card-meta {
    font-size: 0.75rem;
    color: var(--yuval-galaxy-text-soft);
    margin: 0;
  }

  /* Activity indicator — static gradient bar, not a real progress meter. */
  .crc-card-activity {
    height: 3px;
    border-radius: 999px;
    margin-block: 1rem 0.875rem;
    background: linear-gradient(to right,
      var(--card-accent) 0%,
      var(--card-accent) 35%,
      transparent 100%);
    opacity: 0.7;
  }

  .crc-empty {
    padding: 0.75rem 0 0.25rem;
  }
  .crc-empty-text {
    font-size: 0.9375rem;
    color: var(--yuval-galaxy-text-muted);
    margin: 0 0 0.875rem;
  }

  .crc-cta {
    appearance: none;
    min-height: 44px;
    padding: 0.625rem 1.125rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--yuval-galaxy-text-inverse);
    background-color: var(--yuval-galaxy-accent);
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: not-allowed;
    box-shadow: var(--yuval-galaxy-glow-primary);
    transition: box-shadow var(--yuval-galaxy-motion-fast) var(--yuval-galaxy-ease-out);
  }
  .crc-cta:disabled { opacity: 0.78; }
  .crc-cta:focus-visible { box-shadow: var(--yuval-galaxy-glow-primary); }
</style>
