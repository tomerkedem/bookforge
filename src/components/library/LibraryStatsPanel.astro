---
import type { LibraryStats, LibraryCourseProgress, LibraryItemType } from '../../types/library';
import type { Language } from '../../types/index';
import { t } from '../../i18n';
import { getLanguageDirection } from '../../utils/language';

interface Props {
  stats: LibraryStats;
  language: Language;
  /**
   * Accepted for call-site compatibility only. The panel is now a
   * compact "library snapshot" and no longer renders a per-course
   * lessons breakdown, so this prop is intentionally unused.
   */
  courseProgress?: LibraryCourseProgress[];
}

const { stats, language } = Astro.props;
const direction = getLanguageDirection(language);

/* Compact snapshot — only the three top-level content types. Articles
   and the per-course lesson rows were dropped so the panel reads as a
   lightweight snapshot that frames the carousel, not a stats dashboard. */
const typeOrder: Array<{ type: LibraryItemType; labelKey: string }> = [
  { type: 'book',   labelKey: 'library.stats.label.books' },
  { type: 'course', labelKey: 'library.stats.label.courses' },
  { type: 'series', labelKey: 'library.stats.label.series' },
];

const visibleTypes = typeOrder.filter(({ type }) => (stats.byType[type] ?? 0) > 0);
---

<article
  class="library-stats-panel"
  dir={direction}
  aria-label={t('library.a11y.libraryStatsPanel', language)}
>
  <header class="lsp__header">
    <span class="lsp__header-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12A9 9 0 1 1 12 3v9z"></path>
        <path d="M21 12A9 9 0 0 0 12 3v9z"></path>
      </svg>
    </span>
    <h3 class="lsp__title">{t('library.stats.yourLibrary', language)}</h3>
  </header>

  <div class="lsp__total">
    <span class="lsp__total-number">{stats.readable}</span>
    <span class="lsp__total-label">{t('library.stats.itemsInLibrary', language)}</span>
  </div>

  {visibleTypes.length > 0 && (
    <ul class="lsp__breakdown" role="list">
      {visibleTypes.map(({ type, labelKey }) => (
        <li class="lsp__row">
          <span class="lsp__row-dot" data-type={type} aria-hidden="true"></span>
          <span class="lsp__row-label">{t(labelKey, language)}</span>
          <span class="lsp__row-value">{stats.byType[type]}</span>
        </li>
      ))}
    </ul>
  )}

  <a class="lsp__cta" href="/library">
    <span class="lsp__cta-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7" rx="1"></rect>
        <rect x="14" y="3" width="7" height="7" rx="1"></rect>
        <rect x="3" y="14" width="7" height="7" rx="1"></rect>
        <rect x="14" y="14" width="7" height="7" rx="1"></rect>
      </svg>
    </span>
    <span class="lsp__cta-label">{t('library.stats.viewAll', language)}</span>
  </a>
</article>

<style>
  /* Mobile + tablet (≤1023px): hidden — the stats surface on mobile
     lives inside the phone flow (LibraryHero / mobile stats list),
     not as a fixed floating panel that would overlap the content.
     1023px matches index.astro's own mobile/tablet reset breakpoint
     so the entire mobile composition flips in lockstep. */
  @media (max-width: 1023px) {
    .library-stats-panel { display: none !important; }
  }

  .library-stats-panel {
    /* Fixed positioning — pinned to the inline-END edge of the
       viewport (left in RTL Hebrew, right in LTR), opposite the
       ContinueLearningCard. The two panels now frame the carousel
       symmetrically instead of stacking on one side. Anchored at
       the same `top` as ContinueLearningCard. */
    position: fixed;
    top: calc(var(--library-header-offset, 72px) + 20px);
    inset-inline-start: auto;
    /* Comfortable gap from the viewport edge — kept identical to
       ContinueLearningCard's `inset-inline-start` so the two panels
       frame the carousel symmetrically and neither glues to the edge. */
    inset-inline-end: clamp(16px, 1.8vw, 32px);
    z-index: 30;
    /* Layered surface adopted from ContinueLearningCard / FloatingSidebar
       so all premium panels share the same material family:
         1. Soft radial highlight at top, fading to transparent at 60%.
         2. Linear navy with very low contrast top/middle/bottom. */
    background:
      radial-gradient(
        ellipse 80% 40% at 50% 0%,
        rgba(40, 70, 130, 0.22) 0%,
        transparent 60%),
      linear-gradient(
        180deg,
        #08091a 0%,
        #0b0e22 50%,
        #08091a 100%);
    border: 1px solid rgba(120, 140, 200, 0.18);
    border-radius: var(--yuval-galaxy-panel-radius, 20px);
    /* 4-layer depth + glow stack (matches ContinueLearningCard):
         - inset hairline (the "inside cyan line")
         - inset soft glow toward center
         - outer atmospheric halo
         - depth shadow underneath */
    box-shadow:
      inset 0 0 0 1px rgba(140, 190, 255, 0.10),
      inset 0 0 28px rgba(60, 110, 200, 0.12),
      0 0 36px rgba(80, 130, 220, 0.22),
      0 12px 32px rgba(2, 4, 14, 0.45);
    backdrop-filter: blur(var(--yuval-galaxy-card-blur, 20px));
    -webkit-backdrop-filter: blur(var(--yuval-galaxy-card-blur, 20px));
    isolation: isolate;
    /* Compact snapshot — tighter padding + gap than the old dashboard
       card so it never competes with the carousel. */
    padding: 16px;
    width: var(--floating-card-width);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .lsp__header {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--yuval-galaxy-accent-purple);
  }

  .lsp__header-icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
  }
  .lsp__header-icon svg {
    width: 100%;
    height: 100%;
  }

  .lsp__title {
    font-size: 14px;
    font-weight: 500;
    color: var(--yuval-galaxy-text);
    margin: 0;
  }

  /* Compact total — baseline-aligned number + label on one line,
     wrapping gracefully on the narrowest panel width. Replaces the
     old 48px hero block so the panel stays a snapshot, not a hero. */
  .lsp__total {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 2px 8px;
  }

  .lsp__total-number {
    font-size: 30px;
    font-weight: 600;
    color: var(--yuval-galaxy-text);
    line-height: 1;
  }

  .lsp__total-label {
    font-size: 12px;
    color: var(--yuval-galaxy-text-muted);
  }

  .lsp__breakdown {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lsp__row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
  }

  /* Small accent dot — restrained to the three snapshot types only. */
  .lsp__row-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--yuval-galaxy-accent);
    flex-shrink: 0;
  }

  .lsp__row-dot[data-type="book"]   { background: var(--yuval-galaxy-type-book,   var(--yuval-galaxy-accent-purple)); }
  .lsp__row-dot[data-type="course"] { background: var(--yuval-galaxy-type-course, var(--yuval-galaxy-accent-cyan));   }
  .lsp__row-dot[data-type="series"] { background: var(--yuval-galaxy-type-series, var(--yuval-galaxy-accent-gold));   }

  .lsp__row-label {
    flex: 1;
    color: var(--yuval-galaxy-text-soft);
  }

  .lsp__row-value {
    color: var(--yuval-galaxy-text);
    font-weight: 500;
  }

  .lsp__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--yuval-galaxy-surface-elevated);
    border: 1px solid rgba(120, 140, 200, 0.12);
    box-shadow: inset 0 0 0 1px rgba(140, 190, 255, 0.06);
    border-radius: 12px;
    color: var(--yuval-galaxy-text);
    text-decoration: none;
    font-size: 13px;
    transition: opacity 200ms ease-out;
  }

  .lsp__cta:hover {
    opacity: 0.85;
  }

  .lsp__cta-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
  }
  .lsp__cta-icon svg {
    width: 100%;
    height: 100%;
  }

  /* ── Light mode — warm pale-glass snapshot ───────────────────────
     Repaints the hardcoded deep-navy surface, blue halo and inner
     hairlines as translucent warm white with a soft blue-gray border
     and a calm shadow. Token-driven text/accents are already handled
     by galaxy.css. Scoped to `html:not(.dark)`; dark mode untouched. */
  :global(html:not(.dark)) .library-stats-panel {
    background:
      radial-gradient(
        ellipse 80% 40% at 50% 0%,
        rgba(255, 255, 255, 0.65) 0%,
        transparent 62%),
      linear-gradient(
        180deg,
        rgba(255, 253, 249, 0.92) 0%,
        rgba(248, 249, 252, 0.88) 50%,
        rgba(255, 253, 249, 0.92) 100%);
    border-color: rgba(34, 52, 92, 0.16);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.75),
      0 1px 2px rgba(15, 23, 42, 0.05),
      0 12px 30px -10px rgba(30, 45, 80, 0.18);
  }
  :global(html:not(.dark)) .lsp__cta {
    border-color: rgba(34, 52, 92, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.60);
  }
</style>
