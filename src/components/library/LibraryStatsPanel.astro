---
import type { LibraryStats, LibraryCourseProgress, LibraryItemType } from '../../types/library';
import type { Language } from '../../types/index';
import { t } from '../../i18n';
import { getLanguageDirection } from '../../utils/language';

interface Props {
  stats: LibraryStats;
  language: Language;
  courseProgress?: LibraryCourseProgress[];
}

const { stats, language, courseProgress = [] } = Astro.props;
const direction = getLanguageDirection(language);

const typeOrder: Array<{ type: LibraryItemType; labelKey: string }> = [
  { type: 'book',    labelKey: 'library.stats.label.books' },
  { type: 'course',  labelKey: 'library.stats.label.courses' },
  { type: 'series',  labelKey: 'library.stats.label.series' },
  { type: 'article', labelKey: 'library.stats.label.articles' },
];

const visibleTypes = typeOrder.filter(({ type }) => (stats.byType[type] ?? 0) > 0);
const visibleCourses = courseProgress.filter((course) => course.total > 0);
const showCourseGroup = visibleCourses.length > 0;
---

<article
  class="library-stats-panel"
  dir={direction}
  aria-label={t('library.a11y.libraryStatsPanel', language)}
>
  <header class="lsp__header">
    <span class="lsp__header-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12A9 9 0 1 1 12 3v9z"></path>
        <path d="M21 12A9 9 0 0 0 12 3v9z"></path>
      </svg>
    </span>
    <h3 class="lsp__title">{t('library.stats.yourLibrary', language)}</h3>
  </header>

  <div class="lsp__hero">
    <span class="lsp__hero-number">{stats.readable}</span>
    <span class="lsp__hero-subtitle">{t('library.stats.itemsInLibrary', language)}</span>
  </div>

  {visibleTypes.length > 0 && (
    <ul class="lsp__breakdown" role="list">
      {visibleTypes.map(({ type, labelKey }) => (
        <li class="lsp__row">
          <span class="lsp__row-dot" data-type={type} aria-hidden="true"></span>
          <span class="lsp__row-label">{t(labelKey, language)}</span>
          <span class="lsp__row-value">{stats.byType[type]}</span>
        </li>
      ))}
    </ul>
  )}

  {showCourseGroup && visibleCourses.map((course) => {
    const courseName =
      course.titles[language] ??
      course.titles.en ??
      course.titles.he ??
      course.slug;
    return (
      <div class="lsp__course-group">
        <h4 class="lsp__group-title">
          {t('library.stats.courseSummariesTitle', language, { courseName })}
        </h4>
        <div class="lsp__row">
          <span class="lsp__row-dot" data-type="course_lesson" aria-hidden="true"></span>
          <span class="lsp__row-label">{t('library.stats.label.lessons', language)}</span>
          <span class="lsp__row-value">{course.available} / {course.total}</span>
        </div>
      </div>
    );
  })}

  <a class="lsp__cta" href="/library">
    <span class="lsp__cta-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7" rx="1"></rect>
        <rect x="14" y="3" width="7" height="7" rx="1"></rect>
        <rect x="3" y="14" width="7" height="7" rx="1"></rect>
        <rect x="14" y="14" width="7" height="7" rx="1"></rect>
      </svg>
    </span>
    <span class="lsp__cta-label">{t('library.stats.viewAll', language)}</span>
  </a>
</article>

<style>
  .library-stats-panel {
    background: var(--yuval-galaxy-surface);
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: var(--yuval-galaxy-panel-radius, 20px);
    padding: 20px;
    width: 100%;
    max-width: 320px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .lsp__header {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--yuval-galaxy-accent-purple);
  }

  .lsp__header-icon {
    display: inline-flex;
    width: 24px;
    height: 24px;
  }
  .lsp__header-icon svg {
    width: 100%;
    height: 100%;
  }

  .lsp__title {
    font-size: 16px;
    font-weight: 500;
    color: var(--yuval-galaxy-text);
    margin: 0;
  }

  .lsp__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .lsp__hero-number {
    font-size: 48px;
    font-weight: 600;
    color: var(--yuval-galaxy-text);
    line-height: 1;
  }

  .lsp__hero-subtitle {
    font-size: 13px;
    color: var(--yuval-galaxy-text-muted);
  }

  .lsp__breakdown {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lsp__row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
  }

  .lsp__row-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--yuval-galaxy-accent);
    flex-shrink: 0;
  }

  .lsp__row-dot[data-type="book"]          { background: var(--yuval-galaxy-type-book,          var(--yuval-galaxy-accent-purple)); }
  .lsp__row-dot[data-type="course"]        { background: var(--yuval-galaxy-type-course,        var(--yuval-galaxy-accent-cyan));   }
  .lsp__row-dot[data-type="course_lesson"] { background: var(--yuval-galaxy-type-course_lesson, var(--yuval-galaxy-accent-blue));   }
  .lsp__row-dot[data-type="series"]        { background: var(--yuval-galaxy-type-series,        var(--yuval-galaxy-accent-gold));   }
  .lsp__row-dot[data-type="article"]       { background: var(--yuval-galaxy-type-article,       var(--yuval-galaxy-accent));        }

  .lsp__row-label {
    flex: 1;
    color: var(--yuval-galaxy-text-soft);
  }

  .lsp__row-value {
    color: var(--yuval-galaxy-text);
    font-weight: 500;
  }

  .lsp__course-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--yuval-galaxy-border);
  }

  .lsp__group-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--yuval-galaxy-text-muted);
    margin: 0;
    text-align: center;
  }

  .lsp__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--yuval-galaxy-surface-elevated, var(--yuval-galaxy-bg-navy));
    border: 1px solid var(--yuval-galaxy-border);
    border-radius: 12px;
    color: var(--yuval-galaxy-text);
    text-decoration: none;
    font-size: 14px;
    transition: opacity 200ms ease-out;
  }

  .lsp__cta:hover {
    opacity: 0.85;
  }

  .lsp__cta-icon {
    display: inline-flex;
    width: 18px;
    height: 18px;
  }
  .lsp__cta-icon svg {
    width: 100%;
    height: 100%;
  }
</style>
