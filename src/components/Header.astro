---
import type { Language } from '../types/index';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  language?: Language;
  showLanguageToggle?: boolean;
  class?: string;
}

const { language = 'en', showLanguageToggle = true, class: className } =
  Astro.props;
---

<header
  id="site-header"
  class:list={[
    'yuval-header',
    'sticky',
    'top-0',
    'z-50',
    'w-full',
    className,
  ]}
>
  <!-- Skip to content link for keyboard users -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-2 focus:left-2 focus:px-4 focus:py-2 focus:bg-yuval-accent focus:text-yuval-accent-text focus:rounded-md focus:text-sm focus:font-medium"
  >
    {language === 'he' ? 'דלג לתוכן' : 'Skip to content'}
  </a>
  <div
    class:list={[
      'header-inner',
      'flex',
      'items-center',
      'justify-between',
      'h-16',
      'px-4',
      'sm:px-6',
      'lg:px-8',
      language === 'he' && 'flex-row-reverse',
    ]}
  >
    <!-- Logo / Brand -->
    <a
      href="/"
      class="yuval-logo"
      data-he="Yuval"
      data-en="Yuval"
      aria-label={language === 'he' ? 'Yuval — עמוד הבית' : 'Yuval — Home'}
    >
      <span class="logo-letter">Y</span><span class="logo-rest">uval</span>
    </a>

    <!-- Controls: Theme + Language -->
    <div class:list={['flex', 'items-center', 'gap-3', language === 'he' && 'flex-row-reverse']}>
      <ThemeToggle />
      {showLanguageToggle && <LanguageToggle currentLanguage={language} />}
    </div>
  </div>
</header>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     HEADER - Light Mode (warm cream)
     ═══════════════════════════════════════════════════════════════════ */
  .yuval-header {
    background: linear-gradient(to bottom, #faf8f5, #f5f3f0);
    border-bottom: 2px solid #c9a96e;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  /* ═══════════════════════════════════════════════════════════════════
     HEADER - Dark Mode (deep charcoal)
     ═══════════════════════════════════════════════════════════════════ */
  :global(.dark) .yuval-header {
    background: linear-gradient(to bottom, #1a1a1f, #141418);
    border-bottom: 2px solid #8b7355;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
  }

  .header-inner {
    position: relative;
    z-index: 1;
  }

  /* ═══════════════════════════════════════════════════════════════════
     LOGO - Elegant typography
     ═══════════════════════════════════════════════════════════════════ */
  .yuval-logo {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 10px;
    transition: all 0.3s ease;
  }

  .yuval-logo:hover {
    background: rgba(139, 115, 85, 0.1);
  }

  :global(.dark) .yuval-logo:hover {
    background: rgba(212, 196, 168, 0.1);
  }

  .logo-letter {
    font-family: 'Playfair Display', 'Times New Roman', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    font-style: italic;
    color: #2c2c34;
    margin-right: -1px;
    transition: color 0.3s ease;
  }

  .logo-rest {
    font-family: 'Playfair Display', 'Times New Roman', Georgia, serif;
    font-size: 1.65rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: #4a4a54;
    transition: all 0.3s ease;
  }

  :global(.dark) .logo-letter {
    color: #f0f0f4;
  }

  :global(.dark) .logo-rest {
    color: #b8b8c0;
  }

  /* Hover - warm gold tones */
  .yuval-logo:hover .logo-letter {
    color: #8b7355;
  }

  .yuval-logo:hover .logo-rest {
    color: #6b5a48;
    letter-spacing: 0.14em;
  }

  :global(.dark) .yuval-logo:hover .logo-letter {
    color: #d4c4a8;
  }

  :global(.dark) .yuval-logo:hover .logo-rest {
    color: #b8a890;
  }

  .yuval-logo:focus-visible {
    outline: 2px solid #c9a96e;
    outline-offset: 4px;
  }

  :global(.dark) .yuval-logo:focus-visible {
    outline-color: #8b7355;
  }

  @media (min-width: 640px) {
    .logo-letter {
      font-size: 2.4rem;
    }
    .logo-rest {
      font-size: 1.9rem;
      letter-spacing: 0.14em;
    }
  }
</style>
