---
/**
 * Unified Chapter Sidebar (Yuval).
 *
 * Renders a fixed-position sidebar with:
 *   - Header: title, completion counter, overall progress, time
 *     remaining
 *   - Vertical thread + chapter cards (one per chapter)
 *   - Per-chapter expandable section list
 *   - Mobile drawer (separate UI for narrow viewports)
 *
 * Behavior lives in src/utils/sidebar/* TypeScript modules.
 * Styling lives in src/styles/chapter-sidebar.css.
 *
 * The .astro file holds only the server-rendered markup and the
 * thin script glue that bootstraps the module graph.
 */

import type { Language, Chapter } from '../types/index';
import { SOURCE_LANGUAGE, getLanguageDirection } from '../utils/language';
import '../styles/chapter-sidebar.css';

interface Props {
  chapters: Chapter[];
  currentChapterId: number | string;
  bookSlug: string;
  language?: Language;
}

const { chapters, currentChapterId, bookSlug, language = SOURCE_LANGUAGE } = Astro.props;
const isRtl = getLanguageDirection(language) === 'rtl';

function getChapterTitle(chapter: Chapter, lang: Language): string {
  return chapter.titles?.[lang] || chapter.titles?.[SOURCE_LANGUAGE] || '';
}

function serializeTitles(chapter: Chapter): string {
  return JSON.stringify(chapter.titles || {});
}

/** Pad chapter number to 2 digits for chapters 1-99, full number
 *  for 100+. Keeps the visual rhythm consistent for normal-sized
 *  books while not breaking on huge series. */
function formatChapterNumber(id: number | string): string {
  const n = typeof id === 'number' ? id : parseInt(String(id), 10);
  if (Number.isNaN(n)) return String(id);
  return n < 100 ? String(n).padStart(2, '0') : String(n);
}
---

<div class="sidebars-container" transition:persist="sidebars">
  <!-- Mobile TOC toggle button (kept in DOM for FAB delegation; never visible on desktop) -->
  <button
    id="mobile-toc-toggle"
    class="mobile-toc-btn"
    aria-expanded="false"
    aria-hidden="true"
    tabindex="-1"
    hidden
  >
    <span class="sr-only" data-i18n="sidebar.openNavigation">Open navigation</span>
    <span class="mobile-toc-btn-glow"></span>
    <span class="mobile-toc-btn-ring"></span>
    <svg class="mobile-toc-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <!-- Mobile overlay -->
  <div id="mobile-sidebar-overlay" class="mobile-overlay"></div>

  <!-- Mobile combined drawer (outline + chapter list) -->
  <div id="mobile-drawer" class="mobile-drawer">
    <div class="mobile-drawer-tabs" role="tablist">
      <button class="mobile-tab active" data-tab="outline" role="tab" aria-selected="true" aria-controls="mobile-outline-panel">
        <span data-i18n="sidebar.inChapter">In This Chapter</span>
      </button>
      <button class="mobile-tab" data-tab="chapters" role="tab" aria-selected="false" aria-controls="mobile-chapters-panel">
        <span data-i18n="sidebar.chapters">Chapters</span>
      </button>
    </div>
    <div class="mobile-panel active" id="mobile-outline-panel" role="tabpanel">
      <nav id="mobile-chapter-outline" class="outline-list">
        <ul></ul>
      </nav>
    </div>
    <div class="mobile-panel" id="mobile-chapters-panel" role="tabpanel">
      <nav class="toc-list">
        <ul>
          {chapters.map((chapter) => (
            <li
              class:list={[
                'toc-item',
                chapter.id === currentChapterId && 'toc-item-active',
              ]}
            >
              <a
                href={`/read/${bookSlug}/${chapter.id}`}
                class:list={[
                  'toc-link',
                  'mobile-toc-link',
                  chapter.id === currentChapterId && 'toc-link-active',
                ]}
              >
                <span class="toc-number">
                  {formatChapterNumber(chapter.id)}
                </span>
                <span class="toc-chapter-title">
                  <span class="toc-chapter-title-text" data-titles={serializeTitles(chapter)}>
                    {getChapterTitle(chapter, language)}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <!-- ─── Unified Sidebar (Desktop) ─────────────────────────────
       Single sidebar on the inline-start edge (right in RTL, left
       in LTR). Header + vertical timeline thread + per-chapter
       cards + on-demand section lists. -->
  <aside
    class:list={[
      'unified-sidebar',
      isRtl && 'unified-sidebar-rtl',
    ]}
    id="unified-sidebar"
    data-rtl={isRtl}
    data-book-slug={bookSlug}
  >
    <header class="usb-header">
      <div class="usb-header-row">
        <span class="usb-title" data-i18n="sidebar.tableOfContents">תוכן העניינים</span>
        <span class="usb-completion-count">
          <span class="usb-completion-done" id="usb-completion-done">0</span><span class="usb-completion-sep">/</span><span class="usb-completion-total">{chapters.length}</span>
          <span class="usb-completion-suffix" data-i18n="sidebar.completed">הושלמו</span>
        </span>
      </div>
      <div class="usb-progress-track">
        <div class="usb-progress-fill" id="usb-progress-fill" style="width: 0%"></div>
      </div>
      <div class="usb-header-row usb-header-meta">
        <span class="usb-progress-percent" id="usb-progress-percent">0%</span>
        <span class="usb-time-remaining" id="usb-time-remaining"></span>
      </div>
    </header>

    <nav class="usb-timeline" aria-label="Chapter list">
      <!-- Vertical thread runs continuously from first chapter to last -->
      <div class="usb-thread" aria-hidden="true"></div>

      <ol class="usb-chapter-list">
        {chapters.map((chapter) => (
          <li
            class:list={[
              'usb-chapter',
              chapter.id === currentChapterId && 'usb-chapter-active',
            ]}
            data-chapter-id={chapter.id}
            data-word-count={chapter.word_count ?? 0}
            data-section-count={chapter.sections ?? 0}
            data-expanded={chapter.id === currentChapterId && (chapter.sections ?? 0) > 0 ? 'true' : 'false'}
          >
            <a
              href={`/read/${bookSlug}/${chapter.id}`}
              class:list={[
                'usb-chapter-link',
                chapter.id === currentChapterId && 'usb-chapter-link-active',
              ]}
              aria-current={chapter.id === currentChapterId ? 'page' : undefined}
              data-chapter-id={chapter.id}
            >
              <span class="usb-node" aria-hidden="true">
                <span class="usb-node-number">{formatChapterNumber(chapter.id)}</span>
              </span>
              <span class="usb-card">
                <span class="usb-card-title">
                  <span class="usb-card-title-text" data-titles={serializeTitles(chapter)}>
                    {getChapterTitle(chapter, language)}
                  </span>
                </span>
                <span class="usb-card-meta">
                  <span class="usb-card-time" data-word-count={chapter.word_count ?? 0}></span>
                </span>
                <span class="usb-card-check" aria-hidden="true" title="Completed">
                  <svg viewBox="0 0 16 16" width="12" height="12">
                    <path d="M3.5 8.5l3 3L12.5 5" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
              <button
                type="button"
                class="usb-reset-btn"
                data-action="reset-completion"
                data-chapter-id={chapter.id}
                aria-label="Reset completion"
                title="Reset completion"
              >
                <svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true">
                  <path d="M3 8a5 5 0 0 1 8.5-3.5L13 3v4H9" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M13 8a5 5 0 0 1-8.5 3.5L3 13V9h4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </a>

            {(chapter.sections ?? 0) > 0 && (
              <button
                type="button"
                class="usb-toggle-btn"
                data-action="toggle-sections"
                data-chapter-id={chapter.id}
                aria-label="Toggle sections"
                aria-expanded={chapter.id === currentChapterId ? 'true' : 'false'}
                title="Show sections"
              >
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                  <path d="M4 6.5l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            )}
          </li>
        ))}
      </ol>
    </nav>
  </aside>
</div>

<script>
  /* Bootstrap the sidebar runtime. The bootstrap function handles
     DOMContentLoaded vs. already-loaded itself, and idempotently
     installs all lifecycle handlers. */
  import { bootstrap } from '../utils/sidebar/sidebar-init';
  bootstrap();
</script>