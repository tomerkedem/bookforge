---
interface Props {
  lang?: 'he' | 'en';
  currentPath?: string;
}

const { lang = 'he', currentPath = '/' } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';

const otherLang = lang === 'he' ? 'en' : 'he';
const switchHref = `${currentPath}${currentPath.includes('?') ? '&' : '?'}lang=${otherLang}`;
---

<header dir={dir} class="sticky top-0 z-40 bg-white/90 backdrop-blur-sm border-b border-gray-100">
  <nav
    class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between gap-4"
    aria-label={lang === 'he' ? 'ניווט ראשי' : 'Main navigation'}
  >
    <!-- Logo -->
    <a
      href="/"
      class="text-lg font-bold text-gray-900 tracking-tight hover:text-blue-600 transition-colors"
      aria-label={lang === 'he' ? 'Yuval — דף הבית' : 'Yuval — Home'}
    >
      Yuval
    </a>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href="/"
        class:list={[
          'text-sm transition-colors',
          currentPath === '/'
            ? 'text-gray-900 font-medium'
            : 'text-gray-500 hover:text-gray-900',
        ]}
      >
        {lang === 'he' ? 'הספרייה' : 'Library'}
      </a>

      <!-- Language switcher -->
      <a
        href={switchHref}
        class="text-xs border border-gray-200 rounded-full px-3 py-1 text-gray-500 hover:border-blue-400 hover:text-blue-600 transition-colors"
        aria-label={lang === 'he' ? 'Switch to English' : 'עבור לעברית'}
        hreflang={otherLang}
      >
        {lang === 'he' ? 'EN' : 'עב׳'}
      </a>
    </div>
  </nav>
</header>
