---
interface Props {
  lang?: 'he' | 'en';
  currentPath?: string;
}

const { lang = 'he', currentPath = '/' } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const switchHref = currentPath + (currentPath.includes('?') ? '&' : '?') + `lang=${lang === 'he' ? 'en' : 'he'}`;
---

<header
  dir={dir}
  class="sticky top-0 z-40 bg-white border-b border-yuval-border"
  style="height: 64px;"
>
  <div
    class="h-full max-w-6xl mx-auto flex items-center justify-between"
    style="padding: 0 48px;"
  >
    <!-- Brand -->
    <a
      href="/"
      class="font-heading text-yuval-text transition-opacity duration-200 hover:opacity-70"
      style="font-size: 18px; font-weight: 400; letter-spacing: 0.02em;"
      aria-label={lang === 'he' ? 'Yuval — דף הבית' : 'Yuval — Home'}
    >
      תומר קדם
    </a>

    <!-- Right: nav + language toggle -->
    <div class="flex items-center gap-6">
      <a
        href="/"
        class="text-yuval-text-tertiary transition-colors duration-200 hover:text-yuval-text"
        style="font-size: 14px; font-weight: 300;"
      >
        {lang === 'he' ? 'הספרייה' : 'Library'}
      </a>

      <!-- Language toggle -->
      <div
        class="flex items-center border border-yuval-border-secondary overflow-hidden"
        style="border-radius: 20px;"
        role="group"
        aria-label={lang === 'he' ? 'בחירת שפה' : 'Language selection'}
      >
        <a
          href={lang === 'he' ? currentPath : switchHref}
          class="transition-colors duration-200"
          style={`padding: 4px 12px; font-size: 11px; font-weight: 400; letter-spacing: 0.08em;
            background: ${lang === 'he' ? '#1a1a1a' : 'transparent'};
            color: ${lang === 'he' ? '#ffffff' : '#888888'};`}
          hreflang="he"
          aria-current={lang === 'he' ? 'true' : undefined}
        >
          HE
        </a>
        <a
          href={lang === 'en' ? currentPath : switchHref}
          class="transition-colors duration-200"
          style={`padding: 4px 12px; font-size: 11px; font-weight: 400; letter-spacing: 0.08em;
            background: ${lang === 'en' ? '#1a1a1a' : 'transparent'};
            color: ${lang === 'en' ? '#ffffff' : '#888888'};`}
          hreflang="en"
          aria-current={lang === 'en' ? 'true' : undefined}
        >
          EN
        </a>
      </div>
    </div>
  </div>
</header>
