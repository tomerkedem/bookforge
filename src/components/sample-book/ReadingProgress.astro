---
interface Props {
  bookId: string;
  chapterIndex: number;
  totalChapters: number;
}

const { bookId, chapterIndex, totalChapters } = Astro.props;
---

<!-- 2px progress bar below header, per design-system.json -->
<div
  id="reading-progress-bar"
  role="progressbar"
  aria-valuemin={0}
  aria-valuemax={100}
  aria-valuenow={0}
  aria-label="Reading progress"
  style="height: 2px; background: #f0ede8; width: 100%; position: sticky; top: 64px; z-index: 30;"
>
  <div
    id="reading-progress-fill"
    style="height: 100%; background: #1a1a1a; width: 0%; transition: width 0.15s ease-out;"
  ></div>
</div>

<!-- Resume banner (hidden initially) -->
<div id="resume-banner" role="alert" style="display:none; position:fixed; bottom:24px; inset-inline-end:24px; z-index:50; background:#1a1a1a; color:#fff; font-size:13px; padding:12px 20px; display:none; align-items:center; gap:12px;">
  <span id="resume-text"></span>
  <button id="resume-yes" style="text-decoration:underline; font-weight:500; background:none; border:none; color:#fff; cursor:pointer;"></button>
  <button id="resume-no" style="color:#888; background:none; border:none; cursor:pointer; font-size:16px;">×</button>
</div>

<script is:inline define:vars={{ bookId, chapterIndex, totalChapters }}>
  const STORE_KEY = 'yuval-progress-' + bookId;

  function save(pos) {
    try { localStorage.setItem(STORE_KEY, JSON.stringify({ chapter: chapterIndex, pos })); } catch {}
  }

  function updateBar() {
    const scrollTop = window.scrollY;
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docH > 0 ? Math.min(100, (scrollTop / docH) * 100) : 0;
    const fill = document.getElementById('reading-progress-fill');
    const bar = document.getElementById('reading-progress-bar');
    if (fill) fill.style.width = pct + '%';
    if (bar) bar.setAttribute('aria-valuenow', String(Math.round(pct)));
    save(scrollTop);
  }

  // Offer to resume — user must consent
  try {
    const saved = JSON.parse(localStorage.getItem(STORE_KEY) || 'null');
    if (saved && saved.chapter === chapterIndex && saved.pos > 120) {
      const banner = document.getElementById('resume-banner');
      const text = document.getElementById('resume-text');
      const yes = document.getElementById('resume-yes');
      const no = document.getElementById('resume-no');
      if (banner && text && yes && no) {
        const isHe = document.documentElement.lang === 'he';
        text.textContent = isHe ? 'המשך מהמקום שעצרת?' : 'Continue where you left off?';
        yes.textContent = isHe ? 'המשך' : 'Continue';
        banner.style.display = 'flex';
        yes.addEventListener('click', () => {
          window.scrollTo({ top: saved.pos, behavior: 'smooth' });
          banner.style.display = 'none';
        });
        no.addEventListener('click', () => { banner.style.display = 'none'; });
      }
    }
  } catch {}

  window.addEventListener('scroll', updateBar, { passive: true });
  updateBar();
</script>
