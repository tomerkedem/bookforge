---
interface Props {
  prevChapter?: { id: string; title: string };
  nextChapter?: { id: string; title: string };
  lang?: 'he' | 'en';
}

const { prevChapter, nextChapter, lang = 'he' } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';

const labels = {
  prev: lang === 'he' ? 'הפרק הקודם' : 'Previous chapter',
  next: lang === 'he' ? 'הפרק הבא' : 'Next chapter',
};
---

<nav
  dir={dir}
  class="flex justify-between items-start border-t border-yuval-border"
  style="margin-top: 80px; padding-top: 40px; gap: 24px;"
  aria-label={lang === 'he' ? 'ניווט בין פרקים' : 'Chapter navigation'}
>
  <!-- Next (start side in RTL = next) -->
  <div style="flex: 1;">
    {nextChapter && (
      <a
        href={`/sample-book/${nextChapter.id}`}
        class="group flex flex-col gap-1 transition-opacity duration-200 hover:opacity-70"
        style="text-decoration: none;"
      >
        <span style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#bbbbbb;">
          {dir === 'rtl' ? '←' : '→'} {labels.next}
        </span>
        <span class="font-heading text-yuval-text" style="font-size:18px; font-weight:400;">
          {nextChapter.title}
        </span>
      </a>
    )}
  </div>

  <!-- Prev (end side in RTL = prev) -->
  <div style="flex: 1; text-align: end;">
    {prevChapter && (
      <a
        href={`/sample-book/${prevChapter.id}`}
        class="group inline-flex flex-col gap-1 transition-opacity duration-200 hover:opacity-70"
        style="text-decoration: none; align-items: flex-end;"
      >
        <span style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#bbbbbb;">
          {labels.prev} {dir === 'rtl' ? '→' : '←'}
        </span>
        <span class="font-heading text-yuval-text" style="font-size:18px; font-weight:400;">
          {prevChapter.title}
        </span>
      </a>
    )}
  </div>
</nav>
