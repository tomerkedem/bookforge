---
/**
 * Book Overview — Chapters timeline.
 *
 * Wrapped in the same dark glass card as Summary / Learn / Progress.
 * Inside the card a vertical timeline connects each chapter — every
 * row has a circular indicator on the inline-start side, a thin line
 * threads through them, and the rest of the row carries the chapter
 * number + localized title.
 *
 * Status states (driven by `[data-read-status]` set by the page-level
 * updateChapterProgress() script):
 *   - current       purple/violet ring with a play glyph + soft glow
 *   - in-progress   cyan ring (no glow, no glyph)
 *   - completed     muted row, cyan check glyph
 *   - (none)        unread, hollow ring
 *   - locked        dimmed, lock glyph (when chapter.locked === true)
 *
 * Long books collapse after a threshold and reveal the rest behind a
 * "Show all chapters" toggle so the timeline doesn't dominate the
 * column before any reading starts.
 */

import type { Chapter, Language } from '../../types/index';
import { t } from '../../i18n';
import { getLocalizedText } from './utils';

interface Props {
  chapters: Chapter[];
  slug: string;
  language: Language;
  isRtl: boolean;
  /**
   * "full"          — default reading-page timeline (collapsible after 6).
   * "compact-full"  — Book Overview viewport-fit mode: shows ALL chapters
   *                   in a tighter rhythm so nothing is hidden behind a
   *                   "show all" toggle. Same design language, smaller
   *                   row padding and fonts.
   */
  variant?: 'full' | 'compact-full';
}

const { chapters, slug, language, isRtl, variant = 'full' } = Astro.props;

const isCompactFull = variant === 'compact-full';
const COLLAPSED_LIMIT = 6;
// In compact-full we deliberately render every chapter — the whole point
// of the mode is "no hidden tail behind a toggle".
const collapsible = !isCompactFull && chapters.length > COLLAPSED_LIMIT;

// Reading-time per chapter at the project-wide ~200 wpm rate. Returns 0
// when word_count is missing/zero so the duration chip can be skipped
// without inventing data.
function chapterMinutes(chapter: Chapter): number {
  const wc = chapter.word_count ?? 0;
  if (wc <= 0) return 0;
  return Math.max(1, Math.ceil(wc / 200));
}
---

<section
  class:list={['boch', isRtl && 'is-rtl', isCompactFull && 'is-compact-full']}
  data-variant={variant}
  aria-labelledby="boch-title"
>
  <div class="boch-card bo-premium-surface">
    <header class="boch-heading-row">
      <span class="boch-heading-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <circle cx="6" cy="6"  r="2" stroke-width="1.7" />
          <circle cx="6" cy="18" r="2" stroke-width="1.7" />
          <circle cx="18" cy="12" r="2" stroke-width="1.7" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M6 8v8M8 7l8 4M8 17l8-4" />
        </svg>
      </span>
      <h2 id="boch-title" class="boch-heading" data-i18n="lessonSummary.lessonPath.title">
        {t('lessonSummary.lessonPath.title', language)}
      </h2>
      {/* Current-lesson pill. Hidden until at least one row carries
          [data-read-status='current'] — driven entirely by CSS :has(),
          no JS state needed. */}
      <span class="boch-current-pill" aria-hidden="true">
        <span class="boch-current-dot"></span>
        <span data-i18n="lessonSummary.lessonPath.currentLesson">
          {t('lessonSummary.lessonPath.currentLesson', language)}
        </span>
      </span>
    </header>

    <ol
      class:list={['boch-list', collapsible && 'is-collapsible']}
      data-collapsed={collapsible ? 'true' : undefined}
      data-collapsed-limit={collapsible ? COLLAPSED_LIMIT : undefined}
    >
      {
        chapters.map((chapter, idx) => {
          const chapterTitle = getLocalizedText(chapter.titles, language);
          const chapterNum = idx + 1;
          const locked = chapter.locked === true;
          const beyondLimit = collapsible && idx >= COLLAPSED_LIMIT;
          const numberLabel = chapterNum.toString().padStart(2, '0');
          const minutes = chapterMinutes(chapter);
          const ariaLabel = t('lessonSummary.lessonPath.chapterAriaLabel', language, {
            n: numberLabel,
            title: chapterTitle,
          });
          const lockedLabel = t('lessonSummary.lessonPath.locked', language);

          const itemClasses = [
            'boch-item',
            beyondLimit && 'is-beyond-limit',
            locked && 'is-locked',
          ];

          const indicator = (
            <span class="boch-dot" aria-hidden="true">
              {/* Locked icon — rendered server-side when chapter.locked.
                  All other glyphs (play / check) are CSS-driven so they
                  swap cleanly when the page script flips data-read-status. */}
              {locked && (
                <svg class="boch-dot-glyph boch-dot-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <rect x="5" y="11" width="14" height="9" rx="2" stroke-width="1.8" />
                  <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
              {/* Completion check — visibility controlled by the parent's
                  data-read-status. Class kept so the legacy page script's
                  classList toggle still works without errors. */}
              <svg
                class="boch-dot-glyph boch-dot-check chapter-status-check"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M5 12.5l4 4 10-10" />
              </svg>
            </span>
          );

          const content = (
            <span class="boch-content">
              <span class="boch-content-main">
                <span class="boch-num" aria-hidden="true">{numberLabel}</span>
                <h3 class="boch-title" dir={isRtl ? 'rtl' : 'ltr'}>{chapterTitle}</h3>
              </span>
              {(minutes > 0 || locked) && (
                <span class="boch-content-meta" aria-hidden="true">
                  {minutes > 0 && (
                    <span class="boch-duration">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <circle cx="12" cy="12" r="8" stroke-width="1.6" />
                        <path d="M12 8v4l2.5 2" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <span>{t('lessonSummary.lessonPath.durationMinutes', language, { n: minutes })}</span>
                    </span>
                  )}
                </span>
              )}
              {/* SR-only state label. Visible label is conveyed by
                  shape + color; this row keeps the state in the a11y
                  tree for users who rely on it. The page-level script
                  drives [data-read-status] on the parent row, so the
                  three CSS rules below select on it without JS. */}
              <span class="boch-state-sr" data-state="upcoming" data-i18n="lessonSummary.lessonPath.upcoming">
                {t('lessonSummary.lessonPath.upcoming', language)}
              </span>
              <span class="boch-state-sr" data-state="active" data-i18n="lessonSummary.lessonPath.active">
                {t('lessonSummary.lessonPath.active', language)}
              </span>
              <span class="boch-state-sr" data-state="completed" data-i18n="lessonSummary.lessonPath.completed">
                {t('lessonSummary.lessonPath.completed', language)}
              </span>
              <span class="boch-state-sr" data-state="locked" data-i18n="lessonSummary.lessonPath.locked">
                {t('lessonSummary.lessonPath.locked', language)}
              </span>
              {/* Per-row progress fill. Width is updated by the page
                  script (`.chapter-progress-fill`) when chapter
                  progress lives in localStorage. Hidden by CSS when
                  width is 0 to keep upcoming rows clean. */}
              <span class="boch-progress" aria-hidden="true">
                <span class="boch-progress-fill chapter-progress-fill"></span>
              </span>
            </span>
          );

          return (
            <li class:list={itemClasses}>
              {locked ? (
                <span
                  class="boch-row chapter-link"
                  data-chapter-id={chapter.id}
                  data-book-slug={slug}
                  data-locked="true"
                  aria-disabled="true"
                  role="link"
                  aria-label={`${ariaLabel} (${lockedLabel})`}
                >
                  {indicator}
                  {content}
                </span>
              ) : (
                <a
                  href={`/read/${slug}/${chapter.id}`}
                  class="boch-row chapter-link"
                  data-chapter-id={chapter.id}
                  data-book-slug={slug}
                  aria-label={ariaLabel}
                >
                  {indicator}
                  {content}
                </a>
              )}
            </li>
          );
        })
      }
    </ol>

    {collapsible && (
      <button
        type="button"
        class="boch-toggle"
        data-boch-toggle
        data-i18n="bookOverview.showAllChapters"
        aria-expanded="false"
      >
        {t('bookOverview.showAllChapters', language)}
      </button>
    )}
  </div>
</section>

<script>
  // Wire the show-all toggle. Per-row status (current / in-progress /
  // completed) is owned by the page-level updateChapterProgress();
  // this script only flips the list's collapsed flag and swaps the
  // button's i18n key so the platform's language-changed handler
  // keeps the label in sync.
  import { t, resolveLanguage, type TranslationKey } from '../../i18n';

  const COLLAPSED_KEY: TranslationKey = 'bookOverview.showAllChapters';
  const EXPANDED_KEY: TranslationKey = 'bookOverview.showFewerChapters';

  function bind(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-boch-toggle]');
    buttons.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        if (!section) return;
        const list = section.querySelector<HTMLElement>('.boch-list');
        if (!list) return;
        const isCollapsed = list.dataset.collapsed === 'true';
        const next = !isCollapsed;
        list.dataset.collapsed = next ? 'true' : 'false';
        btn.setAttribute('aria-expanded', next ? 'false' : 'true');
        btn.dataset.i18n = next ? COLLAPSED_KEY : EXPANDED_KEY;
        const lang = resolveLanguage(document.documentElement.lang);
        btn.textContent = t(btn.dataset.i18n as TranslationKey, lang);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bind, { once: true });
  } else {
    bind();
  }
  document.addEventListener('astro:after-swap', bind);
</script>

<style>
  /* ═══════════════════════════════════════════════════════════════
     LESSON PATH — local design tokens
     ───────────────────────────────────────────────────────────────
     One namespace (`--lesson-path-*`) the rest of this stylesheet
     reads from. Values lean on the page-level `--bo-*` tokens so
     this component shares the Book Overview palette today, and so
     Phase 3 can split it into true day/night by re-assigning the
     tokens in a single place (here) instead of hunting through
     every selector below.
     ═══════════════════════════════════════════════════════════════ */
  .boch {
    --lesson-path-panel-bg:           var(--bo-surface);
    --lesson-path-panel-border:       var(--bo-border);
    --lesson-path-panel-border-hover: var(--bo-border-strong);

    --lesson-path-item-bg:            transparent;
    --lesson-path-item-border:        transparent;
    --lesson-path-item-hover-bg:      var(--bo-surface-elevated);
    --lesson-path-item-hover-border:  var(--bo-border-strong);

    --lesson-path-item-active-bg:
      linear-gradient(135deg,
        color-mix(in srgb, var(--bo-purple) 14%, transparent),
        color-mix(in srgb, var(--bo-blue) 10%, transparent)
      );
    --lesson-path-item-active-border:
      color-mix(in srgb, var(--bo-purple) 38%, transparent);
    --lesson-path-item-active-ring:
      color-mix(in srgb, var(--bo-purple) 22%, transparent);

    --lesson-path-text-primary:       var(--bo-text-primary);
    --lesson-path-text-secondary:     var(--bo-text-secondary);
    --lesson-path-text-muted:         var(--bo-text-muted);

    --lesson-path-num:                var(--bo-text-muted);
    --lesson-path-num-active:         var(--bo-violet);

    --lesson-path-timeline:           color-mix(in srgb, var(--bo-text-muted) 16%, transparent);
    --lesson-path-timeline-active:    color-mix(in srgb, var(--bo-purple) 55%, transparent);

    --lesson-path-accent:             var(--bo-violet);
    --lesson-path-accent-soft:        var(--bo-purple-soft);
    --lesson-path-accent-glow:        color-mix(in srgb, var(--bo-purple) 16%, transparent);

    --lesson-path-muted-icon:         var(--bo-text-muted);

    --lesson-path-completed:          var(--bo-success);
    --lesson-path-completed-soft:     var(--bo-success-soft);
    --lesson-path-completed-border:   var(--bo-success-border);

    --lesson-path-progress-track:     color-mix(in srgb, var(--bo-text-muted) 12%, transparent);
    --lesson-path-progress-fill:      var(--bo-grad-progress);

    position: relative;
  }
  @media (min-width: 1024px) {
    .boch {
      position: sticky;
      inset-block-start: 1rem;
    }
  }

  /* Surface (background, border, shadow, grain) comes from the shared
     `.bo-premium-surface` class in theme.css — applied via the markup
     so all five Book Overview cards share the same recipe. */
  .boch-card {
    border-radius: 14px;
    padding: 1.25rem 1.25rem;
    color: var(--bo-text-primary);
    /* Cap the card at the viewport height minus the global header
       and breadcrumb row so the heading row stays anchored while the
       chapter list scrolls internally — the surrounding page never
       needs to scroll to reach the bottom of a long TOC. Flex column
       lets the list claim the remaining height after the header.
       `100dvh` follows the visible viewport on mobile (URL bar
       collapse). The subtracted offset (~96px) covers:
         · global site header (56–52px)
         · breadcrumb / sub-nav row above the card (~32px)
         · 3px breathing margin so the bottom edge isn't flush. */
    max-block-size: calc(100dvh - 96px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .boch-card {
      padding: 1.5rem 1.5rem;
    }
  }

  /* ── Heading row ──────────────────────────────────────────────── */
  .boch-heading-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0 0 1.1rem 0;
    flex-wrap: wrap;
  }
  .boch-heading-icon {
    inline-size: 2rem;
    block-size: 2rem;
    flex-shrink: 0;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--lesson-path-accent);
    background: var(--lesson-path-accent-soft);
    border: 1px solid var(--lesson-path-panel-border);
  }
  .boch-heading-icon svg {
    inline-size: 1.05rem;
    block-size: 1.05rem;
  }
  .boch-heading {
    margin: 0;
    font-family: 'Assistant', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.01em;
    color: var(--lesson-path-text-primary);
    flex: 1 1 auto;
    min-inline-size: 0;
  }

  /* ── Current-lesson pill ──────────────────────────────────────
     Hidden until at least one row carries data-read-status='current'.
     `:has()` makes this purely declarative — no JS state hand-off
     beyond the existing page-level updater. */
  .boch-current-pill {
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.6rem 0.22rem;
    border-radius: 999px;
    background: var(--lesson-path-accent-soft);
    border: 1px solid var(--lesson-path-item-active-border);
    color: var(--lesson-path-text-primary);
    font-family: 'Assistant', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .boch:has(.boch-row[data-read-status='current']) .boch-current-pill {
    display: inline-flex;
  }
  .boch-current-dot {
    inline-size: 0.42rem;
    block-size: 0.42rem;
    border-radius: 999px;
    background: var(--lesson-path-accent);
    box-shadow: 0 0 0 3px var(--lesson-path-accent-glow);
    animation: bochCurrentPulse 2.4s ease-in-out infinite;
  }
  @keyframes bochCurrentPulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.78); }
  }
  @media (prefers-reduced-motion: reduce) {
    .boch-current-dot { animation: none; }
  }

  /* ── Timeline list ──────────────────────────────────────────── */
  /* The dot column is fixed at 1.5rem (24px). The line is drawn as a
     pseudo-element on each row, full block height, with the first
     and last items clipping the line so it starts/ends *at* the dot
     centers rather than at the card edges. */
  .boch-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    /* No row-gap — the timeline line needs adjacent items to share an
       unbroken column. Padding inside each row provides the spacing. */
    /* Claim the remaining height inside `.boch-card` and scroll
       internally. `min-block-size: 0` is required so the flex item
       can shrink below its content size, which is what enables the
       inner scrollbar. Applied on every viewport, not just desktop —
       mobile was previously growing the page until the TOC ran off
       the screen. */
    flex: 1 1 auto;
    min-block-size: 0;
    overflow-y: auto;
    padding-inline-end: 0.25rem;
  }
  .boch-list.is-collapsible[data-collapsed='true'] .boch-item.is-beyond-limit {
    display: none;
  }

  .boch-item {
    position: relative;
    margin: 0;
  }

  /* The thin vertical line. Sits in the dot column at logical-start.
     1.5rem matches the dot's column width; the line is offset by half
     of that minus 0.5px so it lands on the dot's center. */
  .boch-item::before {
    content: '';
    position: absolute;
    inset-block: 0;
    inset-inline-start: calc(0.75rem - 0.5px);
    width: 1px;
    background: var(--lesson-path-timeline);
    z-index: 0;
    pointer-events: none;
  }
  /* First row: line starts AT the dot center (top half clipped). */
  .boch-item:first-child::before {
    inset-block-start: 50%;
  }
  /* Last row: line ends AT the dot center (bottom half clipped). */
  .boch-item:last-child::before {
    inset-block-end: 50%;
  }
  /* When the only row in the list is also the first AND last, hide
     the line — there's nothing to connect to. */
  .boch-item:first-child:last-child::before {
    display: none;
  }
  /* When collapsed, the visible-tail item should also clip its line so
     the timeline doesn't draw past the last visible row. */
  .boch-list.is-collapsible[data-collapsed='true'] .boch-item:not(.is-beyond-limit):last-of-type::before {
    inset-block-end: 50%;
  }

  /* ── Row (link or locked span) ────────────────────────────────
     Calm row, no permanent border, no per-card progress strip.
     Hover and current state add the visual weight. */
  .boch-row {
    position: relative;
    display: grid;
    grid-template-columns: 1.5rem minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.65rem;
    border-radius: 10px;
    background: var(--lesson-path-item-bg);
    border: 1px solid var(--lesson-path-item-border);
    text-decoration: none;
    color: inherit;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
    z-index: 1;
  }
  .boch-row:hover {
    background: var(--lesson-path-item-hover-bg);
    border-color: var(--lesson-path-item-hover-border);
  }
  .boch-row:focus-visible {
    outline: 2px solid var(--bo-focus-ring);
    outline-offset: 2px;
  }

  /* ── Indicator dot ───────────────────────────────────────────
     24px outer circle. Inner glyph slot for play / check / lock.
     Sits ABOVE the timeline line (z-index above ::before). */
  .boch-dot {
    inline-size: 1.5rem;
    block-size: 1.5rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--lesson-path-panel-bg);
    border: 1.5px solid var(--lesson-path-timeline);
    color: var(--lesson-path-muted-icon);
    flex-shrink: 0;
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease, box-shadow 160ms ease;
    position: relative;
    z-index: 1;
  }
  .boch-dot-glyph {
    inline-size: 0.7rem;
    block-size: 0.7rem;
    display: none;
  }
  .boch-dot-lock {
    inline-size: 0.75rem;
    block-size: 0.75rem;
  }

  /* ── Content (number + title + meta) ────────────────────────── */
  .boch-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-inline-size: 0;
  }
  .boch-content-main {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.55rem;
    min-inline-size: 0;
  }
  .boch-num {
    font-family: 'Assistant', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    font-feature-settings: 'tnum';
    letter-spacing: 0.04em;
    color: var(--lesson-path-num);
    transition: color 160ms ease;
  }
  .boch-title {
    margin: 0;
    font-family: 'Assistant', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--lesson-path-text-primary);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ── Meta row (duration chip) ──────────────────────────────── */
  .boch-content-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--lesson-path-text-muted);
    font-family: 'Assistant', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
  }
  .boch-duration {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    line-height: 1;
  }
  .boch-duration svg {
    inline-size: 0.78rem;
    block-size: 0.78rem;
    opacity: 0.7;
  }
  .boch-duration > span {
    font-variant-numeric: tabular-nums;
  }

  /* ── SR-only state labels ─────────────────────────────────────
     One label per possible state; CSS reveals only the one that
     matches the row's current [data-read-status]/[data-locked].
     Visually hidden in all cases — purely for assistive tech. */
  .boch-state-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    display: none;
  }
  .boch-row:not([data-read-status]):not([data-locked='true']) .boch-state-sr[data-state='upcoming'] { display: block; }
  .boch-row[data-read-status='current']    .boch-state-sr[data-state='active']    { display: block; }
  .boch-row[data-read-status='in-progress'] .boch-state-sr[data-state='active']    { display: block; }
  .boch-row[data-read-status='completed']  .boch-state-sr[data-state='completed'] { display: block; }
  .boch-row[data-locked='true']            .boch-state-sr[data-state='locked']    { display: block; }

  /* ── Per-row progress fill ────────────────────────────────────
     A 2px rail along the row's block-end edge. The page-level
     script writes `width: X%` on `.chapter-progress-fill`; until
     it does, the rail stays invisible so unread rows don't carry
     an empty trough. */
  .boch-progress {
    position: absolute;
    inset-inline: 0.55rem;
    inset-block-end: 0.35rem;
    block-size: 2px;
    border-radius: 999px;
    background: transparent;
    overflow: hidden;
    pointer-events: none;
  }
  .boch-row[data-read-status] .boch-progress {
    background: var(--lesson-path-progress-track);
  }
  .boch-progress-fill {
    display: block;
    block-size: 100%;
    inline-size: 0%;
    background: var(--lesson-path-progress-fill);
    border-radius: inherit;
    transition: width 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .boch-progress-fill { transition: none; }
  }

  /* ── Status: CURRENT — calm violet/blue tint + play glyph.
     The visual weight comes from a soft accent fill and a thin
     accent border + ring on the dot. No spotlight glow; the row
     stays a focus cue, not a stage light. */
  .boch-row[data-read-status='current'] {
    background: var(--lesson-path-item-active-bg);
    border-color: var(--lesson-path-item-active-border);
  }
  .boch-row[data-read-status='current'] .boch-dot {
    background: var(--lesson-path-accent-soft);
    border-color: var(--lesson-path-item-active-border);
    color: var(--lesson-path-text-primary);
    box-shadow: 0 0 0 3px var(--lesson-path-item-active-ring);
  }
  /* Play triangle drawn via logical borders so it points in the
     reading direction (▶ in LTR, ◀ in RTL — both = "forward"). */
  .boch-row[data-read-status='current'] .boch-dot::after {
    content: '';
    width: 0;
    height: 0;
    border-block-start: 4px solid transparent;
    border-block-end: 4px solid transparent;
    border-inline-start: 6px solid var(--lesson-path-text-primary);
    margin-inline-start: 1px;
  }
  .boch-row[data-read-status='current'] .boch-num {
    color: var(--lesson-path-num-active);
  }
  .boch-row[data-read-status='current'] .boch-title {
    color: var(--lesson-path-text-primary);
    font-weight: 600;
  }

  /* ── Status: IN-PROGRESS — accent ring, no glow, no glyph ───── */
  .boch-row[data-read-status='in-progress'] .boch-dot {
    border-color: var(--lesson-path-accent);
    color: var(--lesson-path-accent);
  }
  .boch-row[data-read-status='in-progress'] .boch-num {
    color: var(--lesson-path-accent);
  }

  /* ── Status: COMPLETED — readable but secondary, green check ── */
  .boch-row[data-read-status='completed'] {
    opacity: 0.82;
  }
  .boch-row[data-read-status='completed']:hover {
    opacity: 1;
  }
  .boch-row[data-read-status='completed'] .boch-dot {
    background: var(--lesson-path-completed-soft);
    border-color: var(--lesson-path-completed-border);
    color: var(--lesson-path-completed);
  }
  .boch-row[data-read-status='completed'] .boch-dot-check {
    display: block;
    color: var(--lesson-path-completed);
  }
  .boch-row[data-read-status='completed'] .boch-title {
    font-weight: 400;
  }
  /* Default: hide check when not completed (page script also toggles
     `.hidden`; the CSS rule below makes it deterministic). */
  .boch-row:not([data-read-status='completed']) .boch-dot-check {
    display: none;
  }

  /* ── Status: LOCKED — dimmed, lock glyph, no link affordance ── */
  .boch-row[data-locked='true'] {
    cursor: not-allowed;
    opacity: 0.45;
    filter: grayscale(0.25);
  }
  .boch-row[data-locked='true']:hover {
    background: transparent;
    border-color: transparent;
    transform: none;
    opacity: 0.55;
  }
  .boch-row[data-locked='true'] .boch-dot {
    background: var(--lesson-path-panel-bg);
    border-color: var(--lesson-path-timeline);
  }
  .boch-row[data-locked='true'] .boch-dot-lock {
    display: block;
    color: var(--lesson-path-muted-icon);
  }

  /* ── Toggle — link-style ─────────────────────────────────────
     Reduced from a pill button to a quiet text link so it doesn't
     compete with the timeline. Cyan text, underline appears only on
     hover/focus. */
  .boch-toggle {
    margin-block-start: 0.85rem;
    padding: 0.25rem 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    color: var(--bo-cyan);
    font: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    border-block-end: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
    align-self: flex-start;
  }
  .boch-toggle:hover {
    color: var(--bo-text-primary);
    border-block-end-color: var(--bo-cyan);
  }
  .boch-toggle:focus-visible {
    outline: 2px solid var(--bo-focus-ring);
    outline-offset: 3px;
    border-block-end-color: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .boch-row,
    .boch-dot,
    .boch-toggle {
      transition: none;
    }
  }

  /* ════════════════════════════════════════════════════════════════
     COMPACT-FULL VARIANT — Book Overview only.
     Same timeline language, tighter rhythm so the entire chapter list
     lives inside the viewport without an internal scrollbar and without
     a "show all" tail. Tokens are pinned to the spec — no gold, no
     warm tones, no neon glow.
     ════════════════════════════════════════════════════════════════ */
  .boch.is-compact-full {
    /* Sticky stays on; the card is the height-bound element. */
  }

  /* ── Compact-full variant tokens ──────────────────────────────
     The dot-center distance describes how far the dot's optical
     center sits from a row's inline-start edge:
       row.padding-inline-start + dot.inline-size / 2
       desktop:  10px + 11px = 21px
       mobile:    7px + 11px = 18px
     The timeline line ::before is anchored to this value (minus 0.5px
     to center its 1px stroke), so dots and line share an axis in
     every viewport and direction. */
  .boch.is-compact-full {
    --boch-dot-center: 21px;
  }

  .boch.is-compact-full .boch-card {
    padding: 14px 14px 12px;
    /* Mobile/tablet default: grow with content. The lg-and-up rule
       below pins the card to a near-viewport height so it reads as a
       real sidebar that almost touches the page floor. The card
       itself never scrolls — its inner list does (see .boch-list
       desktop rule). */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* Solid panel surface with a hair-thin shadow so the panel reads
       as a separate piece of glass — not a wash that bleeds into the
       page. Day mode pearl sits clearly on the pearl page background;
       night mode navy sits clearly on the navy page. The previous
       `color-mix(70%)` + opacity 0.94 made the panel disappear into
       the day-mode pearl bg. */
    background: var(--lesson-path-panel-bg);
    border-color: var(--lesson-path-panel-border);
    box-shadow: var(--bo-shadow-sm);
    transition: border-color 200ms ease;
  }
  /* Desktop card height is now driven by the page-level grid layout:
     `.bo-area-chapters` (in src/pages/books/[slug].astro) is the cell
     in grid row 2, sharing the row with the Hero card. CSS Grid's
     default `align-items: stretch` makes both items match the row's
     intrinsic height (=Hero's content height), so the chapters card's
     bottom line aligns with Hero's bottom line without measurement.
     The flex chain in [slug].astro fills the cell down to .boch-card;
     the .boch-list rule (further down) owns the internal scroll for
     books whose chapter rhythm exceeds the Hero-determined row. */
  .boch.is-compact-full .boch-card:hover {
    border-color: var(--lesson-path-panel-border-hover);
  }
  .boch.is-compact-full .boch-card:hover,
  .boch.is-compact-full .boch-card:focus-within {
    opacity: 1;
  }
  @media (min-width: 640px) {
    .boch.is-compact-full .boch-card {
      padding: 12px 14px;
    }
  }

  .boch.is-compact-full .boch-heading-row {
    margin: 0 0 0.6rem 0;
    gap: 0.5rem;
    /* Stays at the card top while the list scrolls beneath it. */
    flex-shrink: 0;
  }
  .boch.is-compact-full .boch-heading-icon {
    inline-size: 1.65rem;
    block-size: 1.65rem;
  }
  .boch.is-compact-full .boch-heading-icon svg {
    inline-size: 0.9rem;
    block-size: 0.9rem;
  }
  .boch.is-compact-full .boch-heading {
    font-size: 0.95rem;
  }

  .boch.is-compact-full .boch-list {
    /* Tighter rhythm — 4px gap between rows lets the timeline read
       as a more continuous spine. */
    gap: 4px;
    /* Override the default's max-block-size + scroll on lg breakpoints. */
    max-block-size: none;
    overflow: visible;
    padding-inline-end: 0;
  }
  @media (min-width: 1024px) {
    .boch.is-compact-full .boch-list {
      /* The card has a fixed near-viewport height (rule above), so the
         list takes the remaining flex slot below the heading and owns
         the internal scroll. `min-block-size: 0` is required for a
         flex child to actually shrink and scroll instead of overflowing
         the card. `scrollbar-gutter: stable` reserves the scrollbar
         lane so the timeline column doesn't shift when it appears. */
      flex: 1 1 auto;
      min-block-size: 0;
      max-block-size: none;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-gutter: stable;
      padding-inline-end: 0.25rem;
    }
  }

  /* Timeline line — slightly more present than before so the journey
     reads as a connected path, not a list of disconnected dots.
     The line ::before is a child of <li>, so its inline-start is
     measured from the <li>'s edge. The <li> sits flush against the
     <ol> (no padding), and the <li>'s inner .boch-row carries the
     padding-inline-start. The line must therefore sit at:
         row.padding-inline-start + dot.inline-size / 2
     which is exactly --boch-dot-center. The base .boch-item::before
     up the file used a constant `calc(0.75rem - 0.5px)` that ignored
     the row's padding, which is why the line drifted to the inline-
     start of the dot instead of through its center. */
  .boch.is-compact-full .boch-item::before {
    background: color-mix(in srgb, var(--bo-text-muted) 26%, transparent);
    /* Bridge the 4px gap above this row so the line is continuous. */
    inset-block-start: -4px;
    inset-inline-start: calc(var(--boch-dot-center) - 0.5px);
  }
  .boch.is-compact-full .boch-item:first-child::before {
    inset-block-start: 50%;
  }
  .boch.is-compact-full .boch-item:last-child::before {
    inset-block-end: 50%;
  }

  /* ── Row — compact rhythm ─────────────────────────────────────── */
  .boch.is-compact-full .boch-row {
    /* Dot column shrank from 30px to 22px — smaller, more refined,
       reads as a learning waypoint instead of a radio button. */
    grid-template-columns: 22px minmax(0, 1fr);
    gap: 0.65rem;
    padding: 8px 10px 12px;
    border-radius: 8px;
    border-color: transparent;
  }
  .boch.is-compact-full .boch-row:hover {
    background: var(--lesson-path-item-hover-bg);
    border-color: transparent;
  }

  /* ── Node (circle) — default ─────────────────────────────────── */
  .boch.is-compact-full .boch-dot {
    inline-size: 22px;
    block-size: 22px;
    background: var(--lesson-path-panel-bg);
    border: 1.5px solid color-mix(in srgb, var(--bo-text-muted) 28%, transparent);
    color: var(--lesson-path-muted-icon);
  }

  .boch.is-compact-full .boch-content {
    gap: 0.2rem;
  }
  /* Title and number flow together as one line, with the duration
     pushed to the inline-end of the meta row so visual hierarchy
     reads as: [number] [title…] [duration]. */
  .boch.is-compact-full .boch-content-main {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: baseline;
    gap: 0.5rem;
  }
  /* Small number badge — fixed-width tabular numerals so the column
     stays optically aligned across rows regardless of the digit. */
  .boch.is-compact-full .boch-num {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--lesson-path-num);
    font-variant-numeric: tabular-nums;
  }
  /* Title — clamp to 1 line with ellipsis. Long mixed-script titles
     (Hebrew + English) no longer reflow the row height; the dot stays
     on the same baseline as the title.

     Direction: the inline `dir` attribute on the <h3> (rtl/ltr from
     isRtl) pins the paragraph direction to the UI language. CSS then
     uses:
       text-align: start;        respects the pinned direction (right
                                 in RTL, left in LTR)
       direction: inherit;       takes the value from the dir attr above
       unicode-bidi: isolate;    isolates the bidi runs INSIDE the title
                                 so an English word doesn't drag the
                                 whole line to the LTR side
     Earlier we used `unicode-bidi: plaintext`, which derives the
     paragraph direction from the FIRST strong character — so a Hebrew
     UI showed titles starting with "Pandas AI", "NumPy", "CLI" etc.
     glued to the visual left edge of the row instead of the Hebrew
     reading start. `isolate` keeps the embedding direction explicit. */
  .boch.is-compact-full .boch-title {
    font-size: clamp(0.82rem, 0.9vw, 0.92rem);
    font-weight: 500;
    line-height: 1.35;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    -webkit-line-clamp: 1;
    text-align: start;
    direction: inherit;
    unicode-bidi: isolate;
    min-inline-size: 0;
  }
  .boch.is-compact-full .boch-content-meta {
    font-size: 0.68rem;
    color: var(--lesson-path-text-muted);
  }
  .boch.is-compact-full .boch-progress {
    inset-inline: 10px;
    inset-block-end: 5px;
    block-size: 2px;
  }

  /* ── Status: CURRENT — calm violet tint with a clear active ring.
     The dot now carries an outer accent ring (3px stroke) so the
     active waypoint reads from across the panel, while the row
     background stays soft so it doesn't compete with the Summary. */
  .boch.is-compact-full .boch-row[data-read-status='current'] {
    background: var(--lesson-path-item-active-bg);
    border: 1px solid var(--lesson-path-item-active-border);
    border-radius: 10px;
  }
  .boch.is-compact-full .boch-row[data-read-status='current'] .boch-dot {
    background: var(--lesson-path-accent);
    border-color: var(--lesson-path-accent);
    color: var(--lesson-path-panel-bg);
    /* Outer halo — readable on both day pearl and night navy. */
    box-shadow:
      0 0 0 3px var(--lesson-path-item-active-ring),
      0 2px 8px var(--lesson-path-accent-glow);
  }
  .boch.is-compact-full .boch-row[data-read-status='current'] .boch-dot::after {
    border-inline-start-color: var(--lesson-path-panel-bg);
  }
  .boch.is-compact-full .boch-row[data-read-status='current'] .boch-title {
    color: var(--lesson-path-text-primary);
    font-weight: 600;
  }
  .boch.is-compact-full .boch-row[data-read-status='current'] .boch-num {
    color: var(--lesson-path-num-active);
  }

  /* ── Status: COMPLETED — green per spec (NOT cyan) ───────────── */
  .boch.is-compact-full .boch-row[data-read-status='completed'] {
    opacity: 0.82;
  }
  .boch.is-compact-full .boch-row[data-read-status='completed']:hover {
    opacity: 1;
  }
  .boch.is-compact-full .boch-row[data-read-status='completed'] .boch-dot {
    background: var(--lesson-path-completed-soft);
    border-color: var(--lesson-path-completed-border);
    color: var(--lesson-path-completed);
  }
  .boch.is-compact-full .boch-row[data-read-status='completed'] .boch-dot-check {
    color: var(--lesson-path-completed);
  }

  /* In-progress kept consistent with rest of variant — soft, no glow. */
  .boch.is-compact-full .boch-row[data-read-status='in-progress'] .boch-dot {
    border-color: var(--lesson-path-item-active-border);
    color: var(--lesson-path-accent);
  }

  /* ── Status: LOCKED — quiet, per spec ────────────────────────── */
  .boch.is-compact-full .boch-row[data-locked='true'] {
    opacity: 0.55;
    filter: none;
  }
  .boch.is-compact-full .boch-row[data-locked='true']:hover {
    opacity: 0.6;
    background: transparent;
  }
  .boch.is-compact-full .boch-row[data-locked='true'] .boch-dot {
    background: color-mix(in srgb, var(--lesson-path-muted-icon) 5%, transparent);
    border-color: color-mix(in srgb, var(--lesson-path-muted-icon) 22%, transparent);
    color: var(--lesson-path-muted-icon);
  }
  .boch.is-compact-full .boch-row[data-locked='true'] .boch-dot-lock {
    color: var(--lesson-path-muted-icon);
  }

  /* ── Mobile / tablet guard ───────────────────────────────────
     Below 1024px the boch panel no longer sits beside the content
     column — the page stacks it AFTER Learn (order: 2). Loosen the
     sticky cap so the whole list expands and contains every chapter,
     and tighten rows so the rail doesn't dominate the small viewport.

     --boch-dot-center is re-pinned to the mobile row padding here:
         row.padding-inline-start (9px) + dot.inline-size / 2 (11px) = 20px
     so the timeline stays centered through the dots in this density too. */
  @media (max-width: 1023px) {
    .boch.is-compact-full {
      --boch-dot-center: 20px;
    }
    .boch.is-compact-full .boch-card {
      max-block-size: none;
      overflow-y: visible;
      padding: 12px 12px 10px;
    }
    .boch.is-compact-full .boch-row {
      padding: 7px 9px 11px;
    }
    .boch.is-compact-full .boch-list {
      gap: 3px;
    }
    .boch.is-compact-full .boch-progress {
      inset-inline: 9px;
      inset-block-end: 4px;
    }
    /* Slightly tighter active state on small screens so the row
       doesn't visibly stand out above its neighbors at a phone
       reading distance. */
    .boch.is-compact-full .boch-row[data-read-status='current'] .boch-dot {
      box-shadow:
        0 0 0 2px var(--lesson-path-item-active-ring),
        0 2px 6px var(--lesson-path-accent-glow);
    }
  }

  /* ── Bottom action — text link, no pill ──────────────────────── */
  .boch.is-compact-full .boch-toggle {
    margin-block-start: 0.5rem;
    color: var(--bo-cyan);
    background: transparent;
    border: 0;
    padding: 0;
    text-decoration: none;
  }
  .boch.is-compact-full .boch-toggle:hover {
    color: #67e8f9;
    text-decoration: underline;
    border-block-end-color: transparent;
  }

  /* Hide title clamp at very narrow widths — we still want all rows
     visible; truncation handles overflow without growing the row. */
</style>
