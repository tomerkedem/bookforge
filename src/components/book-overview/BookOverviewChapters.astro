  /* ════════════════════════════════════════════════════════════════
     COMPACT-FULL VARIANT — Book Overview only.
     Same timeline language, tighter rhythm so the entire chapter list
     lives inside the viewport without an internal scrollbar and without
     a "show all" tail. Tokens are pinned to the spec — no gold, no
     warm tones, no neon glow.
     ════════════════════════════════════════════════════════════════ */
  .boch.is-compact-full {
    /* Sticky stays on; the card is the height-bound element. */
  }

  .boch.is-compact-full .boch-card {
    padding: 12px 14px;
    max-block-size: calc(100vh - 220px);
    /* No internal scroll inside the card (per spec). */
    overflow: visible;
    display: flex;
    flex-direction: column;
    /* Secondary navigation: softer surface and lighter border, no
       elevation shadow. Summary is the focal element on this page —
       the timeline supports it rather than competing with it. */
    background: color-mix(in srgb, var(--lesson-path-panel-bg) 70%, transparent);
    border-color: var(--lesson-path-panel-border);
    box-shadow: none;
    opacity: 0.94;
