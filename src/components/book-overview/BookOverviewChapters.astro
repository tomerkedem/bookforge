    block-size: 0.9rem;
  }
  .boch.is-compact-full .boch-heading {
    font-size: 0.95rem;
  }

  .boch.is-compact-full .boch-list {
    /* Rows get spaced via the gap (per spec) — the timeline line is
       redrawn so it bridges the gap cleanly. */
    gap: 6px;
    /* Override the default's max-block-size + scroll on lg breakpoints. */
    max-block-size: none;
    overflow: visible;
    padding-inline-end: 0;
  }
  @media (min-width: 1024px) {
    .boch.is-compact-full .boch-list {
      max-block-size: none;
      overflow: visible;
      padding-inline-end: 0;
    }
  }

  /* Timeline line — desaturated slate per spec. Extends past the row
