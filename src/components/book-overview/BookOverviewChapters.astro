  /* ── Node (circle) — default ─────────────────────────────────── */
  .boch.is-compact-full .boch-dot {
    inline-size: 30px;
    block-size: 30px;
    background: transparent;
    border: 1px solid var(--lesson-path-timeline);
    color: var(--lesson-path-muted-icon);
