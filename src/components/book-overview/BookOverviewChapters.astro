---
/**
 * Book Overview — Chapters list.
 *
 * Clean vertical list. Each row carries a chapter number and the
 * localized title — no reading-time / sections meta clutter.
 * Per-card progress bar and completion check are still present so the
 * page-level updateChapterProgress() can paint them; statuses are
 * driven by data attributes so styling stays declarative.
 *
 * Status states (driven by `[data-read-status]` set by the page script):
 *   - current       gold-accented "you are here" highlight
 *   - in-progress   subtle progress fill, still active
 *   - completed     muted card with green check
 *   - (none)        unread, default surface
 *   - locked        dimmed, no link, lock glyph (when chapter.locked)
 *
 * Long books collapse after a threshold and reveal the rest behind a
 * "Show all chapters" toggle so the column doesn't dominate the page
 * before any reading starts.
 */

import type { Chapter, Language } from '../../types/index';
import { t } from '../../i18n';
import { getLocalizedText } from './utils';

interface Props {
  chapters: Chapter[];
  slug: string;
  language: Language;
  isRtl: boolean;
}

const { chapters, slug, language, isRtl } = Astro.props;

// Collapse threshold. Anything above this number of chapters renders
// with the tail hidden until the user clicks the toggle.
const COLLAPSED_LIMIT = 6;
const collapsible = chapters.length > COLLAPSED_LIMIT;
---

<section class:list={['boch', isRtl && 'is-rtl']} aria-labelledby="boch-title">
  <div class="boch-heading-row">
    <h2 id="boch-title" class="boch-heading">
      {t('sidebar.chapters', language)}
    </h2>
    <span class="boch-heading-rule" aria-hidden="true"></span>
  </div>

  <ol
    class:list={['boch-list', collapsible && 'is-collapsible']}
    data-collapsed={collapsible ? 'true' : undefined}
    data-collapsed-limit={collapsible ? COLLAPSED_LIMIT : undefined}
  >
    {
      chapters.map((chapter, idx) => {
        const chapterTitle = getLocalizedText(chapter.titles, language);
        const chapterNum = idx + 1;
        const locked = chapter.locked === true;
        const beyondLimit = collapsible && idx >= COLLAPSED_LIMIT;
        const numberLabel = chapterNum.toString().padStart(2, '0');
        const lockedLabel = t('bookOverview.locked', language);

        const itemClasses = [
          'boch-item',
          beyondLimit && 'is-beyond-limit',
          locked && 'is-locked',
        ];

        const inner = (
          <>
            <span class="boch-progress" aria-hidden="true">
              <span class="boch-progress-fill chapter-progress-fill"></span>
            </span>

            <span class="boch-num chapter-number-badge" aria-hidden="true">
              {numberLabel}
            </span>

            <span class="boch-title-wrap">
              <svg
                class="boch-check chapter-status-check"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" stroke-width="1.8" fill="rgba(34,197,94,0.12)" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M8 12.5l2.5 2.5L16 9.5" />
              </svg>
              <h3 class="boch-title">{chapterTitle}</h3>
            </span>

            {locked && (
              <svg class="boch-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <rect x="5" y="11" width="14" height="9" rx="2" stroke-width="1.8" />
                <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            )}
          </>
        );

        return (
          <li class:list={itemClasses}>
            {locked ? (
              <span
                class="boch-card chapter-link"
                data-chapter-id={chapter.id}
                data-book-slug={slug}
                data-locked="true"
                aria-disabled="true"
                role="link"
                aria-label={`${numberLabel} — ${chapterTitle} (${lockedLabel})`}
              >
                {inner}
              </span>
            ) : (
              <a
                href={`/read/${slug}/${chapter.id}`}
                class="boch-card chapter-link"
                data-chapter-id={chapter.id}
                data-book-slug={slug}
              >
                {inner}
              </a>
            )}
          </li>
        );
      })
    }
  </ol>

  {collapsible && (
    <button
      type="button"
      class="boch-toggle"
      data-boch-toggle
      data-i18n="bookOverview.showAllChapters"
      aria-expanded="false"
    >
      {t('bookOverview.showAllChapters', language)}
    </button>
  )}
</section>

<script>
  // Wire the show-all toggle. Per-card status (current / in-progress /
  // completed) is owned by the page-level updateChapterProgress();
  // this script only flips the list's collapsed flag and swaps the
  // button's i18n key so the platform's language-changed handler
  // keeps the label in sync.
  import { t, resolveLanguage, type TranslationKey } from '../../i18n';

  const COLLAPSED_KEY: TranslationKey = 'bookOverview.showAllChapters';
  const EXPANDED_KEY: TranslationKey = 'bookOverview.showFewerChapters';

  function bind(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-boch-toggle]');
    buttons.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        if (!section) return;
        const list = section.querySelector<HTMLElement>('.boch-list');
        if (!list) return;
        const isCollapsed = list.dataset.collapsed === 'true';
        const next = !isCollapsed;
        list.dataset.collapsed = next ? 'true' : 'false';
        btn.setAttribute('aria-expanded', next ? 'false' : 'true');
        btn.dataset.i18n = next ? COLLAPSED_KEY : EXPANDED_KEY;
        const lang = resolveLanguage(document.documentElement.lang);
        btn.textContent = t(btn.dataset.i18n as TranslationKey, lang);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bind, { once: true });
  } else {
    bind();
  }
  document.addEventListener('astro:after-swap', bind);
</script>

<style>
  .boch {
    position: relative;
  }
  @media (min-width: 1024px) {
    .boch {
      position: sticky;
      inset-block-start: 1rem;
    }
  }
  .boch.is-rtl .boch-heading-row { text-align: start; }

  .boch-heading-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-block-end: 0.85rem;
  }
  .boch-heading {
    margin: 0;
    font-family: 'Spectral', 'Frank Ruhl Libre', ui-serif, Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.15rem, 1.6vw, 1.45rem);
    color: var(--yuval-text, #f5efe1);
  }
  .boch-heading-rule {
    flex: 1;
    block-size: 1px;
    background: linear-gradient(to inline-end, rgba(232, 197, 71, 0.55), transparent);
  }

  .boch-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .boch-list.is-collapsible[data-collapsed='true'] .boch-item.is-beyond-limit {
    display: none;
  }
  @media (min-width: 1024px) {
    .boch-list {
      max-block-size: calc(100vh - 8rem);
      overflow-y: auto;
      padding-inline-end: 0.25rem;
    }
  }

  .boch-item { margin: 0; }

  .boch-card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 0.85rem;
    border-radius: 10px;
    background: rgba(232, 197, 71, 0.04);
    border: 1px solid rgba(232, 197, 71, 0.12);
    text-decoration: none;
    color: inherit;
    transition: background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
    overflow: hidden;
  }
  .boch-card:hover {
    background: rgba(232, 197, 71, 0.10);
    border-color: rgba(232, 197, 71, 0.36);
    transform: translateY(-1px);
  }
  .boch-card:focus-visible {
    outline: 2px solid #e8c547;
    outline-offset: 2px;
  }

  :root:not(.dark) .boch-card {
    background: rgba(184, 146, 63, 0.05);
    border-color: rgba(184, 146, 63, 0.18);
  }
  :root:not(.dark) .boch-card:hover {
    background: rgba(184, 146, 63, 0.10);
    border-color: rgba(184, 146, 63, 0.45);
  }

  .boch-num {
    inline-size: 2.1rem;
    block-size: 2.1rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Spectral', 'Frank Ruhl Libre', ui-serif, Georgia, serif;
    font-weight: 600;
    font-size: 0.8rem;
    font-feature-settings: 'tnum';
    letter-spacing: 0.02em;
    color: rgba(245, 239, 225, 0.85);
    background: rgba(232, 197, 71, 0.08);
    border: 1px solid rgba(232, 197, 71, 0.32);
  }
  :root:not(.dark) .boch-num {
    color: rgba(44, 36, 24, 0.85);
    background: rgba(184, 146, 63, 0.08);
    border-color: rgba(184, 146, 63, 0.4);
  }

  .boch-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-inline-size: 0;
  }
  .boch-title {
    margin: 0;
    font-family: 'Spectral', 'Frank Ruhl Libre', ui-serif, Georgia, serif;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.35;
    color: rgba(245, 239, 225, 0.92);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  :root:not(.dark) .boch-title {
    color: #1f1808;
  }

  .boch-check {
    inline-size: 1rem;
    block-size: 1rem;
    flex-shrink: 0;
    color: #5DCAA5;
  }
  /* Hidden by default — page script reveals it on completion. */
  .boch-card:not([data-read-status='completed']) .boch-check {
    display: none;
  }

  .boch-lock {
    inline-size: 1rem;
    block-size: 1rem;
    flex-shrink: 0;
    color: rgba(245, 239, 225, 0.55);
  }
  :root:not(.dark) .boch-lock {
    color: rgba(44, 36, 24, 0.5);
  }

  .boch-card[data-locked='true'] {
    cursor: not-allowed;
    opacity: 0.5;
    filter: grayscale(0.4);
  }
  .boch-card[data-locked='true']:hover {
    background: rgba(232, 197, 71, 0.04);
    border-color: rgba(232, 197, 71, 0.12);
    transform: none;
  }
  :root:not(.dark) .boch-card[data-locked='true']:hover {
    background: rgba(184, 146, 63, 0.05);
    border-color: rgba(184, 146, 63, 0.18);
  }

  /* Per-card progress strip — same DOM hooks the page script writes
     to (.chapter-progress-fill). Width is set via inline `style.width`
     on the inner element; we keep that as a percentage so it renders
     correctly in both LTR and RTL. */
  .boch-progress {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    block-size: 2px;
    background: rgba(232, 197, 71, 0.06);
    pointer-events: none;
  }
  .boch-progress-fill {
    display: block;
    block-size: 100%;
    inline-size: 0;
    background: rgba(232, 197, 71, 0.55);
    transition: inline-size 600ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* CURRENT — gold accent, "you are here". */
  .boch-card[data-read-status='current'] {
    background: rgba(232, 197, 71, 0.12);
    border-color: rgba(232, 197, 71, 0.55);
    box-shadow:
      0 0 0 1px rgba(232, 197, 71, 0.25),
      0 4px 14px -8px rgba(232, 197, 71, 0.45);
  }
  .boch-card[data-read-status='current'] .boch-num {
    background: linear-gradient(145deg, #ddb52f 0%, #c9a227 100%);
    color: #1f1808;
    border-color: transparent;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
  }
  .boch-card[data-read-status='current'] .boch-title {
    color: #ffe9a8;
    font-weight: 600;
  }
  :root:not(.dark) .boch-card[data-read-status='current'] {
    background: rgba(184, 146, 63, 0.14);
    border-color: rgba(184, 146, 63, 0.65);
  }
  :root:not(.dark) .boch-card[data-read-status='current'] .boch-title {
    color: #4a3712;
  }
  .boch-card[data-read-status='current'] .boch-progress-fill {
    background: linear-gradient(90deg, #c9a227 0%, #ddb52f 50%, #f4d97a 100%);
  }

  /* IN-PROGRESS — subtle progress, no special highlight. */
  .boch-card[data-read-status='in-progress'] .boch-num {
    border-color: rgba(232, 197, 71, 0.55);
    color: #f5e4a3;
  }
  :root:not(.dark) .boch-card[data-read-status='in-progress'] .boch-num {
    color: #6a4f12;
  }

  /* COMPLETED — quiet. Muted text, green check, faded number. */
  .boch-card[data-read-status='completed'] {
    background: rgba(93, 202, 165, 0.04);
    border-color: rgba(93, 202, 165, 0.22);
  }
  .boch-card[data-read-status='completed'] .boch-num {
    background: rgba(93, 202, 165, 0.08);
    border-color: rgba(93, 202, 165, 0.32);
    color: rgba(245, 239, 225, 0.55);
  }
  .boch-card[data-read-status='completed'] .boch-title {
    color: rgba(245, 239, 225, 0.6);
    font-weight: 400;
  }
  :root:not(.dark) .boch-card[data-read-status='completed'] {
    background: rgba(16, 185, 129, 0.04);
    border-color: rgba(16, 185, 129, 0.22);
  }
  :root:not(.dark) .boch-card[data-read-status='completed'] .boch-num {
    color: rgba(44, 36, 24, 0.55);
  }
  :root:not(.dark) .boch-card[data-read-status='completed'] .boch-title {
    color: rgba(44, 36, 24, 0.55);
  }
  .boch-card[data-read-status='completed'] .boch-progress-fill {
    background: rgba(93, 202, 165, 0.65);
  }

  .boch-toggle {
    margin-block-start: 0.6rem;
    padding: 0.4rem 0.85rem;
    background: transparent;
    border: 1px solid rgba(232, 197, 71, 0.36);
    border-radius: 999px;
    color: #f5e4a3;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .boch-toggle:hover {
    background: rgba(232, 197, 71, 0.10);
    border-color: rgba(232, 197, 71, 0.6);
    color: #ffe9a8;
  }
  .boch-toggle:focus-visible {
    outline: 2px solid #e8c547;
    outline-offset: 2px;
  }
  :root:not(.dark) .boch-toggle {
    color: #6a4f12;
    border-color: rgba(184, 146, 63, 0.45);
  }
  :root:not(.dark) .boch-toggle:hover {
    background: rgba(184, 146, 63, 0.10);
    border-color: rgba(184, 146, 63, 0.7);
    color: #4a3712;
  }

  @media (prefers-reduced-motion: reduce) {
    .boch-card,
    .boch-progress-fill,
    .boch-toggle {
      transition: none;
    }
    .boch-card:hover {
      transform: none;
    }
  }
</style>
