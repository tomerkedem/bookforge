---
/**
 * Book Overview — Hero card.
 *
 * Premium dark glass card on the new BO palette (purple / blue / cyan).
 * Cover sits on the inline-start side at lg+, content (level badge,
 * title, subtitle, credits, meta row, primary + secondary CTA, bookmark)
 * on the inline-end. Stacks on mobile.
 *
 * All colors come from the `--bo-*` tokens in src/styles/theme.css.
 * No gold is used here — gold is reserved for the Yuval brand mark in
 * the global header.
 *
 * Generic for every book:
 *  - Title / subtitle / cover come from props (already localized).
 *  - Level badge renders only when `level` is defined; the label is
 *    resolved through i18n (`library.level.<key>`).
 *  - Reading time is computed from chapter word counts at ~200 wpm.
 *  - Available languages are the book's discovered language list,
 *    rendered as native labels.
 *
 * The primary CTA starts as "Start learning" and is upgraded
 * client-side to "Continue learning" if any chapter under this book
 * has progress in localStorage.
 *
 * The bookmark button toggles a per-book flag in localStorage under
 * `yuval_bookmark_<slug>`. Visual state mirrors `aria-pressed`.
 */

import type { BookLevel, Chapter, Language } from '../../types/index';
import type { BookCredits } from '../../utils/book-discovery';
import { t, type TranslationKey } from '../../i18n';
import { getLanguageMeta } from '../../utils/language';
import { getCreditText, creditDataAttr, formatChapterCount, renderInlineMarkdown } from './utils';
import BookOverviewProgress from './BookOverviewProgress.astro';

interface Props {
  title: string;
  subtitle: string;
  description: string;
  coverImage: string;
  credits?: BookCredits;
  chapters: Chapter[];
  slug: string;
  level?: BookLevel;
  languages: Language[];
  language: Language;
  isRtl: boolean;
}

const {
  title,
  subtitle,
  description,
  coverImage,
  credits,
  chapters,
  slug,
  level,
  languages,
  language,
  isRtl,
} = Astro.props;

const totalWords = chapters.reduce((sum, ch) => sum + (ch.word_count ?? 0), 0);
const totalMinutes = Math.max(1, Math.ceil(totalWords / 200));

const firstChapter = chapters[0];
const startHref = firstChapter ? `/read/${slug}/${firstChapter.id}` : '#';

const languageNames = languages.map((l) => getLanguageMeta(l).label).join(' · ');
const languagesAriaLabel = `${t('book.availableIn', language)}: ${languageNames}`;

const levelKey: TranslationKey | undefined = level
  ? (`library.level.${level}` as TranslationKey)
  : undefined;
const levelLabel = level && levelKey ? t(levelKey, language) : '';

// Some manifests append per-lesson metadata to the end of the description
// as bolded "Label: value" lines (e.g. "**מרצה:** ערן סלע", "**תאריך:**
// 19/05/2026"). Pull them out so they render as proper credits below the
// title instead of as part of the prose, and so they don't appear twice
// when the description body is shown.
function extractInlineMeta(
  text: string,
  labelAlternates: string,
): { value?: string; remaining: string } {
  // Matches: optional bold open, label, optional colon (in or out of
  // bold), optional bold close, then the value up to end-of-line. The
  // colon may sit inside the bold ("**Label:**") or after it
  // ("**Label**:") — both are common in authored markdown.
  const re = new RegExp(
    `\\*\\*\\s*(?:${labelAlternates})\\s*:?\\s*\\*\\*\\s*:?\\s*([^\\n]+)`,
    'i',
  );
  const match = text.match(re);
  if (!match || !match[1]) return { remaining: text };
  const value = match[1].trim().replace(/\*+$/, '').trim();
  const remaining = text.replace(match[0], '').replace(/\n{3,}/g, '\n\n').trim();
  return { value, remaining };
}

const extractedLecturerPass = extractInlineMeta(
  description,
  'מרצה|Lecturer|Profesor|Profesora',
);
const extractedDatePass = extractInlineMeta(
  extractedLecturerPass.remaining,
  'תאריך|Date|Fecha',
);
const extractedLecturer = extractedLecturerPass.value;
const extractedDate = extractedDatePass.value;
const cleanedDescription = extractedDatePass.remaining;

// Description (formerly its own Summary card, now folded into Hero so
// the page is one card less tall). A description is considered
// "meaningful" only if at least one paragraph carries 20+ chars after
// stripping a trailing label colon — that filters out stub manifests
// like just "תקציר:" / "Summary:" without dropping legitimately short
// summaries. When nothing meaningful exists the block + TTS are
// skipped entirely and the Hero stays compact.
const descriptionParagraphs = cleanedDescription.split(/\n\s*\n/).filter((p) => p.trim());
const hasDescription = descriptionParagraphs.some((p) => {
  const cleaned = p.trim().replace(/[:：]\s*$/, '').trim();
  return cleaned.length >= 20;
});
const DESCRIPTION_TRUNCATE_THRESHOLD = 280;
const descriptionTruncatable = hasDescription && cleanedDescription.length > DESCRIPTION_TRUNCATE_THRESHOLD;

// Lecturer + date can also live in `credits` directly (manifest field).
// If the description didn't carry them inline, fall back to whatever the
// data layer provided so a future manifest schema upgrade just works.
const lecturerFromCredits =
  credits?.lecturer ? getCreditText(credits.lecturer, language) : undefined;
const displayLecturer = extractedLecturer || lecturerFromCredits;
const displayDate = extractedDate;
---

<!-- Hidden context for the reading-page bookmarks system. The system's
     getCurrentBook() reads `#chapter-container[data-book]`, so we expose
     the slug here without rendering anything. The element is empty, so
     the contextmenu/dblclick "add bookmark" hooks (which match
     `#chapter-container p`) safely no-op on this page. -->
<div id="chapter-container" data-book={slug} hidden aria-hidden="true"></div>

<section class:list={['boh', isRtl && 'is-rtl']} aria-labelledby="boh-title">
  <div class="boh-card bo-premium-surface">
    <!-- Cover with subtle purple/blue aura behind it (`bo-hero-glow`
         handles the radial aura via theme.css).

         When the page resolves a real cover URL (from knowledge-cards
         or book metadata), render the real image. When it falls back
         to an empty string, render a designed fallback card with the
         BO palette and the lesson title instead — never the generic
         dark "No Cover" placeholder, which looks like a missing
         asset rather than intentional branding. -->
    <figure class="boh-cover-wrap bo-hero-glow">
      {coverImage ? (
        <img
          src={coverImage}
          alt={title}
          loading="lazy"
          decoding="async"
          class="book-cover-img boh-cover"
        />
      ) : (
        <div class="boh-cover boh-cover-fallback" role="img" aria-label={title}>
          <span class="boh-cover-fallback-glow" aria-hidden="true"></span>
          <span class="boh-cover-fallback-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 5.5A1.5 1.5 0 0 1 5.5 4H10a3 3 0 0 1 2 .8A3 3 0 0 1 14 4h4.5A1.5 1.5 0 0 1 20 5.5V18a1 1 0 0 1-1 1h-5a2 2 0 0 0-2 2 2 2 0 0 0-2-2H5a1 1 0 0 1-1-1V5.5z" />
              <path stroke-linecap="round" stroke-width="1.5" d="M12 6v15" />
            </svg>
          </span>
          {level && levelKey && (
            <span class="boh-cover-fallback-cat" data-i18n={levelKey}>{levelLabel}</span>
          )}
          <span class="boh-cover-fallback-title">{title}</span>
        </div>
      )}
    </figure>

    <div class="boh-content">
      {level && levelKey && (
        <div class="boh-top">
          <span class="boh-level" data-i18n={levelKey}>
            {levelLabel}
          </span>
        </div>
      )}

      <h1 id="boh-title" class="boh-title">{title}</h1>

      {subtitle && <p class="boh-subtitle">{subtitle}</p>}

      {(credits?.author || credits?.editor || displayLecturer || displayDate) && (
        <div class="boh-credits">
          {credits?.author && (
            <p class="boh-credits-line">
              <span class="boh-credits-label">{t('book.by', language)}</span>{' '}
              <span data-credit-localized={creditDataAttr(credits.author)}>{getCreditText(credits.author, language)}</span>
            </p>
          )}
          {displayLecturer && (
            <p class="boh-credits-line">
              <span class="boh-credits-label">{t('book.lecturer', language)}:</span>{' '}
              {credits?.lecturer && !extractedLecturer ? (
                <span data-credit-localized={creditDataAttr(credits.lecturer)}>{displayLecturer}</span>
              ) : (
                <span>{displayLecturer}</span>
              )}
            </p>
          )}
          {credits?.type === 'lecture_summary' && credits.editor && (
            <p class="boh-credits-line">
              <span class="boh-credits-label">{t('book.editedBy', language)}:</span>{' '}
              <span data-credit-localized={creditDataAttr(credits.editor)}>{getCreditText(credits.editor, language)}</span>
            </p>
          )}
          {displayDate && (
            <p class="boh-credits-line">
              <span class="boh-credits-label">{t('book.date', language)}:</span>{' '}
              <span>{displayDate}</span>
            </p>
          )}
        </div>
      )}

      {hasDescription && (
        <div class="boh-description">
          <div class="boh-description-row">
            <!-- `.chapter-content` is the contract the TTS engine
                 reads from (initTextToSpeech looks for paragraph
                 nodes inside this class). The truncate state is
                 applied on the same node so collapsed text is still
                 readable by the TTS pipeline — the engine reads the
                 full DOM text, only the visual is clipped. -->
            <div
              class:list={['boh-description-body', 'chapter-content']}
              data-truncatable={descriptionTruncatable ? 'true' : undefined}
              data-collapsed={descriptionTruncatable ? 'true' : undefined}
            >
              {descriptionParagraphs.map((para) => (
                <p class="boh-description-para" set:html={renderInlineMarkdown(para.trim())} />
              ))}
            </div>
            <!-- TTS control. The page-level boot script in
                 src/pages/books/[slug].astro still looks for
                 `#tts-inline-trigger`, so keeping the id + classes
                 here means the engine attaches without any wiring
                 change at the page level. The icon-only square
                 matches the BO palette; the global gold pill style
                 in [slug].astro is overridden by `.boh-tts` below. -->
            <button
              id="tts-inline-trigger"
              class="boh-tts tts-inline-btn"
              type="button"
              aria-label={t('lessonSummary.summary.readAloud', language)}
              aria-pressed="false"
              data-i18n-aria-label="lessonSummary.summary.readAloud"
            >
              <span class="tts-inline-icon" aria-hidden="true"></span>
              <span class="tts-inline-label sr-only" data-i18n="lessonSummary.summary.readAloud">
                {t('lessonSummary.summary.readAloud', language)}
              </span>
            </button>
          </div>
          {descriptionTruncatable && (
            <button
              type="button"
              class="boh-description-toggle"
              data-boh-description-toggle
              data-i18n="bookOverview.readMore"
              aria-expanded="false"
            >
              {t('bookOverview.readMore', language)}
            </button>
          )}
        </div>
      )}

      <!-- Meta row: chapter count · reading time · languages · level (if any) -->
      <ul class="boh-meta" role="list">
        <li class="boh-meta-item">
          <svg class="boh-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          <span>{formatChapterCount(chapters.length, language)}</span>
        </li>

        <li class="boh-meta-item">
          <svg class="boh-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke-width="1.8" />
            <path stroke-linecap="round" stroke-width="1.8" d="M12 7v5l3 2" />
          </svg>
          <span>{t('book.minutesRead', language, { n: totalMinutes.toString() })}</span>
        </li>

        <li class="boh-meta-item" aria-label={languagesAriaLabel}>
          <svg class="boh-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke-width="1.8" />
            <path stroke-width="1.8" d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
          </svg>
          <span aria-hidden="true">{languageNames}</span>
        </li>

        {level && levelKey && (
          <li class="boh-meta-item" data-meta-level>
            <svg class="boh-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7L12 3 4 7v10l8 4 8-4V7z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7l8 4 8-4M12 11v10" />
            </svg>
            <span data-i18n={levelKey}>{levelLabel}</span>
          </li>
        )}
      </ul>

      <!-- Actions row: CTA · bookmark · inline progress.
           DOM order is intentional: CTA → bookmark → progress.
           Flex layout in RTL produces visual order [CTA][bookmark]
           [progress] reading right-to-left; in LTR the same order
           reads left-to-right. The Progress component takes the
           remaining inline space (flex: 1) so the bar grows into the
           gap left of the bookmark and never wraps to its own line
           on desktop. On narrow viewports `flex-wrap` lets it drop
           below the CTA without ever leaving the Hero card. -->
      <div class="boh-actions">
        <a
          href={startHref}
          class="boh-cta boh-cta-primary"
          data-cta-primary
          data-book-slug={slug}
          data-i18n="book.startLearning"
        >
          {t('book.startLearning', language)}
        </a>
        <button
          type="button"
          class="boh-bookmark"
          data-bookmark-trigger
          data-book-slug={slug}
          aria-label={t('bookmarks.title', language)}
          data-i18n-aria-label="bookmarks.title"
        >
          <svg class="boh-bookmark-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linejoin="round"
            />
          </svg>
        </button>
        <BookOverviewProgress
          chapters={chapters}
          slug={slug}
          language={language}
          isRtl={isRtl}
          variant="inline"
        />
      </div>
    </div>
  </div>
</section>

<script>
  // Primary CTA progress upgrade + bookmark toggle.
  // Both observe localStorage and re-run on view transitions, language
  // toggles, tab focus, and pageshow.
  import { t, resolveLanguage, type TranslationKey } from '../../i18n';

  // ── Primary CTA: start vs continue ────────────────────────────────
  function updatePrimaryCta(): void {
    const cta = document.querySelector<HTMLAnchorElement>('[data-cta-primary]');
    if (!cta) return;
    const slug = cta.dataset.bookSlug;
    if (!slug) return;

    const keyFragment = `reading_progress_${slug}_ch`;
    let hasProgress = false;
    let bestKey: string | null = null;
    let bestUpdated = -Infinity;

    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (!k || !k.includes(keyFragment)) continue;
      try {
        const d = JSON.parse(localStorage.getItem(k) || '{}');
        const has =
          (typeof d.percentage === 'number' && d.percentage > 0) ||
          (typeof d.scrollPosition === 'number' && d.scrollPosition > 200);
        if (!has) continue;
        hasProgress = true;
        const updated = typeof d.lastUpdated === 'number' ? d.lastUpdated : 0;
        if (updated >= bestUpdated) {
          bestUpdated = updated;
          bestKey = k;
        }
      } catch {
        /* skip malformed */
      }
    }

    const newKey: TranslationKey = hasProgress
      ? 'book.continueLearning'
      : 'book.startLearning';
    cta.dataset.i18n = newKey;

    if (hasProgress && bestKey) {
      const m = bestKey.match(/_ch(.+)$/);
      if (m && m[1]) cta.href = `/read/${slug}/${m[1]}`;
    }

    const lang = resolveLanguage(document.documentElement.lang);
    cta.textContent = t(newKey, lang);
  }

  // ── Bookmark trigger ──────────────────────────────────────────────
  // Reuses the reading-page bookmarks system (src/scripts/bookmarks.ts).
  // We initialize it once per page load, then delegate clicks from our
  // Hero button to the system's invisible FAB (`#bm-fab-btn`). The
  // panel that opens lists every paragraph the reader has bookmarked
  // for this book, with a click-to-jump UX identical to the reading
  // page.
  let bookmarksInitialized = false;

  async function ensureBookmarks(): Promise<void> {
    if (bookmarksInitialized) return;
    if (document.getElementById('bm-fab-btn')) {
      bookmarksInitialized = true;
      return;
    }
    const { initBookmarks } = await import('../../scripts/bookmarks');
    // The FAB / overlay / panel are appended to <body>. We hide the
    // FAB via global CSS in the page; the panel + overlay still render
    // when triggered.
    initBookmarks(new AbortController().signal);
    bookmarksInitialized = true;
  }

  function bindBookmarkTrigger(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>(
      '[data-bookmark-trigger]',
    );
    buttons.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        await ensureBookmarks();
        const fab = document.getElementById('bm-fab-btn');
        if (fab) (fab as HTMLButtonElement).click();
      });
    });
  }

  // ── Description read-more toggle ──────────────────────────────────
  // Flips `data-collapsed` on the sibling .boh-description-body and
  // swaps the button's `data-i18n` key so the global language-changed
  // handler keeps the label in sync. Mirrors the pattern that used to
  // live in BookOverviewSummary.
  const DESC_COLLAPSED_KEY: TranslationKey = 'bookOverview.readMore';
  const DESC_EXPANDED_KEY: TranslationKey = 'bookOverview.showLess';

  function bindDescriptionToggle(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>(
      '[data-boh-description-toggle]',
    );
    buttons.forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const container = btn.closest('.boh-description');
        if (!container) return;
        const body = container.querySelector<HTMLElement>('.boh-description-body');
        if (!body) return;

        const isCollapsed = body.dataset.collapsed === 'true';
        const next = !isCollapsed;

        body.dataset.collapsed = next ? 'true' : 'false';
        btn.setAttribute('aria-expanded', next ? 'false' : 'true');
        btn.dataset.i18n = next ? DESC_COLLAPSED_KEY : DESC_EXPANDED_KEY;

        const lang = resolveLanguage(document.documentElement.lang);
        btn.textContent = t(btn.dataset.i18n as TranslationKey, lang);
      });
    });
  }

  function boot(): void {
    updatePrimaryCta();
    bindBookmarkTrigger();
    bindDescriptionToggle();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }

  document.addEventListener('astro:after-swap', boot);
  window.addEventListener('language-changed', boot);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') boot();
  });
  window.addEventListener('pageshow', boot);
</script>

<style>
  /* ── Card shell ───────────────────────────────────────────────────
     Dark glass surface, no gold. Cool-tinted shadow + subtle purple
     bloom from --bo-shadow-lg. The `bo-hero-glow` class on the cover
     wrapper handles the radial aura behind the image; nothing inside
     this block paints a glow on its own. */
  .boh {
    container-type: inline-size;
  }

  /* Surface (background, border, shadow, grain) comes from the shared
     `.bo-premium-surface` class in src/styles/theme.css. This rule
     adds only the layout-specific bits: grid, gap, padding, radius,
     and the `overflow: hidden` that clips the inline-start accent
     strip below.

     Compact-by-design: the Hero is the page's entry gate, not its
     main content. Summary takes the visual weight; padding and gaps
     here are tuned to give the Hero presence without claiming the
     prime real estate. */
  .boh-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 0.6rem 0.95rem;
    border-radius: 16px;
    color: var(--bo-text-primary);
    overflow: hidden;
  }

  /* Subtle accent edge along the inline-start side. Cool blue/purple
     instead of gold. Day mode reduces the opacity slightly so the
     ribbon doesn't read as a colored bar against pearl. */
  .boh-card::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0;
    inset-block-end: 0;
    width: 3px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--bo-purple) 35%,
      var(--bo-cyan) 75%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0.55;
  }
  :global(.dark) .boh-card::before {
    opacity: 0.6;
  }

  @media (min-width: 640px) {
    .boh-card { padding: 0.75rem 1.1rem; gap: 0.95rem; }
  }

  @container (min-width: 720px) {
    .boh-card {
      grid-template-columns: minmax(110px, 128px) minmax(0, 1fr);
      align-items: center;
    }
  }

  /* ── Cover ───────────────────────────────────────────────────── */
  .boh-cover-wrap {
    margin: 0;
    display: flex;
    justify-content: center;
  }

  .boh-cover {
    width: 100%;
    max-width: 128px;
    height: auto;
    border-radius: 10px;
    background: transparent;
    /* Layered shadow: themed drop from the global shadow token + a
       hairline outline so the cover never floats unbordered on a
       light surface. The drop uses the day/night token so it stays
       restrained on pearl and richer on navy without redefining. */
    box-shadow:
      var(--bo-shadow-md),
      0 0 0 1px var(--bo-border);
  }
  /* Subtle glow only — no longer a focal halo. Day mode dampens it
     further since the aura color (alpha 0.14) is already much lower
     than night (alpha 0.28). */
  .boh-cover-wrap.bo-hero-glow::before {
    opacity: 0.5;
    filter: blur(6px);
  }
  :global(.dark) .boh-cover-wrap.bo-hero-glow::before {
    opacity: 0.45;
  }

  @container (min-width: 720px) {
    .boh-cover-wrap { justify-content: flex-start; }
    .boh-cover { max-width: 118px; }
  }

  /* ── Fallback cover ──────────────────────────────────────────
     Rendered when no real artwork is available for the lesson.
     A designed mini-card on the BO palette rather than the generic
     dark "No Cover" SVG. The 2:3 ratio matches a book cover. Theme-
     aware via --bo-* tokens — pearl in day, navy in night. */
  .boh-cover-fallback {
    aspect-ratio: 2 / 3;
    width: 100%;
    max-width: 150px;
    border-radius: 10px;
    padding: 0.85rem 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--bo-purple) 14%, var(--bo-surface)) 0%,
        var(--bo-surface) 55%,
        color-mix(in srgb, var(--bo-cyan) 10%, var(--bo-surface)) 100%
      );
    color: var(--bo-text-primary);
    isolation: isolate;
  }
  @container (min-width: 720px) {
    .boh-cover-fallback { max-width: 140px; }
  }

  /* Soft accent glow behind the icon, anchored to the upper-inline-end
     so it reads as a "spine highlight" without dominating. */
  .boh-cover-fallback-glow {
    position: absolute;
    inset-block-start: -20%;
    inset-inline-end: -20%;
    width: 70%;
    height: 70%;
