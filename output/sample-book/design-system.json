{
  "book_id": "sample-book",
  "framework": "astro",
  "css": "tailwind",
  "language": "typescript",
  "typography": {
    "fontFamily": {
      "heading": "'Frank Ruhl Libre', 'David Libre', serif",
      "body": "'Heebo', 'Assistant', system-ui, sans-serif",
      "mono": "'JetBrains Mono', 'Courier New', monospace"
    },
    "scale": {
      "h1": "text-3xl md:text-4xl lg:text-5xl font-bold leading-tight",
      "h2": "text-2xl md:text-3xl font-semibold leading-snug",
      "body": "text-base md:text-lg leading-relaxed",
      "small": "text-sm leading-normal"
    }
  },
  "colors": {
    "primary": "#1a1a1a",
    "secondary": "#4a4a4a",
    "background": "#ffffff",
    "text": "#1a1a1a",
    "muted": "#6b7280",
    "border": "#e5e7eb",
    "accent": "#2563eb",
    "surface": "#f9fafb",
    "highlight": "#fef9c3"
  },
  "spacing": {
    "base": "1rem",
    "section": "3rem",
    "chapter": "6rem",
    "readingMaxWidth": "68ch",
    "sidebarWidth": "280px"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "rtl": {
    "enabled": true,
    "dir": "rtl"
  },
  "components": ["ChapterNav", "ReadingProgress", "QuoteShare", "TableOfContents"],
  "themes": {
    "day": { "background": "#ffffff", "text": "#1a1a1a" },
    "night": { "background": "#111827", "text": "#f3f4f6" },
    "sepia": { "background": "#f5f0e8", "text": "#3d2b1f" }
  },
  "features": {
    "readingProgress": { "enabled": true, "cookieName": "yuval-progress-sample-book" },
    "quoteShare": { "enabled": true, "useWebShareAPI": true },
    "mobileFirst": { "enabled": true }
  }
}
