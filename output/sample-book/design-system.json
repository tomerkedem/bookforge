{
  "_comment": "Yuval design system — monochromatic, reading-first. Standard: Apple / The Economist / Medium.",

  "colors": {
    "background": "#ffffff",
    "backgroundSecondary": "#fafaf8",
    "text": "#1a1a1a",
    "textSecondary": "#666666",
    "textTertiary": "#888888",
    "textMuted": "#bbbbbb",
    "border": "#f0ede8",
    "borderSecondary": "#e0ddd8",
    "accent": "#1a1a1a",
    "forbidden": "No blue, green, red, or any external color. Black, white, gray only."
  },

  "typography": {
    "headingFont": "Frank Ruhl Libre",
    "bodyFont": "Heebo",
    "scale": {
      "h1": { "size": "72px", "weight": 700, "lineHeight": 1.05, "letterSpacing": "-0.02em" },
      "h2": { "size": "42px", "weight": 700, "lineHeight": 1.15, "letterSpacing": "-0.01em" },
      "h3": { "size": "28px", "weight": 400, "lineHeight": 1.3 },
      "body": { "size": "17px", "weight": 300, "lineHeight": 1.85, "color": "#333333" },
      "secondary": { "size": "14px", "weight": 300, "lineHeight": 1.7, "color": "#666666" },
      "label": { "size": "11px", "weight": 400, "letterSpacing": "0.12em", "textTransform": "uppercase", "color": "#888888" }
    }
  },

  "spacing": {
    "paddingHorizontalDesktop": "48px",
    "paddingHorizontalMobile": "24px",
    "paragraphGap": "24px",
    "aboveH2": "64px",
    "belowH2": "40px",
    "headerHeight": "64px",
    "cardPadding": "40px",
    "readingMaxWidth": "680px"
  },

  "components": {
    "header": {
      "position": "sticky",
      "top": 0,
      "background": "#ffffff",
      "borderBottom": "1px solid #f0ede8",
      "height": "64px",
      "padding": "0 48px",
      "left": "Author name — Frank Ruhl Libre 18px weight 400 letter-spacing 0.02em",
      "right": "Navigation + language toggle",
      "languageToggle": {
        "border": "1px solid #e0ddd8",
        "borderRadius": "20px",
        "activeBackground": "#1a1a1a",
        "activeColor": "#ffffff",
        "inactiveBackground": "transparent",
        "inactiveColor": "#888888"
      }
    },
    "bookCard": {
      "gridGap": "1px",
      "gridBackground": "#f0ede8",
      "cardBackground": "#ffffff",
      "cardPadding": "40px",
      "sequentialNumber": "11px, letter-spacing 0.1em, color #bbb, margin-bottom 32px",
      "title": "Frank Ruhl Libre 24px weight 700 color #1a1a1a",
      "description": "Heebo 14px weight 300 color #888 line-height 1.7",
      "arrow": "hidden by default, visible on hover, color #1a1a1a",
      "hover": "background #fafaf8"
    },
    "readingPage": {
      "contentMaxWidth": "680px",
      "contentMargin": "0 auto",
      "contentPadding": "64px 48px",
      "progressBar": {
        "height": "2px",
        "background": "#f0ede8",
        "fill": "#1a1a1a",
        "position": "below header"
      }
    },
    "tableOfContents": {
      "position": "fixed",
      "width": "240px",
      "defaultState": "hidden (opacity: 0, transform: translateX(100%))",
      "hoverState": "visible (opacity: 1, transform: translateX(0))",
      "transition": "all 0.3s ease",
      "background": "#ffffff",
      "borderLeft": "1px solid #f0ede8",
      "padding": "40px 32px",
      "activeItem": "color #1a1a1a font-weight 500",
      "normalItem": "color #888"
    }
  },

  "interactions": {
    "links": "transition color 0.2s ease",
    "buttons": "transition opacity 0.2s ease, hover opacity 0.85",
    "menus": "transition all 0.3s ease",
    "scroll": "scroll-behavior smooth",
    "cards": "transition background 0.2s ease"
  },

  "rules": {
    "forbidden": [
      "No dark backgrounds anywhere",
      "No more than one heading font and one body font",
      "No heavy shadows",
      "No gradients",
      "No distracting animations",
      "No more than two colors in the entire system",
      "No colored cards",
      "No text below 13px"
    ],
    "selfCheck": [
      "Can you read for 30 minutes without eye strain?",
      "Would someone seeing this for the first time say 'wow, that's clean'?",
      "Does every element serve reading or is it noise?",
      "Would a senior Apple designer approve this?"
    ]
  }
}
